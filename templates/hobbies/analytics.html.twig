{% extends 'base.html.twig' %}

{% block title %}Statistiques des Loisirs - Ghrami{% endblock %}

{% block body %}
<div style="display: grid; grid-template-columns: 1fr; gap: 24px; padding: 20px; max-width: 1400px; margin: 0 auto;">
    
    <!-- En-tête -->
    <div style="display: flex; justify-content: space-between; align-items: center; background: white; padding: 20px; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <h1 style="margin: 0; font-size: 28px; font-weight: bold; color: #1c1e21;">📊 Statistiques des Loisirs</h1>
        <a href="{{ path('app_hobbies_index') }}" style="padding: 12px 24px; background: #667eea; color: white; border: none; border-radius: 8px; text-decoration: none; font-weight: 600; cursor: pointer;">← Retour aux Loisirs</a>
    </div>

    <!-- Aperçu des statistiques -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px;">
        <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 24px; border-radius: 16px; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);">
            <div style="font-size: 32px; margin-bottom: 8px;">⏱️</div>
            <p style="margin: 0; font-size: 14px; opacity: 0.9;">Total des Heures Suivies</p>
            <h3 style="margin: 4px 0 0 0; font-size: 32px; font-weight: bold;">{{ total_hours }}</h3>
        </div>

        <div style="background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%); color: white; padding: 24px; border-radius: 16px; box-shadow: 0 4px 15px rgba(76, 175, 80, 0.3);">
            <div style="font-size: 32px; margin-bottom: 8px;">🎯</div>
            <p style="margin: 0; font-size: 14px; opacity: 0.9;">Loisirs Actifs</p>
            <h3 style="margin: 4px 0 0 0; font-size: 32px; font-weight: bold;">{{ hobby_stats|length }}</h3>
        </div>

        <div style="background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%); color: white; padding: 24px; border-radius: 16px; box-shadow: 0 4px 15px rgba(255, 152, 0, 0.3);">
            <div style="font-size: 32px; margin-bottom: 8px;">📈</div>
            <p style="margin: 0; font-size: 14px; opacity: 0.9;">Moy. Heures/Loisir</p>
            <h3 style="margin: 4px 0 0 0; font-size: 32px; font-weight: bold;">{% if hobby_stats|length > 0 %}{{ (total_hours / hobby_stats|length)|round(1) }}{% else %}0{% endif %}</h3>
        </div>
    </div>

    <!-- Grille des graphiques -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 20px;">
        
        <!-- Top Loisirs -->
        <div style="background: white; padding: 24px; border-radius: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
            <h3 style="margin: 0 0 20px 0; font-size: 18px; font-weight: bold; color: #1c1e21;">🏆 Top Loisirs par Heures</h3>
            <div style="display: flex; flex-direction: column; gap: 16px;">
                {% if hobby_stats|length == 0 %}
                    <p style="color: #65676b; margin: 0;">Aucun loisir suivi pour l'instant</p>
                {% else %}
                    {% set topHours = hobby_stats[0].hours|default(0) %}
                    {% set maxHours = topHours > 0 ? topHours : 1 %}
                    {% for hobby in hobby_stats|slice(0, 5) %}
                    <div>
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                            <span style="font-weight: 600; color: #1c1e21;">{{ hobby.name }}</span>
                            <span style="background: #667eea; color: white; padding: 4px 12px; border-radius: 12px; font-size: 13px; font-weight: 600;">{{ hobby.hours|round(1) }}h</span>
                        </div>
                        <div style="width: 100%; height: 20px; background: #f0f2f5; border-radius: 10px; overflow: hidden;">
                            <div style="height: 100%; background: linear-gradient(90deg, #667eea, #764ba2); width: {{ ((hobby.hours / maxHours) * 100)|round }}%;">
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        <!-- Répartition par Catégorie -->
        <div style="background: white; padding: 24px; border-radius: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
            <h3 style="margin: 0 0 20px 0; font-size: 18px; font-weight: bold; color: #1c1e21;">🎨 Heures par Catégorie</h3>
            <div style="display: flex; flex-direction: column; gap: 12px;">
                {% if category_stats|length == 0 %}
                    <p style="color: #65676b; margin: 0;">Aucune catégorie suivie pour l'instant</p>
                {% else %}
                    {% set sorted_stats = category_stats|keys|sort %}
                    {% for category in sorted_stats|reverse %}
                    <div style="background: #f0f2f5; padding: 12px; border-radius: 8px; display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-weight: 600; color: #1c1e21;">{{ category }}</span>
                        <span style="background: #FF9800; color: white; padding: 4px 12px; border-radius: 12px; font-size: 13px; font-weight: 600;">{{ category_stats[category]|round(1) }}h</span>
                    </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

    </div>

    <!-- Activité par Jour de la Semaine -->
    <div style="background: white; padding: 24px; border-radius: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <h3 style="margin: 0 0 20px 0; font-size: 18px; font-weight: bold; color: #1c1e21;">📅 Activité par Jour de la Semaine</h3>
        <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 12px;">
            {% for i, label in day_labels %}
                {% set hours = day_of_week_stats[i] %}
                <div style="background: #f0f2f5; padding: 16px; border-radius: 8px; text-align: center;">
                    <div style="font-weight: bold; color: #1c1e21; margin-bottom: 8px;">{{ label }}</div>
                    <div style="font-size: 24px; font-weight: bold; color: #667eea;">{{ hours|round(1) }}</div>
                    <div style="font-size: 12px; color: #65676b; margin-top: 4px;">heures</div>
                </div>
            {% endfor %}
        </div>
    </div>

    <!-- Liste détaillée des loisirs -->
    <div style="background: white; padding: 24px; border-radius: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <h3 style="margin: 0 0 20px 0; font-size: 18px; font-weight: bold; color: #1c1e21;">📋 Aperçu de Tous les Loisirs</h3>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 2px solid #e4e6eb;">
                        <th style="padding: 12px; text-align: left; font-weight: 600; color: #1c1e21; background: #f0f2f5;">Loisir</th>
                        <th style="padding: 12px; text-align: center; font-weight: 600; color: #1c1e21; background: #f0f2f5;">Catégorie</th>
                        <th style="padding: 12px; text-align: center; font-weight: 600; color: #1c1e21; background: #f0f2f5;">Heures</th>
                        <th style="padding: 12px; text-align: center; font-weight: 600; color: #1c1e21; background: #f0f2f5;">% du Total</th>
                    </tr>
                </thead>
                <tbody>
                    {% for hobby in hobby_stats %}
                    <tr style="border-bottom: 1px solid #e4e6eb;">
                        <td style="padding: 12px; color: #1c1e21; font-weight: 600;">{{ hobby.name }}</td>
                        <td style="padding: 12px; text-align: center; color: #65676b;">{{ hobby.category }}</td>
                        <td style="padding: 12px; text-align: center; font-weight: bold; color: #667eea;">{{ hobby.hours|round(1) }}h</td>
                        <td style="padding: 12px; text-align: center; color: #4CAF50; font-weight: bold;">
                            {% if total_hours > 0 %}
                                {{ ((hobby.hours / total_hours) * 100)|round(1) }}%
                            {% else %}
                                0%
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>

<style>
    @media (max-width: 768px) {
        [style*="grid-template-columns: repeat"] {
            grid-template-columns: 1fr !important;
        }
    }
</style>
{% endblock %}

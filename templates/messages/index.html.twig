{% extends 'base.html.twig' %}

{% block title %}Messages - Ghrami{% endblock %}

{% block body %}
<div style="display: grid; grid-template-columns: 320px 1fr 280px; gap: 20px; margin-top: 20px;">
    
    <!-- Left Sidebar -->
    <aside style="display: flex; flex-direction: column; gap: 16px;">
        
        <!-- Messages Header Card -->
        <div class="card">
            <div class="card-header">
                <h3>💬 Messages</h3>
            </div>
            <div class="card-body">
                <input type="text" id="searchConversations" placeholder="Rechercher..." 
                       style="width: 100%; padding: var(--spacing-md) var(--spacing-lg); border: 1px solid var(--color-border); border-radius: 20px; font-size: var(--font-size-sm); font-family: var(--font-family); margin-bottom: var(--spacing-md);">
                <div style="font-size: var(--font-size-xs); color: var(--color-text-secondary);">
                    {{ conversations | length }} conversation(s)
                </div>
            </div>
        </div>

        <!-- Conversations List -->
        <div class="card" style="flex: 1; overflow-y: auto; padding: 0;">
            <div id="conversationsList">
                {% if conversations is empty %}
                    <div style="padding: var(--spacing-xl); text-align: center; color: var(--color-text-secondary);">
                        <p style="margin: 0;">Aucune conversation</p>
                        <p style="font-size: var(--font-size-xs); margin: var(--spacing-md) 0 0;">Commencez à converser avec vos amis</p>
                    </div>
                {% else %}
                    {% for conv in conversations %}
                        <a href="?with={{ conv.other_user_id }}" 
                           id="conv-{{ conv.other_user_id }}"
                           class="conversation-item {% if selectedConversationUser == conv.other_user_id %}active{% endif %}"
                           style="display: flex; padding: var(--spacing-md) var(--spacing-lg); cursor: pointer; border-bottom: 1px solid var(--color-border-light); text-decoration: none; 
                                   background: {% if selectedConversationUser == conv.other_user_id %}var(--color-background-light){% else %}transparent{% endif %};
                                   align-items: center; gap: var(--spacing-md); transition: var(--transition-fast);"
                           onmouseover="this.style.background='var(--color-background-light)'; this.style.transform='translateX(4px)';"
                           onmouseout="this.style.background='{% if selectedConversationUser == conv.other_user_id %}var(--color-background-light){% else %}transparent{% endif %}'; this.style.transform='translateX(0)';">
                            
                            <!-- Avatar -->
                            <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--gradient-primary); flex-shrink: 0; display: flex; align-items: center; justify-content: center; position: relative;">
                                {% if conv.profile_picture %}
                                    <img src="{% if conv.profile_picture starts with 'http' %}{{ conv.profile_picture }}{% else %}{{ asset('images/profile_pictures/' ~ conv.profile_picture) }}{% endif %}" 
                                         alt="{{ conv.other_full_name }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                                {% else %}
                                    <span style="color: white; font-weight: bold; font-size: var(--font-size-lg);">{{ conv.other_full_name[0:1] | upper }}</span>
                                {% endif %}
                                {% if conv.is_online %}
                                    <span style="position: absolute; bottom: 0; right: 0; width: 10px; height: 10px; border-radius: 50%; background: #22c55e; border: 2px solid white;"></span>
                                {% endif %}
                            </div>

                            <!-- Text -->
                            <div style="flex: 1; min-width: 0;">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                                    <h4 style="margin: 0; color: var(--color-text-primary); font-weight: {% if conv.unread_count %}700{% else %}600{% endif %}; font-size: var(--font-size-base);">
                                        {{ conv.other_full_name ?: conv.other_username }}
                                    </h4>
                                    <span style="font-size: var(--font-size-xs); color: var(--color-text-secondary);">
                                        {% set lastMsgTime = conv.last_message_at %}
                                        {% if lastMsgTime %}
                                            {% set today = 'now' | date('Y-m-d') %}
                                            {% set msgDate = lastMsgTime | date('Y-m-d') %}
                                            {% if msgDate == today %}
                                                {{ lastMsgTime | date('H:i') }}
                                            {% else %}
                                                {{ lastMsgTime | date('d/m') }}
                                            {% endif %}
                                        {% endif %}
                                    </span>
                                </div>
                                <p style="margin: 0; color: {% if conv.unread_count %}var(--color-text-primary){% else %}var(--color-text-secondary){% endif %}; font-size: var(--font-size-xs); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: {% if conv.unread_count %}600{% else %}400{% endif %};">
                                    {% set msg = conv.last_message %}
                                    {% if msg | length > 40 %}
                                        {{ msg | slice(0, 40) }}…
                                    {% else %}
                                        {{ msg }}
                                    {% endif %}
                                </p>
                            </div>

                            <!-- Unread Badge -->
                            {% if conv.unread_count %}
                                <div style="background: var(--color-primary); color: white; border-radius: 50%; width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; font-size: var(--font-size-xs); font-weight: bold; flex-shrink: 0;">
                                    {{ conv.unread_count > 9 ? '9+' : conv.unread_count }}
                                </div>
                            {% endif %}
                        </a>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        <!-- All Friends Card -->
        <div class="card" style="max-height: 300px; overflow-y: auto; padding: 0;">
            <div class="card-header">
                <h4 style="margin: 0;">👥 Tous les amis</h4>
            </div>
            <div id="friendsList">
                {% if acceptedFriends is empty %}
                    <div style="padding: var(--spacing-lg); text-align: center; color: var(--color-text-secondary); font-size: var(--font-size-xs);">
                        Aucun ami disponible
                    </div>
                {% else %}
                    {% for userId, friend in acceptedFriends %}
                        <a href="?with={{ userId }}" 
                           class="friend-item"
                           style="display: flex; padding: var(--spacing-md) var(--spacing-lg); cursor: pointer; border-bottom: 1px solid var(--color-border-light); text-decoration: none; 
                                   background: transparent;
                                   align-items: center; gap: var(--spacing-md); transition: var(--transition-fast);"
                           onmouseover="this.style.background='var(--color-background-light)'; this.style.transform='translateX(4px)';"
                           onmouseout="this.style.background='transparent'; this.style.transform='translateX(0)';">
                            
                            <!-- Avatar -->
                            <div style="width: 36px; height: 36px; border-radius: 50%; background: var(--gradient-primary); flex-shrink: 0; display: flex; align-items: center; justify-content: center; position: relative;">
                                {% if friend.profile_picture %}
                                    <img src="{% if friend.profile_picture starts with 'http' %}{{ friend.profile_picture }}{% else %}{{ asset('images/profile_pictures/' ~ friend.profile_picture) }}{% endif %}" 
                                         alt="{{ friend.full_name }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                                {% else %}
                                    <span style="color: white; font-weight: bold; font-size: var(--font-size-base);">{{ friend.full_name[0:1] | upper }}</span>
                                {% endif %}
                                {% if friend.is_online %}
                                    <span style="position: absolute; bottom: 0; right: 0; width: 8px; height: 8px; border-radius: 50%; background: #22c55e; border: 2px solid white;"></span>
                                {% endif %}
                            </div>

                            <!-- Text -->
                            <div style="flex: 1; min-width: 0;">
                                <h4 style="margin: 0; color: var(--color-text-primary); font-weight: 600; font-size: var(--font-size-sm);">
                                    {{ friend.full_name ?: friend.username }}
                                </h4>
                            </div>
                        </a>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </aside>

    <!-- Center Main Chat Area -->
    <main>
        {% if selectedConversationUser > 0 %}
            {% set friend = null %}
            {% for candidate in acceptedFriends %}
                {% if candidate.user_id == selectedConversationUser %}
                    {% set friend = candidate %}
                {% endif %}
            {% endfor %}

            {% if friend %}
            <div class="card" style="display: flex; flex-direction: column; height: calc(100vh - 110px);">
                
                <!-- Chat Header -->
                <div class="card-header" style="display: flex; align-items: center; gap: var(--spacing-lg); border-bottom: 1px solid var(--color-border);">
                    <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--gradient-primary); flex-shrink: 0; display: flex; align-items: center; justify-content: center; position: relative;">
                        {% if friend and friend.profile_picture %}
                            <img src="{% if friend.profile_picture starts with 'http' %}{{ friend.profile_picture }}{% else %}{{ asset('images/profile_pictures/' ~ friend.profile_picture) }}{% endif %}" 
                                 alt="{{ friend.full_name }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                        {% else %}
                            <span style="color: white; font-weight: bold; font-size: var(--font-size-xl);">{{ (friend.full_name ?? 'U')[0:1] | upper }}</span>
                        {% endif %}
                        {% if friend.is_online %}
                            <span style="position: absolute; bottom: 0; right: 0; width: 12px; height: 12px; border-radius: 50%; background: #22c55e; border: 2px solid white;"></span>
                        {% endif %}
                    </div>
                    <div style="flex: 1;">
                        <h3 style="margin: 0; color: var(--color-text-primary); font-weight: 600;">{{ friend.full_name ?: (friend.username ?? 'User') }}</h3>
                        <p style="margin: 4px 0 0; color: {% if friend.is_online %}#22c55e{% else %}var(--color-text-secondary){% endif %}; font-size: var(--font-size-xs); font-weight: 500;">
                            ● {% if friend.is_online %}En ligne{% else %}Hors ligne{% endif %}
                        </p>
                    </div>
                    <!-- Video Call Button -->
                    <button id="videoCallBtn" onclick="initiateCall({{ selectedConversationUser }})" 
                            style="width: 40px; height: 40px; padding: 0; background: var(--color-primary); color: white; border: none; border-radius: 50%; cursor: pointer; font-size: 18px; display: flex; align-items: center; justify-content: center; transition: var(--transition-fast);"
                            title="Appel vidéo"
                            onmouseover="this.style.background='var(--color-primary-dark)';"
                            onmouseout="this.style.background='var(--color-primary)';">
                        📹
                    </button>
                </div>

                <!-- Messages Container -->
                <div id="messagesContainer" style="flex: 1; overflow-y: auto; padding: var(--spacing-lg); display: flex; flex-direction: column; gap: var(--spacing-md); background: var(--color-background-light);">
                    {% if conversation is empty %}
                        <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: var(--color-text-secondary); flex-direction: column; gap: var(--spacing-md);">
                            <div style="font-size: 48px;">💬</div>
                            <p style="margin: 0; font-size: var(--font-size-lg);">Commencez la conversation ! 👋</p>
                        </div>
                    {% else %}
                        {% set lastDate = '' %}
                        {% for msg in conversation %}
                            {% set msgDate = msg.sent_at | date('Y-m-d') %}
                            {% if msgDate != lastDate %}
                                {% set lastDate = msgDate %}
                                <div style="display: flex; justify-content: center; padding: var(--spacing-md) 0;">
                                    <span style="background: var(--color-white); border: 1px solid var(--color-border); border-radius: 20px; padding: var(--spacing-sm) var(--spacing-lg); font-size: var(--font-size-xs); color: var(--color-text-secondary); font-weight: 500;">
                                        {% set today = 'now' | date('Y-m-d') %}
                                        {% if msgDate == today %}
                                            Aujourd'hui
                                        {% else %}
                                            {{ msgDate | date('d/m/Y') }}
                                        {% endif %}
                                    </span>
                                </div>
                            {% endif %}

                            <div style="display: flex; {% if msg.sender_id == currentUser.id %}justify-content: flex-end;{% else %}justify-content: flex-start;{% endif %}">
                                <div style="max-width: 60%; padding: var(--spacing-md) var(--spacing-lg); border-radius: {% if msg.sender_id == currentUser.id %}16px 16px 4px 16px;{% else %}16px 16px 16px 4px;{% endif %} 
                                            background: {% if msg.sender_id == currentUser.id %}var(--gradient-primary);{% else %}var(--color-white);{% endif %}
                                            box-shadow: {% if msg.sender_id == currentUser.id %}none;{% else %}var(--shadow-sm);{% endif %}">
                                    <p style="margin: 0; color: {% if msg.sender_id == currentUser.id %}white;{% else %}var(--color-text-primary);{% endif %} font-size: var(--font-size-base); word-wrap: break-word; line-height: 1.5;">
                                        {{ msg.content }}
                                    </p>
                                    <p style="margin: var(--spacing-sm) 0 0 0; color: {% if msg.sender_id == currentUser.id %}rgba(255,255,255,0.7);{% else %}var(--color-text-secondary);{% endif %} font-size: var(--font-size-xs); text-align: right;">
                                        {{ msg.sent_at | date('H:i') }}
                                        {% if msg.sender_id == currentUser.id and msg.is_read %}
                                            <span>✓✓</span>
                                        {% elseif msg.sender_id == currentUser.id %}
                                            <span>✓</span>
                                        {% endif %}
                                    </p>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>

                <!-- Smart Replies -->
                <div id="smartRepliesBar" style="display: none; padding: var(--spacing-md) var(--spacing-lg); background: var(--color-background-light); border-top: 1px solid var(--color-border); gap: var(--spacing-md); flex-wrap: wrap; align-items: center;">
                    <span style="font-size: 14px;">✨</span>
                </div>

                <!-- Message Input -->
                <div class="card-footer" style="border-top: 1px solid var(--color-border); padding: var(--spacing-lg); display: flex; gap: var(--spacing-md); align-items: flex-end; background: white; flex-wrap: wrap;">
                    <form id="messageForm" style="display: flex; gap: var(--spacing-md); flex: 1; min-width: 200px;" onsubmit="return sendMessage(event, {{ selectedConversationUser }});">
                        <input type="text" id="messageInput" placeholder="Écrivez votre message..." 
                               style="flex: 1; padding: var(--spacing-md) var(--spacing-lg); border: 1px solid var(--color-border); border-radius: 20px; font-size: var(--font-size-base); font-family: var(--font-family); outline: none; transition: var(--transition-fast);"
                               onfocus="this.style.borderColor='var(--color-primary)';"
                               onblur="this.style.borderColor='var(--color-border)';">
                        <button type="button" id="micButton" onclick="toggleMicrophone()" style="width: 40px; height: 40px; padding: 0; background: var(--color-background-light); color: var(--color-text-secondary); border: 1px solid var(--color-border); border-radius: 50%; cursor: pointer; font-size: 18px; display: flex; align-items: center; justify-content: center; transition: var(--transition-fast);"
                                title="Enregistrement vocal">
                            🎤
                        </button>
                        <button type="submit" style="padding: var(--spacing-md) var(--spacing-xl); background: var(--color-primary); color: white; border: none; border-radius: 20px; cursor: pointer; font-weight: 600; font-size: var(--font-size-base); transition: var(--transition-fast); font-family: var(--font-family);"
                                onmouseover="this.style.background='var(--color-primary-dark)';"
                                onmouseout="this.style.background='var(--color-primary)';">
                            Envoyer
                        </button>
                    </form>
                </div>
            </div>
            {% else %}
            <div class="card" style="display: flex; align-items: center; justify-content: center; height: calc(100vh - 110px); flex-direction: column; gap: var(--spacing-xl);">
                <div style="font-size: 64px;">💬</div>
                <div style="text-align: center;">
                    <h3 style="margin: 0; color: var(--color-text-primary); font-size: var(--font-size-2xl);">Conversation introuvable</h3>
                    <p style="font-size: var(--font-size-base); margin: var(--spacing-md) 0 0; color: var(--color-text-secondary);">Choisissez une conversation valide dans la liste de gauche</p>
                </div>
            </div>
            {% endif %}

        {% else %}
            <!-- Empty State -->
            <div class="card" style="display: flex; align-items: center; justify-content: center; height: calc(100vh - 110px); flex-direction: column; gap: var(--spacing-xl);">
                <div style="font-size: 64px;">💬</div>
                <div style="text-align: center;">
                    <h3 style="margin: 0; color: var(--color-text-primary); font-size: var(--font-size-2xl);">Sélectionnez une conversation</h3>
                    <p style="font-size: var(--font-size-base); margin: var(--spacing-md) 0 0; color: var(--color-text-secondary);">Choisissez un ami pour commencer à discuter</p>
                </div>
            </div>
        {% endif %}
    </main>

    <!-- Right Sidebar -->
    <aside style="display: flex; flex-direction: column; gap: 16px;">
        
        <!-- User Profile Mini Card -->
        <div class="card" style="text-align: center;">
            <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--gradient-primary); margin: 0 auto var(--spacing-md); border: 3px solid white; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                {% if currentUser.profilePicture %}
                    <img src="{% if currentUser.profilePicture starts with 'http' %}{{ currentUser.profilePicture }}{% else %}{{ asset('images/profile_pictures/' ~ currentUser.profilePicture) }}{% endif %}" 
                         alt="{{ currentUser.fullName }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                {% else %}
                    <span style="color: white; font-weight: bold; font-size: 32px;">{{ (currentUser.fullName ?? 'U')[0:1] | upper }}</span>
                {% endif %}
            </div>
            <h4 style="margin: 0 0 4px 0; color: var(--color-text-primary);">{{ currentUser.fullName }}</h4>
            <p style="color: var(--color-text-secondary); font-size: var(--font-size-sm); margin: 0;">@{{ currentUser.username }}</p>
        </div>
        
        <!-- Quick Stats -->
        <div class="card">
            <div class="card-header">
                <h4 style="margin: 0;">📊 Statistiques</h4>
            </div>
            <div class="card-body">
                <div style="display: flex; flex-direction: column; gap: var(--spacing-md);">
                    <div>
                        <p style="margin: 0; font-size: var(--font-size-xs); color: var(--color-text-secondary);">Conversations</p>
                        <p style="margin: var(--spacing-sm) 0 0; font-size: var(--font-size-2xl); font-weight: bold; color: var(--color-primary);">{{ conversations | length }}</p>
                    </div>
                    <div>
                        <p style="margin: 0; font-size: var(--font-size-xs); color: var(--color-text-secondary);">Messages non lus</p>
                        <p style="margin: var(--spacing-sm) 0 0; font-size: var(--font-size-2xl); font-weight: bold; color: {% if unreadMessageCount > 0 %}#dc3545{% else %}#22c55e{% endif %};">{{ unreadMessageCount }}</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Navigation Links -->
        <div class="card">
            <div style="display: flex; flex-direction: column; gap: 8px;">
                <a href="{{ path('app_dashboard') }}" class="nav-link" style="justify-content: flex-start;">📰 Accueil</a>
                <a href="{{ path('app_social_index') }}" class="nav-link" style="justify-content: flex-start;">👥 Amis</a>
                <a href="{{ path('app_messages_index') }}" class="nav-link active" style="justify-content: flex-start;">💬 Messages</a>
                <a href="{{ path('app_progress_index') }}" class="nav-link" style="justify-content: flex-start;">🏆 Badges</a>
            </div>
        </div>
    </aside>
</div>

<!-- ║ INCOMING CALL NOTIFICATION MODAL ║ -->
<div id="incomingCallModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
    <div class="card" style="width: 90%; max-width: 400px; text-align: center; padding: var(--spacing-2xl);">
        <div style="width: 100px; height: 100px; border-radius: 50%; background: var(--gradient-primary); margin: 0 auto var(--spacing-2xl); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <span id="incomingCallerInitial" style="color: white; font-weight: bold; font-size: 40px;">U</span>
        </div>
        <h2 id="incomingCallerName" style="margin: 0 0 var(--spacing-md); color: var(--color-text-primary);">Appel entrant</h2>
        <p id="incomingCallerUsername" style="margin: 0 0 var(--spacing-2xl); color: var(--color-text-secondary); font-size: var(--font-size-base);">@user</p>
        <div style="display: flex; gap: var(--spacing-lg);">
            <button onclick="rejectCall()" style="flex: 1; padding: var(--spacing-md) var(--spacing-lg); background: #dc3545; color: white; border: none; border-radius: 20px; cursor: pointer; font-weight: 600; transition: var(--transition-fast);"
                    onmouseover="this.style.background='#bb2d3b';"
                    onmouseout="this.style.background='#dc3545';">
                ❌ Rejeter
            </button>
            <button onclick="acceptCall()" style="flex: 1; padding: var(--spacing-md) var(--spacing-lg); background: #22c55e; color: white; border: none; border-radius: 20px; cursor: pointer; font-weight: 600; transition: var(--transition-fast);"
                    onmouseover="this.style.background='#16a34a';"
                    onmouseout="this.style.background='#22c55e';">
                ✅ Accepter
            </button>
        </div>
    </div>
</div>

<!-- ║ ACTIVE VIDEO CALL MODAL ║ -->
<div id="activeCallModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.95); z-index: 1000; align-items: center; justify-content: center; flex-direction: column; padding: var(--spacing-lg);">
    <div style="width: 100%; max-width: 600px; display: flex; flex-direction: column; gap: var(--spacing-lg);">
        <!-- Remote Video (Large) -->
        <video id="remoteVideo" autoplay playsinline style="width: 100%; background: #000; border-radius: 8px; aspect-ratio: 16/9; object-fit: cover;"></video>
        
        <!-- Local Video (Small, Bottom Right) -->
        <div style="position: relative; width: 120px; height: 90px;">
            <video id="localVideo" autoplay muted playsinline style="width: 100%; height: 100%; background: #000; border-radius: 8px; object-fit: cover; border: 2px solid var(--color-primary);"></video>
        </div>

        <!-- Call Status -->
        <div style="text-align: center; color: white;">
            <p id="callStatus" style="margin: 0; font-size: var(--font-size-lg); font-weight: 600;">Connexion en cours...</p>
            <p id="callDuration" style="margin: var(--spacing-sm) 0 0; font-size: var(--font-size-base); color: rgba(255,255,255,0.7);">00:00</p>
        </div>

        <!-- End Call Button -->
        <button onclick="endCall()" style="width: 100%; padding: var(--spacing-md) var(--spacing-lg); background: #dc3545; color: white; border: none; border-radius: 20px; cursor: pointer; font-weight: 600; font-size: var(--font-size-lg); transition: var(--transition-fast);"
                onmouseover="this.style.background='#bb2d3b';"
                onmouseout="this.style.background='#dc3545';">
            📞 Terminer l'appel
        </button>
    </div>
</div>

<script>
    const userId = {{ userId }};
    const selectedUserId = {{ selectedConversationUser }};
    let lastMessageId = 0;
    let pollInterval = null;
    let chatSocket = null;
    let wsConnected = false;

    function getWebSocketUrl() {
        const protocol = window.location.protocol === 'https:' ? 'wss' : 'ws';
        return `${protocol}://${window.location.hostname}:9090`;
    }

    function connectWebSocket() {
        if (selectedUserId <= 0) return;

        try {
            chatSocket = new WebSocket(getWebSocketUrl());

            chatSocket.onopen = () => {
                wsConnected = true;
                stopPolling();
                chatSocket.send(`REGISTER:${userId}`);
            };

            chatSocket.onmessage = (event) => {
                const payload = String(event.data || '');
                
                // Handle chat messages
                if (payload.startsWith('MSG:')) {
                    const parts = payload.split(':');
                    if (parts.length < 4) return;

                    const fromId = Number(parts[1]);
                    const toId = Number(parts[2]);
                    const content = parts.slice(3).join(':');

                    if (content === '__TYPING__') {
                        return;
                    }

                    if (fromId === selectedUserId && toId === userId) {
                        appendMessageToChat(fromId, toId, content, true);
                    }
                }
                // Handle call initiation
                else if (payload.startsWith('CALL_INIT:')) {
                    const parts = payload.split(':');
                    if (parts.length < 3) return;
                    const fromId = Number(parts[1]);
                    console.log('[WebSocket] CALL_INIT received from', fromId);
                    
                    // Show incoming call modal
                    incomingCallFromId = fromId;
                    const modal = document.getElementById('incomingCallModal');
                    const nameEl = document.getElementById('incomingCallerName');
                    const usernameEl = document.getElementById('incomingCallerUsername');
                    const initialEl = document.getElementById('incomingCallerInitial');
                    
                    nameEl.textContent = selectedUserId === fromId ? (document.querySelector('.card-header h3')?.textContent || 'Appel entrant') : 'Appel entrant';
                    usernameEl.textContent = '📞 Appel entrant...';
                    initialEl.textContent = (nameEl.textContent[0] || 'U');
                    
                    modal.style.display = 'flex';

                    // Auto-reject after 30 seconds if not answered
                    incomingCallTimeout = setTimeout(() => {
                        if (incomingCallFromId && !isCallActive) {
                            rejectCall();
                        }
                    }, 30000);
                }
                // Handle WebRTC offer
                else if (payload.startsWith('CALL_OFFER:')) {
                    const match = payload.match(/^CALL_OFFER:(\d+):(\d+):(.*)/);
                    if (match) {
                        const fromId = Number(match[1]);
                        const offerJson = match[3];
                        console.log('[WebSocket] CALL_OFFER received from', fromId);
                        handleWebRtcOffer(fromId, offerJson);
                    }
                }
                // Handle WebRTC answer
                else if (payload.startsWith('CALL_ANSWER_OFFER:')) {
                    const match = payload.match(/^CALL_ANSWER_OFFER:(\d+):(\d+):(.*)/);
                    if (match) {
                        const fromId = Number(match[1]);
                        const answerJson = match[3];
                        console.log('[WebSocket] CALL_ANSWER_OFFER received from', fromId);
                        handleWebRtcAnswer(fromId, answerJson);
                    }
                }
                // Handle ICE candidates
                else if (payload.startsWith('CALL_ICE:')) {
                    const match = payload.match(/^CALL_ICE:(\d+):(\d+):(.*)/);
                    if (match) {
                        const fromId = Number(match[1]);
                        const candidateJson = match[3];
                        handleIceCandidate(fromId, candidateJson);
                    }
                }
                // Handle call acceptance
                else if (payload.startsWith('CALL_ANSWER:')) {
                    const parts = payload.split(':');
                    if (parts.length < 3) return;
                    const fromId = Number(parts[1]);
                    console.log('[WebSocket] CALL_ANSWER received from', fromId);
                    
                    // Now that recipient is ready, send the offer
                    if (peerConnection && peerConnection.signalingState === 'stable') {
                        (async () => {
                            try {
                                const offer = await peerConnection.createOffer();
                                await peerConnection.setLocalDescription(offer);
                                const offerJson = JSON.stringify(offer);
                                if (wsConnected && chatSocket && chatSocket.readyState === WebSocket.OPEN) {
                                    chatSocket.send(`CALL_OFFER:${userId}:${fromId}:${offerJson}`);
                                    console.log('[Call] WebRTC offer sent after CALL_ANSWER');
                                }
                            } catch (err) {
                                console.error('[Call] Error creating offer:', err);
                            }
                        })();
                    } else {
                        console.warn('[Call] Peer connection not ready for offer creation');
                    }
                }
                // Handle call rejection
                else if (payload.startsWith('CALL_REJECT:')) {
                    const parts = payload.split(':');
                    if (parts.length < 3) return;
                    const fromId = Number(parts[1]);
                    console.log('[WebSocket] CALL_REJECT received from', fromId);
                    endCall();
                    alert('Appel rejeté');
                }
                // Handle call end
                else if (payload.startsWith('CALL_END:')) {
                    const parts = payload.split(':');
                    if (parts.length < 3) return;
                    const fromId = Number(parts[1]);
                    console.log('[WebSocket] CALL_END received from', fromId);
                    endCall();
                }
            };

            chatSocket.onclose = () => {
                wsConnected = false;
                startPolling();
            };

            chatSocket.onerror = () => {
                wsConnected = false;
                startPolling();
            };
        } catch (error) {
            wsConnected = false;
            startPolling();
        }
    }

    function sendMessageViaWebSocket(recipientId, content) {
        if (!wsConnected || !chatSocket || chatSocket.readyState !== WebSocket.OPEN) {
            return false;
        }

        try {
            chatSocket.send(`MSG:${userId}:${recipientId}:${content}`);
            return true;
        } catch (error) {
            return false;
        }
    }

    function sendTypingIndicator(recipientId) {
        if (!wsConnected || !chatSocket || chatSocket.readyState !== WebSocket.OPEN) {
            return false;
        }

        try {
            chatSocket.send(`MSG:${userId}:${recipientId}:__TYPING__`);
            return true;
        } catch (error) {
            return false;
        }
    }

    function startPolling() {
        if (selectedUserId <= 0) return;

        // Poll every 2 seconds for new messages
        pollInterval = setInterval(() => {
            pollForNewMessages();
        }, 2000);
    }

    function stopPolling() {
        if (pollInterval) {
            clearInterval(pollInterval);
            pollInterval = null;
        }
    }

    function pollForNewMessages() {
        if (selectedUserId <= 0) return;

        fetch(`{{ path('app_messages_poll') }}?other_user_id=${selectedUserId}`, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => r.json())
        .then(data => {
            if (data.success && data.messages && data.messages.length > 0) {
                data.messages.forEach(msg => {
                    // Only display messages from the selected user (received messages)
                    if (msg.sender_id == selectedUserId) {
                        appendMessageToChat(msg.sender_id, msg.receiver_id, msg.content, true);
                    }
                });
            }
        })
        .catch(err => console.error('[Poll] Error:', err));
    }

    function appendMessageToChat(fromId, toId, content, isRemote = false) {
        const container = document.getElementById('messagesContainer');
        if (!container) return;


    // Initialize realtime + fallback polling on page load
    document.addEventListener('DOMContentLoaded', () => {
        if (selectedUserId > 0) {
            startPolling();
            connectWebSocket();
        }
    });

    // Auto-scroll to bottom on load
    const messagesContainer = document.getElementById('messagesContainer');
    if (messagesContainer) {
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    // Search conversations
    document.getElementById('searchConversations')?.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase();
        const items = document.querySelectorAll('.conversation-item');
        items.forEach(item => {
            const text = item.textContent.toLowerCase();
            item.style.display = text.includes(query) ? 'flex' : 'none';
        });
    });

    // Send message via WebSocket when available, otherwise fallback to HTTP
    function sendMessage(event, recipientId) {
        event.preventDefault();
        const input = document.getElementById('messageInput');
        const content = input.value.trim();
        
        if (!content) return false;

        if (sendMessageViaWebSocket(recipientId, content)) {
            appendMessageToChat(userId, recipientId, content, false);
            input.value = '';
            return false;
        }

        const formData = new FormData();
        formData.append('receiver_id', recipientId);
        formData.append('content', content);

        fetch('{{ path("app_messages_send") }}', {
            method: 'POST',
            body: formData,
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                // Add message to UI immediately
                appendMessageToChat(userId, recipientId, content, false);
                input.value = '';
                // Auto-scroll to bottom
                const container = document.getElementById('messagesContainer');
                if (container) {
                    container.scrollTop = container.scrollHeight;
                }
            } else {
                alert('Erreur: ' + (data.error || 'Failed to send message'));
            }
        })
        .catch(err => {
            console.error('Error:', err);
            alert('Erreur lors de l\'envoi du message');
        });

        return false;
    }

    // Show typing indicator while typing (debounced)
    let typingTimeout;
    document.getElementById('messageInput')?.addEventListener('input', () => {
        clearTimeout(typingTimeout);
        if (selectedUserId > 0) {
            sendTypingIndicator(selectedUserId);
            typingTimeout = setTimeout(() => {
                // Clear typing indicator after 2 seconds of inactivity
            }, 2000);
        }
    });

    // ══════════════════════════════════════════════════
    // Smart Replies (Groq LLaMA)
    // ══════════════════════════════════════════════════
    
    async function fetchSmartReplies(lastMessage) {
        if (selectedUserId <= 0) return;

        try {
            const response = await fetch('{{ path("app_messages_smart_replies") }}', {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    other_user_id: selectedUserId,
                    last_message: lastMessage,
                })
            });

            const data = await response.json();
            if (data.success && data.replies && data.replies.length > 0) {
                renderSmartReplies(data.replies);
            }
        } catch (err) {
            console.error('[SmartReplies] Error:', err);
        }
    }

    function renderSmartReplies(replies) {
        const bar = document.getElementById('smartRepliesBar');
        if (!bar) return;

        // Clear existing replies (keep the ✨ emoji)
        while (bar.children.length > 1) {
            bar.removeChild(bar.lastChild);
        }

        bar.style.display = 'flex';

        for (const reply of replies) {
            const chip = document.createElement('button');
            chip.type = 'button';
            chip.textContent = reply;
            chip.style.cssText = `
                background: var(--color-background-white);
                color: var(--color-text-primary);
                border: 1px solid var(--color-border);
                padding: 6px 14px;
                border-radius: 20px;
                font-size: var(--font-size-sm);
                cursor: pointer;
                font-family: var(--font-family);
                transition: var(--transition-fast);
            `;
            chip.onmouseover = () => {
                chip.style.background = 'var(--color-primary)';
                chip.style.color = 'white';
                chip.style.borderColor = 'var(--color-primary)';
            };
            chip.onmouseout = () => {
                chip.style.background = 'var(--color-background-white)';
                chip.style.color = 'var(--color-text-primary)';
                chip.style.borderColor = 'var(--color-border)';
            };
            chip.onclick = () => {
                document.getElementById('messageInput').value = reply;
                document.getElementById('messageInput').focus();
                hideSmartReplies();
            };
            bar.appendChild(chip);
        }
    }

    function hideSmartReplies() {
        const bar = document.getElementById('smartRepliesBar');
        if (bar) {
            bar.style.display = 'none';
            while (bar.children.length > 1) {
                bar.removeChild(bar.lastChild);
            }
        }
    }

    // ══════════════════════════════════════════════════
    // Voice-to-Text (Groq Whisper)
    // ══════════════════════════════════════════════════

    let msgIsRecording = false;
    let msgMediaRecorder = null;
    let msgAudioChunks = [];
    let msgRecordingMimeType = 'audio/wav';

    function setMicIdleState(disabled = false) {
        const micBtn = document.getElementById('micButton');
        if (!micBtn) return;
        micBtn.textContent = '🎤';
        micBtn.style.setProperty('background', 'var(--color-background-light)', 'important');
        micBtn.style.setProperty('color', 'var(--color-text-secondary)', 'important');
        micBtn.style.setProperty('box-shadow', 'none', 'important');
        micBtn.disabled = disabled;
        micBtn.style.opacity = disabled ? '0.65' : '1';
    }

    function setMicRecordingState() {
        const micBtn = document.getElementById('micButton');
        if (!micBtn) return;
        micBtn.textContent = '🎤';
        micBtn.style.setProperty('background', '#dc3545', 'important');
        micBtn.style.setProperty('color', '#ffffff', 'important');
        micBtn.style.setProperty('box-shadow', '0 0 0 3px rgba(220, 53, 69, 0.25)', 'important');
        micBtn.disabled = false;
        micBtn.style.opacity = '1';
    }

    async function toggleMicrophone() {
        if (!msgIsRecording) {
            await startRecording();
        } else {
            stopRecordingAndTranscribe();
        }
    }

    async function startRecording() {
        try {
            // Show recording state immediately on click
            setMicRecordingState();

            const stream = await navigator.mediaDevices.getUserMedia({ audio: { sampleRate: 16000 } });
            
            // Try to use WAV format if supported, fallback to browser default
            const mimeType = MediaRecorder.isTypeSupported('audio/wav')
                ? 'audio/wav'
                : MediaRecorder.isTypeSupported('audio/webm')
                ? 'audio/webm'
                : '';
            msgRecordingMimeType = mimeType || 'audio/webm';
            
            const options = mimeType ? { mimeType } : {};
            msgMediaRecorder = new MediaRecorder(stream, options);
            msgAudioChunks = [];

            console.log('[Voice] Recording started with format:', mimeType || 'browser default');

            msgMediaRecorder.ondataavailable = (e) => {
                msgAudioChunks.push(e.data);
            };

            msgMediaRecorder.onstop = async () => {
                console.log('[Voice] Recording stopped, chunks:', msgAudioChunks.length);
                const audioBlob = new Blob(msgAudioChunks, { type: msgRecordingMimeType });
                console.log('[Voice] Audio blob size:', audioBlob.size, 'bytes');
                await transcribeAudio(audioBlob);
                stream.getTracks().forEach(track => track.stop());
            };

            msgMediaRecorder.onerror = (e) => {
                console.error('[Voice] Recording error:', e.error);
                alert('Erreur lors de l\'enregistrement: ' + e.error);
            };

            msgMediaRecorder.start();
            msgIsRecording = true;
        } catch (err) {
            console.error('[Voice] Error:', err);
            setMicIdleState(false);
            alert('Erreur: Impossible d\'accéder au microphone. Vérifiez les permissions.');
        }
    }

    function stopRecordingAndTranscribe() {
        if (msgMediaRecorder && msgIsRecording) {
            msgMediaRecorder.stop();
            msgIsRecording = false;

            // Revert immediately on stop; keep disabled during upload/transcribe
            setMicIdleState(true);
        }
    }

    async function transcribeAudio(audioBlob) {
        try {
            console.log('[Transcribe] Starting transcription, blob size:', audioBlob.size);
            
            const formData = new FormData();
            const extension = msgRecordingMimeType.includes('webm') ? 'webm' : 'wav';
            formData.append('audio', audioBlob, `audio.${extension}`);

            const response = await fetch('{{ path("app_messages_transcribe") }}', {
                method: 'POST',
                body: formData,
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            console.log('[Transcribe] Response status:', response.status);
            const data = await response.json();
            console.log('[Transcribe] Response data:', data);

            if (data.success && data.text) {
                console.log('[Transcribe] Success! Text:', data.text);
                const input = document.getElementById('messageInput');
                const current = input.value.trim();
                input.value = current ? current + ' ' + data.text : data.text;
                input.focus();
                // Hide smart replies since user has typed
                hideSmartReplies();
            } else if (data.text) {
                // Handle case where success flag might be missing but text is present
                console.log('[Transcribe] Text received without explicit success flag:', data.text);
                const input = document.getElementById('messageInput');
                const current = input.value.trim();
                input.value = current ? current + ' ' + data.text : data.text;
                input.focus();
                hideSmartReplies();
            } else {
                console.error('[Transcribe] Error response:', data);
                alert('Erreur: ' + (data.error || 'Transcription failed'));
            }
        } catch (err) {
            console.error('[Transcribe] Exception:', err);
            alert('Erreur lors de la transcription: ' + err.message);
        } finally {
            // Reset mic button
            setMicIdleState(false);
        }
    }

    // Update polling to fetch smart replies on new messages
    const originalAppendMessage = appendMessageToChat;
    window.appendMessageToChat = function(fromId, toId, content, isRemote = false) {
        originalAppendMessage.call(this, fromId, toId, content, isRemote);
        
        // Fetch smart replies for incoming messages
        if (isRemote && fromId !== userId && selectedUserId > 0) {
            hideSmartReplies();
            fetchSmartReplies(content);
        }
    };

    // Hide smart replies when user starts typing
    document.getElementById('messageInput')?.addEventListener('input', (e) => {
        if (e.target.value.length > 0) {
            hideSmartReplies();
        }
    });

    // ══════════════════════════════════════════════════
    // WebRTC Video Calling (Manual Signaling via WebSocket)
    // ══════════════════════════════════════════════════

    let peerConnection = null;
    let localStream = null;
    let remoteStream = null;
    let isCallActive = false;
    let callStartTime = null;
    let callDurationInterval = null;
    let incomingCallTimeout = null;
    let incomingCallFromId = null;
    let pendingIceCandidates = []; // Queue ICE candidates if peer connection isn't ready yet

    const ICE_SERVERS = {
        iceServers: [
            { urls: ['stun:stun.l.google.com:19302'] },
            { urls: ['stun:stun1.l.google.com:19302'] },
            { urls: ['stun:stun2.l.google.com:19302'] },
            { urls: ['stun:stun3.l.google.com:19302'] },
        ]
    };

    async function attachRemoteStreamFromTrackEvent(event) {
        const remoteVideoEl = document.getElementById('remoteVideo');
        if (!remoteVideoEl) return;

        if (event.streams && event.streams[0]) {
            remoteStream = event.streams[0];
        } else {
            if (!remoteStream) {
                remoteStream = new MediaStream();
            }
            remoteStream.addTrack(event.track);
        }

        remoteVideoEl.srcObject = remoteStream;
        remoteVideoEl.muted = false;
        remoteVideoEl.volume = 1;

        try {
            await remoteVideoEl.play();
        } catch (err) {
            console.warn('[WebRTC] Remote video autoplay blocked; user interaction may be required.', err);
        }

        isCallActive = true;
        if (!callStartTime) {
            callStartTime = Date.now();
            startCallDurationTimer();
        }
        document.getElementById('callStatus').textContent = '🟢 Appel actif';
    }

    // Initiate call to recipient
    async function initiateCall(recipientId) {
        if (!recipientId || recipientId <= 0) {
            alert('Erreur: Destinataire invalide');
            return;
        }

        try {
            // Notify recipient of incoming call via WebSocket
            if (wsConnected && chatSocket && chatSocket.readyState === WebSocket.OPEN) {
                chatSocket.send(`CALL_INIT:${userId}:${recipientId}`);
                console.log('[Call] CALL_INIT sent to', recipientId);
            } else {
                alert('WebSocket non connecté. Impossible d\'effectuer l\'appel.');
                return;
            }

            // Get local media
            const stream = await navigator.mediaDevices.getUserMedia({ 
                video: { width: { ideal: 480 }, height: { ideal: 360 } },
                audio: true 
            });

            console.log('[Call] Got local media stream');
            localStream = stream;

            // Show active call modal
            const activeModal = document.getElementById('activeCallModal');
            const localVideoEl = document.getElementById('localVideo');
            
            activeModal.style.display = 'flex';
            localVideoEl.srcObject = stream;
            document.getElementById('callStatus').textContent = '⏳ En attente de réponse...';

            // Create peer connection
            peerConnection = new RTCPeerConnection(ICE_SERVERS);

            // Add local stream tracks
            stream.getTracks().forEach(track => {
                peerConnection.addTrack(track, stream);
            });

            // Handle remote stream
            peerConnection.ontrack = async (event) => {
                console.log('[WebRTC] Received remote track');
                await attachRemoteStreamFromTrackEvent(event);
            };

            // Handle ICE candidates
            peerConnection.onicecandidate = (event) => {
                if (event.candidate) {
                    const candidate = JSON.stringify(event.candidate);
                    if (wsConnected && chatSocket && chatSocket.readyState === WebSocket.OPEN) {
                        chatSocket.send(`CALL_ICE:${userId}:${recipientId}:${candidate}`);
                    }
                }
            };

            // Handle connection state changes
            peerConnection.onconnectionstatechange = () => {
                console.log('[WebRTC] Connection state:', peerConnection.connectionState);
                if (peerConnection.connectionState === 'failed' || peerConnection.connectionState === 'disconnected') {
                    endCall();
                }
            };

            // Store recipient ID for later when sending offer
            window.currentCallRecipientId = recipientId;
            console.log('[Call] Peer connection created, waiting for CALL_ANSWER from recipient');

        } catch (err) {
            console.error('[Call] Error getting media:', err);
            alert('Erreur: Impossible d\'accéder à la caméra/microphone.\n' + err.message);
            endCall();
        }
    }

    // Accept incoming call
    async function acceptCall() {
        if (!incomingCallFromId) {
            console.error('[Call] No incoming call to accept');
            return;
        }

        // Clear auto-reject timeout
        if (incomingCallTimeout) {
            clearTimeout(incomingCallTimeout);
            incomingCallTimeout = null;
        }

        try {
            // Close incoming modal, show active call modal
            document.getElementById('incomingCallModal').style.display = 'none';
            
            // Get local media
            const stream = await navigator.mediaDevices.getUserMedia({ 
                video: { width: { ideal: 480 }, height: { ideal: 360 } },
                audio: true 
            });

            console.log('[Call] Got local media stream for accepting call');

            localStream = stream;

            const activeModal = document.getElementById('activeCallModal');
            const localVideoEl = document.getElementById('localVideo');
            
            activeModal.style.display = 'flex';
            localVideoEl.srcObject = stream;
            document.getElementById('callStatus').textContent = '⏳ En attente de connexion...';

            // Create peer connection
            peerConnection = new RTCPeerConnection(ICE_SERVERS);

            // Add local stream tracks
            stream.getTracks().forEach(track => {
                peerConnection.addTrack(track, stream);
            });

            // Handle remote stream
            peerConnection.ontrack = async (event) => {
                console.log('[WebRTC] Received remote track');
                await attachRemoteStreamFromTrackEvent(event);
            };

            // Handle ICE candidates
            peerConnection.onicecandidate = (event) => {
                if (event.candidate) {
                    const candidate = JSON.stringify(event.candidate);
                    if (wsConnected && chatSocket && chatSocket.readyState === WebSocket.OPEN) {
                        chatSocket.send(`CALL_ICE:${userId}:${incomingCallFromId}:${candidate}`);
                    }
                }
            };

            // Handle connection state changes
            peerConnection.onconnectionstatechange = () => {
                console.log('[WebRTC] Connection state:', peerConnection.connectionState);
                if (peerConnection.connectionState === 'failed' || peerConnection.connectionState === 'disconnected') {
                    endCall();
                }
            };

            // Now that peer connection and media are ready, notify caller
            if (wsConnected && chatSocket && chatSocket.readyState === WebSocket.OPEN) {
                chatSocket.send(`CALL_ANSWER:${userId}:${incomingCallFromId}`);
                console.log('[Call] CALL_ANSWER sent to', incomingCallFromId);
            }

        } catch (err) {
            console.error('[Call] Error accepting call:', err);
            alert('Erreur: Impossible d\'accéder à la caméra/microphone.\n' + err.message);
            rejectCall();
        }
    }

    // Reject incoming call
    function rejectCall() {
        if (incomingCallTimeout) {
            clearTimeout(incomingCallTimeout);
            incomingCallTimeout = null;
        }

        document.getElementById('incomingCallModal').style.display = 'none';

        // Notify caller
        if (incomingCallFromId && wsConnected && chatSocket && chatSocket.readyState === WebSocket.OPEN) {
            chatSocket.send(`CALL_REJECT:${userId}:${incomingCallFromId}`);
            console.log('[Call] CALL_REJECT sent to', incomingCallFromId);
        }

        incomingCallFromId = null;

        // Close peer connection if it exists
        if (peerConnection) {
            peerConnection.close();
            peerConnection = null;
        }

        console.log('[Call] Call rejected');
    }

    // End active call
    function endCall() {
        // Stop duration timer
        if (callDurationInterval) {
            clearInterval(callDurationInterval);
            callDurationInterval = null;
        }

        // Clear pending ICE candidates
        pendingIceCandidates = [];

        // Close video streams
        const localVideoEl = document.getElementById('localVideo');
        const remoteVideoEl = document.getElementById('remoteVideo');
        
        if (localStream) {
            localStream.getTracks().forEach(track => track.stop());
            localStream = null;
        }

        if (localVideoEl) {
            localVideoEl.srcObject = null;
        }

        if (remoteVideoEl) {
            remoteVideoEl.srcObject = null;
        }
        remoteStream = null;

        // Close peer connection
        if (peerConnection) {
            peerConnection.close();
            peerConnection = null;
        }

        // Hide modals
        document.getElementById('activeCallModal').style.display = 'none';
        document.getElementById('incomingCallModal').style.display = 'none';

        isCallActive = false;
        callStartTime = null;
        incomingCallFromId = null;

        console.log('[Call] Call ended');

        // Notify peer
        if (selectedUserId > 0 && wsConnected && chatSocket && chatSocket.readyState === WebSocket.OPEN) {
            chatSocket.send(`CALL_END:${userId}:${selectedUserId}`);
        }
    }

    // Start call duration timer
    function startCallDurationTimer() {
        callDurationInterval = setInterval(() => {
            if (callStartTime) {
                const elapsed = Math.floor((Date.now() - callStartTime) / 1000);
                const minutes = Math.floor(elapsed / 60);
                const seconds = elapsed % 60;
                document.getElementById('callDuration').textContent = 
                    String(minutes).padStart(2, '0') + ':' + String(seconds).padStart(2, '0');
            }
        }, 1000);
    }

    // Handle incoming WebRTC offer
    async function handleWebRtcOffer(fromId, offerJson) {
        if (!peerConnection) {
            console.error('[WebRTC] No peer connection for offer handling');
            return;
        }

        // Only accept an offer when in stable state
        if (peerConnection.signalingState !== 'stable') {
            console.warn('[WebRTC] Ignoring offer – wrong signaling state:', peerConnection.signalingState);
            return;
        }

        try {
            const offer = JSON.parse(offerJson);
            await peerConnection.setRemoteDescription(new RTCSessionDescription(offer));
            console.log('[WebRTC] Remote description set with offer');

            // Drain any ICE candidates queued before the offer arrived
            if (pendingIceCandidates.length > 0) {
                console.log('[WebRTC] Draining', pendingIceCandidates.length, 'queued ICE candidates');
                for (const candidateJson of pendingIceCandidates) {
                    try {
                        const candidate = JSON.parse(candidateJson);
                        if (candidate && candidate.candidate) {
                            await peerConnection.addIceCandidate(new RTCIceCandidate(candidate));
                        }
                    } catch (err) {
                        console.error('[WebRTC] Error adding queued ICE candidate:', err);
                    }
                }
                pendingIceCandidates = [];
            }

            // Create and send answer
            const answer = await peerConnection.createAnswer();
            await peerConnection.setLocalDescription(answer);

            const answerJson = JSON.stringify(answer);
            if (wsConnected && chatSocket && chatSocket.readyState === WebSocket.OPEN) {
                chatSocket.send(`CALL_ANSWER_OFFER:${userId}:${fromId}:${answerJson}`);
                console.log('[WebRTC] Answer sent');
            }
        } catch (err) {
            console.error('[WebRTC] Error handling offer:', err);
        }
    }

    // Handle incoming WebRTC answer
    async function handleWebRtcAnswer(fromId, answerJson) {
        if (!peerConnection) {
            console.error('[WebRTC] No peer connection for answer handling');
            return;
        }

        // Only valid to set a remote answer when we have sent a local offer
        if (peerConnection.signalingState !== 'have-local-offer') {
            console.warn('[WebRTC] Ignoring answer – wrong signaling state:', peerConnection.signalingState);
            return;
        }

        try {
            const answer = JSON.parse(answerJson);
            await peerConnection.setRemoteDescription(new RTCSessionDescription(answer));
            console.log('[WebRTC] Remote description set with answer');

            // Drain ICE candidates that arrived before the answer
            if (pendingIceCandidates.length > 0) {
                console.log('[WebRTC] Draining', pendingIceCandidates.length, 'queued ICE candidates');
                for (const candidateJson of pendingIceCandidates) {
                    try {
                        const candidate = JSON.parse(candidateJson);
                        if (candidate && candidate.candidate) {
                            await peerConnection.addIceCandidate(new RTCIceCandidate(candidate));
                        }
                    } catch (err) {
                        console.error('[WebRTC] Error adding queued ICE candidate:', err);
                    }
                }
                pendingIceCandidates = [];
            }
        } catch (err) {
            console.error('[WebRTC] Error handling answer:', err);
        }
    }

    // Handle incoming ICE candidate
    async function handleIceCandidate(fromId, candidateJson) {
        // Queue if peer connection doesn't exist OR remote description not yet set
        if (!peerConnection || !peerConnection.remoteDescription) {
            console.log('[WebRTC] Queuing ICE candidate (remote description not ready)');
            pendingIceCandidates.push(candidateJson);
            return;
        }

        try {
            const candidate = JSON.parse(candidateJson);
            if (candidate && candidate.candidate) {
                await peerConnection.addIceCandidate(new RTCIceCandidate(candidate));
            }
        } catch (err) {
            console.error('[WebRTC] Error adding ICE candidate:', err);
        }
    }

</script>


        messageDiv.style.justifyContent = isMine ? 'flex-end' : 'flex-start';

        const bubble = document.createElement('div');
        bubble.style.maxWidth = '60%';
        bubble.style.padding = 'var(--spacing-md) var(--spacing-lg)';
        bubble.style.borderRadius = isMine ? '16px 16px 4px 16px' : '16px 16px 16px 4px';
        bubble.style.background = isMine ? 'var(--gradient-primary)' : 'var(--color-white)';
        bubble.style.boxShadow = isMine ? 'none' : 'var(--shadow-sm)';

        const contentP = document.createElement('p');
        contentP.style.margin = '0';
        contentP.style.color = isMine ? 'white' : 'var(--color-text-primary)';
        contentP.style.fontSize = 'var(--font-size-base)';
        contentP.style.wordWrap = 'break-word';
        contentP.style.lineHeight = '1.5';
        contentP.textContent = content;

        const timeP = document.createElement('p');
        timeP.style.margin = 'var(--spacing-sm) 0 0 0';

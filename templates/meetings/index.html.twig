        if (dtErr) { showToast(dtErr, 'error'); return; }
        if (type === 'physical' && !location) { showToast('Please enter a location for an in-person meeting.', 'error'); return; }

        const btn = document.getElementById('btnEmGoogleCalendar');
        const originalText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = 'Adding...';

        try {
            const resp = await fetch(`/api/meetings/${meetingId}/update`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    meeting_type: type,
                    scheduled_at: `${dateVal} ${timeVal}:00`,
                    duration,
                    location: type === 'physical' ? location : null,
                    add_to_calendar: true
                }),
            });
            const data = await resp.json();
            if (data.ok) {
                if (data.calendar_added) {
                    showToast('✅ Added to Google Calendar!', 'success');
                    closeModal('editMeetingModal');
                    loadMeetings(state.currentMeetingFilter);
                } else if (data.calendar_error) {
                    if (data.calendar_error.includes('authenticated') || data.calendar_error.includes('token')) {
                        if (confirm('Google account not connected or session expired. Connect now?')) {
                            const width = 500, height = 600;
                            const left = (window.innerWidth / 2) - (width / 2);
                            const top = (window.innerHeight / 2) - (height / 2);
                            window.open('/google/calendar/connect', 'google_auth', `width=${width},height=${height},top=${top},left=${left}`);
                        }
                    } else {
                        showToast('Error: ' + data.calendar_error, 'error');
                    }

            if (data.ok) {
                closeModal('quickConnectModal');
                showToast(`Connection request sent to ${state.quickConnectUserName}! 🎉`, 'success');
                loadMatches();
            } else {
                showToast(data.error || 'Failed to send request.', 'error');
            }
        } catch (err) { console.error(err); }
    });

    // ─────────────────────────────────────────────
    // CREATE CONNECTION (from Connections tab)
    // ─────────────────────────────────────────────

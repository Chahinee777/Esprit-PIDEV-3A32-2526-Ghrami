        document.getElementById('ccReceiverSkill').value = '';
        document.getElementById('ccSkillsSection').style.display = 'block'; // skill is default
        document.querySelectorAll('input[name="cc-type"]').forEach(r => {
            r.checked = (r.value === 'skill');
            r.closest('.type-radio-label').classList.toggle('active', r.value === 'skill');
        });
        openModal('createConnectionModal');
    });

    // User dropdown now loaded by loadAllUsers()
    // Removed old user ID lookup logic

    document.querySelectorAll('input[name="cc-type"]').forEach(radio => {
        radio.addEventListener('change', function () {
            document.querySelectorAll('input[name="cc-type"]').forEach(r =>
                r.closest('.type-radio-label').classList.remove('active'));
            this.closest('.type-radio-label').classList.add('active');
            document.getElementById('ccSkillsSection').style.display = this.value === 'skill' ? 'block' : 'none';
        });
    });

    document.getElementById('btnCcConfirm').addEventListener('click', async () => {
        const userId = parseInt(document.getElementById('ccUser').value);

{% extends 'base.html.twig' %}

{% block title %}Meetings & Connections - Ghrami{% endblock %}

{% block body %}

<div class="meetings-container">

    <!-- DASHBOARD STATS -->
    <section class="dashboard-stats">
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon-wrap" style="background:linear-gradient(135deg,#667eea,#4f46e5)">🤝</div>
                <div class="stat-content">
                    <div class="stat-value">{{ stats.connections }}</div>
                    <div class="stat-label">Active Connections</div>
                </div>
                <div class="stat-decoration"></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon-wrap" style="background:linear-gradient(135deg,#0ea5e9,#0284c7)">📅</div>
                <div class="stat-content">
                    <div class="stat-value">{{ stats.upcoming }}</div>
                    <div class="stat-label">Upcoming Meetings</div>
                </div>
                <div class="stat-decoration"></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon-wrap" style="background:linear-gradient(135deg,#f59e0b,#d97706)">⏳</div>
                <div class="stat-content">
                    <div class="stat-value">{{ stats.pending }}</div>
                    <div class="stat-label">Pending Requests</div>
                </div>
                <div class="stat-decoration"></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon-wrap" style="background:linear-gradient(135deg,#10b981,#059669)">✨</div>
                <div class="stat-content">
                    <div class="stat-value">{{ stats.scheduled }}</div>
                    <div class="stat-label">Scheduled Meetings</div>
                </div>
                <div class="stat-decoration"></div>
            </div>
        </div>
    </section>

    <!-- NAVIGATION TABS -->
    <div class="nav-pill-bar">
        <div class="nav-pill-track">
            <button class="tab-btn active" data-tab="discovery">
                <span class="tab-icon">💫</span>
                <span>Discover</span>
            </button>
            <button class="tab-btn" data-tab="connections">
                <span class="tab-icon">🔗</span>
                <span>Connections</span>
            </button>
            <button class="tab-btn" data-tab="meetings">
                <span class="tab-icon">📅</span>
                <span>Meetings</span>
            </button>
            <div class="nav-pill-slider"></div>
        </div>
    </div>

    <!-- DISCOVERY TAB -->
    <section class="tab-content active" id="discovery-tab">
        <div class="swipe-header">
            <div>
                <h2 class="swipe-title">Find Your Match</h2>
                <p class="swipe-subtitle">Swipe or tap to connect with people near you</p>
            </div>
            <span class="swipe-counter" id="swipeCounter"></span>
        </div>

        <div class="discovery-view-toggle" id="discoveryViewToggle">
            <button type="button" class="filter-btn active" data-discovery-view="swipe">💫 Swipe</button>
            <button type="button" class="filter-btn" data-discovery-view="grid">📋 All Users</button>
        </div>

        <div id="discoveryGrid" class="swipe-arena">
            <div class="loading-placeholder">Loading matches…</div>
        </div>

        <div id="discoveryListGrid" class="discovery-list-grid" style="display:none;"></div>

        <div class="swipe-controls" id="swipeControls" style="display:none;">
            <button class="swipe-btn pass" id="btnPass" title="Pass">✕</button>
            <button class="swipe-btn view-profile" id="btnViewProfile" title="View Profile">👤</button>
            <button class="swipe-btn connect" id="btnConnect" title="Connect">💫</button>
        </div>
        <p class="swipe-hint" id="discoveryHint">Drag the card or use the buttons</p>
    </section>

    <!-- CONNECTIONS TAB -->
    <section class="tab-content" id="connections-tab">
        <div class="section-header">
            <div>
                <h2 class="section-title">Connections</h2>
                <p class="section-sub">Your people, all in one place</p>
            </div>
            <button class="btn-primary" id="btnCreateConnection">+ New Connection</button>
        </div>

        <div id="pendingSection" style="display: none;">
            <div class="pending-label">⏳ Pending Requests</div>
            <div id="pendingList" class="pending-list"></div>
        </div>

        <div class="filter-buttons">
            <button class="filter-btn active" data-filter="all">All</button>
            <button class="filter-btn" data-filter="accepted">Accepted</button>
            <button class="filter-btn" data-filter="skill">🎯 Skill</button>
            <button class="filter-btn" data-filter="activity">🏃 Activity</button>
            <button class="filter-btn" data-filter="hobby">🎨 Hobby</button>
        </div>

        <div id="connectionsGrid" class="connections-list">
            <div class="loading-placeholder">Loading connections…</div>
        </div>
    </section>

    <!-- MEETINGS TAB -->
    <section class="tab-content" id="meetings-tab">
        <div class="section-header">
            <div>
                <h2 class="section-title">Your Meetings</h2>
                <p class="section-sub">Stay on top of your schedule</p>
            </div>
            <button class="btn-primary" id="btnCreateMeeting">+ Schedule</button>
        </div>

        <div class="meeting-filter-row">
            <span class="filter-label">Show:</span>
            <select id="meetingFilterSelect" class="meeting-select">
                <option value="upcoming">Upcoming</option>
                <option value="past">Past</option>
                <option value="scheduled">Scheduled</option>
                <option value="completed">Completed</option>
                <option value="cancelled">Cancelled</option>
                <option value="physical">Physical Only</option>
                <option value="virtual">Virtual Only</option>
            </select>
        </div>

        <div id="meetingsList" class="meetings-list">
            <div class="loading-placeholder">Loading meetings…</div>
        </div>
    </section>
</div>

<!-- ═══════════════════════════════════════════════
     MODALS
═══════════════════════════════════════════════ -->

<!-- Quick Connect Modal (from Discovery card) -->
<div class="modal" id="quickConnectModal">
    <div class="modal-overlay"></div>
    <div class="modal-content">
        <div class="modal-header gradient-teal">
            <div>
                <div style="font-size:10px;font-weight:700;letter-spacing:1px;opacity:.75;margin-bottom:4px;">QUICK CONNECT</div>
                <h2>⚡ Send Connection Request</h2>
            </div>
            <button class="close-btn" onclick="closeModal('quickConnectModal')">✕</button>
        </div>
        <div class="modal-body">
            <div style="display:flex;align-items:center;gap:14px;background:#f0fdf4;border-radius:12px;padding:14px;margin-bottom:20px;">
                <div class="user-avatar" id="quickConnectAvatar" style="margin:0;flex-shrink:0;width:48px;height:48px;font-size:22px;"></div>
                <div>
                    <div id="quickConnectName" style="font-size:16px;font-weight:700;color:#1e293b;"></div>
                    <div style="font-size:12px;color:#64748b;">Your connection request will be sent to this user.</div>
                </div>
            </div>
            <div class="form-group">
                <label>Connection Type</label>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <label class="type-radio-label">
                        <input type="radio" name="qc-type" value="skill"> 🎯 Skill Exchange
                    </label>
                    <label class="type-radio-label">
                        <input type="radio" name="qc-type" value="activity"> 🏃 Activity
                    </label>
                    <label class="type-radio-label">
                        <input type="radio" name="qc-type" value="hobby"> 🎨 Hobby
                    </label>
                    <label class="type-radio-label active">
                        <input type="radio" name="qc-type" value="general" checked> 🤝 General
                    </label>
                </div>
            </div>
            <div id="qcSkillsSection" style="display: none;">
                <div class="form-group">
                    <label>Your skill to share</label>
                    <input type="text" id="qcInitiatorSkill" class="form-control" placeholder="e.g., Guitar, Python, Photography…">
                </div>
                <div class="form-group" style="margin-bottom:0;">
                    <label>Skill you want to learn</label>
                    <input type="text" id="qcReceiverSkill" class="form-control" placeholder="e.g., Piano, Data Science, Cooking…">
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('quickConnectModal')">Cancel</button>
            <button class="btn-primary" id="btnQcConfirm">💫 Send Request</button>
        </div>
    </div>
</div>

<!-- Create Connection Modal (from Connections tab) -->
<div class="modal" id="createConnectionModal">
    <div class="modal-overlay"></div>
    <div class="modal-content">
        <div class="modal-header gradient-cyan">
            <div>
                <div style="font-size:10px;font-weight:700;letter-spacing:1px;opacity:.75;margin-bottom:4px;">NEW CONNECTION</div>
                <h2>🤝 Create Connection</h2>
            </div>
            <button class="close-btn" onclick="closeModal('createConnectionModal')">✕</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>Target User</label>
                <select id="ccUser" class="form-control" required style="padding: 10px 14px; border: 1.5px solid #e2e8f0; border-radius: 10px; font-size: 13px;">
                    <option value="">📋 Select a user...</option>
                </select>
                <div id="ccUserLookup" style="margin-top:8px;font-size:12px;min-height:18px;"></div>
            </div>
            <div class="form-group">
                <label>Connection Type</label>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <label class="type-radio-label active">
                        <input type="radio" name="cc-type" value="skill" checked> 🎯 Skill Exchange
                    </label>
                    <label class="type-radio-label">
                        <input type="radio" name="cc-type" value="activity"> 🏃 Activity
                    </label>
                    <label class="type-radio-label">
                        <input type="radio" name="cc-type" value="hobby"> 🎨 Hobby
                    </label>
                    <label class="type-radio-label">
                        <input type="radio" name="cc-type" value="general"> 🤝 General
                    </label>
                </div>
            </div>
            <div id="ccSkillsSection">
                <div class="form-group">
                    <label>Your skill to share</label>
                    <input type="text" id="ccInitiatorSkill" class="form-control" placeholder="e.g., Guitar, Python, Photoshop…">
                </div>
                <div class="form-group" style="margin-bottom:0;">
                    <label>Skill you want to learn</label>
                    <input type="text" id="ccReceiverSkill" class="form-control" placeholder="e.g., Piano, Data Science, Cooking…">
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('createConnectionModal')">Cancel</button>
            <button class="btn-primary" id="btnCcConfirm">🤝 Send Request</button>
        </div>
    </div>
</div>

<!-- Create Meeting Modal -->
<div class="modal" id="createMeetingModal">
    <div class="modal-overlay"></div>
    <div class="modal-content" style="max-width:560px;">
        <div class="modal-header gradient-indigo">
            <div>
                <div style="font-size:10px;font-weight:700;letter-spacing:1px;opacity:.75;margin-bottom:4px;">NEW MEETING</div>
                <h2>📅 Schedule Meeting</h2>
            </div>
            <button class="close-btn" onclick="closeModal('createMeetingModal')">✕</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>Connection</label>
                <select id="cmConnection" class="form-control" required>
                    <option value="">-- Select a connection --</option>
                </select>
            </div>
            <div class="form-group">
                <label>Meeting Type</label>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <label class="type-radio-label active">
                        <input type="radio" name="cm-type" value="virtual" checked> 💻 Virtual
                    </label>
                    <label class="type-radio-label">
                        <input type="radio" name="cm-type" value="physical"> 📍 In-Person
                    </label>
                </div>
            </div>
            <div id="cmVirtualLocationField" class="form-group" style="display: block;">
                <label>Google Meet Link</label>
                <div style="background-color: #f0f9ff; border: 2px solid #0284c7; border-radius: 8px; padding: 12px; display: flex; justify-content: space-between; align-items: center;">
                    <input type="text" id="cmVirtualLocation" readonly class="form-control" placeholder="Auto-generated when date/time is set..." style="background: transparent; border: none; flex: 1; margin: 0; padding: 0; cursor: default; font-size: 14px;">
                    <button type="button" class="btn" id="btnCopyMeetLink" style="background: #0284c7; color: white; padding: 6px 12px; border-radius: 6px; border: none; margin-left: 8px; display: none;">📋 Copy</button>
                </div>
                <div style="margin-top: 8px; display: flex; align-items: center; gap: 10px;">
                    <button type="button" class="btn" id="btnConnectGoogleCalendar" style="background: #0f766e; color: white; padding: 6px 12px; border-radius: 6px; border: none; display: none;">🔐 Connect Google Calendar</button>
                    <span id="cmGoogleAuthHint" style="font-size: 12px; color: #64748b;"></span>
                </div>
            </div>
            <div id="cmLocationField" style="display: none;" class="form-group">
                <label>Location / Address <span style="color:#dc2626;">*</span></label>
                <input type="text" id="cmLocation" class="form-control" placeholder="Search location or click map to select...">
                <div id="cmMapContainer" style="margin-top: 12px; border-radius: 10px; overflow: hidden; height: 250px; border: 2px solid #e2e8f0; display: none;">
                    <div id="cmMap" style="width: 100%; height: 100%;"></div>
                </div>
                <div id="cmLocationCoords" style="margin-top: 8px; font-size: 12px; color: #64748b; min-height: 18px;"></div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div class="form-group">
                    <label>Date <span style="color:#dc2626;">*</span></label>
                    <input type="date" id="cmDate" class="form-control">
                </div>
                <div class="form-group">
                    <label>Time (HH:MM) <span style="color:#dc2626;">*</span></label>
                    <input type="time" id="cmTime" class="form-control" value="14:00">
                </div>
            </div>
            <div class="form-group" style="margin-bottom:0;">
                <label>Duration</label>
                <div id="cmDurationChips" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px;">
                    <button type="button" class="dur-chip" data-min="30">30 min</button>
                    <button type="button" class="dur-chip" data-min="45">45 min</button>
                    <button type="button" class="dur-chip active" data-min="60">1 hour</button>
                    <button type="button" class="dur-chip" data-min="90">1h 30</button>
                    <button type="button" class="dur-chip" data-min="120">2 hours</button>
                    <button type="button" class="dur-chip" data-min="custom">✏ Custom</button>
                </div>
                <input type="number" id="cmDurationCustom" class="form-control" value="60" min="1" max="1440" placeholder="Minutes" style="display:none;max-width:140px;">
                <input type="hidden" id="cmDurationValue" value="60">
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('createMeetingModal')">Cancel</button>
            <button class="btn-primary" id="btnCmConfirm">✅ Confirm Meeting</button>
        </div>
    </div>
</div>

<!-- Edit Meeting Modal -->
<div class="modal" id="editMeetingModal">
    <div class="modal-overlay"></div>
    <div class="modal-content" style="max-width:520px;">
        <div class="modal-header gradient-amber">
            <div>
                <div style="font-size:10px;font-weight:700;letter-spacing:1px;opacity:.75;margin-bottom:4px;">EDIT MEETING</div>
                <h2>✏️ Modify Meeting</h2>
            </div>
            <button class="close-btn" onclick="closeModal('editMeetingModal')">✕</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="emMeetingId">
            <div class="form-group">
                <label>Meeting Type</label>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <label class="type-radio-label active">
                        <input type="radio" name="em-type" value="virtual" checked> 💻 Virtual
                    </label>
                    <label class="type-radio-label">
                        <input type="radio" name="em-type" value="physical"> 📍 In-Person
                    </label>
                </div>
            </div>
            <div class="form-group" id="emLocationField" style="display:none;">
                <label>Location / Address <span style="color:#dc2626;">*</span></label>
                <input type="text" id="emLocation" class="form-control" placeholder="Enter meeting location">
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div class="form-group">
                    <label>Date <span style="color:#dc2626;">*</span></label>
                    <input type="date" id="emDate" class="form-control">
                </div>
                <div class="form-group">
                    <label>Time (HH:MM) <span style="color:#dc2626;">*</span></label>
                    <input type="time" id="emTime" class="form-control">
                </div>
            </div>
            <div class="form-group" style="margin-bottom:0;">
                <label>Duration</label>
                <div id="emDurationChips" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px;">
                    <button type="button" class="dur-chip" data-min="30">30 min</button>
                    <button type="button" class="dur-chip" data-min="45">45 min</button>
                    <button type="button" class="dur-chip active" data-min="60">1 hour</button>
                    <button type="button" class="dur-chip" data-min="90">1h 30</button>
                    <button type="button" class="dur-chip" data-min="120">2 hours</button>
                    <button type="button" class="dur-chip" data-min="custom">✏ Custom</button>
                </div>
                <input type="number" id="emDurationCustom" class="form-control" value="60" min="1" max="1440" placeholder="Minutes" style="display:none;max-width:140px;">
                <input type="hidden" id="emDurationValue" value="60">
            </div>
        </div>
        <div class="modal-footer">
            <div style="display: flex; gap: 8px; width: 100%;">
                <button class="btn-cancel" onclick="closeModal('editMeetingModal')" style="flex:1;">Cancel</button>
                <button class="btn-primary" id="btnEmGoogleCalendar" style="background: #fff; color: #4285f4; border: 1px solid #4285f4; flex: 2; display: flex; align-items: center; justify-content: center; font-weight: 600;">
                    <img src="https://www.gstatic.com/images/branding/product/1x/calendar_2020q4_48dp.png" alt="G" style="width:18px; margin-right: 8px;">
                    Add to Google
                </button>
                <button class="btn-primary" id="btnEmConfirm" style="background:linear-gradient(to right,#b45309,#d97706); flex:2;">💾 Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- User Profile Modal -->
<div class="modal" id="profileModal">
    <div class="modal-overlay"></div>
    <div class="modal-content" style="max-width:560px;">
        <div class="modal-header gradient-slate">
            <div>
                <div style="font-size:10px;font-weight:700;letter-spacing:1px;opacity:.75;margin-bottom:4px;">USER PROFILE</div>
                <h2 id="profileModalTitle">👤 Profile</h2>
            </div>
            <button class="close-btn" onclick="closeModal('profileModal')">✕</button>
        </div>
        <div class="modal-body" id="profileModalBody">
            <div class="loading-placeholder">Loading profile...</div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('profileModal')">Close</button>
            <button class="btn-primary" id="profileConnectBtn" style="display:none;">💫 Connect</button>
        </div>
    </div>
</div>

<style>
/* ═══════════════════════════════════════════════
   BASE
═══════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; }

.meetings-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 28px 20px 60px;
    font-family: var(--font-family);
}

/* ═══════════════════════════════════════════════
   STATS
═══════════════════════════════════════════════ */
.dashboard-stats { margin-bottom: 36px; }

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
}

.stat-card {
    background: #fff;
    border-radius: 18px;
    padding: 20px 22px;
    display: flex;
    align-items: center;
    gap: 16px;
    border: 1px solid #e8ecf4;
    box-shadow: 0 2px 12px rgba(79,70,229,0.06);
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
}
.stat-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(79,70,229,0.12);
}

.stat-icon-wrap {
    width: 48px; height: 48px;
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
}

.stat-value {
    font-family: var(--font-family);
    font-size: 30px; font-weight: 800;
    color: #0f172a;
    line-height: 1;
}
.stat-label { font-size: 12px; font-weight: 600; color: #94a3b8; margin-top: 4px; text-transform: uppercase; letter-spacing: 0.4px; }

.stat-decoration {
    position: absolute; right: -10px; bottom: -14px;
    width: 70px; height: 70px;
    border-radius: 50%;
    background: rgba(79,70,229,0.04);
    pointer-events: none;
}

/* ═══════════════════════════════════════════════
   TABS — PILL BAR
═══════════════════════════════════════════════ */
.nav-pill-bar {
    margin-bottom: 32px;
}
.nav-pill-track {
    display: inline-flex;
    background: #f1f3f9;
    border-radius: 50px;
    padding: 5px;
    gap: 0;
    position: relative;
}

.tab-btn {
    display: flex; align-items: center; gap: 7px;
    padding: 9px 22px;
    border: none; background: none;
    font-family: var(--font-family);
    font-size: 13px; font-weight: 700;
    color: #64748b;
    border-radius: 50px;
    cursor: pointer;
    transition: color 0.25s;
    position: relative; z-index: 1;
    white-space: nowrap;
}
.tab-btn .tab-icon { font-size: 15px; }
.tab-btn.active { color: #fff; }

.nav-pill-slider {
    position: absolute;
    top: 5px; left: 5px;
    height: calc(100% - 10px);
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    border-radius: 50px;
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1), width 0.3s;
    z-index: 0;
    box-shadow: 0 4px 14px rgba(79,70,229,0.35);
}

.tab-content { display: none; }
.tab-content.active { display: block; }

/* ═══════════════════════════════════════════════
   SECTION HEADER
═══════════════════════════════════════════════ */
.section-header {
    display: flex; justify-content: space-between;
    align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 12px;
}
.section-title {
    font-family: var(--font-family);
    font-size: 22px; font-weight: 800; color: #0f172a; margin: 0;
}
.section-sub { font-size: 13px; color: #94a3b8; margin: 4px 0 0; }

/* ═══════════════════════════════════════════════
   SWIPE DECK — DISCOVERY
═══════════════════════════════════════════════ */
.swipe-header {
    display: flex; justify-content: space-between;
    align-items: flex-start; margin-bottom: 20px;
}
.swipe-title {
    font-family: var(--font-family);
    font-size: 22px; font-weight: 800; color: #0f172a; margin: 0;
}
.swipe-subtitle { font-size: 13px; color: #94a3b8; margin: 5px 0 0; }

.swipe-counter {
    font-family: var(--font-family);
    font-size: 13px; font-weight: 700;
    color: #4f46e5;
    background: #eef2ff;
    padding: 5px 14px; border-radius: 20px;
    white-space: nowrap; margin-top: 4px;
}

.discovery-view-toggle {
    display: flex;
    gap: 8px;
    margin: 0 0 14px;
    flex-wrap: wrap;
}

.discovery-list-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
    margin-bottom: 8px;
}

.discovery-user-card {
    background: #fff;
    border: 1px solid #e8ecf4;
    border-radius: 14px;
    padding: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.discovery-user-top {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 10px;
}

.discovery-user-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #eef2ff;
    flex-shrink: 0;
    font-size: 20px;
}

.discovery-user-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.discovery-user-name {
    font-size: 14px;
    font-weight: 700;
    color: #0f172a;
    margin: 0;
}

.discovery-user-username {
    font-size: 12px;
    color: #94a3b8;
    margin: 2px 0 0;
}

.discovery-user-actions {
    display: flex;
    gap: 8px;
    margin-top: 10px;
}

.btn-view-discovery,
.btn-connect-discovery {
    flex: 1;
    border: none;
    border-radius: 8px;
    padding: 7px 10px;
    font-family: var(--font-family);
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
}

.btn-view-discovery {
    background: #eef2ff;
    color: #3730a3;
}

.btn-connect-discovery {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    color: #fff;
}

/* The card arena */
.swipe-arena {
    position: relative;
    height: 490px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
}

/* Individual swipe cards */
.swipe-card {
    position: absolute;
    width: 330px;
    max-width: calc(100vw - 64px);
    height: 460px;
    border-radius: 28px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 20px 60px rgba(0,0,0,0.16);
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    will-change: transform;
    transition: box-shadow 0.2s;
}
.swipe-card:active { cursor: grabbing; }

/* Stack depth */
.swipe-card[data-pos="0"] { z-index: 10; }
.swipe-card[data-pos="1"] { z-index: 9; transform: translateY(14px) scale(0.96); pointer-events: none; }
.swipe-card[data-pos="2"] { z-index: 8; transform: translateY(28px) scale(0.92); pointer-events: none; }

/* Card photo top section */
.sc-photo {
    width: 100%; height: 230px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    background-size: cover; background-position: center;
    position: relative;
    display: flex; align-items: center; justify-content: center;
}
.sc-emoji { font-size: 64px; }

/* Gradient overlay for readability */
.sc-photo::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.25) 100%);
    pointer-events: none;
}

/* Card info section */
.sc-body {
    padding: 18px 20px 16px;
    display: flex; flex-direction: column; gap: 6px;
}
.sc-match-badge {
    display: inline-flex; align-items: center;
    font-size: 11px; font-weight: 800; letter-spacing: 0.3px;
    padding: 3px 10px; border-radius: 20px;
    border: 1.5px solid;
    width: fit-content;
}
.sc-name {
    font-family: var(--font-family);
    font-size: 20px; font-weight: 800;
    color: #0f172a; margin: 0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.sc-location { font-size: 12px; color: #64748b; margin: 0; }
.sc-reason {
    font-size: 12px; color: #4f46e5;
    background: #eef2ff; border-radius: 8px;
    padding: 7px 10px; margin-top: 2px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.sc-tags { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 4px; }
.sc-tag {
    font-size: 11px; font-weight: 600;
    background: #f1f5f9; color: #475569;
    padding: 3px 9px; border-radius: 10px;
}

/* Like / Nope stamps */
.sc-like-stamp, .sc-nope-stamp {
    position: absolute;
    top: 32px;
    font-size: 20px; font-weight: 900;
    padding: 6px 16px;
    border-radius: 10px;
    border: 3px solid;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.1s;
    letter-spacing: 1px;
    transform: rotate(-15deg);
}
.sc-like-stamp {
    right: 20px;
    color: #4f46e5; border-color: #4f46e5;
    transform: rotate(15deg);
}
.sc-nope-stamp {
    left: 20px;
    color: #dc2626; border-color: #dc2626;
    transform: rotate(-15deg);
}

/* Swipe action buttons */
.swipe-controls {
    display: flex; justify-content: center; align-items: center;
    gap: 20px; margin-top: 16px; margin-bottom: 6px;
}
.swipe-btn {
    width: 56px; height: 56px;
    border-radius: 50%; border: none;
    font-size: 20px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
}
.swipe-btn:hover { transform: scale(1.12); }
.swipe-btn:active { transform: scale(0.96); }

.swipe-btn.pass { background: #fff; color: #dc2626; box-shadow: 0 4px 16px rgba(220,38,38,0.15); font-size: 18px; }
.swipe-btn.view-profile { background: #fff; color: #0f172a; width: 44px; height: 44px; font-size: 16px; }
.swipe-btn.connect { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; box-shadow: 0 4px 18px rgba(79,70,229,0.4); }

.swipe-hint { text-align: center; font-size: 12px; color: #cbd5e1; margin: 0; }
.swipe-done {
    text-align: center; padding: 40px 20px;
    font-size: 16px; color: #94a3b8;
    font-family: var(--font-family);
}

/* ═══════════════════════════════════════════════
   FILTER PILLS
═══════════════════════════════════════════════ */
.filter-buttons {
    display: flex; flex-wrap: wrap; gap: 8px;
    margin: 20px 0 24px;
}
.filter-btn {
    padding: 6px 16px; border-radius: 20px;
    border: 1.5px solid #e2e8f0; background: white;
    font-family: var(--font-family);
    font-size: 12px; font-weight: 700; color: #64748b; cursor: pointer;
    transition: all 0.2s;
}
.filter-btn.active, .filter-btn:hover {
    background: #4f46e5; color: white; border-color: #4f46e5;
    box-shadow: 0 2px 8px rgba(79,70,229,0.25);
}

.pending-label {
    font-family: var(--font-family);
    font-size: 12px; font-weight: 700;
    color: #92400e; background: #fef3c7;
    border: 1px solid #fbbf24;
    padding: 6px 14px; border-radius: 20px;
    display: inline-block;
    margin: 20px 0 14px;
    letter-spacing: 0.4px;
}

/* ═══════════════════════════════════════════════
   CONNECTION CARDS
═══════════════════════════════════════════════ */
.connections-list { display: flex; flex-direction: column; gap: 12px; }

.connection-card {
    background: white;
    border-radius: 16px;
    padding: 16px 20px;
    border: 1px solid #e8ecf4;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
    transition: box-shadow 0.2s, transform 0.2s;
    border-left: 4px solid #4f46e5;
}
.connection-card:hover {
    box-shadow: 0 6px 20px rgba(79,70,229,0.1);
    transform: translateX(2px);
}

.conn-avatar {
    width: 52px; height: 52px; border-radius: 50%;
    background: #eef2ff;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; flex-shrink: 0; overflow: hidden;
}
.conn-avatar img { width: 100%; height: 100%; object-fit: cover; }
.conn-info { flex: 1; min-width: 160px; }
.conn-name { font-family: var(--font-family); font-size: 15px; font-weight: 700; color: #0f172a; margin: 0 0 3px; }
.conn-username { font-size: 12px; color: #94a3b8; margin: 0 0 6px; }
.conn-badges { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 4px; }
.conn-skills { font-size: 12px; color: #475569; margin-top: 3px; }
.conn-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-left: auto; }
.conn-actions button {
    padding: 6px 14px; border: none; border-radius: 8px;
    font-family: var(--font-family);
    font-size: 12px; font-weight: 700; cursor: pointer; transition: all 0.2s;
}

/* ═══════════════════════════════════════════════
   PENDING CARDS
═══════════════════════════════════════════════ */
.pending-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 4px; }
.pending-card {
    display: flex; align-items: center; gap: 14px;
    background: #fffbeb; padding: 14px 16px;
    border-radius: 14px; border: 1px solid #fbbf24;
}
.pending-avatar { width: 46px; height: 46px; border-radius: 50%; overflow: hidden; flex-shrink: 0; background: #fef3c7; display: flex; align-items: center; justify-content: center; font-size: 20px; }
.pending-avatar img { width: 100%; height: 100%; object-fit: cover; }
.pending-info { flex: 1; }
.pending-name { font-size: 14px; font-weight: 700; color: #1e293b; margin: 0 0 2px; }
.pending-type { font-size: 12px; color: #64748b; margin: 0; }
.pending-actions { display: flex; gap: 8px; }

/* ═══════════════════════════════════════════════
   MEETINGS LIST — TIMELINE STYLE
═══════════════════════════════════════════════ */
.meeting-filter-row {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 24px;
}
.filter-label { font-size: 13px; font-weight: 700; color: #64748b; }
.meeting-select {
    padding: 8px 14px;
    border: 1.5px solid #e2e8f0;
    border-radius: 10px;
    font-family: var(--font-family);
    font-size: 13px; font-weight: 600;
    color: #1e293b;
    background: white;
    cursor: pointer;
    outline: none;
    transition: border-color 0.2s;
}
.meeting-select:focus { border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,0.1); }

.meetings-list { display: flex; flex-direction: column; gap: 14px; }

.meeting-card {
    background: white;
    border-radius: 16px;
    border: 1px solid #e8ecf4;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    transition: box-shadow 0.2s, transform 0.2s;
    display: flex;
    border-left: 5px solid #4f46e5;
}
.meeting-card:hover {
    box-shadow: 0 6px 20px rgba(79,70,229,0.1);
    transform: translateX(2px);
}

/* Status border colors */
.meeting-card.status-scheduled { border-left-color: #4f46e5; }
.meeting-card.status-completed { border-left-color: #059669; }
.meeting-card.status-cancelled { border-left-color: #dc2626; }

.meeting-inner { flex: 1; }

.meeting-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 20px; background: #f8fafc;
    border-bottom: 1px solid #e8ecf4;
    flex-wrap: wrap; gap: 10px;
}
.meeting-datetime {
    font-family: var(--font-family);
    font-size: 15px; font-weight: 700; color: #0f172a;
}
.meeting-badges { display: flex; gap: 8px; align-items: center; }
.meeting-body { padding: 14px 20px; }
.meeting-location { font-size: 13px; color: #475569; margin: 4px 0; word-break: break-all; }
.meeting-meta { font-size: 12px; color: #94a3b8; margin: 3px 0; }
.meeting-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
.meeting-actions button, .meeting-actions a {
    padding: 7px 14px; border: none; border-radius: 8px;
    font-family: var(--font-family);
    font-size: 12px; font-weight: 700; cursor: pointer;
    transition: all 0.2s; text-decoration: none; display: inline-block;
}

/* Meeting action buttons */
.btn-join { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: white; }
.btn-join:hover { opacity: 0.9; transform: translateY(-1px); }
.btn-complete { background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0; }
.btn-complete:hover { background: #bbf7d0; }
.btn-edit { background: #dbeafe; color: #1d4ed8; border: 1px solid #bfdbfe; }
.btn-edit:hover { background: #bfdbfe; }
.btn-cancel-meeting { background: #fef3c7; color: #92400e; border: 1px solid #fde68a; }
.btn-cancel-meeting:hover { background: #fde68a; }
.btn-delete-meeting { background: #fee2e2; color: #dc2626; border: 1px solid #fecaca; }
.btn-delete-meeting:hover { background: #fecaca; }
.btn-copy { background: #f1f5f9; color: #64748b; border: 1px solid #e2e8f0; padding: 7px 10px; }
.btn-copy:hover { background: #e8ecf4; }

/* ── Status badges ──────────────────────────── */
.status-badge {
    display: inline-block; padding: 3px 10px; border-radius: 10px;
    font-size: 11px; font-weight: 700; white-space: nowrap;
}
.status-scheduled { background: #ede9fe; color: #4f46e5; }
.status-completed { background: #dcfce7; color: #15803d; }
.status-cancelled { background: #fee2e2; color: #dc2626; }
.status-pending   { background: #fef9c3; color: #854d0e; }
.status-accepted  { background: #d1fae5; color: #065f46; }
.status-rejected  { background: #fee2e2; color: #991b1b; }

.type-badge {
    display: inline-block; padding: 3px 10px; border-radius: 10px;
    font-size: 11px; font-weight: 600; background: #e0e7ff; color: #3730a3;
}
.type-virtual  { background: #e0f2fe; color: #0369a1; }
.type-physical { background: #fef3c7; color: #92400e; }

/* ── Connection action buttons ──────────────── */
.btn-schedule { background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0; }
.btn-schedule:hover { background: #bbf7d0; }
.btn-delete-conn { background: #fee2e2; color: #dc2626; border: 1px solid #fecaca; }
.btn-delete-conn:hover { background: #fecaca; }
.btn-accept-connection { background: #dcfce7; color: #15803d; padding: 6px 12px; border: none; border-radius: 6px; font-size: 11px; font-weight: 700; cursor: pointer; }
.btn-accept-connection:hover { background: #bbf7d0; }
.btn-reject-connection  { background: #fee2e2; color: #dc2626; padding: 6px 12px; border: none; border-radius: 6px; font-size: 11px; font-weight: 700; cursor: pointer; }
.btn-reject-connection:hover { background: #fecaca; }

/* ═══════════════════════════════════════════════
   MODALS
═══════════════════════════════════════════════ */
.modal { display: none; position: fixed; inset: 0; z-index: 1000; align-items: center; justify-content: center; }
.modal.active { display: flex; }
.modal-overlay {
    position: absolute; inset: 0;
    background: rgba(15,23,42,0.55);
    backdrop-filter: blur(4px);
    cursor: pointer;
}
.modal-content {
    position: relative; background: white; border-radius: 20px;
    width: 90%; max-width: 500px; max-height: 90vh;
    overflow-y: auto; box-shadow: 0 24px 80px rgba(0,0,0,0.25);
    animation: modalIn 0.25s cubic-bezier(0.34,1.56,0.64,1);
}
@keyframes modalIn { from { opacity:0; transform: scale(0.92) translateY(12px); } to { opacity:1; transform: none; } }

.modal-header {
    padding: 20px 24px; border-radius: 20px 20px 0 0;
    display: flex; justify-content: space-between; align-items: flex-start;
    color: white; position: sticky; top: 0; z-index: 1;
}
.modal-header h2 { margin: 0; font-family: var(--font-family); font-size: 18px; font-weight: 800; }
.close-btn {
    background: rgba(255,255,255,0.2); border: none; color: white;
    width: 32px; height: 32px; border-radius: 50%; cursor: pointer;
    font-size: 16px; display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; transition: background 0.2s;
}
.close-btn:hover { background: rgba(255,255,255,0.35); }
.modal-body { padding: 24px; }
.modal-footer {
    padding: 16px 24px; display: flex; gap: 12px;
    justify-content: flex-end; border-top: 1px solid #e8ecf4;
    position: sticky; bottom: 0; background: white;
}

/* ── Gradients ──────────────────────────────── */
.gradient-teal   { background: linear-gradient(135deg, #134e4a, #0d9488); }
.gradient-cyan   { background: linear-gradient(135deg, #0c4a6e, #0369a1); }
.gradient-indigo { background: linear-gradient(135deg, #1e1b4b, #4338ca); }
.gradient-amber  { background: linear-gradient(135deg, #78350f, #d97706); }
.gradient-slate  { background: linear-gradient(135deg, #0f172a, #334155); }

/* ── Forms ──────────────────────────────────── */
.form-group { margin-bottom: 20px; }
.form-group label {
    display: block; font-size: 13px; font-weight: 700;
    color: #1e293b; margin-bottom: 8px;
}
.form-control {
    width: 100%; padding: 10px 14px;
    border: 1.5px solid #e2e8f0; border-radius: 10px;
    font-size: 13px; font-family: var(--font-family);
    box-sizing: border-box; transition: border-color 0.2s, box-shadow 0.2s;
}
.form-control:focus { outline: none; border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,0.12); }

.type-radio-label {
    display: flex; align-items: center; gap: 8px; padding: 10px 12px;
    border: 1.5px solid #e2e8f0; border-radius: 10px; cursor: pointer;
    margin: 0; font-weight: 600; font-size: 13px; color: #475569;
    transition: all 0.2s;
}
.type-radio-label.active, .type-radio-label:has(input:checked) {
    border-color: #4f46e5; background: #eef2ff; color: #3730a3;
}
.type-radio-label input[type="radio"] { accent-color: #4f46e5; }

/* ── Duration chips ─────────────────────────── */
.dur-chip {
    padding: 7px 14px; border-radius: 20px;
    border: 1.5px solid #e2e8f0; background: white;
    font-family: var(--font-family);
    font-size: 12px; font-weight: 700; color: #64748b; cursor: pointer;
    transition: all 0.2s;
}
.dur-chip.active, .dur-chip:hover {
    background: #4f46e5; color: white; border-color: #4f46e5;
    box-shadow: 0 2px 8px rgba(79,70,229,0.3);
}

/* ── Primary / Cancel buttons ───────────────── */
.btn-primary {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    color: white; padding: 10px 22px; border: none; border-radius: 10px;
    font-family: var(--font-family);
    font-size: 13px; font-weight: 700; cursor: pointer; transition: all 0.2s;
    white-space: nowrap;
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(79,70,229,0.35); }

.btn-cancel {
    background: #f1f5f9; color: #64748b; padding: 10px 20px;
    border: none; border-radius: 10px;
    font-family: var(--font-family);
    font-size: 13px; font-weight: 700; cursor: pointer; transition: all 0.2s;
}
.btn-cancel:hover { background: #e2e8f0; }

/* ── Misc ───────────────────────────────────── */
.user-avatar {
    width: 64px; height: 64px; border-radius: 50%; background: #eef2ff;
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; margin: 0 auto 16px; overflow: hidden;
}
.user-avatar img { width: 100%; height: 100%; object-fit: cover; }

.loading-placeholder { text-align: center; padding: 48px 20px; color: #94a3b8; font-size: 14px; }
.empty-state { text-align: center; padding: 48px 20px; color: #94a3b8; font-size: 14px; }

.toast {
    position: fixed; bottom: 24px; right: 24px; z-index: 9999;
    background: #1e293b; color: white; padding: 12px 20px;
    border-radius: 12px; font-family: var(--font-family);
    font-size: 13px; font-weight: 600;
    box-shadow: 0 8px 28px rgba(0,0,0,0.22);
    animation: slideIn 0.3s ease, fadeOut 0.3s ease 2.7s forwards;
}
.toast.toast-error   { background: #dc2626; }
.toast.toast-success { background: #059669; }
@keyframes slideIn { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
@keyframes fadeOut { from { opacity: 1; } to { opacity: 0; pointer-events: none; } }

/* ── Responsive ─────────────────────────────── */
@media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .connection-card { flex-direction: column; align-items: flex-start; }
    .conn-actions { margin-left: 0; }
    .swipe-arena { height: 520px; }
    .swipe-card { width: calc(100vw - 64px); }
    .nav-pill-track { width: 100%; }
}
</style>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// ═══════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════
const state = {
    currentTab: 'discovery',
    discoveryView: 'swipe',
    quickConnectUserId: null,
    quickConnectUserName: null,
    allConnections: [],
    currentConnectionFilter: 'all',
    currentMeetingFilter: 'upcoming',
};

// ═══════════════════════════════════════════════
// TOAST UTILITY
// ═══════════════════════════════════════════════
function showToast(msg, type = 'info') {
    const t = document.createElement('div');
    t.className = 'toast' + (type === 'error' ? ' toast-error' : type === 'success' ? ' toast-success' : '');
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(() => t.remove(), 3200);
}


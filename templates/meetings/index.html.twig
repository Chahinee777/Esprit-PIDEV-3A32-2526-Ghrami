                    showToast('Meeting updated, but not added to calendar.', 'info');
                    closeModal('editMeetingModal');
                    loadMeetings(state.currentMeetingFilter);
                }
            } else {
                showToast(data.error || 'Failed to update meeting.', 'error');
            }
        } catch (err) {
            console.error(err);
            showToast('Network error.', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    });

    // ── Meeting filter select ──
    document.getElementById('meetingFilterSelect').addEventListener('change', function () {
        loadMeetings(this.value);
    });

    // ── Initial loads ──
    applyDiscoveryView();
    loadMatches();
    loadConnections();
    loadMeetings('upcoming');
    loadAllUsers();
});
</script>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
// ═══════════════════════════════════════════════
// LOAD ALL USERS FOR DROPDOWN
// ═══════════════════════════════════════════════
let cmMap = null;
let cmMapMarker = null;
let cmGoogleOauthInProgress = false;

async function loadAllUsers() {
    try {
        const resp = await fetch('/meetings/api/users');
        const data = await resp.json();
        if (!data.ok || !data.users) return;
        const select = document.getElementById('ccUser');
        data.users.forEach(user => {
            const option = document.createElement('option');
            option.value = user.id;
            option.textContent = `${user.fullName} (@${user.username})`;
            select.appendChild(option);
        });
    } catch (err) { console.error('Error loading users:', err); }
}

// ═══════════════════════════════════════════════
// GOOGLE MEET LINK GENERATION
// ═══════════════════════════════════════════════
async function generateGoogleMeetLink() {
    const dateVal     = document.getElementById('cmDate').value;
    const timeVal     = document.getElementById('cmTime').value;
    const meetingType = document.querySelector('input[name="cm-type"]:checked')?.value;
    if (meetingType !== 'virtual' || !dateVal || !timeVal) return;

    try {
        const datetime   = `${dateVal}T${timeVal}:00`;
        const duration   = parseInt(document.getElementById('cmDurationValue').value) || 60;
        const connectBtn = document.getElementById('btnConnectGoogleCalendar');
        const authHint   = document.getElementById('cmGoogleAuthHint');
        const generateBtn = document.getElementById('btnGenerateMeetLink');

        if (generateBtn) {
            generateBtn.disabled = true;
            generateBtn.textContent = 'Generating...';
        }

        const resp = await fetch('/meetings/api/google-meet-link', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `datetime=${encodeURIComponent(datetime)}&duration=${duration}`
        });
        const data = await resp.json().catch(() => ({}));
        if (data.ok && data.link) {
            document.getElementById('cmVirtualLocation').value = data.link;
            document.getElementById('btnCopyMeetLink').style.display = 'inline-block';
            showToast('✅ Google Meet link generated! 📞', 'success');
            if (connectBtn) connectBtn.style.display = 'none';
            if (authHint)   authHint.textContent = '';
            if (generateBtn) {
                generateBtn.disabled = false;
                generateBtn.textContent = 'Re-generate Link';
            }
            return;
        }
        document.getElementById('cmVirtualLocation').value = '';
        document.getElementById('btnCopyMeetLink').style.display = 'none';
        if (connectBtn) connectBtn.style.display = 'inline-block';
        if (generateBtn) {
            generateBtn.disabled = false;
            generateBtn.textContent = 'Generate Meet Link';
        }
        const details = Array.isArray(data.details) ? data.details.filter(Boolean).join(' | ') : '';
        if (authHint) authHint.textContent = details || 'Connect Google Calendar to generate a real Meet room automatically.';
        showToast(data.error || 'Could not generate real Google Meet link.', 'error');
    } catch (err) {
        console.error('Error generating Google Meet link:', err);
        document.getElementById('cmVirtualLocation').value = '';
        document.getElementById('btnCopyMeetLink').style.display = 'none';
        const connectBtn = document.getElementById('btnConnectGoogleCalendar');
        const authHint   = document.getElementById('cmGoogleAuthHint');
        const generateBtn = document.getElementById('btnGenerateMeetLink');
        if (generateBtn) {
            generateBtn.disabled = false;
            generateBtn.textContent = 'Generate Meet Link';
        }
        if (connectBtn) connectBtn.style.display = 'inline-block';
        if (authHint)   authHint.textContent = 'Google Meet generation failed. Connect Google Calendar and try again.';
        showToast('Google Meet generation failed.', 'error');
    }
}

function connectGoogleCalendarFromMeeting() {
    if (cmGoogleOauthInProgress) return;
    cmGoogleOauthInProgress = true;
    const popup = window.open('/auth/google/calendar/connect?popup=1', 'ghrami-google-calendar-auth', 'width=560,height=760,resizable=yes,scrollbars=yes');
    if (!popup) {
        cmGoogleOauthInProgress = false;
        showToast('Popup blocked. Please allow popups and try again.', 'error');
        return;
    }
    const onMessage = (event) => {
        if (event.origin !== window.location.origin) return;
        const data = event.data || {};
        if (data.type !== 'ghrami-google-calendar') return;
        window.removeEventListener('message', onMessage);
        cmGoogleOauthInProgress = false;
        if (data.ok) { showToast('Google Calendar connected. Regenerating Meet link...', 'success'); generateGoogleMeetLink(); }
        else { showToast('Google Calendar connection failed. Try again.', 'error'); }
    };
    window.addEventListener('message', onMessage);
}

// ═══════════════════════════════════════════════
// MAP INITIALIZATION & LOCATION SELECTION
// ═══════════════════════════════════════════════
async function initializeMap() {
    const container = document.getElementById('cmMap');
    if (!container) return;
    if (cmMap) { cmMap.setView([33.8869, 9.5375], 6); return; }
    cmMap = L.map('cmMap').setView([33.8869, 9.5375], 6);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap contributors', maxZoom: 19 }).addTo(cmMap);

    let searchControl = L.Control.extend({
        onAdd: function(map) {
            let div = L.DomUtil.create('div', 'leaflet-control leaflet-bar');
            let searchBox = document.createElement('input');
            searchBox.type = 'text'; searchBox.placeholder = '🔍 Search location...';
            searchBox.style.cssText = 'padding: 8px 12px; border: 1px solid #ccc; border-radius: 4px; width: 180px; font-size: 13px;';
            searchBox.addEventListener('keydown', async (e) => {
                if (e.key === 'Enter') {
                    const query = searchBox.value.trim();
                    if (query) {
                        try {
                            const resp = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&bounded=1&viewbox=8.4607,30.2273,11.5641,37.3436`);
                            const results = await resp.json();
                            if (results.length > 0) {
                                const place = results[0];
                                const lat = parseFloat(place.lat), lng = parseFloat(place.lon);
                                cmMap.setView([lat, lng], 12);
                                if (cmMapMarker) cmMap.removeLayer(cmMapMarker);
                                cmMapMarker = L.marker([lat, lng]).addTo(cmMap);
                                document.getElementById('cmLocation').value = place.display_name || query;
                                document.getElementById('cmLocationCoords').textContent = `📍 ${place.display_name || query}`;
                            }
                        } catch (err) { console.error('Search error:', err); }
                    }
                }
            });
            div.appendChild(searchBox);
            return div;
        }
    });
    cmMap.addControl(new searchControl({position: 'topleft'}));

    cmMap.on('click', async function(e) {
        const lat = e.latlng.lat, lng = e.latlng.lng;
        if (cmMapMarker) cmMap.removeLayer(cmMapMarker);
        cmMapMarker = L.marker([lat, lng]).addTo(cmMap);
        try {
            const resp = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`);
            const data = await resp.json();
            const placeName = data.address?.city || data.address?.town || data.address?.village || data.name || `${lat.toFixed(4)}, ${lng.toFixed(4)}`;
            document.getElementById('cmLocation').value = placeName;
            document.getElementById('cmLocationCoords').textContent = `📍 ${placeName}`;
        } catch (err) {
            document.getElementById('cmLocation').value = `${lat.toFixed(4)}, ${lng.toFixed(4)}`;
            document.getElementById('cmLocationCoords').textContent = `📍 ${lat.toFixed(4)}, ${lng.toFixed(4)}`;
        }
    });
}

// Wire up map visibility & location search
document.addEventListener('DOMContentLoaded', function() {
    const cmTypeRadios = document.querySelectorAll('input[name="cm-type"]');
    cmTypeRadios.forEach(radio => {
        radio.addEventListener('change', function() {
            const isPhysical   = this.value === 'physical';
            const mapContainer = document.getElementById('cmMapContainer');
            const virtualField = document.getElementById('cmVirtualLocationField');
            const physicalField = document.getElementById('cmLocationField');
            if (isPhysical) {
                physicalField.style.display = 'block'; mapContainer.style.display = 'block'; virtualField.style.display = 'none';
                document.getElementById('cmLocation').placeholder = 'Click on map or search location...';
                setTimeout(() => initializeMap(), 50);
            } else {
                physicalField.style.display = 'none'; mapContainer.style.display = 'none'; virtualField.style.display = 'block';
                document.getElementById('cmLocation').placeholder = 'Click on map or search location...';
                setTimeout(() => generateGoogleMeetLink(), 100);
            }
        });
    });

    document.getElementById('cmDate')?.addEventListener('change', generateGoogleMeetLink);
    document.getElementById('cmTime')?.addEventListener('change', generateGoogleMeetLink);
    document.getElementById('cmDurationChips')?.addEventListener('click', generateGoogleMeetLink);
    document.getElementById('cmDurationValue')?.addEventListener('change', generateGoogleMeetLink);

    const btnCopyMeetLink = document.getElementById('btnCopyMeetLink');
    if (btnCopyMeetLink) {
        btnCopyMeetLink.addEventListener('click', function(e) {
            e.preventDefault();
            const meetLink = document.getElementById('cmVirtualLocation').value;
            if (meetLink) {
                navigator.clipboard.writeText(meetLink).then(() => {
                    showToast('📋 Google Meet link copied!', 'success');
                    const originalText = this.textContent;
                    this.textContent = '✓ Copied!';
                    setTimeout(() => { this.textContent = originalText; }, 2000);
                });
            }
        });
    }

    const btnConnectGoogleCalendar = document.getElementById('btnConnectGoogleCalendar');
    if (btnConnectGoogleCalendar) {
        btnConnectGoogleCalendar.addEventListener('click', function(e) { e.preventDefault(); connectGoogleCalendarFromMeeting(); });
    }
});
</script>
{% endblock %}

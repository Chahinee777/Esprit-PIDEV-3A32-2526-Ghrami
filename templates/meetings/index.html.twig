document.addEventListener('DOMContentLoaded', function () {

    // ── Tab switching ──
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.getElementById(this.dataset.tab + '-tab').classList.add('active');
            if (this.dataset.tab === 'discovery') loadMatches();
            else if (this.dataset.tab === 'connections') loadConnections();
            else if (this.dataset.tab === 'meetings') loadMeetings(state.currentMeetingFilter);
        });
    });

    // ── Modal overlays ──
    document.querySelectorAll('.modal-overlay').forEach(overlay => {
        overlay.addEventListener('click', () => overlay.closest('.modal').classList.remove('active'));
    });

    // ── Duration chips setup ──
    setupDurationChips('cmDurationChips', 'cmDurationCustom', 'cmDurationValue');
    setupDurationChips('emDurationChips', 'emDurationCustom', 'emDurationValue');

    // ── Set today's date as min for date pickers ──
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('cmDate').min = today;
    document.getElementById('emDate').min = today;

    // ─────────────────────────────────────────────
    // QUICK CONNECT

// ═══════════════════════════════════════════════
// EDIT MEETING MODAL
// ═══════════════════════════════════════════════
function openEditMeetingModal(meetingId, type, location, datetime, duration) {
    document.getElementById('emMeetingId').value = meetingId;
    document.querySelectorAll('input[name="em-type"]').forEach(r => {
        r.checked = (r.value === type);
        r.closest('.type-radio-label').classList.toggle('active', r.value === type);
    });
    document.getElementById('emLocationField').style.display = type === 'physical' ? 'block' : 'none';
    document.getElementById('emLocation').value = type === 'physical' ? location : '';
    if (datetime) {
        const dt = new Date(datetime);
        const yyyy = dt.getFullYear();
        const mm   = String(dt.getMonth() + 1).padStart(2, '0');
        const dd   = String(dt.getDate()).padStart(2, '0');
        document.getElementById('emDate').value = `${yyyy}-${mm}-${dd}`;
        const hh  = String(dt.getHours()).padStart(2, '0');
        const min = String(dt.getMinutes()).padStart(2, '0');
        document.getElementById('emTime').value = `${hh}:${min}`;
    }
    document.getElementById('emDurationValue').value = duration;
    document.getElementById('emDurationCustom').style.display = 'none';
    const presets = [30, 45, 60, 90, 120];
    document.getElementById('emDurationChips').querySelectorAll('.dur-chip').forEach(c => {
        c.classList.toggle('active', parseInt(c.dataset.min) === duration);
    });
    if (!presets.includes(duration)) {
        document.getElementById('emDurationChips').querySelectorAll('.dur-chip').forEach(c => {
            c.classList.toggle('active', c.dataset.min === 'custom');
        });
        document.getElementById('emDurationCustom').style.display = 'block';
        document.getElementById('emDurationCustom').value = duration;
    }
    openModal('editMeetingModal');
}

// ═══════════════════════════════════════════════
// VALIDATION HELPERS
// ═══════════════════════════════════════════════
function validateMeetingDatetime(dateVal, timeVal) {
    if (!dateVal || !timeVal) return 'Please enter both date and time.';
    const dt = new Date(`${dateVal}T${timeVal}:00`);
    if (isNaN(dt.getTime())) return 'Invalid date or time format.';
    if (dt <= new Date()) return 'The meeting date and time must be in the future.';
    return null;
}

// ═══════════════════════════════════════════════
// ESCAPE HELPERS
// ═══════════════════════════════════════════════
function escapeHtml(str) {
    return String(str || '')
        .replace(/&/g, '&amp;').replace(/</g, '&lt;')
        .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}
function escapeAttr(str) {
    return String(str || '').replace(/'/g, "\\'").replace(/"/g, '\\"');
}


        const dtErr = validateMeetingDatetime(dateVal, timeVal);
        if (dtErr) { showToast(dtErr, 'error'); return; }
        if (type === 'physical' && !location) { showToast('Please enter a location for an in-person meeting.', 'error'); return; }
        if (duration <= 0 || duration > 1440) { showToast('Duration must be between 1 and 1440 minutes.', 'error'); return; }

        try {
            const resp = await fetch(`/api/meetings/${meetingId}/update`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    meeting_type: type,
                    scheduled_at: `${dateVal} ${timeVal}:00`,
                    duration,
                    location:     type === 'physical' ? location : null,
                }),

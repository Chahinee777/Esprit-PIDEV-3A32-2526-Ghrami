            document.getElementById('cmLocationField').style.display = isPhysical ? 'block' : 'none';
            document.getElementById('cmMapContainer').style.display = isPhysical ? 'block' : 'none';
            const virtualField = document.getElementById('cmVirtualLocationField');
            if (virtualField) virtualField.style.display = isPhysical ? 'none' : 'block';
        });
    });

    document.getElementById('btnCmConfirm').addEventListener('click', async () => {
        const connId   = document.getElementById('cmConnection').value;
        const type     = document.querySelector('input[name="cm-type"]:checked')?.value || 'virtual';
        const dateVal  = document.getElementById('cmDate').value;
        const timeVal  = document.getElementById('cmTime').value;
        const duration = parseInt(document.getElementById('cmDurationValue').value) || 60;
        const location = document.getElementById('cmLocation').value.trim();
        const virtualLocation = document.getElementById('cmVirtualLocation')?.value?.trim() || '';

        if (!connId) { showToast('Please select a connection.', 'error'); return; }
        const dtErr = validateMeetingDatetime(dateVal, timeVal);
        if (dtErr) { showToast(dtErr, 'error'); return; }
        if (type === 'physical' && !location) { showToast('Please enter a location for an in-person meeting.', 'error'); return; }
        if (type === 'virtual' && !/^https:\/\/meet\.google\.com\//.test(virtualLocation)) {
            showToast('Please generate a real Google Meet link first.', 'error');
            return;
        }
        if (duration <= 0 || duration > 1440) { showToast('Duration must be between 1 and 1440 minutes.', 'error'); return; }

        try {
            const resp = await fetch('/meetings/api/create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },

        loadMeetings(this.value);
    });

    // ─────────────────────────────────────────────
    // INITIAL LOAD
    // ─────────────────────────────────────────────
    loadMatches();
    loadConnections();
    loadMeetings('upcoming');
    loadAllUsers();
});
</script>


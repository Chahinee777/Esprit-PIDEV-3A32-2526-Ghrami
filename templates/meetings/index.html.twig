            const data = await resp.json();
            if (data.ok) {
                closeModal('createMeetingModal');
                resetCreateMeetingForm();
                const linkMsg = data.meet_link && data.meet_link.startsWith('http')
                    ? ' ✅ Google Meet link auto-generated!' : '';
                showToast(`Meeting scheduled!${linkMsg} 📅`, 'success');
                loadMeetings(state.currentMeetingFilter);
            } else {
                showToast(data.error || 'Failed to schedule meeting.', 'error');
            }
        } catch (err) { 
            console.error('Error scheduling meeting:', err);
            showToast('Error scheduling meeting. Please try again.', 'error');
        }
    });

    // ─────────────────────────────────────────────
    // EDIT MEETING – type radio toggle
    // ─────────────────────────────────────────────
    document.querySelectorAll('input[name="em-type"]').forEach(radio => {
        radio.addEventListener('change', function () {
            document.querySelectorAll('input[name="em-type"]').forEach(r =>

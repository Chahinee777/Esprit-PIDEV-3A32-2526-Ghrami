async function openProfileModal(userId) {
    openModal('profileModal');
    document.getElementById('profileModalBody').innerHTML = '<div class="loading-placeholder">Loading profile...</div>';
    document.getElementById('profileConnectBtn').style.display = 'none';

    try {
        const resp = await fetch(`/api/discovery/user/${userId}`);
        const data = await resp.json();
        if (!data.ok) { document.getElementById('profileModalBody').innerHTML = '<div class="empty-state">User not found.</div>'; return; }

        const u = data.user;
        document.getElementById('profileModalTitle').textContent = `👤 ${u.full_name || u.username}`;

        const hobbiesHtml = data.hobbies.length
            ? `<div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;">${data.hobbies.map(h => `<span class="interest-tag">${escapeHtml(h)}</span>`).join('')}</div>`
            : '<p style="color:#94a3b8;font-size:13px;">No interests listed.</p>';

        const badgesHtml = data.badges.length
            ? data.badges.map(b => `<div style="display:flex;align-items:center;gap:10px;padding:8px;background:#fefce8;border-radius:8px;margin-top:6px;"><span>🏆</span><div><div style="font-size:13px;font-weight:600;">${escapeHtml(b.badge_name)}</div><div style="font-size:11px;color:#64748b;">${escapeHtml(b.description || '')}</div></div></div>`).join('')
            : '';

        const profileImageUrl = resolveProfilePictureUrl(u.profile_picture);
        document.getElementById('profileModalBody').innerHTML = `
            <div style="display:flex;align-items:center;gap:16px;background:#f8fafc;border-radius:12px;padding:16px;margin-bottom:20px;">
                <div style="width:64px;height:64px;border-radius:50%;overflow:hidden;background:#eef2ff;display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0;">
                    ${profileImageUrl ? `<img src="${profileImageUrl}" style="width:100%;height:100%;object-fit:cover;">` : '👤'}
                </div>
                <div>
                    <div style="font-family:var(--font-family);font-size:18px;font-weight:800;color:#1e293b;">${escapeHtml(u.full_name || u.username)}</div>
                    <div style="font-size:13px;color:#94a3b8;">@${escapeHtml(u.username)}</div>
                    ${u.location ? `<div style="font-size:12px;color:#4f46e5;margin-top:2px;">📍 ${escapeHtml(u.location)}</div>` : ''}
                </div>
            </div>
            ${u.bio ? `<div style="background:#f8fafc;border-radius:10px;padding:14px;margin-bottom:16px;"><div style="font-size:12px;font-weight:700;color:#64748b;margin-bottom:6px;">BIO</div><p style="font-size:13px;color:#334155;margin:0;">${escapeHtml(u.bio)}</p></div>` : ''}
            ${data.hobbies.length ? `<div style="margin-bottom:16px;"><div style="font-size:12px;font-weight:700;color:#64748b;margin-bottom:8px;">INTERESTS & SKILLS</div>${hobbiesHtml}</div>` : ''}
            ${badgesHtml ? `<div><div style="font-size:12px;font-weight:700;color:#64748b;margin-bottom:4px;">ACHIEVEMENTS</div>${badgesHtml}</div>` : ''}
        `;

        const connectBtn = document.getElementById('profileConnectBtn');
        connectBtn.style.display = 'inline-block';
        connectBtn.onclick = () => {
            closeModal('profileModal');
            openQuickConnect(u.id, u.full_name || u.username, profileImageUrl || '');
        };
    } catch (err) {
        console.error(err);
        document.getElementById('profileModalBody').innerHTML = '<div class="empty-state">Failed to load profile.</div>';
    }
}

// ═══════════════════════════════════════════════
// CONNECTIONS
// ═══════════════════════════════════════════════
async function loadConnections() {
    try {
        const resp = await fetch('/api/connections');
        const data = await resp.json();
        if (!data.ok) return;
        state.allConnections = data.connections || [];
        renderPending(data.pending || []);
        renderConnections(state.allConnections, state.currentConnectionFilter);
    } catch (err) { console.error(err); }
}

function renderPending(pending) {
    const section = document.getElementById('pendingSection');
    if (!pending.length) { section.style.display = 'none'; return; }
    section.style.display = 'block';
    document.getElementById('pendingList').innerHTML = pending.map(c => `
        <div class="pending-card">
            <div class="pending-avatar">
                ${resolveProfilePictureUrl(c.profile_picture) ? `<img src="${resolveProfilePictureUrl(c.profile_picture)}" alt="">` : '👤'}
            </div>
            <div class="pending-info">
                <p class="pending-name">${escapeHtml(c.full_name || c.username || 'Unknown')}</p>
                <p class="pending-type">Type: ${escapeHtml(c.connection_type || '')}
                    ${c.initiator_skill ? ` · Offers: <strong>${escapeHtml(c.initiator_skill)}</strong>` : ''}
                    ${c.receiver_skill  ? ` · Wants: <strong>${escapeHtml(c.receiver_skill)}</strong>`  : ''}
                </p>
            </div>
            <div class="pending-actions">
                <button class="btn-accept-connection" onclick="acceptConnection('${c.connection_id}')">✓ Accept</button>
                <button class="btn-reject-connection" onclick="rejectConnection('${c.connection_id}')">✕ Reject</button>
            </div>
        </div>`).join('');
}

function renderConnections(connections, filter) {
    const grid = document.getElementById('connectionsGrid');
    let list = connections;

    if (filter === 'accepted') {
        list = connections.filter(c => (c.status || '').toLowerCase() === 'accepted');
    } else if (['skill', 'activity', 'hobby', 'general'].includes(filter)) {
        list = connections.filter(c => (c.connection_type || '').toLowerCase() === filter);
    }

    if (!list.length) {
        grid.innerHTML = '<div class="empty-state">No connections match this filter.</div>';
        return;
    }

    grid.innerHTML = list.map(c => {
        const status     = (c.status || 'pending').toLowerCase();
        const type       = (c.connection_type || 'general').toLowerCase();
        const isAccepted = status === 'accepted';
        const skillsHtml = (c.initiator_skill || c.receiver_skill)
            ? `<div class="conn-skills">
                ${c.initiator_skill ? `🎯 Offers: <strong>${escapeHtml(c.initiator_skill)}</strong>` : ''}
                ${c.initiator_skill && c.receiver_skill ? ' · ' : ''}
                ${c.receiver_skill  ? `📚 Wants: <strong>${escapeHtml(c.receiver_skill)}</strong>`  : ''}
               </div>` : '';
        const typeIcon = { skill: '🎯', activity: '🏃', hobby: '🎨', general: '🤝' }[type] || '🔗';
        const borderColors = { accepted: '#4f46e5', pending: '#f59e0b', rejected: '#dc2626' };
        return `
        <div class="connection-card" style="border-left-color:${borderColors[status] || '#4f46e5'}">
            <div class="conn-avatar">
                ${resolveProfilePictureUrl(c.profile_picture) ? `<img src="${resolveProfilePictureUrl(c.profile_picture)}" alt="">` : '👤'}
            </div>
            <div class="conn-info">
                <p class="conn-name">${escapeHtml(c.full_name || c.username || 'Unknown')}</p>
                <p class="conn-username">@${escapeHtml(c.username || '')}</p>
                <div class="conn-badges">
                    <span class="status-badge status-${status}">${status.toUpperCase()}</span>
                    <span class="type-badge">${typeIcon} ${escapeHtml(c.connection_type || type)}</span>
                </div>
                ${skillsHtml}
            </div>
            <div class="conn-actions">
                ${isAccepted ? `<button class="btn-schedule" onclick="openScheduleMeetingModal('${c.connection_id}', '${escapeAttr(c.full_name || c.username || '')}')">📅 Schedule</button>` : ''}
                <button class="btn-delete-conn" onclick="deleteConnection('${c.connection_id}')">🗑 Delete</button>
            </div>
        </div>`;
    }).join('');
}

async function acceptConnection(connId) {
    try {
        const resp = await fetch(`/api/connections/${connId}/accept`, { method: 'POST' });
        const data = await resp.json();
        if (data.ok) { showToast('Connection accepted! 🎉', 'success'); loadConnections(); }
        else showToast(data.error || 'Failed to accept.', 'error');
    } catch (err) { console.error(err); }
}

async function rejectConnection(connId) {
    try {
        const resp = await fetch(`/api/connections/${connId}/reject`, { method: 'POST' });
        const data = await resp.json();
        if (data.ok) { showToast('Connection rejected.'); loadConnections(); }
        else showToast(data.error || 'Failed to reject.', 'error');
    } catch (err) { console.error(err); }
}

async function deleteConnection(connId) {
    if (!confirm('Are you sure you want to remove this connection?')) return;
    try {
        const resp = await fetch(`/api/connections/${connId}/delete`, { method: 'POST' });
        const data = await resp.json();
        if (data.ok) { showToast('Connection removed.'); loadConnections(); }
        else showToast(data.error || 'Failed to delete.', 'error');
    } catch (err) { console.error(err); }
}

// ═══════════════════════════════════════════════
// MEETINGS
// ═══════════════════════════════════════════════
async function loadMeetings(filter = 'upcoming') {
    state.currentMeetingFilter = filter;
    try {
        const resp = await fetch(`/api/meetings/list?filter=${encodeURIComponent(filter)}`);
        const data = await resp.json();
        if (!data.ok) return;
        renderMeetings(data.meetings || [], filter);
    } catch (err) { console.error(err); }
}

function renderMeetings(meetings, filter) {
    const list = document.getElementById('meetingsList');
    if (!meetings.length) {
        list.innerHTML = '<div class="empty-state">No meetings found for this filter.</div>';
        return;
    }

    list.innerHTML = meetings.map(m => {
        const dt      = m.datetime ? new Date(m.datetime) : null;
        const dateStr = dt ? dt.toLocaleDateString('en-GB', {day:'2-digit',month:'short',year:'numeric'}) : 'TBD';
        const timeStr = dt ? dt.toLocaleTimeString([], {hour: '2-digit', minute: '2-digit'}) : '';
        const status  = (m.status || 'scheduled').toLowerCase();
        const mType   = (m.type || 'virtual').toLowerCase();
        const isPast  = dt ? dt < new Date() : false;

        const canComplete = status === 'scheduled' && isPast;
        const canEdit     = status === 'scheduled';
        const canCancel   = status === 'scheduled';
        const canDelete   = status === 'completed' || status === 'cancelled';
        const hasJoinLink = mType === 'virtual' && m.google_meet_link && m.google_meet_link.startsWith('http');

        const locationIcon = mType === 'virtual' ? '💻' : '📍';
        const locationHtml = m.location ? `<p class="meeting-location">${locationIcon} ${escapeHtml(m.location)}</p>` : '';
        const participantsHtml = m.participant_count > 0 ? `<p class="meeting-meta">👥 ${m.participant_count} participant${m.participant_count > 1 ? 's' : ''}</p>` : '';
        const durationHtml = m.duration ? `<p class="meeting-meta">⏱ ${m.duration} min</p>` : '';

        return `
        <div class="meeting-card status-${status}">
            <div class="meeting-inner">
                <div class="meeting-header">
                    <div>
                        <div class="meeting-datetime">📅 ${dateStr}${timeStr ? ' · ' + timeStr : ''}</div>
                        <div style="font-size:12px;color:#64748b;margin-top:2px;">${escapeHtml(m.connection_name || 'Meeting')}</div>
                    </div>
                    <div class="meeting-badges">
                        <span class="status-badge status-${status}">${status.toUpperCase()}</span>
                        <span class="type-badge type-${mType}">${mType === 'virtual' ? '💻 Virtual' : '📍 Physical'}</span>
                    </div>
                </div>
                <div class="meeting-body">
                    ${locationHtml}${durationHtml}${participantsHtml}
                    <div class="meeting-actions">
                        ${hasJoinLink ? `<a href="${m.google_meet_link}" target="_blank" class="btn-join">🚀 Join</a>
                            <button class="btn-copy" onclick="copyToClipboard('${escapeAttr(m.google_meet_link)}', this)" title="Copy Meet link">📋</button>` : ''}
                        ${canEdit     ? `<button class="btn-edit"           onclick="openEditMeetingModal('${m.id}', '${mType}', '${escapeAttr(m.location||'')}', '${escapeAttr(m.datetime||'')}', ${m.duration || 60})">✏️ Edit</button>` : ''}
                        ${canComplete ? `<button class="btn-complete"       data-action="complete" data-id="${m.id}">✅ Complete</button>` : ''}
                        ${canCancel   ? `<button class="btn-cancel-meeting" data-action="cancel"   data-id="${m.id}">❌ Cancel</button>`  : ''}
                        ${canDelete   ? `<button class="btn-delete-meeting" data-action="delete"   data-id="${m.id}">🗑️ Delete</button>` : ''}
                    </div>
                </div>
            </div>
        </div>`;
    }).join('');

    list.querySelectorAll('[data-action]').forEach(btn => {
        btn.addEventListener('click', function () {
            handleMeetingAction(this.dataset.action, this.dataset.id, state.currentMeetingFilter);
        });
    });
}

async function handleMeetingAction(action, meetingId, currentFilter) {
    const routes = {
        complete: `/api/meetings/${meetingId}/mark-complete`,
        cancel:   `/api/meetings/${meetingId}/cancel`,
        delete:   `/api/meetings/${meetingId}/delete`,
    };
    if (!routes[action]) return;
    if (!confirm(`Are you sure you want to ${action} this meeting?`)) return;

    try {
        const resp = await fetch(routes[action], { method: 'POST' });
        const data = await resp.json();
        if (!data.ok) {
            if (action === 'complete' && data.scheduled_at) {
                const scheduledDate = new Date(data.scheduled_at);
                const formatted = scheduledDate.toLocaleDateString('en-GB', {day:'2-digit',month:'short',year:'numeric'}) + ' ' +
                                  scheduledDate.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
                showToast(`⏳ Cannot complete yet. Meeting is scheduled for ${formatted}. ${data.remaining ? '(' + data.remaining + ' remaining)' : ''}`, 'error');
            } else {
                showToast(data.error || `Failed to ${action} meeting.`, 'error');
            }
            return;
        }
        showToast(`Meeting ${action === 'complete' ? 'marked as completed ✅' : action === 'cancel' ? 'cancelled' : 'deleted'}.`, 'success');
        loadMeetings(currentFilter || 'upcoming');
    } catch (err) { console.error(err); }
}

function copyToClipboard(text, btn) {
    navigator.clipboard.writeText(text).then(() => {
        const orig = btn.textContent;
        btn.textContent = '✅';
        setTimeout(() => btn.textContent = orig, 1800);
    });
}


async function populateConnectionDropdown(selectId) {
    try {
        const resp = await fetch('/api/connections');
        const data = await resp.json();
        if (!data.ok) return;
        const select   = document.getElementById(selectId);
        const accepted = (data.connections || []).filter(c => (c.status || '').toLowerCase() === 'accepted');
        select.innerHTML = '<option value="">-- Select a connection --</option>';
        accepted.forEach(c => {
            const opt = document.createElement('option');
            opt.value = c.connection_id;
            opt.textContent = `${c.full_name || c.username || 'Unknown'} (@${c.username || ''})`;
            select.appendChild(opt);
        });
    } catch (err) { console.error(err); }
}

function resetCreateMeetingForm() {
    document.getElementById('cmDate').value = '';
    document.getElementById('cmTime').value = '14:00';
    document.getElementById('cmLocation').value = '';
    const virtualField = document.getElementById('cmVirtualLocationField');
    const physicalField = document.getElementById('cmLocationField');
    if (physicalField) physicalField.style.display = 'none';
    if (virtualField)  virtualField.style.display  = 'block';
    document.getElementById('cmMapContainer').style.display = 'none';
    document.getElementById('cmDurationValue').value = '60';
    document.getElementById('cmDurationCustom').style.display = 'none';
    document.getElementById('cmDurationChips').querySelectorAll('.dur-chip').forEach(c => {
        c.classList.toggle('active', c.dataset.min === '60');
    });

        radio.addEventListener('change', function () {
            document.querySelectorAll('input[name="qc-type"]').forEach(r =>
                r.closest('.type-radio-label').classList.remove('active'));
            this.closest('.type-radio-label').classList.add('active');
            document.getElementById('qcSkillsSection').style.display = this.value === 'skill' ? 'block' : 'none';
        });
    });

    document.getElementById('btnQcConfirm').addEventListener('click', async () => {

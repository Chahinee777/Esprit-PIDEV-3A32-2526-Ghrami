// MODAL HELPERS
// ═══════════════════════════════════════════════
function closeModal(modalId) { document.getElementById(modalId).classList.remove('active'); }
function openModal(modalId)  { document.getElementById(modalId).classList.add('active'); }

// ═══════════════════════════════════════════════
// DURATION CHIPS
// ═══════════════════════════════════════════════
function setupDurationChips(chipContainerId, customInputId, hiddenId) {
    const container   = document.getElementById(chipContainerId);
    const customInput = document.getElementById(customInputId);
    const hidden      = document.getElementById(hiddenId);
    if (!container) return;
    container.querySelectorAll('.dur-chip').forEach(chip => {
        chip.addEventListener('click', () => {
            container.querySelectorAll('.dur-chip').forEach(c => c.classList.remove('active'));
            chip.classList.add('active');
            const min = chip.dataset.min;
            if (min === 'custom') {
                customInput.style.display = 'block';
                customInput.focus();
                hidden.value = customInput.value || 60;
            } else {
                customInput.style.display = 'none';
                hidden.value = min;
            }
        });
    });
    customInput.addEventListener('input', () => { hidden.value = customInput.value; });
}

// ═══════════════════════════════════════════════
// PILL NAV SLIDER (animates the background pill)
// ═══════════════════════════════════════════════
function updatePillSlider(activeBtn) {
    const track  = document.querySelector('.nav-pill-track');
    const slider = document.querySelector('.nav-pill-slider');
    if (!track || !slider) return;
    const trackRect  = track.getBoundingClientRect();
    const btnRect    = activeBtn.getBoundingClientRect();
    slider.style.width  = btnRect.width + 'px';
    slider.style.transform = `translateX(${btnRect.left - trackRect.left}px)`;
}

// ═══════════════════════════════════════════════
// DISCOVERY — TINDER SWIPE DECK
// ═══════════════════════════════════════════════
let discoveryMatches = [];
let discoveryIndex   = 0;
let _dragStartX = 0, _dragCurX = 0, _dragging = false;

function getDismissedDiscoveryIds() {
    try {
        const raw = sessionStorage.getItem('meetings_discovery_dismissed_ids');
        const arr = raw ? JSON.parse(raw) : [];
        return Array.isArray(arr) ? arr.map(v => Number(v)).filter(v => !Number.isNaN(v)) : [];
    } catch {
        return [];
    }
}

function setDismissedDiscoveryIds(ids) {
    sessionStorage.setItem('meetings_discovery_dismissed_ids', JSON.stringify(Array.from(new Set(ids))));
}

function persistDiscoveryCache() {
    sessionStorage.setItem('meetings_discovery_matches_cache', JSON.stringify(discoveryMatches));
    sessionStorage.setItem('meetings_discovery_matches_cache_ts', String(Date.now()));
}

function removeDiscoveredUser(userId) {
    const numericId = Number(userId);
    if (Number.isNaN(numericId)) return;

    const dismissed = getDismissedDiscoveryIds();
    dismissed.push(numericId);
    setDismissedDiscoveryIds(dismissed);

    discoveryMatches = discoveryMatches.filter(m => Number(m.id) !== numericId);
    if (discoveryIndex >= discoveryMatches.length) {
        discoveryIndex = Math.max(0, discoveryMatches.length - 1);
    }
    persistDiscoveryCache();

    if (state.discoveryView === 'grid') {
        renderDiscoveryList();
    } else {
        renderSwipeStack();
    }
}

function applyDiscoveryView() {
    const swipeContainer = document.getElementById('discoveryGrid');
    const listContainer = document.getElementById('discoveryListGrid');
    const controls = document.getElementById('swipeControls');
    const counter = document.getElementById('swipeCounter');
    const hint = document.getElementById('discoveryHint');

    const isSwipe = state.discoveryView === 'swipe';
    if (swipeContainer) swipeContainer.style.display = isSwipe ? '' : 'none';
    if (listContainer) listContainer.style.display = isSwipe ? 'none' : 'grid';
    if (controls) controls.style.display = isSwipe && discoveryMatches.length > 0 ? 'flex' : 'none';
    if (counter) counter.style.display = isSwipe ? '' : 'none';
    if (hint) hint.textContent = isSwipe
        ? 'Drag the card or use the buttons'
        : 'Browse all profiles and connect directly';
}

function resolveProfilePictureUrl(profilePicture) {
    const raw = String(profilePicture || '').trim();
    if (!raw) return null;
    if (raw.startsWith('http://') || raw.startsWith('https://')) return raw;
    if (raw.startsWith('/')) return raw;
    if (raw.includes('images/profile_pictures/')) return '/' + raw.replace(/^\/+/, '');
    return `/images/profile_pictures/${encodeURIComponent(raw)}`;
}

async function fetchJsonWithRetry(url, { timeoutMs = 12000, retries = 1 } = {}) {
    let lastError = null;
    for (let attempt = 0; attempt <= retries; attempt++) {
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), timeoutMs);
        try {
            const response = await fetch(url, {
                signal: controller.signal,
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            clearTimeout(timeoutId);
            if (!response.ok) throw new Error(`HTTP ${response.status}`);
            return await response.json();
        } catch (err) {
            clearTimeout(timeoutId);
            lastError = err;
            if (attempt === retries) break;
        }
    }
    throw lastError || new Error('Request failed');
}

async function loadMatches(forceRefresh = false) {
    const grid = document.getElementById('discoveryGrid');
    const listGrid = document.getElementById('discoveryListGrid');
    grid.innerHTML = '<div class="loading-placeholder">Loading matches…</div>';
    if (listGrid) listGrid.innerHTML = '';
    document.getElementById('swipeControls').style.display = 'none';
    document.getElementById('swipeCounter').textContent = '';

    try {
        const cacheKey = 'meetings_discovery_matches_cache';
        const cacheTsKey = 'meetings_discovery_matches_cache_ts';
        const now = Date.now();

        if (!forceRefresh) {
            const cached = sessionStorage.getItem(cacheKey);
            const cachedTs = Number(sessionStorage.getItem(cacheTsKey) || '0');
            if (cached && now - cachedTs < 120000) {
                const parsed = JSON.parse(cached);
                if (Array.isArray(parsed) && parsed.length > 0) {
                    const dismissed = new Set(getDismissedDiscoveryIds());
                    discoveryMatches = parsed.filter(m => !dismissed.has(Number(m.id)));
                    discoveryIndex = 0;
                    if (state.discoveryView === 'grid') renderDiscoveryList();
                    else renderSwipeStack();
                    applyDiscoveryView();
                    return;
                }
            }
        }

        const query = forceRefresh ? '?refresh=1' : '';
        const data = await fetchJsonWithRetry(`/api/discovery/matches${query}`, { timeoutMs: 12000, retries: 1 });

        if (!data.ok || !data.matches || data.matches.length === 0) {
            grid.innerHTML = '<div class="empty-state">No matches found. Set up your profile to find connections!</div>';
            return;
        }
        const dismissed = new Set(getDismissedDiscoveryIds());
        discoveryMatches = data.matches.filter(m => !dismissed.has(Number(m.id)));
        discoveryIndex   = 0;
        sessionStorage.setItem(cacheKey, JSON.stringify(discoveryMatches));
        sessionStorage.setItem(cacheTsKey, String(now));
        if (state.discoveryView === 'grid') renderDiscoveryList();
        else renderSwipeStack();
        applyDiscoveryView();
    } catch (err) {
        console.error(err);
        grid.innerHTML = '<div class="empty-state">Error loading matches. <button class="btn-primary" style="margin-left:8px;" onclick="loadMatches(true)">Retry</button></div>';
    }
}

function renderDiscoveryList() {
    const list = document.getElementById('discoveryListGrid');
    if (!list) return;

    if (!discoveryMatches.length) {
        list.innerHTML = '<div class="empty-state" style="grid-column:1/-1;">No users left to discover.</div>';
        return;
    }

    list.innerHTML = discoveryMatches.map(match => {
        const imageUrl = resolveProfilePictureUrl(match.profile_picture);
        const location = match.location ? `📍 ${escapeHtml(match.location)}` : `@${escapeHtml(match.username)}`;
        const score = Number(match.percentage || 0);
        return `
            <div class="discovery-user-card">
                <div class="discovery-user-top">
                    <div class="discovery-user-avatar">${imageUrl ? `<img src="${imageUrl}" alt="">` : '👤'}</div>
                    <div>
                        <p class="discovery-user-name">${escapeHtml(match.full_name || match.username)}</p>
                        <p class="discovery-user-username">${location}</p>
                        <p class="discovery-user-username">${score}% Match</p>
                    </div>
                </div>
                ${match.reason ? `<p class="discovery-user-username" style="color:#475569;">💫 ${escapeHtml(match.reason)}</p>` : ''}
                <div class="discovery-user-actions">
                    <button class="btn-view-discovery" onclick="openProfileModal('${match.id}')">View</button>
                    <button class="btn-connect-discovery" onclick="openQuickConnect('${match.id}', '${escapeAttr(match.full_name || match.username)}', '${escapeAttr(match.profile_picture || '')}')">Connect</button>
                </div>
            </div>
        `;
    }).join('');
}

function renderSwipeStack() {
    const container = document.getElementById('discoveryGrid');
    const remaining = discoveryMatches.length - discoveryIndex;
    container.innerHTML = '';

    if (remaining <= 0) {
        container.innerHTML = `<div class="swipe-done">🎉 You've seen everyone!<br><button onclick="loadMatches(true)" class="btn-primary" style="margin-top:20px;display:inline-block;">↺ Refresh</button></div>`;
        document.getElementById('swipeControls').style.display = 'none';
        document.getElementById('swipeCounter').textContent = '';
        return;
    }

    // Render back-to-front so front card is on top
    const count = Math.min(3, remaining);
    for (let i = count - 1; i >= 0; i--) {
        const match = discoveryMatches[discoveryIndex + i];
        const card  = buildSwipeCard(match, i);
        container.appendChild(card);
    }

    const counter = document.getElementById('swipeCounter');
    if (counter) counter.textContent = `${discoveryIndex + 1} / ${discoveryMatches.length}`;

    const front = container.querySelector('[data-pos="0"]');
    if (front) attachDrag(front);
}

function buildSwipeCard(match, pos) {
    const div = document.createElement('div');
    div.className = 'swipe-card';
    div.dataset.pos = pos;

    const imageUrl = resolveProfilePictureUrl(match.profile_picture);

    const scoreColor = match.percentage >= 60 ? '#059669' : match.percentage >= 40 ? '#4f46e5' : '#d97706';

    div.innerHTML = `
        <div class="sc-photo" style="${imageUrl ? `background-image:url('${imageUrl}')` : 'background:linear-gradient(135deg,#667eea,#764ba2)'}">
            ${!imageUrl ? '<div class="sc-emoji">👤</div>' : ''}
        </div>
        <div class="sc-body">
            <div class="sc-match-badge" style="color:${scoreColor};border-color:${scoreColor}33;background:${scoreColor}14">${match.percentage}% Match</div>
            <h3 class="sc-name">${escapeHtml(match.full_name || match.username)}</h3>
            <p class="sc-location">${match.location ? `📍 ${escapeHtml(match.location)}` : `@${escapeHtml(match.username)}`}</p>
            ${match.reason ? `<p class="sc-reason">💫 ${escapeHtml(match.reason)}</p>` : ''}
            <div class="sc-tags">${(match.common_interests || []).slice(0,4).map(i => `<span class="sc-tag">${escapeHtml(i)}</span>`).join('')}</div>
        </div>
        <div class="sc-like-stamp">CONNECT 💫</div>
        <div class="sc-nope-stamp">PASS ✕</div>
    `;
    return div;
}

function attachDrag(card) {
    _dragStartX = 0; _dragCurX = 0; _dragging = false;

    function onStart(e) {
        const pt = e.touches ? e.touches[0] : e;
        _dragStartX = pt.clientX;
        _dragging   = true;
        card.style.transition = 'none';
    }
    function onMove(e) {
        if (!_dragging) return;
        const pt = e.touches ? e.touches[0] : e;
        _dragCurX  = pt.clientX - _dragStartX;
        const rot  = _dragCurX * 0.07;
        card.style.transform = `translateX(${_dragCurX}px) rotate(${rot}deg)`;
        const like = card.querySelector('.sc-like-stamp');
        const nope = card.querySelector('.sc-nope-stamp');
        if (like) like.style.opacity = Math.max(0, Math.min(1, _dragCurX / 80));
        if (nope) nope.style.opacity = Math.max(0, Math.min(1, -_dragCurX / 80));
    }
    function onEnd() {
        if (!_dragging) return;
        _dragging = false;
        if (_dragCurX > 90)       { animateOut(card, 'right'); }
        else if (_dragCurX < -90) { animateOut(card, 'left'); }
        else {
            card.style.transition = 'transform 0.35s cubic-bezier(0.34,1.56,0.64,1)';
            card.style.transform  = '';
            const like = card.querySelector('.sc-like-stamp');
            const nope = card.querySelector('.sc-nope-stamp');
            if (like) like.style.opacity = 0;
            if (nope) nope.style.opacity = 0;
        }
    }

    card.addEventListener('mousedown',  onStart);
    card.addEventListener('touchstart', onStart, { passive: true });
    document.addEventListener('mousemove',  onMove);
    document.addEventListener('touchmove',  onMove, { passive: true });
    document.addEventListener('mouseup',    onEnd);
    document.addEventListener('touchend',   onEnd);
}

function animateOut(card, direction) {
    const tx  = direction === 'right' ? '160%' : '-160%';
    const rot = direction === 'right' ? '20deg' : '-20deg';
    card.style.transition = 'transform 0.42s ease, opacity 0.42s ease';
    card.style.transform  = `translateX(${tx}) rotate(${rot})`;
    card.style.opacity    = '0';

    if (direction === 'right') {
        const match = discoveryMatches[discoveryIndex];
        setTimeout(() => {
            discoveryIndex++;
            renderSwipeStack();
            openQuickConnect(match.id, (match.full_name || '').replace(/'/g, "\\'"), (match.profile_picture || '').replace(/'/g, "\\'"));
        }, 380);
    } else {
        setTimeout(() => { discoveryIndex++; renderSwipeStack(); }, 380);
    }
}

function swipeLeft() {
    const front = document.querySelector('.swipe-card[data-pos="0"]');
    if (front) animateOut(front, 'left');
}
function swipeRight() {
    const front = document.querySelector('.swipe-card[data-pos="0"]');
    if (front) animateOut(front, 'right');
}
function viewCurrentCard() {
    if (discoveryMatches[discoveryIndex]) openProfileModal(discoveryMatches[discoveryIndex].id);
}

function openQuickConnect(userId, name, pic) {
    state.quickConnectUserId  = userId;
    state.quickConnectUserName = name;
    document.getElementById('quickConnectName').textContent = name;
    const picUrl = resolveProfilePictureUrl(pic);
    document.getElementById('quickConnectAvatar').innerHTML = picUrl ? `<img src="${picUrl}" alt="">` : '👤';
    document.querySelectorAll('input[name="qc-type"]').forEach(r => {
        r.checked = (r.value === 'general');
        r.closest('.type-radio-label').classList.toggle('active', r.value === 'general');
    });
    document.getElementById('qcSkillsSection').style.display = 'none';
    document.getElementById('qcInitiatorSkill').value = '';
    document.getElementById('qcReceiverSkill').value  = '';
    openModal('quickConnectModal');
}


{% extends 'base.html.twig' %}

{% block title %}Meetings Calendar - Ghrami{% endblock %}

{% block body %}

<div class="meetings-container">
    <!-- Header -->
    <div class="section-header" style="margin-bottom: 32px;">
        <div>
            <h1 class="section-title">📅 Meetings Calendar</h1>
            <p class="section-sub">View and manage all your scheduled meetings</p>
        </div>
        <button id="createMeetingBtn" onclick="openModal('createMeetingModal')" style="padding: 10px 24px; background: linear-gradient(135deg, #4f46e5, #7c3aed); color: white; border: none; border-radius: 10px; font-weight: 700; font-size: 13px; cursor: pointer; white-space: nowrap;">
            + New Meeting
        </button>
    </div>

    <!-- Filter Options -->
    <div class="meeting-filter-row" style="margin-bottom: 24px;">
        <label class="filter-label">Filter by Status:</label>
        <select id="calendarFilterSelect" class="meeting-select" onchange="filterCalendarByStatus(this.value)">
            <option value="">All Meetings</option>
            <option value="scheduled">📅 Scheduled</option>
            <option value="completed">✅ Completed</option>
            <option value="cancelled">❌ Cancelled</option>
        </select>
    </div>

    <!-- Calendar View -->
    <div style="background: white; border-radius: 16px; border: 1px solid #e8ecf4; box-shadow: 0 2px 8px rgba(0,0,0,0.05); overflow: hidden;">
        <table class="calendar-table" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f8fafc;">
                    <th style="padding: 12px; text-align: center; font-weight: 700; color: #0f172a; border: 1px solid #e8ecf4;">Sun</th>
                    <th style="padding: 12px; text-align: center; font-weight: 700; color: #0f172a; border: 1px solid #e8ecf4;">Mon</th>
                    <th style="padding: 12px; text-align: center; font-weight: 700; color: #0f172a; border: 1px solid #e8ecf4;">Tue</th>
                    <th style="padding: 12px; text-align: center; font-weight: 700; color: #0f172a; border: 1px solid #e8ecf4;">Wed</th>
                    <th style="padding: 12px; text-align: center; font-weight: 700; color: #0f172a; border: 1px solid #e8ecf4;">Thu</th>
                    <th style="padding: 12px; text-align: center; font-weight: 700; color: #0f172a; border: 1px solid #e8ecf4;">Fri</th>
                    <th style="padding: 12px; text-align: center; font-weight: 700; color: #0f172a; border: 1px solid #e8ecf4;">Sat</th>
                </tr>
            </thead>
            <tbody id="calendarBody">
                <!-- Calendar generated by JavaScript -->
            </tbody>
        </table>
    </div>

    <!-- Meeting Details Section (when clicking a meeting) -->
    <div id="meetingDetailsPanel" style="display: none; margin-top: 24px;">
        <button onclick="closeMeetingDetails()" style="margin-bottom: 12px; padding: 8px 16px; background: #f1f5f9; color: #64748b; border: none; border-radius: 8px; font-weight: 700; cursor: pointer;">← Back to Calendar</button>
        <div id="meetingDetailsContent" style="background: white; border-radius: 16px; padding: 24px; border: 1px solid #e8ecf4; box-shadow: 0 2px 8px rgba(0,0,0,0.05);"></div>
    </div>
</div>

<!-- Create Meeting Modal (reuse from index.html.twig) -->
<div class="modal" id="createMeetingModal">
    <div class="modal-overlay"></div>
    <div class="modal-content" style="max-width:560px;">
        <div class="modal-header gradient-indigo">
            <h2>➕ Schedule a Meeting</h2>
            <button type="button" class="close-btn" onclick="closeModal('createMeetingModal')">✕</button>
        </div>
        <div class="modal-body">
            <form id="createMeetingForm" onsubmit="submitCreateMeeting(event)">
                <div class="form-group">
                    <label for="createMeetingTitle">Title</label>
                    <input type="text" id="createMeetingTitle" class="form-control" placeholder="e.g., Project Discussion" required>
                </div>

                <div class="form-group">
                    <label for="createMeetingConn">Connection</label>
                    <select id="createMeetingConn" class="form-control" required>
                        <option value="">Select connection...</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="createMeetingType">Type</label>
                    <div style="display: flex; gap: 8px;">
                        <label class="type-radio-label">
                            <input type="radio" name="type" value="virtual" checked>
                            🖥️ Virtual
                        </label>
                        <label class="type-radio-label">
                            <input type="radio" name="type" value="physical">
                            📍 Physical
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label for="createMeetingLocation">Location/Link</label>
                    <input type="text" id="createMeetingLocation" class="form-control" placeholder="Zoom link or physical location">
                </div>

                <div class="form-group">
                    <label for="meetingDateTimePicker">Date & Time *</label>
                    <input 
                        type="text" 
                        id="meetingDateTimePicker" 
                        class="form-control" 
                        placeholder="Click to select date and time..."
                        required>
                    <input type="hidden" id="createMeetingDate">
                    <input type="hidden" id="createMeetingTime">
                </div>

                <div class="form-group">
                    <label>Duration</label>
                    <div id="durationChipsContainer" style="display: flex; gap: 8px; flex-wrap: wrap;">
                        <button type="button" class="dur-chip active" data-duration="30">30 min</button>
                        <button type="button" class="dur-chip" data-duration="60">1 hour</button>
                        <button type="button" class="dur-chip" data-duration="90">1.5 hours</button>
                        <button type="button" class="dur-chip" data-duration="120">2 hours</button>
                    </div>
                    <input type="hidden" id="createMeetingDuration" value="30">
                </div>

                <div class="form-group">
                    <label for="createMeetingNotes">Notes (optional)</label>
                    <textarea id="createMeetingNotes" class="form-control" rows="3" placeholder="Additional details..."></textarea>
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cancel" onclick="closeModal('createMeetingModal')">Cancel</button>
            <button type="submit" form="createMeetingForm" class="btn-primary">Schedule Meeting</button>
        </div>
    </div>
</div>

<style>
    .calendar-custom {
        font-family: var(--font-family);
    }

    .calendar-custom table {
        margin: 0;
        width: 100%;
    }

    .calendar-custom td,
    .calendar-custom th {
        padding: 12px;
        text-align: center;
        border-color: #e8ecf4;
        vertical-align: top;
        min-height: 100px;
    }

    .calendar-custom th {
        background: #f8fafc;
        font-weight: 700;
        color: #0f172a;
    }

    .calendar-custom td {
        background: white;
        cursor: pointer;
        transition: background 0.2s;
    }

    .calendar-custom td:hover {
        background: #f8fafc;
    }

    .calendar-custom .table-success {
        background-color: #dcfce7 !important;
    }

    .calendar-custom a {
        color: #4f46e5;
        text-decoration: none;
        cursor: pointer;
        font-weight: 600;
        font-size: 12px;
        padding: 2px 6px;
        background: #eef2ff;
        border-radius: 4px;
        display: inline-block;
        margin-bottom: 4px;
        transition: all 0.2s;
    }

    .calendar-custom a:hover {
        background: #4f46e5;
        color: white;
    }

    .meeting-event-badge {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        margin-bottom: 2px;
        line-height: 1.2;
    }

    .event-scheduled {
        background: #ede9fe;
        color: #4f46e5;
    }

    .event-completed {
        background: #dcfce7;
        color: #15803d;
    }

    .event-cancelled {
        background: #fee2e2;
        color: #dc2626;
    }

    @media (max-width: 768px) {
        .calendar-custom {
            font-size: 12px;
        }

        .calendar-custom td,
        .calendar-custom th {
            padding: 8px;
            min-height: 80px;
        }
    }

    /* ═══════════════════════════════════════════════
       FLATPICKR CUSTOM STYLING
       ═══════════════════════════════════════════════ */
    .flatpickr-calendar {
        background: white;
        border: 1px solid #e8ecf4;
        border-radius: 12px;
        box-shadow: 0 8px 28px rgba(0,0,0,0.15);
        z-index: 9999;
    }

    .flatpickr-calendar.open {
        display: block !important;
    }

    .flatpickr-prev, .flatpickr-next {
        color: #4f46e5;
        border: none;
        padding: 8px;
        height: 32px;
        width: 32px;
        fill: #4f46e5;
    }

    .flatpickr-prev:hover, .flatpickr-next:hover {
        background: #eef2ff;
        border-radius: 6px;
    }

    .flatpickr-months {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        color: white;
        padding: 12px;
        border-radius: 12px 12px 0 0;
    }

    .flatpickr-current-month {
        color: white;
        font-weight: 700;
        font-size: 14px;
    }

    .flatpickr-weekdays {
        background: #f8fafc;
        color: #0f172a;
        font-weight: 700;
        padding: 8px 0;
    }

    .flatpickr-day {
        color: #0f172a;
        flex-basis: 14.2857142857%;
        border-radius: 6px;
        margin: 4px;
        padding: 8px 4px;
        max-width: calc(14.2857142857% - 8px);
        font-size: 13px;
    }

    .flatpickr-day:hover {
        background: #eef2ff;
        color: #4f46e5;
    }

    .flatpickr-day.selected {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        border-color: #4f46e5;
        color: white;
        font-weight: 700;
    }

    .flatpickr-day.today {
        border: 2px solid #4f46e5;
        color: #4f46e5;
        font-weight: 700;
        background: #eef2ff;
    }

    .flatpickr-time {
        background: #f8fafc;
        border-top: 1px solid #e8ecf4;
        padding: 12px;
    }

    .flatpickr-hour, .flatpickr-minute {
        background: white;
        color: #0f172a;
        font-weight: 600;
        border: 1px solid #e8ecf4;
        border-radius: 6px;
    }

    .numInputWrapper {
        position: relative;
        flex: 1;
    }

    .numInputWrapper span.arrowUp:hover,
    .numInputWrapper span.arrowDown:hover {
        background: #eef2ff;
        color: #4f46e5;
    }

    .flatpickr-separator {
        color: #0f172a;
        font-weight: 700;
    }
</style>

<!-- Flatpickr Calendar Picker CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
    // Calendar data from controller
    const eventsData = {{ events | json_encode | raw }};

    // Generate calendar month view
    function generateCalendar() {
        const today = new Date();
        const year = today.getFullYear();
        const month = today.getMonth();
        
        const firstDay = new Date(year, month, 1);
        const lastDay = new Date(year, month + 1, 0);
        const daysInMonth = lastDay.getDate();
        const startingDayOfWeek = firstDay.getDay();
        
        let html = '';
        let dayCounter = 1;
        
        // Generate 6 rows for the calendar
        for (let week = 0; week < 6; week++) {
            html += '<tr>';
            for (let day = 0; day < 7; day++) {
                const cellIndex = week * 7 + day;
                
                if ((week === 0 && day < startingDayOfWeek) || dayCounter > daysInMonth) {
                    html += '<td style="padding: 12px; background: #f8fafc; border: 1px solid #e8ecf4; height: 120px; vertical-align: top;"></td>';
                } else {
                    const currentDate = new Date(year, month, dayCounter);
                    const dateStr = currentDate.toISOString().split('T')[0];
                    
                    // Get meetings for this day
                    const meetingsOnDay = eventsData.filter(e => {
                        const eventDate = e.start.split('T')[0];
                        return eventDate === dateStr;
                    });
                    
                    let meetingsHtml = '';
                    meetingsOnDay.forEach(meeting => {
                        const status = meeting.extendedProps.status;
                        const statusClass = `event-${status}`;
                        meetingsHtml += `
                            <div class="meeting-event-badge ${statusClass}" onclick="loadMeetingDetails(${meeting.extendedProps.meetingId})" style="cursor: pointer; width: 100%; text-align: left; overflow: hidden; text-overflow: ellipsis;">
                                ${meeting.title}
                            </div>
                        `;
                    });
                    
                    const isToday = currentDate.toDateString() === today.toDateString();
                    const bgColor = isToday ? '#eef2ff' : (meetingsOnDay.length > 0 ? '#f8fafc' : 'white');
                    const borderColor = isToday ? '#4f46e5' : '#e8ecf4';
                    
                    html += `
                        <td style="padding: 12px; background: ${bgColor}; border: 1px solid ${borderColor}; height: 120px; vertical-align: top; cursor: pointer;" 
                            onmouseover="this.style.background='#f0f2f5'" 
                            onmouseout="this.style.background='${bgColor}'">
                            <div style="font-weight: 700; font-size: 14px; color: #0f172a; margin-bottom: 6px;">${dayCounter}</div>
                            <div style="font-size: 11px; overflow-y: auto; max-height: 90px;">
                                ${meetingsHtml || '<span style="color: #cbd5e1;">No meetings</span>'}
                            </div>
                        </td>
                    `;
                    
                    dayCounter++;
                }
            }
            html += '</tr>';
            
            if (dayCounter > daysInMonth) break;
        }
        
        document.getElementById('calendarBody').innerHTML = html;
    }

    // Initialize Flatpickr calendar date/time picker
    let flatpickrInstance = null;
    
    function initFlatpickr() {
        flatpickrInstance = flatpickr("#meetingDateTimePicker", {
            enableTime: true,
            dateFormat: "Y-m-d H:i",
            minDate: "today",
            time_24hr: false,
            defaultDate: new Date(),
            inline: false,
            minuteIncrement: 15,
            onChange: function(selectedDates) {
                if (selectedDates.length > 0) {
                    const date = selectedDates[0];
                    document.getElementById('createMeetingDate').value = date.toISOString().split('T')[0];
                    const hours = String(date.getHours()).padStart(2, '0');
                    const minutes = String(date.getMinutes()).padStart(2, '0');
                    document.getElementById('createMeetingTime').value = hours + ':' + minutes;
                }
            }
        });
    }
    
    // Initialize calendar and populate connections
    document.addEventListener('DOMContentLoaded', function() {
        generateCalendar();
        populateConnectionDropdown();
        initFlatpickr();
    });

    // Initialize duration chips
    document.querySelectorAll('.dur-chip').forEach(chip => {
        chip.addEventListener('click', function(e) {
            e.preventDefault();
            document.querySelectorAll('.dur-chip').forEach(c => c.classList.remove('active'));
            this.classList.add('active');
            document.getElementById('createMeetingDuration').value = this.dataset.duration;
        });
    });

    // Populate connections dropdown
    async function populateConnectionDropdown() {
        try {
            const res = await fetch('{{ path('api_connections_list') }}');
            const data = await res.json();
            const select = document.getElementById('createMeetingConn');
            
            if (data.ok && data.connections) {
                data.connections.forEach(conn => {
                    const opt = document.createElement('option');
                    opt.value = conn.id;
                    opt.textContent = conn.name;
                    select.appendChild(opt);
                });
            }
        } catch(e) {
            console.error('Error loading connections:', e);
        }
    }

    // Submit meeting form
    async function submitCreateMeeting(e) {
        e.preventDefault();
        const formData = new FormData(document.getElementById('createMeetingForm'));
        
        const data = {
            title: document.getElementById('createMeetingTitle').value,
            connectionId: document.getElementById('createMeetingConn').value,
            type: document.querySelector('input[name="type"]:checked').value,
            location: document.getElementById('createMeetingLocation').value,
            scheduledAt: document.getElementById('createMeetingDate').value + 'T' + document.getElementById('createMeetingTime').value,
            duration: document.getElementById('createMeetingDuration').value,
            notes: document.getElementById('createMeetingNotes').value,
        };

        try {
            const res = await fetch('{{ path('api_meetings_create') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify(data)
            });
            
            const result = await res.json();
            if (result.ok) {
                showToast('Meeting created successfully!', 'success');
                closeModal('createMeetingModal');
                setTimeout(() => location.reload(), 800);
            } else {
                showToast('Error: ' + (result.error || 'Failed to create meeting'), 'error');
            }
        } catch(e) {
            showToast('Error: ' + e.message, 'error');
        }
    }

    // Load meeting details
    async function loadMeetingDetails(meetingId) {
        try {
            const res = await fetch(`{{ path('api_meetings_details') }}?id=${meetingId}`);
            const data = await res.json();
            
            if (data.ok && data.meeting) {
                const meeting = data.meeting;
                document.getElementById('meetingDetailsPanel').style.display = 'block';
                document.getElementById('meetingDetailsContent').innerHTML = `
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <h3 style="margin: 0; font-size: 20px; font-weight: 700;">${escapeHtml(meeting.title)}</h3>
                        <div style="display: flex; gap: 8px;">
                            <span class="status-badge status-${meeting.status}">${meeting.status}</span>
                            <span class="type-badge type-${meeting.type}">${meeting.type === 'virtual' ? '🖥️ Virtual' : '📍 Physical'}</span>
                        </div>
                    </div>
                    
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px;">
                        <div>
                            <p style="margin: 0 0 4px; font-size: 12px; color: #94a3b8; font-weight: 700; text-transform: uppercase;">Date & Time</p>
                            <p style="margin: 0; font-size: 14px; color: #0f172a; font-weight: 600;">${new Date(meeting.scheduledAt).toLocaleString()}</p>
                        </div>
                        <div>
                            <p style="margin: 0 0 4px; font-size: 12px; color: #94a3b8; font-weight: 700; text-transform: uppercase;">Duration</p>
                            <p style="margin: 0; font-size: 14px; color: #0f172a; font-weight: 600;">${meeting.duration} minutes</p>
                        </div>
                        <div>
                            <p style="margin: 0 0 4px; font-size: 12px; color: #94a3b8; font-weight: 700; text-transform: uppercase;">Location/Link</p>
                            <p style="margin: 0; font-size: 14px; color: #0f172a; font-weight: 600; word-break: break-all;">${escapeHtml(meeting.location || 'N/A')}</p>
                        </div>
                    </div>

                    ${meeting.notes ? `
                        <div style="background: #f8fafc; padding: 12px; border-radius: 8px; border-left: 3px solid #4f46e5; margin-bottom: 20px;">
                            <p style="margin: 0 0 4px; font-size: 12px; color: #94a3b8; font-weight: 700;">Notes</p>
                            <p style="margin: 0; font-size: 13px; color: #0f172a;">${escapeHtml(meeting.notes)}</p>
                        </div>
                    ` : ''}

                    ${meeting.googleMeetLink ? `
                        <div style="background: #eef2ff; padding: 12px; border-radius: 8px; border-left: 3px solid #4f46e5; margin-bottom: 20px;">
                            <p style="margin: 0 0 4px; font-size: 12px; color: #4f46e5; font-weight: 700;">Google Meet Link</p>
                            <a href="${escapeHtml(meeting.googleMeetLink)}" target="_blank" style="color: #4f46e5; text-decoration: underline; font-size: 13px; word-break: break-all;">Open Meeting</a>
                        </div>
                    ` : ''}

                    <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 20px; padding-top: 20px; border-top: 1px solid #e8ecf4;">
                        ${meeting.status === 'scheduled' ? `
                            <button onclick="editMeeting(${meeting.id})" style="padding: 8px 16px; background: #dbeafe; color: #1d4ed8; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 12px;">✏️ Edit</button>
                            <button onclick="completeMeeting(${meeting.id})" style="padding: 8px 16px; background: #dcfce7; color: #15803d; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 12px;">✅ Mark Complete</button>
                            <button onclick="cancelMeeting(${meeting.id})" style="padding: 8px 16px; background: #fee2e2; color: #dc2626; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 12px;">❌ Cancel</button>
                        ` : ''}
                        <button onclick="deleteMeeting(${meeting.id})" style="padding: 8px 16px; background: #fee2e2; color: #dc2626; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 12px; margin-left: auto;">🗑️ Delete</button>
                    </div>
                `;
            }
        } catch(e) {
            console.error('Error loading meeting details:', e);
            showToast('Error loading meeting details', 'error');
        }
    }

    function closeMeetingDetails() {
        document.getElementById('meetingDetailsPanel').style.display = 'none';
        document.getElementById('meetingDetailsContent').innerHTML = '';
    }

    function escapeHtml(str) {
        if (!str) return '';
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }

    function filterCalendarByStatus(status) {
        if (status) {
            window.location.href = '{{ path('app_meetings_calendar') }}?status=' + status;
        } else {
            window.location.href = '{{ path('app_meetings_calendar') }}';
        }
    }

    function showToast(msg, type = 'info') {
        const t = document.createElement('div');
        t.className = 'toast' + (type === 'error' ? ' toast-error' : type === 'success' ? ' toast-success' : '');
        t.textContent = msg;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 3200);
    }

    function openModal(modalId) {
        document.getElementById(modalId).classList.add('active');
    }

    function closeModal(modalId) {
        document.getElementById(modalId).classList.remove('active');
    }

    // Placeholder functions for meeting actions (you can wire these to actual endpoints)
    function editMeeting(id) {
        showToast('Edit meeting #' + id, 'info');
    }

    function completeMeeting(id) {
        showToast('Marking meeting as complete...', 'info');
    }

    function cancelMeeting(id) {
        showToast('Cancelling meeting...', 'info');
    }

    function deleteMeeting(id) {
        if (confirm('Are you sure you want to delete this meeting?')) {
            showToast('Meeting deleted', 'success');
            closeMeetingDetails();
        }
    }
</script>

{% endblock %}

{% extends 'auth_layout.html.twig' %}

{% block title %}Login | Ghrami{% endblock %}

{% block auth_body %}
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .gl-wrap {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 35fr 65fr;
    font-family: 'Sora', sans-serif;
  }

  /* ── LEFT ── */
  .gl-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 64px 48px;
    background: #ffffff;
  }

  .gl-left-inner {
    width: 100%;
    max-width: 380px;
  }

  .gl-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 44px;
  }

  .gl-logo-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
  }
  .gl-logo-placeholder img {
    width: 150px;
    height: 150px;
    object-fit: contain;
  }
  .gl-logo-placeholder.gl-logo-fallback::after {
    content: "Logo";
    font-size: 13px;
    font-weight: 600;
    color: #adb0bb;
    letter-spacing: .5px;
  }
  .gl-logo-placeholder.gl-logo-fallback img {
    display: none;
  }

  .gl-brand-name {
    font-size: 24px;
    font-weight: 800;
    background: linear-gradient(135deg, #667eea, #764ba2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .gl-brand-by {
    font-size: 11px;
    color: #b0b3bb;
    font-weight: 500;
    margin-top: 2px;
    letter-spacing: .6px;
  }

  .gl-heading {
    font-size: 28px;
    font-weight: 800;
    color: #0d0f14;
    letter-spacing: -.5px;
    margin-bottom: 6px;
  }
  .gl-sub {
    font-size: 14px;
    color: #9095a0;
    margin-bottom: 32px;
  }

  .gl-error {
    background: #fff1f0;
    border-left: 4px solid #e53e3e;
    border-radius: 8px;
    padding: 13px 16px;
    color: #c53030;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 24px;
  }

  .gl-field { margin-bottom: 20px; }
  .gl-field-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 7px;
  }
  .gl-label { font-size: 13px; font-weight: 600; color: #0d0f14; }
  .gl-forgot { font-size: 12px; color: #667eea; text-decoration: none; font-weight: 600; }
  .gl-forgot:hover { opacity: .75; }

  .gl-input {
    width: 100%;
    padding: 13px 16px;
    border: 1.5px solid #eaecf2;
    border-radius: 10px;
    font-size: 14px;
    font-family: 'Sora', sans-serif;
    color: #0d0f14;
    background: #f9fafc;
    outline: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
  }
  .gl-input::placeholder { color: #c2c5cf; }
  .gl-input:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 4px rgba(102,126,234,.12);
    background: #fff;
  }

  .gl-btn-primary {
    width: 100%;
    padding: 14px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    font-family: 'Sora', sans-serif;
    cursor: pointer;
    letter-spacing: .3px;
    box-shadow: 0 6px 20px rgba(102,126,234,.38);
    transition: transform .2s, box-shadow .2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 4px;
  }
  .gl-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(102,126,234,.5);
  }
  .gl-btn-primary:active { transform: translateY(1px); }
  .gl-btn-primary .arr { transition: transform .2s; }
  .gl-btn-primary:hover .arr { transform: translateX(4px); }

  .gl-divider {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 20px 0;
  }
  .gl-divider-line { flex: 1; height: 1px; background: #eaecf2; }
  .gl-divider-text { font-size: 11px; color: #adb0bb; font-weight: 600; text-transform: uppercase; letter-spacing: .8px; }

  .gl-btn-google {
    width: 100%;
    padding: 13px;
    background: white;
    color: #0d0f14;
    border: 1.5px solid #eaecf2;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    font-family: 'Sora', sans-serif;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all .2s;
  }
  .gl-btn-google:hover {
    border-color: #667eea;
    background: #f5f6ff;
    box-shadow: 0 4px 14px rgba(102,126,234,.15);
    transform: translateY(-1px);
  }
  .gl-google-svg { width: 18px; height: 18px; flex-shrink: 0; }

  .gl-footer {
    margin-top: 28px;
    text-align: center;
    font-size: 13px;
    color: #9095a0;
  }
  .gl-footer a { color: #667eea; text-decoration: none; font-weight: 700; }
  .gl-footer a:hover { opacity: .75; }

  /* ── RIGHT ── */
  .gl-right {
    background: linear-gradient(150deg, #7c6bf0 0%, #6050d4 45%, #9b59c0 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 64px 72px;
    position: relative;
    overflow: hidden;
  }

  .gl-deco {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    background: rgba(255,255,255,.07);
  }
  .gl-deco-1 { width: 500px; height: 500px; top: -120px; right: -100px; }
  .gl-deco-2 { width: 300px; height: 300px; bottom: -100px; left: -80px; }
  .gl-deco-3 { width: 120px; height: 120px; top: 46%; left: 6%; background: rgba(255,255,255,.05); }
  .gl-dot { position: absolute; border-radius: 50%; background: rgba(255,255,255,.22); pointer-events: none; }
  .gl-dot-1 { width: 13px; height: 13px; top: 28%; left: 12%; }
  .gl-dot-2 { width: 9px;  height: 9px;  top: 58%; right: 10%; }
  .gl-dot-3 { width: 17px; height: 17px; bottom: 20%; right: 6%; }

  .gl-right-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 620px;
  }

  .gl-rocket-wrap { display: flex; justify-content: center; margin-bottom: 40px; }
  .gl-rocket-circle {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: rgba(255,255,255,.14);
    border: 2px solid rgba(255,255,255,.22);
    backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 60px;
    animation: glFloat 4s ease-in-out infinite;
  }
  @keyframes glFloat {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-14px); }
  }

  .gl-headline { text-align: center; margin-bottom: 44px; }
  .gl-headline h2 {
    font-size: 56px;
    font-weight: 900;
    color: white;
    line-height: 1.15;
    letter-spacing: -1.5px;
    text-shadow: 0 2px 20px rgba(0,0,0,.15);
  }

  .gl-cards { display: flex; flex-direction: column; gap: 16px; }
  .gl-card {
    background: rgba(255,255,255,.13);
    border: 1px solid rgba(255,255,255,.22);
    border-radius: 16px;
    padding: 20px 26px;
    display: flex;
    align-items: center;
    gap: 20px;
    backdrop-filter: blur(12px);
    transition: background .25s, transform .25s;
    cursor: default;
  }
  .gl-card:hover { background: rgba(255,255,255,.21); transform: translateX(8px); }
  .gl-card-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: rgba(255,255,255,.16);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    flex-shrink: 0;
  }
  .gl-card-title { font-size: 16px; font-weight: 700; color: white; margin-bottom: 4px; letter-spacing: -.2px; }
  .gl-card-desc { font-size: 13px; color: rgba(255,255,255,.72); line-height: 1.4; }

  /* Responsive */
  @media (max-width: 900px) {
    .gl-wrap { grid-template-columns: 1fr; }
    .gl-right { display: none; }
    .gl-left { padding: 48px 32px; }
  }
</style>

<div class="gl-wrap">

  <!-- ── LEFT: FORM ── -->
  <div class="gl-left">
    <div class="gl-left-inner">

      <div class="gl-brand">
        <div class="gl-logo-placeholder">
          <img src="{{ asset('images/assets/ghrami.svg') }}"
               alt="Ghrami Logo"
               onerror="this.parentElement.classList.add('gl-logo-fallback')">
        </div>
        <div class="gl-brand-by">by OPGG</div>
      </div>

      <h1 class="gl-heading">✦ Bienvenue</h1>
      <p class="gl-sub">Connectez-vous à votre compte</p>

      {% if error %}
        <div class="gl-error">
          ⚠️ {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
      {% endif %}

      <form method="post">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div class="gl-field">
          <div class="gl-field-header">
            <label class="gl-label" for="username">Email</label>
          </div>
          <input class="gl-input" id="username" type="text" name="_username"
                 value="{{ last_username }}" autofocus
                 placeholder="votre@email.com" />
        </div>

        <div class="gl-field">
          <div class="gl-field-header">
            <label class="gl-label" for="password">Mot de passe</label>
            <a class="gl-forgot" href="{{ path('app_reset_password_request') }}">Mot de passe oublié ?</a>
          </div>
          <input class="gl-input" id="password" type="password" name="_password"
                 placeholder="••••••••" />
        </div>

        <button class="gl-btn-primary" type="submit">
          Se connecter <span class="arr">→</span>
        </button>

        <div class="gl-divider">
          <div class="gl-divider-line"></div>
          <span class="gl-divider-text">ou</span>
          <div class="gl-divider-line"></div>
        </div>

        <button class="gl-btn-google" type="button"
                onclick="window.location.href='{{ path('app_auth_google_start') }}'">
          <svg class="gl-google-svg" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Se connecter avec Google
        </button>
      </form>

      <div class="gl-footer">
        <p>Pas encore de compte ? <a href="{{ path('app_register') }}">S'inscrire</a></p>
      </div>

    </div>
  </div>

  <!-- ── RIGHT: HERO ── -->
  <div class="gl-right">
    <div class="gl-deco gl-deco-1"></div>
    <div class="gl-deco gl-deco-2"></div>
    <div class="gl-deco gl-deco-3"></div>
    <div class="gl-dot gl-dot-1"></div>
    <div class="gl-dot gl-dot-2"></div>
    <div class="gl-dot gl-dot-3"></div>

    <div class="gl-right-inner">
      <div class="gl-rocket-wrap">
        <div class="gl-rocket-circle">🚀</div>
      </div>

      <div class="gl-headline">
        <h2>Connectez.<br>Partagez.<br>Explorez.</h2>
      </div>

      <div class="gl-cards">
        <div class="gl-card">
          <div class="gl-card-icon">👥</div>
          <div>
            <div class="gl-card-title">Communauté Vibrante</div>
            <div class="gl-card-desc">Rejoignez 10,000+ tunisiens passionnés</div>
          </div>
        </div>
        <div class="gl-card">
          <div class="gl-card-icon">🎯</div>
          <div>
            <div class="gl-card-title">Hobbies &amp; Meetups</div>
            <div class="gl-card-desc">Organisez 500+ événements locaux</div>
          </div>
        </div>
        <div class="gl-card">
          <div class="gl-card-icon">📚</div>
          <div>
            <div class="gl-card-title">Cours &amp; Marketplace</div>
            <div class="gl-card-desc">Accédez à 100+ cours et partagez vos skills</div>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>
{% endblock %}
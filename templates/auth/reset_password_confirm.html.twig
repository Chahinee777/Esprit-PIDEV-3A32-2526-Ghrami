{% extends 'auth_layout.html.twig' %}

{% block title %}Nouveau mot de passe | Ghrami{% endblock %}

{% block auth_body %}
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .rc-wrap {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 35fr 65fr;
    font-family: 'Sora', sans-serif;
  }

  .rc-left {
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    padding: 64px 48px;
    background: #ffffff;
  }
  .rc-left-inner { width: 100%; max-width: 380px; }

  .rc-brand {
    display: flex; flex-direction: column;
    align-items: center; margin-bottom: 44px;
  }
  .rc-logo-placeholder {
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 12px;
  }
  .rc-logo-placeholder img { width: 150px; height: 150px; object-fit: contain; }
  .rc-logo-placeholder.rc-logo-fallback::after {
    content: "Logo"; font-size: 13px; font-weight: 600; color: #adb0bb; letter-spacing: .5px;
  }
  .rc-logo-placeholder.rc-logo-fallback img { display: none; }
  .rc-brand-name {
    font-size: 22px; font-weight: 800;
    background: linear-gradient(135deg, #667eea, #764ba2);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .rc-brand-by { font-size: 11px; color: #b0b3bb; font-weight: 500; margin-top: 2px; letter-spacing: .6px; }

  .rc-heading { font-size: 26px; font-weight: 800; color: #0d0f14; letter-spacing: -.5px; margin-bottom: 6px; }
  .rc-sub { font-size: 13px; color: #9095a0; margin-bottom: 32px; line-height: 1.6; }

  .rc-error {
    background: #fff1f0; border-left: 4px solid #e53e3e;
    border-radius: 8px; padding: 12px 16px;
    color: #c53030; font-size: 13px; font-weight: 500;
    margin-bottom: 20px;
  }
  .rc-error ul { margin: 6px 0 0 0; padding-left: 16px; }
  .rc-error li { margin-bottom: 2px; }

  .rc-expired {
    background: #fffbeb; border-left: 4px solid #f59e0b;
    border-radius: 12px; padding: 28px 24px; text-align: center;
  }
  .rc-expired-icon { font-size: 48px; margin-bottom: 14px; }
  .rc-expired h3 { font-size: 16px; font-weight: 700; color: #92400e; margin-bottom: 8px; }
  .rc-expired p { font-size: 13px; color: #b45309; line-height: 1.6; margin-bottom: 20px; }
  .rc-expired a {
    display: inline-flex; align-items: center; gap: 6px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white; padding: 12px 24px; border-radius: 10px;
    text-decoration: none; font-size: 14px; font-weight: 700;
    box-shadow: 0 4px 14px rgba(102,126,234,.35);
    transition: transform .2s, box-shadow .2s;
  }
  .rc-expired a:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(102,126,234,.45); }

  .rc-field { margin-bottom: 20px; }
  .rc-label { display: block; font-size: 13px; font-weight: 600; color: #0d0f14; margin-bottom: 7px; }
  .rc-hint { font-size: 12px; color: #adb0bb; margin-top: 6px; }

  .rc-input {
    width: 100%; padding: 13px 16px;
    border: 1.5px solid #eaecf2; border-radius: 10px;
    font-size: 14px; font-family: 'Sora', sans-serif; color: #0d0f14;
    background: #f9fafc; outline: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
  }
  .rc-input::placeholder { color: #c2c5cf; }
  .rc-input:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 4px rgba(102,126,234,.12);
    background: #fff;
  }

  .rc-btn-primary {
    width: 100%; padding: 14px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white; border: none; border-radius: 10px;
    font-size: 15px; font-weight: 700; font-family: 'Sora', sans-serif;
    cursor: pointer; letter-spacing: .3px;
    box-shadow: 0 6px 20px rgba(102,126,234,.38);
    transition: transform .2s, box-shadow .2s;
    display: flex; align-items: center; justify-content: center; gap: 6px;
    margin-top: 4px;
  }
  .rc-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(102,126,234,.5); }
  .rc-btn-primary:active { transform: translateY(1px); }

  .rc-back {
    display: inline-flex; align-items: center; gap: 6px;
    color: #667eea; text-decoration: none;
    font-size: 13px; font-weight: 600;
    margin-top: 24px;
    transition: opacity .2s;
  }
  .rc-back:hover { opacity: .75; }

  /* ── RIGHT ── */
  .rc-right {
    background: linear-gradient(150deg, #7c6bf0 0%, #6050d4 45%, #9b59c0 100%);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 64px 72px;
    position: relative; overflow: hidden;
  }
  .rc-deco {
    position: absolute; border-radius: 50%; pointer-events: none;
    background: rgba(255,255,255,.07);
  }
  .rc-deco-1 { width: 500px; height: 500px; top: -120px; right: -100px; }
  .rc-deco-2 { width: 300px; height: 300px; bottom: -100px; left: -80px; }
  .rc-deco-3 { width: 120px; height: 120px; top: 46%; left: 6%; background: rgba(255,255,255,.05); }
  .rc-dot { position: absolute; border-radius: 50%; background: rgba(255,255,255,.22); pointer-events: none; }
  .rc-dot-1 { width: 13px; height: 13px; top: 28%; left: 12%; }
  .rc-dot-2 { width: 9px;  height: 9px;  top: 58%; right: 10%; }
  .rc-dot-3 { width: 17px; height: 17px; bottom: 20%; right: 6%; }

  .rc-right-inner { position: relative; z-index: 2; width: 100%; max-width: 580px; text-align: center; }

  .rc-icon-wrap {
    width: 140px; height: 140px; border-radius: 50%; margin: 0 auto 40px;
    background: rgba(255,255,255,.14);
    border: 2px solid rgba(255,255,255,.22);
    backdrop-filter: blur(10px);
    display: flex; align-items: center; justify-content: center;
    font-size: 60px;
    animation: rcFloat 4s ease-in-out infinite;
  }
  @keyframes rcFloat {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-14px); }
  }

  .rc-right-inner h2 {
    font-size: 46px; font-weight: 900; color: white;
    line-height: 1.2; letter-spacing: -1.5px;
    text-shadow: 0 2px 20px rgba(0,0,0,.15);
    margin-bottom: 20px;
  }
  .rc-right-inner p {
    font-size: 15px; color: rgba(255,255,255,.78);
    line-height: 1.7; max-width: 440px; margin: 0 auto 44px;
  }

  .rc-tips { display: flex; flex-direction: column; gap: 14px; text-align: left; }
  .rc-tip {
    background: rgba(255,255,255,.13);
    border: 1px solid rgba(255,255,255,.22);
    border-radius: 14px; padding: 16px 22px;
    display: flex; align-items: center; gap: 16px;
    backdrop-filter: blur(12px);
    transition: background .25s, transform .25s;
  }
  .rc-tip:hover { background: rgba(255,255,255,.21); transform: translateX(8px); }
  .rc-tip-icon {
    width: 44px; height: 44px; border-radius: 12px;
    background: rgba(255,255,255,.16);
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; flex-shrink: 0;
  }
  .rc-tip-title { font-size: 14px; font-weight: 700; color: white; margin-bottom: 2px; }
  .rc-tip-desc { font-size: 12px; color: rgba(255,255,255,.7); }

  @media (max-width: 900px) {
    .rc-wrap { grid-template-columns: 1fr; }
    .rc-right { display: none; }
    .rc-left { padding: 48px 28px; }
  }
</style>

<div class="rc-wrap">

  <!-- ── LEFT: FORM ── -->
  <div class="rc-left">
    <div class="rc-left-inner">

      <div class="rc-brand">
        <div class="rc-logo-placeholder">
          <img src="{{ asset('images/assets/ghrami.svg') }}" alt="Ghrami Logo"
               onerror="this.parentElement.classList.add('rc-logo-fallback')">
        </div>
      </div>

      {% if isTokenValid %}

        <h1 class="rc-heading">🔐 Nouveau mot de passe</h1>
        <p class="rc-sub">Choisissez un mot de passe fort pour sécuriser votre compte.</p>

        {% if errors is not empty %}
          <div class="rc-error">
            ⚠️ Veuillez corriger les erreurs :
            <ul>
              {% for item in errors %}
                <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        <form method="post">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset_password_confirm') }}">
          <input type="hidden" name="token" value="{{ token }}">

          <div class="rc-field">
            <label class="rc-label" for="password">Nouveau mot de passe</label>
            <input class="rc-input" id="password" type="password" name="password"
                   placeholder="Créez un mot de passe fort" autofocus />
          </div>

          <div class="rc-field">
            <label class="rc-label" for="confirm_password">Confirmer le mot de passe</label>
            <input class="rc-input" id="confirm_password" type="password" name="confirm_password"
                   placeholder="Répétez votre mot de passe" />
            <p class="rc-hint">Minimum 6 caractères, avec des lettres et des chiffres</p>
          </div>

          <button class="rc-btn-primary" type="submit">
            Réinitialiser le mot de passe <span>→</span>
          </button>
        </form>

      {% else %}

        <div class="rc-expired">
          <div class="rc-expired-icon">⏰</div>
          <h3>Lien expiré</h3>
          <p>Ce lien de réinitialisation a expiré pour des raisons de sécurité. Veuillez en demander un nouveau.</p>
          <a href="{{ path('app_reset_password_request') }}">Demander un nouveau lien →</a>
        </div>

      {% endif %}

      <a class="rc-back" href="{{ path('app_login') }}">← Retour à la connexion</a>

    </div>
  </div>

  <!-- ── RIGHT: HERO ── -->
  <div class="rc-right">
    <div class="rc-deco rc-deco-1"></div>
    <div class="rc-deco rc-deco-2"></div>
    <div class="rc-deco rc-deco-3"></div>
    <div class="rc-dot rc-dot-1"></div>
    <div class="rc-dot rc-dot-2"></div>
    <div class="rc-dot rc-dot-3"></div>

    <div class="rc-right-inner">
      <div class="rc-icon-wrap">🛡️</div>
      <h2>Sécurisez votre compte</h2>
      <p>Un bon mot de passe est la première ligne de défense de votre compte. Suivez ces conseils.</p>
      <div class="rc-tips">
        <div class="rc-tip">
          <div class="rc-tip-icon">🔤</div>
          <div>
            <div class="rc-tip-title">Mélangez les caractères</div>
            <div class="rc-tip-desc">Combinez majuscules, minuscules, chiffres et symboles</div>
          </div>
        </div>
        <div class="rc-tip">
          <div class="rc-tip-icon">📏</div>
          <div>
            <div class="rc-tip-title">Minimum 8 caractères</div>
            <div class="rc-tip-desc">Plus votre mot de passe est long, plus il est sécurisé</div>
          </div>
        </div>
        <div class="rc-tip">
          <div class="rc-tip-icon">🚫</div>
          <div>
            <div class="rc-tip-title">Évitez les infos personnelles</div>
            <div class="rc-tip-desc">N'utilisez pas votre nom, date de naissance ou email</div>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>
{% endblock %}
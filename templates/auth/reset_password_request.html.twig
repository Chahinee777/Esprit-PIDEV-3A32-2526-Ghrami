{% extends 'auth_layout.html.twig' %}

{% block title %}Reset Password | Ghrami{% endblock %}

{% block auth_body %}
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .rp-wrap {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 35fr 65fr;
    font-family: 'Sora', sans-serif;
  }

  .rp-left {
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    padding: 64px 48px;
    background: #ffffff;
  }
  .rp-left-inner { width: 100%; max-width: 380px; }

  .rp-brand {
    display: flex; flex-direction: column;
    align-items: center; margin-bottom: 44px;
  }
  .rp-logo-placeholder {
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 12px;
  }
  .rp-logo-placeholder img { width: 150px; height: 150px; object-fit: contain; }
  .rp-logo-placeholder.rp-logo-fallback::after {
    content: "Logo"; font-size: 13px; font-weight: 600; color: #adb0bb; letter-spacing: .5px;
  }
  .rp-logo-placeholder.rp-logo-fallback img { display: none; }
  .rp-brand-name {
    font-size: 22px; font-weight: 800;
    background: linear-gradient(135deg, #667eea, #764ba2);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .rp-brand-by { font-size: 11px; color: #b0b3bb; font-weight: 500; margin-top: 2px; letter-spacing: .6px; }

  .rp-heading { font-size: 26px; font-weight: 800; color: #0d0f14; letter-spacing: -.5px; margin-bottom: 6px; }
  .rp-sub { font-size: 13px; color: #9095a0; margin-bottom: 32px; line-height: 1.6; }

  .rp-field { margin-bottom: 20px; }
  .rp-label { display: block; font-size: 13px; font-weight: 600; color: #0d0f14; margin-bottom: 7px; }
  .rp-hint { font-size: 12px; color: #adb0bb; margin-top: 6px; }

  .rp-input {
    width: 100%; padding: 13px 16px;
    border: 1.5px solid #eaecf2; border-radius: 10px;
    font-size: 14px; font-family: 'Sora', sans-serif; color: #0d0f14;
    background: #f9fafc; outline: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
  }
  .rp-input::placeholder { color: #c2c5cf; }
  .rp-input:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 4px rgba(102,126,234,.12);
    background: #fff;
  }

  .rp-btn-primary {
    width: 100%; padding: 14px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white; border: none; border-radius: 10px;
    font-size: 15px; font-weight: 700; font-family: 'Sora', sans-serif;
    cursor: pointer; letter-spacing: .3px;
    box-shadow: 0 6px 20px rgba(102,126,234,.38);
    transition: transform .2s, box-shadow .2s;
    display: flex; align-items: center; justify-content: center; gap: 6px;
    margin-top: 4px;
  }
  .rp-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(102,126,234,.5); }
  .rp-btn-primary:active { transform: translateY(1px); }

  .rp-back {
    display: inline-flex; align-items: center; gap: 6px;
    color: #667eea; text-decoration: none;
    font-size: 13px; font-weight: 600;
    margin-top: 24px;
    transition: opacity .2s;
  }
  .rp-back:hover { opacity: .75; }

  /* ── RIGHT ── */
  .rp-right {
    background: linear-gradient(150deg, #7c6bf0 0%, #6050d4 45%, #9b59c0 100%);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 64px 72px;
    position: relative; overflow: hidden;
  }
  .rp-deco {
    position: absolute; border-radius: 50%; pointer-events: none;
    background: rgba(255,255,255,.07);
  }
  .rp-deco-1 { width: 500px; height: 500px; top: -120px; right: -100px; }
  .rp-deco-2 { width: 300px; height: 300px; bottom: -100px; left: -80px; }
  .rp-deco-3 { width: 120px; height: 120px; top: 46%; left: 6%; background: rgba(255,255,255,.05); }
  .rp-dot { position: absolute; border-radius: 50%; background: rgba(255,255,255,.22); pointer-events: none; }
  .rp-dot-1 { width: 13px; height: 13px; top: 28%; left: 12%; }
  .rp-dot-2 { width: 9px;  height: 9px;  top: 58%; right: 10%; }
  .rp-dot-3 { width: 17px; height: 17px; bottom: 20%; right: 6%; }

  .rp-right-inner { position: relative; z-index: 2; width: 100%; max-width: 580px; text-align: center; }

  .rp-icon-wrap {
    width: 140px; height: 140px; border-radius: 50%; margin: 0 auto 40px;
    background: rgba(255,255,255,.14);
    border: 2px solid rgba(255,255,255,.22);
    backdrop-filter: blur(10px);
    display: flex; align-items: center; justify-content: center;
    font-size: 60px;
    animation: rpFloat 4s ease-in-out infinite;
  }
  @keyframes rpFloat {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-14px); }
  }

  .rp-right-inner h2 {
    font-size: 48px; font-weight: 900; color: white;
    line-height: 1.2; letter-spacing: -1.5px;
    text-shadow: 0 2px 20px rgba(0,0,0,.15);
    margin-bottom: 20px;
  }
  .rp-right-inner p {
    font-size: 16px; color: rgba(255,255,255,.78);
    line-height: 1.7; max-width: 440px; margin: 0 auto 44px;
  }

  .rp-steps { display: flex; flex-direction: column; gap: 16px; text-align: left; }
  .rp-step {
    background: rgba(255,255,255,.13);
    border: 1px solid rgba(255,255,255,.22);
    border-radius: 16px; padding: 18px 24px;
    display: flex; align-items: center; gap: 18px;
    backdrop-filter: blur(12px);
    transition: background .25s, transform .25s;
  }
  .rp-step:hover { background: rgba(255,255,255,.21); transform: translateX(8px); }
  .rp-step-num {
    width: 40px; height: 40px; border-radius: 50%;
    background: rgba(255,255,255,.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 15px; font-weight: 800; color: white; flex-shrink: 0;
  }
  .rp-step-title { font-size: 14px; font-weight: 700; color: white; margin-bottom: 2px; }
  .rp-step-desc { font-size: 12px; color: rgba(255,255,255,.7); }

  @media (max-width: 900px) {
    .rp-wrap { grid-template-columns: 1fr; }
    .rp-right { display: none; }
    .rp-left { padding: 48px 28px; }
  }
</style>

<div class="rp-wrap">

  <!-- ── LEFT: FORM ── -->
  <div class="rp-left">
    <div class="rp-left-inner">

      <div class="rp-brand">
        <div class="rp-logo-placeholder">
          <img src="{{ asset('images/assets/ghrami.svg') }}" alt="Ghrami Logo"
               onerror="this.parentElement.classList.add('rp-logo-fallback')">
        </div>
      </div>

      <h1 class="rp-heading">🔑 Mot de passe oublié ?</h1>
      <p class="rp-sub">Pas de panique. Entrez votre email et nous vous enverrons un lien pour réinitialiser votre mot de passe.</p>

      <form method="post">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset_password_request') }}">

        <div class="rp-field">
          <label class="rp-label" for="email">Adresse email</label>
          <input class="rp-input" id="email" type="text" name="email"
                 placeholder="votre@email.com" autofocus />
          <p class="rp-hint">Nous enverrons un lien de réinitialisation à cette adresse</p>
        </div>

        <button class="rp-btn-primary" type="submit">
          Envoyer le lien <span>→</span>
        </button>
      </form>

      <a class="rp-back" href="{{ path('app_login') }}">← Retour à la connexion</a>

    </div>
  </div>

  <!-- ── RIGHT: HERO ── -->
  <div class="rp-right">
    <div class="rp-deco rp-deco-1"></div>
    <div class="rp-deco rp-deco-2"></div>
    <div class="rp-deco rp-deco-3"></div>
    <div class="rp-dot rp-dot-1"></div>
    <div class="rp-dot rp-dot-2"></div>
    <div class="rp-dot rp-dot-3"></div>

    <div class="rp-right-inner">
      <div class="rp-icon-wrap">🔐</div>
      <h2>Récupérez votre accès</h2>
      <p>Suivez ces étapes simples pour retrouver l'accès à votre compte en toute sécurité.</p>
      <div class="rp-steps">
        <div class="rp-step">
          <div class="rp-step-num">1</div>
          <div>
            <div class="rp-step-title">Entrez votre email</div>
            <div class="rp-step-desc">L'adresse liée à votre compte Ghrami</div>
          </div>
        </div>
        <div class="rp-step">
          <div class="rp-step-num">2</div>
          <div>
            <div class="rp-step-title">Consultez votre boîte mail</div>
            <div class="rp-step-desc">Un lien sécurisé vous sera envoyé dans quelques secondes</div>
          </div>
        </div>
        <div class="rp-step">
          <div class="rp-step-num">3</div>
          <div>
            <div class="rp-step-title">Créez un nouveau mot de passe</div>
            <div class="rp-step-desc">Choisissez un mot de passe fort et sécurisé</div>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>
{% endblock %}
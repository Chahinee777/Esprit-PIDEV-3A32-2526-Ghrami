                        <div id="editCommentImagePreview" style="display: flex; align-items: center; min-height: 40px;"></div>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 8px;">
                        <span id="editCommentCharCounter" style="font-size: 12px; color: #65676b;">0 / 500</span>
                    </div>
                    <div id="editCommentError" style="color: #e74c3c; font-size: 13px; margin-top: 8px; display: none;"></div>

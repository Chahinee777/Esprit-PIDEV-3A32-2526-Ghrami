    function updateEditCommentCounter() {
        const modal = document.getElementById('editCommentModal');
        if (!modal) return;
        const textarea = modal.querySelector('textarea[name="content"]');
        const fileInput = modal.querySelector('input[name="image_file"]');
        const removeImage = modal.querySelector('input[name="remove_image"]');
        const hasExistingImage = modal.querySelector('#editCommentImagePreview img') !== null;
        const counter = modal.querySelector('#editCommentCharCounter');
        const MAX_CHARS = 500;
        const len = textarea.value.length;
        const hasImage = !!fileInput.files?.length || (hasExistingImage && !removeImage.checked);
        
        counter.textContent = len + ' / ' + MAX_CHARS;
        
        if (len > MAX_CHARS) {
            counter.style.color = '#e74c3c';
            counter.style.fontWeight = 'bold';
            textarea.style.borderColor = '#e74c3c';
        } else if (len === 0 && !hasImage) {
            counter.style.color = '#e74c3c';
            textarea.style.borderColor = '#e74c3c';
        } else {
            counter.style.color = '#65676b';
            counter.style.fontWeight = 'normal';
            textarea.style.borderColor = '#e4e6eb';
        }
    }

    function submitEditComment() {
        const modal = document.getElementById('editCommentModal');
        const textarea = modal.querySelector('textarea[name="content"]');
        const fileInput = modal.querySelector('input[name="image_file"]');
        const removeImage = modal.querySelector('input[name="remove_image"]');
        const hasExistingImage = modal.querySelector('#editCommentImagePreview img') !== null;
        const errorDiv = modal.querySelector('#editCommentError');
        const content = textarea.value.trim();
        const MAX_CHARS = 500;
        
        // Validation
        if (!content && !fileInput.files?.length && !(hasExistingImage && !removeImage.checked)) {
            errorDiv.textContent = '❌ Ajoutez du texte ou une image.';
            errorDiv.style.display = 'block';
            textarea.style.borderColor = '#e74c3c';
            return;
        }
        
        if (content.length > MAX_CHARS) {
            errorDiv.textContent = '❌ Le commentaire dépasse ' + MAX_CHARS + ' caractères.';
            errorDiv.style.display = 'block';
            textarea.style.borderColor = '#e74c3c';
            return;
        }
        
        // Submit
        document.getElementById('social-edit-comment-id').value = modal.dataset.commentId;
        document.getElementById('social-edit-comment-form').submit();
    }

    function closeEditCommentModal() {
        const modal = document.getElementById('editCommentModal');
        if (modal) {
            modal.style.display = 'none';
            modal.querySelector('#editCommentError').style.display = 'none';
        }
    }

    (function () {
        const content = document.getElementById('social-post-content');
        const imageUrlInput = document.getElementById('social-post-image-url');
        const completeBtn = document.getElementById('social-ai-complete-btn');
        const photoBtn = document.getElementById('social-photo-btn');
        const publishBtn = document.getElementById('social-publish-btn');
        const postInput = document.getElementById('social-post-input');
        const imageFileInput = document.getElementById('social-image-file');
        const postForm = document.getElementById('social-post-form');
        const MAX_POST_CHARS = 5000;
        const MAX_COMMENT_CHARS = 500;

        // Update post input counter
        postInput?.addEventListener('input', () => {
            const len = postInput.value.trim().length;
            const counter = document.getElementById('postCharCount');
            const status = document.getElementById('postInputStatus');
            
            counter.textContent = len + ' / ' + MAX_POST_CHARS;
            
            if (len === 0) {
                counter.style.color = '#e4e6eb';
                status.textContent = '';
            } else if (len > MAX_POST_CHARS) {
                counter.style.color = '#e74c3c';
                counter.style.fontWeight = 'bold';
                status.textContent = '❌ Trop long';
                status.style.color = '#e74c3c';
            } else {
                counter.style.color = '#65676b';
                counter.style.fontWeight = 'normal';
                status.textContent = '✅ Prêt';
                status.style.color = '#27ae60';
            }
        });

        // Photo button - trigger file picker
        photoBtn?.addEventListener('click', (e) => {
            e.preventDefault();
            imageFileInput?.click();
        });

        // Handle file selection from file picker
        imageFileInput?.addEventListener('change', async () => {
            if (imageFileInput.files?.length > 0) {
                const file = imageFileInput.files[0];
                const fileName = file.name;
                const size = (file.size / 1024 / 1024).toFixed(2);
                const status = document.getElementById('postInputStatus');
                
                status.textContent = '🤖 Analyse de l\'image...';
                status.style.color = '#667eea';

                try {
                    // Send image to AI captioning endpoint
                    const formData = new FormData();
                    formData.append('image', file);
                    formData.append('_csrf_token', '{{ csrf_token('social_ai_caption') }}');

                    const response = await fetch('{{ path('app_social_ai_caption') }}', {
                        method: 'POST',
                        body: formData
                    });

                    const data = await response.json();

                    if (data.ok && data.caption) {
                        // Insert caption into textarea
                        postInput.value = data.caption;
                        postInput.dispatchEvent(new Event('input'));
                        
                        status.textContent = '✨ Caption générée | 📷 Image: ' + fileName + ' (' + size + 'MB)';
                        status.style.color = '#27ae60';
                    } else {
                        status.textContent = '⚠️ Caption échouée: ' + (data.error || 'Erreur inconnue');
                        status.style.color = '#f39c12';
                    }
                } catch (e) {
                    console.error('Image analysis failed:', e);
                    status.textContent = '⚠️ Erreur réseau lors de l\'analyse';
                    status.style.color = '#f39c12';
                }
            }
        });

        // Publish button - submit the form with content and optional image
        publishBtn?.addEventListener('click', (e) => {
            e.preventDefault();
            
            const postContent = postInput?.value?.trim();
            const postLength = postContent?.length || 0;
            const status = document.getElementById('postInputStatus');
            const errorMsg = document.createElement('div');
            
            // Validation
            if (!postContent) {
                status.textContent = '❌ Écrivez quelque chose avant de publier';
                status.style.color = '#e74c3c';
                postInput?.focus();
                return;
            }
            
            if (postLength > MAX_POST_CHARS) {
                status.textContent = '❌ Le post dépasse ' + MAX_POST_CHARS + ' caractères';
                status.style.color = '#e74c3c';
                return;
            }

            // Set the hidden content textarea with the post input value
            if (content) {
                content.value = postContent;
            }

            // Disable button and show loading state
            publishBtn.disabled = true;
            publishBtn.textContent = '⏳ Publication...';

            // Submit the form
            postForm?.submit();
        });

        completeBtn?.addEventListener('click', async () => {
            const current = postInput?.value?.trim() || content?.value?.trim();
            if (!current) {
                alert('Écrivez quelque chose d\'abord');
                return;
            }

            completeBtn.disabled = true;
            completeBtn.textContent = '⏳ Complétion par IA...';
            try {
                const response = await fetch('{{ path('app_social_ai_complete') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: new URLSearchParams({
                        _csrf_token: '{{ csrf_token('social_ai_complete') }}',
                        content: current
                    })
                });
                const data = await response.json();
                if (data.ok && data.fullText) {
                    postInput.value = data.fullText;
                    if (content) content.value = data.fullText;
                    postInput.dispatchEvent(new Event('input'));
                    const status = document.getElementById('postInputStatus');
                    status.textContent = '✨ Complété par IA!';
                    status.style.color = '#667eea';
                } else {
                    alert('❌ Erreur: ' + (data.error || 'Impossible de compléter'));
                }
            } catch (e) {
                console.error('AI completion failed:', e);
                alert('❌ Erreur réseau');
            } finally {
                completeBtn.disabled = false;
                completeBtn.textContent = '🤖 Compléter avec IA';
            }
        });

        // Real-time comment validation
        document.addEventListener('input', (e) => {
            if (e.target.classList.contains('comment-textarea')) {
                const form = e.target.closest('form');
                if (!form) return;
                
                const charCount = form.querySelector('.comment-char-count');
                const status = form.querySelector('.comment-status');
                const len = e.target.value.trim().length;
                const fileInput = form.querySelector('input[name="image_file"]');
                const hasImage = !!fileInput?.files?.length;
                
                charCount.textContent = len + ' / ' + MAX_COMMENT_CHARS;
                
                if (len === 0 && !hasImage) {
                    charCount.style.color = '#e4e6eb';
                    charCount.style.fontWeight = 'normal';
                    status.textContent = '';
                } else if (len > MAX_COMMENT_CHARS) {
                    charCount.style.color = '#e74c3c';
                    charCount.style.fontWeight = 'bold';
                    status.textContent = '❌ Trop long';
                    status.style.color = '#e74c3c';
                } else {
                    charCount.style.color = '#65676b';
                    charCount.style.fontWeight = 'normal';
                    status.textContent = '✅ Prêt';
                    status.style.color = '#27ae60';
                }
            }
        });

        document.addEventListener('change', (e) => {
            if (e.target.classList.contains('comment-image-input')) {
                const form = e.target.closest('form');
                if (!form) return;

                const textarea = form.querySelector('textarea[name="content"]');
                const charCount = form.querySelector('.comment-char-count');
                const status = form.querySelector('.comment-status');
                const len = textarea?.value?.trim().length || 0;
                const hasImage = !!e.target.files?.length;

                charCount.textContent = len + ' / ' + MAX_COMMENT_CHARS;

                if (len === 0 && !hasImage) {
                    charCount.style.color = '#e4e6eb';
                    charCount.style.fontWeight = 'normal';
                    status.textContent = '';
                } else if (len > MAX_COMMENT_CHARS) {
                    charCount.style.color = '#e74c3c';
                    charCount.style.fontWeight = 'bold';
                    status.textContent = '❌ Trop long';
                    status.style.color = '#e74c3c';
                } else {
                    charCount.style.color = '#65676b';
                    charCount.style.fontWeight = 'normal';
                    status.textContent = hasImage ? '🖼️ Image prête' : '✅ Prêt';
                    status.style.color = '#27ae60';
                }
            }
        });

        // Comment form validation on submit
        document.addEventListener('submit', (e) => {
            if (e.target.classList && e.target.classList.contains('social-comment-form')) {
                const textarea = e.target.querySelector('textarea[name="content"]');
                const content = textarea?.value?.trim();
                const imageInput = e.target.querySelector('input[name="image_file"]');
                const status = e.target.querySelector('.comment-status');
                const charCount = e.target.querySelector('.comment-char-count');
                const hasImage = !!imageInput?.files?.length;
                
                if (!content && !hasImage) {
                    e.preventDefault();
                    if (textarea) {
                        textarea.style.borderColor = '#e74c3c';
                        textarea.style.backgroundColor = '#ffe6e6';
                        textarea.focus();
                    }
                    if (status) {
                        status.textContent = '❌ Écrivez un commentaire ou ajoutez une image';
                        status.style.color = '#e74c3c';
                    }
                    if (charCount) {
                        charCount.style.color = '#e74c3c';
                        charCount.style.fontWeight = 'bold';
                    }
                    return false;
                }
                
                if ((content?.length || 0) > MAX_COMMENT_CHARS) {
                    e.preventDefault();
                    if (status) {
                        status.textContent = '❌ Le commentaire est trop long';
                        status.style.color = '#e74c3c';
                    }
                    alert('❌ Le commentaire dépasse ' + MAX_COMMENT_CHARS + ' caractères.');
                    return false;
                }
            }
        });
    })();
</script>

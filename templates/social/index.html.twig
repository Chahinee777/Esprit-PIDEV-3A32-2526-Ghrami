        // Submit
        document.getElementById('social-edit-post-id').value = modal.dataset.postId;
        document.getElementById('social-edit-post-content').value = content;
        document.getElementById('social-edit-post-form').submit();
    }

    function closeEditPostModal() {
        const modal = document.getElementById('editPostModal');
        if (modal) {
            modal.style.display = 'none';
            modal.querySelector('#editPostError').style.display = 'none';
        }
    }


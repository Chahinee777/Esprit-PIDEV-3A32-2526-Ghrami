    function updateEditPostCounter() {
        const modal = document.getElementById('editPostModal');
        if (!modal) return;
        const textarea = modal.querySelector('textarea[name="content"]');
        const counter = modal.querySelector('#editPostCharCounter');
        const MAX_CHARS = 5000;
        const len = textarea.value.length;
        
        counter.textContent = len + ' / ' + MAX_CHARS;
        
        if (len > MAX_CHARS) {
            counter.style.color = '#e74c3c';
            counter.style.fontWeight = 'bold';
            textarea.style.borderColor = '#e74c3c';
        } else if (len === 0) {
            counter.style.color = '#e74c3c';
            textarea.style.borderColor = '#e74c3c';
        } else {
            counter.style.color = '#65676b';
            counter.style.fontWeight = 'normal';
            textarea.style.borderColor = '#e4e6eb';
        }
    }

    function submitEditPost() {
        const modal = document.getElementById('editPostModal');
        const textarea = modal.querySelector('textarea[name="content"]');
        const errorDiv = modal.querySelector('#editPostError');
        const content = textarea.value.trim();
        const MAX_CHARS = 5000;
        
        // Validation
        if (!content) {
            errorDiv.textContent = '❌ Le post ne peut pas être vide.';
            errorDiv.style.display = 'block';
            textarea.style.borderColor = '#e74c3c';

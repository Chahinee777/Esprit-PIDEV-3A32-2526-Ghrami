        <!-- Footer -->
        <div style="padding: 14px 20px; border-top: 1px solid #e4e6eb; background: white; border-radius: 0 0 16px 16px; display: flex; gap: 12px;">
            <button onclick="closeShareDialog()" style="flex: 1; padding: 12px 24px; background: #f0f2f5; color: #1c1e21; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 14px;">Annuler</button>
            <button onclick="shareToFacebook()" style="flex: 1; padding: 12px 24px; background: #1877F2; color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 14px; transition: background 0.2s;" onmouseover="this.style.background='#145db2'" onmouseout="this.style.background='#1877F2'">Ouvrir Facebook</button>
        </div>
    </div>
</div>

<script>
    // Story Modal Functions
    function openCreateStoryModal() {
        document.getElementById('createStoryModal').style.display = 'flex';
        setupDropZone();
    }
    
    function closeCreateStoryModal() {
        document.getElementById('createStoryModal').style.display = 'none';
        document.getElementById('imageInput').value = '';
        document.getElementById('imagePreview').innerHTML = '';
    }
    
    function openStoryModal(element) {
        const storyId = element.getAttribute('data-story-id');
        const userId = element.getAttribute('data-user-id');
        const username = element.getAttribute('data-username');
        const fullName = element.getAttribute('data-full-name');
        const imageUrl = element.getAttribute('data-image-url');
        const profilePicture = element.getAttribute('data-profile-picture');
        const caption = element.getAttribute('data-caption');
        const createdAt = element.getAttribute('data-created-at');
        
        // Set story content
        document.getElementById('storyImage').src = imageUrl;
        document.getElementById('storyAuthorName').textContent = fullName;
        document.getElementById('storyCreatedAt').textContent = new Date(createdAt).toLocaleDateString() + ' à ' + new Date(createdAt).toLocaleTimeString();
        
        // Set avatar
        const avatarContainer = document.getElementById('storyAvatarContainer');
        if (profilePicture && !profilePicture.includes('null')) {
            avatarContainer.style.backgroundImage = 'url(' + profilePicture + ')';
            avatarContainer.style.backgroundSize = 'cover';
            avatarContainer.style.backgroundPosition = 'center';
            avatarContainer.textContent = '';
        } else {
            avatarContainer.style.backgroundImage = 'none';
            avatarContainer.textContent = fullName.charAt(0).toUpperCase();
        }
        
        // Set caption
        if (caption && caption.trim()) {
            document.getElementById('storyCaption').textContent = caption;
            document.getElementById('storyCaptionContainer').style.display = 'block';
        } else {
            document.getElementById('storyCaptionContainer').style.display = 'none';
        }
        
        document.getElementById('viewStoryModal').style.display = 'flex';
    }
    
    function closeStoryModal() {
        document.getElementById('viewStoryModal').style.display = 'none';
    }
    
    // Share Dialog Functions
    function openShareDialog(post) {
        const modal = document.getElementById('shareModal');
        const textarea = document.getElementById('shareTextarea');
        const imageContainer = document.getElementById('shareImageContainer');
        const imagePreview = document.getElementById('shareImagePreview');
        
        // Set text content
        textarea.value = post.content;
        
        // Update character counter
        updateShareCounter();
        
        // Show image if exists
        if (post.image_url && post.image_url.trim()) {
            let imageUrl = post.image_url;
            if (!imageUrl.startsWith('http')) {
                imageUrl = '{{ asset('images/posts/') }}' + imageUrl;
            }
            imagePreview.src = imageUrl;
            imageContainer.style.display = 'block';
        } else {
            imageContainer.style.display = 'none';
        }
        
        // Store post data in global variable for sharing
        window.currentSharePost = post;
        
        // Open modal
        modal.style.display = 'flex';
        textarea.focus();
    }
    
    function closeShareDialog() {
        document.getElementById('shareModal').style.display = 'none';
    }
    
    function updateShareCounter() {
        const textarea = document.getElementById('shareTextarea');
        const counter = document.getElementById('shareCharCounter');
        const MAX_CHARS = 500;
        const len = textarea.value.length;
        
        counter.textContent = len + ' / ' + MAX_CHARS;
        
        if (len > MAX_CHARS) {
            counter.style.color = '#e74c3c';
            counter.style.fontWeight = 'bold';
            textarea.style.borderColor = '#e74c3c';
        } else {
            counter.style.color = '#65676b';
            counter.style.fontWeight = 'normal';
            textarea.style.borderColor = '#dde0e8';
        }
    }
    
    function shareToFacebook() {
        const textarea = document.getElementById('shareTextarea');
        const text = textarea.value.trim();
        const MAX_CHARS = 500;
        
        if (text.length > MAX_CHARS) {
            alert('Le texte dépasse ' + MAX_CHARS + ' caractères.\nVeuillez le raccourcir avant de partager.');
            return;
        }
        
        // Copy to clipboard
        navigator.clipboard.writeText(text).catch(err => {
            console.warn('Clipboard copy failed:', err);
        });
        
        // Open Facebook sharer
        try {
            const encoded = encodeURIComponent(text);
            const facebookUrl = 'https://www.facebook.com/sharer/sharer.php?quote=' + encoded;
            window.open(facebookUrl, '_blank');
            
            closeShareDialog();
            
            // Show notification
            setTimeout(() => {
                alert('✅ Texte copié ! Facebook ouvert.\nSi le texte n\'est pas pré-rempli, appuyez sur Ctrl+V pour coller.');
            }, 400);
        } catch (err) {
            console.error('Error opening Facebook:', err);
            alert('Erreur: Impossible d\'ouvrir Facebook');
        }
    }
    
    // Update counter while typing
    document.getElementById('shareTextarea')?.addEventListener('input', updateShareCounter);
    
    // Close modal when clicking outside
    document.getElementById('shareModal')?.addEventListener('click', (e) => {
        if (e.target.id === 'shareModal') closeShareDialog();
    });
    
    function setupDropZone() {
        const dropZone = document.getElementById('dropZone');
        const imageInput = document.getElementById('imageInput');
        const imagePreview = document.getElementById('imagePreview');
        const storyForm = document.getElementById('storyCreateForm');
        
        if (!dropZone || !imageInput) return;
        
        // Handle form submission
        storyForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(storyForm);
            const submitBtn = storyForm.querySelector('button[type="submit"]');
            const originalText = submitBtn.textContent;
            submitBtn.disabled = true;
            submitBtn.textContent = '⏳ Envoi...';
            
            try {
                const response = await fetch('{{ path('app_story_create') }}', {
                    method: 'POST',
                    body: formData
                });
                
                const data = await response.json();
                if (data.ok) {
                    alert('✨ Histoire publiée! Elle expirera dans 24 heures.');
                    closeCreateStoryModal();
                    location.reload();
                } else {
                    alert('Erreur: ' + (data.error || 'Une erreur est survenue'));
                }
            } catch (e) {
                alert('Erreur réseau: ' + e.message);
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = originalText;
            }
        });
        
        // Click to upload
        dropZone.addEventListener('click', () => imageInput.click());
        
        // Drag and drop
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.style.background = '#e8ecff';
            dropZone.style.borderColor = '#764ba2';
        });
        
        dropZone.addEventListener('dragleave', () => {
            dropZone.style.background = '#f8f9ff';
            dropZone.style.borderColor = '#667eea';
        });
        
        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.style.background = '#f8f9ff';
            dropZone.style.borderColor = '#667eea';
            
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                imageInput.files = files;
                imageInput.dispatchEvent(new Event('change', { bubbles: true }));
            }
        });
        
        // File preview
        imageInput.addEventListener('change', function(e) {
            const file = this.files[0];
            if (file) {
                const validTypes = ['image/jpeg', 'image/png', 'image/webp'];
                const maxSize = 5242880;
                
                if (!validTypes.includes(file.type)) {
                    alert('Format invalide. Utilisez JPG, PNG ou WEBP.');
                    this.value = '';
                    imagePreview.innerHTML = '';
                    return;
                }
                
                if (file.size > maxSize) {
                    alert('Fichier trop volumineux. Maximum 5MB.');
                    this.value = '';
                    imagePreview.innerHTML = '';
                    return;
                }
                
                const reader = new FileReader();
                reader.onload = function(event) {
                    imagePreview.innerHTML = '<img src="' + event.target.result + '" style="width: 100%; border-radius: 8px; max-height: 300px; object-fit: cover;">';
                };
                reader.readAsDataURL(file);
            }
        });
    }
    
    // Close modals when clicking outside
    document.getElementById('createStoryModal')?.addEventListener('click', (e) => {
        if (e.target.id === 'createStoryModal') closeCreateStoryModal();
    });
    
    document.getElementById('viewStoryModal')?.addEventListener('click', (e) => {
        if (e.target.id === 'viewStoryModal') closeStoryModal();
    });

    // P2 Fix 9: Comment threading - add mention to reply
    function addMention(mention, postId) {
        const textarea = document.querySelector(`textarea[name="content"]`);
        if (textarea) {
            const current = textarea.value.trim();
            if (current && !current.startsWith(mention)) {
                textarea.value = mention + ' ' + current;
            } else if (!current) {
                textarea.value = mention + ' ';
            }
            textarea.focus();
            textarea.parentElement.parentElement.scrollIntoView({ behavior: 'smooth' });
        }
    }


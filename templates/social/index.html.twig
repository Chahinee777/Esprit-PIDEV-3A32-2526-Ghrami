{% extends 'base.html.twig' %}

{% block title %}Fil Social - Ghrami{% endblock %}

{% block body %}
<div style="display: grid; grid-template-columns: 280px 1fr 280px; gap: 20px; margin-top: 20px;">
    
    <!-- Left Sidebar -->
    <aside style="display: flex; flex-direction: column; gap: 16px; position: sticky; top: 90px;">
        
        <!-- User Profile Card -->
        <div class="card" style="text-align: center; padding: 20px;">
            <div style="width: 100px; height: 100px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); margin: 0 auto 12px; border: 3px solid white; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                {% if app.user.profilePicture %}
                    <img src="{% if app.user.profilePicture starts with 'http' %}{{ app.user.profilePicture }}{% else %}{{ asset('images/profile_pictures/' ~ app.user.profilePicture) }}{% endif %}" alt="{{ app.user.fullName }}" style="width: 100%; height: 100%; object-fit: cover;">
                {% else %}
                    <span style="color: white; font-weight: bold; font-size: 40px;">{{ app.user.fullName[0:1] | upper }}</span>
                {% endif %}
            </div>
            <h4 style="margin: 0 0 4px 0; color: #1c1e21; font-weight: 700;">{{ app.user.fullName }}</h4>
            <p style="color: #65676b; font-size: 13px; margin: 0 0 16px 0;">{{ app.user.email }}</p>
            
            <!-- Stats -->
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; padding-top: 12px; border-top: 1px solid #e4e6eb;">
                <div>
                    <p style="margin: 0; font-size: 11px; color: #65676b; text-transform: uppercase;">Posts</p>
                    <p style="margin: 4px 0 0 0; font-size: 18px; font-weight: bold; color: #667eea;">{{ userPostCount }}</p>
                </div>
                <div>
                    <p style="margin: 0; font-size: 11px; color: #65676b; text-transform: uppercase;">Abonnés</p>
                    <p style="margin: 4px 0 0 0; font-size: 18px; font-weight: bold; color: #667eea;">{{ userFollowerCount }}</p>
                </div>
                <div>
                    <p style="margin: 0; font-size: 11px; color: #65676b; text-transform: uppercase;">Hobby</p>
                    <p style="margin: 4px 0 0 0; font-size: 18px; font-weight: bold; color: #667eea;">{{ userHobbyCount }}</p>
                </div>
            </div>
        </div>
        
        <!-- Navigation Rapide -->
        <div class="card" style="padding: 16px;">
            <h5 style="margin: 0 0 12px 0; color: #1c1e21; font-weight: 700; font-size: 14px;">Navigation Rapide</h5>
            <div style="display: flex; flex-direction: column; gap: 8px;">
                <a href="{{ path('app_dashboard') }}" style="padding: 10px 12px; border-radius: 8px; text-decoration: none; color: #1c1e21; font-size: 14px; transition: background 0.2s; {% if app.request.attributes.get('_route') == 'app_dashboard' %}background: #f0f2f5; font-weight: 600;{% else %}background: transparent; hover:background: #f0f2f5;{% endif %}" onmouseover="this.style.background='#f0f2f5'" onmouseout="this.style.background='{% if app.request.attributes.get('_route') == 'app_dashboard' %}#f0f2f5{% else %}transparent{% endif %}'">
                    📰 Fil d'Actualité
                </a>
                <a href="{{ path('app_hobbies_index') }}" style="padding: 10px 12px; border-radius: 8px; text-decoration: none; color: #1c1e21; font-size: 14px; transition: background 0.2s; {% if app.request.attributes.get('_route') == 'app_hobbies_index' %}background: #f0f2f5; font-weight: 600;{% else %}background: transparent; hover:background: #f0f2f5;{% endif %}" onmouseover="this.style.background='#f0f2f5'" onmouseout="this.style.background='{% if app.request.attributes.get('_route') == 'app_hobbies_index' %}#f0f2f5{% else %}transparent{% endif %}'">
                    🎮 Mes Loisirs
                </a>
                <a href="#" style="padding: 10px 12px; border-radius: 8px; text-decoration: none; color: #1c1e21; font-size: 14px; cursor: pointer; transition: background 0.2s; background: transparent; hover:background: #f0f2f5;" onmouseover="this.style.background='#f0f2f5'" onmouseout="this.style.background='transparent'">
                    🌟 Découvrir
                </a>
                <a href="{{ path('app_friends_index') }}" style="padding: 10px 12px; border-radius: 8px; text-decoration: none; color: #1c1e21; font-size: 14px; transition: background 0.2s; {% if app.request.attributes.get('_route') == 'app_friends_index' %}background: #f0f2f5; font-weight: 600;{% else %}background: transparent; hover:background: #f0f2f5;{% endif %}" onmouseover="this.style.background='#f0f2f5'" onmouseout="this.style.background='{% if app.request.attributes.get('_route') == 'app_friends_index' %}#f0f2f5{% else %}transparent{% endif %}'">
                    👥 Mes Amis
                </a>
                <a href="{{ path('app_badges_index') }}" style="padding: 10px 12px; border-radius: 8px; text-decoration: none; color: #1c1e21; font-size: 14px; transition: background 0.2s; {% if app.request.attributes.get('_route') == 'app_badges_index' %}background: #f0f2f5; font-weight: 600;{% else %}background: transparent; hover:background: #f0f2f5;{% endif %}" onmouseover="this.style.background='#f0f2f5'" onmouseout="this.style.background='{% if app.request.attributes.get('_route') == 'app_badges_index' %}#f0f2f5{% else %}transparent{% endif %}'">
                    ⭐ Badges
                </a>
                <a href="{{ path('app_meetings_index') }}" style="padding: 10px 12px; border-radius: 8px; text-decoration: none; color: #1c1e21; font-size: 14px; transition: background 0.2s; {% if app.request.attributes.get('_route') == 'app_meetings_index' %}background: #f0f2f5; font-weight: 600;{% else %}background: transparent; hover:background: #f0f2f5;{% endif %}" onmouseover="this.style.background='#f0f2f5'" onmouseout="this.style.background='{% if app.request.attributes.get('_route') == 'app_meetings_index' %}#f0f2f5{% else %}transparent{% endif %}'">
                    📅 Événements
                </a>
                <a href="#" style="padding: 10px 12px; border-radius: 8px; text-decoration: none; color: #1c1e21; font-size: 14px; cursor: pointer; transition: background 0.2s; background: transparent; hover:background: #f0f2f5;" onmouseover="this.style.background='#f0f2f5'" onmouseout="this.style.background='transparent'">
                    👫 Groupes
                </a>
                <a href="{{ path('app_marketplace_index') }}" style="padding: 10px 12px; border-radius: 8px; text-decoration: none; color: #1c1e21; font-size: 14px; transition: background 0.2s; {% if app.request.attributes.get('_route') == 'app_marketplace_index' %}background: #f0f2f5; font-weight: 600;{% else %}background: transparent; hover:background: #f0f2f5;{% endif %}" onmouseover="this.style.background='#f0f2f5'" onmouseout="this.style.background='{% if app.request.attributes.get('_route') == 'app_marketplace_index' %}#f0f2f5{% else %}transparent{% endif %}'">
                    🎓 Classes
                </a>
                <a href="{{ path('app_meetings_index') }}" style="padding: 10px 12px; border-radius: 8px; text-decoration: none; color: #1c1e21; font-size: 14px; transition: background 0.2s; {% if app.request.attributes.get('_route') == 'app_meetings_index' %}background: #f0f2f5; font-weight: 600;{% else %}background: transparent; hover:background: #f0f2f5;{% endif %}" onmouseover="this.style.background='#f0f2f5'" onmouseout="this.style.background='{% if app.request.attributes.get('_route') == 'app_meetings_index' %}#f0f2f5{% else %}transparent{% endif %}'">
                    🤝 Meetups
                </a>
                <a href="{{ path('app_vr_rooms') }}" style="padding: 10px 12px; border-radius: 8px; text-decoration: none; color: #1c1e21; font-size: 14px; transition: background 0.2s; {% if app.request.attributes.get('_route') == 'app_vr_rooms' %}background: #f0f2f5; font-weight: 600;{% else %}background: transparent; hover:background: #f0f2f5;{% endif %}" onmouseover="this.style.background='#f0f2f5'" onmouseout="this.style.background='{% if app.request.attributes.get('_route') == 'app_vr_rooms' %}#f0f2f5{% else %}transparent{% endif %}'">
                    🥽 Salles VR
                </a>
            </div>
        </div>
    </aside>
    
    <!-- Center Feed -->
    <main style="display: flex; flex-direction: column; gap: 20px;">
        
        <!-- Stories Section -->
        <div class="card" style="padding: 12px;">
            <div class="stories-container">
                <!-- User's Own Story or Add Story Button -->
                {% set userStory = stories|filter((s) => s.user_id == userId)|first %}
                
                {% if userStory %}
                    <!-- User's Story with Add Overlay -->
                    <div class="story-item" style="position: relative; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; padding-bottom: 8px; background-image: url('{{ userStory.image_url }}'); background-size: cover; background-position: center; cursor: pointer;">
                        <!-- Add Story Overlay -->
                        <div onclick="openCreateStoryModal()" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: rgba(0, 0, 0, 0.4); border-radius: 8px; transition: background 0.2s; z-index: 10;" onmouseover="this.style.background='rgba(0, 0, 0, 0.6)'" onmouseout="this.style.background='rgba(0, 0, 0, 0.4)'">
                            <div style="text-align: center;">
                                <div style="font-size: 28px; margin-bottom: 4px; color: white;">+</div>
                                <div style="font-size: 11px; font-weight: 600; color: white;">Ajouter</div>
                            </div>
                        </div>
                        <!-- Story Avatar -->
                        <div style="position: absolute; top: 8px; width: 48px; height: 48px; border-radius: 50%; border: 3px solid #667eea; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); background-clip: padding-box; overflow: hidden; display: flex; align-items: center; justify-content: center; z-index: 5;">
                            {% if app.user.profilePicture %}
                                <img src="{% if app.user.profilePicture starts with 'http' %}{{ app.user.profilePicture }}{% else %}{{ asset('images/profile_pictures/' ~ app.user.profilePicture) }}{% endif %}" alt="{{ app.user.fullName }}" style="width: 44px; height: 44px; border-radius: 50%; border: 2px solid white; object-fit: cover;">
                            {% else %}
                                <div style="width: 44px; height: 44px; border-radius: 50%; border: 2px solid white; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold;">{{ app.user.fullName[0:1] | upper }}</div>
                            {% endif %}
                        </div>
                        <!-- Story Name -->
                        <div style="background: rgba(0, 0, 0, 0.6); color: white; font-size: 11px; font-weight: 600; padding: 4px 6px; border-radius: 4px; text-align: center; width: 100%; margin-top: auto; z-index: 5;">Votre Histoire</div>
                    </div>
                {% else %}
                    <!-- Add Your Story Button (Placeholder) -->
                    <div class="story-item add-story" onclick="openCreateStoryModal()" style="cursor: pointer;">
                        <div style="text-align: center;">
                            <div style="font-size: 28px; margin-bottom: 4px;">+</div>
                            <div style="font-size: 11px; font-weight: 600;">Story</div>
                        </div>
                    </div>
                {% endif %}
                
                <!-- Friend Stories -->
                {% for story in stories %}
                    {% if story.user_id != userId %}
                    <div class="story-item" onclick="openStoryModal(this)" data-story-id="{{ story.story_id }}" data-user-id="{{ story.user_id }}" data-username="{{ story.username }}" data-full-name="{{ story.full_name ?: story.username }}" data-image-url="{{ story.image_url }}" data-profile-picture="{% if story.profile_picture starts with 'http' %}{{ story.profile_picture }}{% else %}{{ asset('images/profile_pictures/' ~ story.profile_picture) }}{% endif %}" data-caption="{{ story.caption ?: '' }}" data-created-at="{{ story.created_at }}" style="position: relative; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; padding-bottom: 8px; background-image: url('{{ story.image_url }}'); background-size: cover; background-position: center; cursor: pointer;">
                        <!-- Story Ring (Gradient border if has story) -->
                        <div style="position: absolute; top: 8px; width: 48px; height: 48px; border-radius: 50%; border: 3px solid #667eea; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); background-clip: padding-box; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                            {% if story.profile_picture %}
                                <img src="{% if story.profile_picture starts with 'http' %}{{ story.profile_picture }}{% else %}{{ asset('images/profile_pictures/' ~ story.profile_picture) }}{% endif %}" alt="{{ story.full_name ?: story.username }}" style="width: 44px; height: 44px; border-radius: 50%; border: 2px solid white; object-fit: cover;">
                            {% else %}
                                <div style="width: 44px; height: 44px; border-radius: 50%; border: 2px solid white; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold;">{{ (story.full_name ?: story.username)[0:1] | upper }}</div>
                            {% endif %}
                        </div>
                        <!-- Story Name -->
                        <div style="background: rgba(0, 0, 0, 0.6); color: white; font-size: 11px; font-weight: 600; padding: 4px 6px; border-radius: 4px; text-align: center; width: 100%; margin-top: auto;">{{ (story.full_name ?: story.username) | split(' ')[0] }}</div>
                    </div>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
        
        <!-- Search and Sort Section -->
        <div class="card" style="padding: 16px;">
            <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
                <!-- Search Form -->
                <form method="get" action="{{ path('app_social_index') }}" style="display: flex; gap: 8px; flex: 1; min-width: 250px;">
                    <input type="hidden" name="page" value="1">
                    <input type="hidden" name="perPage" value="{{ perPage }}">
                    <input type="text" name="query" placeholder="Rechercher des posts, utilisateurs..." value="{{ searchQuery }}" style="flex: 1; padding: 10px 12px; border: 1px solid #e4e6eb; border-radius: 20px; font-size: 14px;">
                    <button type="submit" style="padding: 10px 16px; background: #667eea; color: white; border: none; border-radius: 20px; cursor: pointer; font-weight: 600; font-size: 14px; transition: all 0.2s;" onmouseover="this.style.background='#5568d3'" onmouseout="this.style.background='#667eea'">🔍 Chercher</button>
                    {% if searchQuery %}
                    <a href="{{ path('app_social_index', { sort: sort, page: 1, perPage: perPage }) }}" style="padding: 10px 16px; background: #f0f2f5; color: #e74c3c; text-decoration: none; border: none; border-radius: 20px; cursor: pointer; font-weight: 600; font-size: 14px; transition: all 0.2s;" title="Effacer la recherche" onmouseover="this.style.background='#e8e9eb'" onmouseout="this.style.background='#f0f2f5'">✕ Réinitialiser</a>
                    {% endif %}
                </form>
                
                <!-- Sort Buttons -->
                <div style="display: flex; gap: 8px;">
                    <a href="{{ path('app_social_index', { query: searchQuery, sort: 'recent', page: 1, perPage: perPage }) }}" style="padding: 10px 16px; background: {% if sort == 'recent' %}#667eea{% else %}#f0f2f5{% endif %}; color: {% if sort == 'recent' %}white{% else %}#1c1e21{% endif %}; text-decoration: none; border: none; border-radius: 20px; cursor: pointer; font-weight: 600; font-size: 14px; transition: all 0.2s;" onmouseover="this.style.background='{% if sort == 'recent' %}#5568d3{% else %}#e8e9eb{% endif %}'" onmouseout="this.style.background='{% if sort == 'recent' %}#667eea{% else %}#f0f2f5{% endif %}'">📅 Récent</a>
                    <a href="{{ path('app_social_index', { query: searchQuery, sort: 'popular', page: 1, perPage: perPage }) }}" style="padding: 10px 16px; background: {% if sort == 'popular' %}#667eea{% else %}#f0f2f5{% endif %}; color: {% if sort == 'popular' %}white{% else %}#1c1e21{% endif %}; text-decoration: none; border: none; border-radius: 20px; cursor: pointer; font-weight: 600; font-size: 14px; transition: all 0.2s;" onmouseover="this.style.background='{% if sort == 'popular' %}#5568d3{% else %}#e8e9eb{% endif %}'" onmouseout="this.style.background='{% if sort == 'popular' %}#667eea{% else %}#f0f2f5{% endif %}'">👍 Populaire</a>
                </div>
            </div>
        </div>
        
        <!-- Create Post Box -->
        <div class="create-post-card">
            <div class="create-post-header">
                <div class="create-post-avatar" style="{% if app.user.profilePicture %}background-image: url('{% if app.user.profilePicture starts with 'http' %}{{ app.user.profilePicture }}{% else %}{{ asset('images/profile_pictures/' ~ app.user.profilePicture) }}{% endif %}'); background-size: cover; background-position: center;{% else %}background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 20px;{% endif %}">
                    {% if not app.user.profilePicture %}{{ app.user.fullName[0:1] | upper }}{% endif %}
                </div>
                <div style="flex: 1;">
                    <input type="text" id="social-post-input" class="create-post-input" placeholder="Quoi de neuf ? Partagez votre passion... 🤖 L'IA peut vous aider !">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 6px; font-size: 12px;">
                        <span id="postInputStatus" style="color: #65676b;"></span>
                        <span id="postCharCount" style="color: #65676b;">0 / 5000</span>
                    </div>
                </div>
            </div>
            
            <div class="create-post-actions">
                <button class="action-btn" id="social-photo-btn">
                    <span>📷</span> Photo
                </button>
                <button class="action-btn" id="social-ai-complete-btn">
                    <span>🤖</span> Compléter avec IA
                </button>
                <button class="publish-btn" id="social-publish-btn">Publier</button>
            </div>
            <div class="create-post-meta" style="display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; margin-top: 12px;">
                <div style="position: relative;">
                    <select name="location" form="social-post-form" style="padding: 10px 12px; border-radius: 16px; border: 1px solid #e4e6eb; font-size: 13px; width: 100%; background: white;">
                        <option value="">📍 Choisir un gouvernorat</option>
                        {% for governorate in governorates %}
                        <option value="{{ governorate }}">{{ governorate }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div style="position: relative;">
                    <select name="mood" form="social-post-form" style="padding: 10px 12px; border-radius: 16px; border: 1px solid #e4e6eb; font-size: 13px; width: 100%; background: white;">
                        <option value="">😊 Choisir une humeur</option>
                        {% for mood in moodOptions %}
                        <option value="{{ mood }}">{{ mood }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div style="position: relative;">
                    <select name="hobbyTag" form="social-post-form" style="padding: 10px 12px; border-radius: 16px; border: 1px solid #e4e6eb; font-size: 13px; width: 100%; background: white;">
                        <option value="">🏷️ Choisir un loisir</option>
                        {% for hobby in hobbyOptions %}
                        <option value="{{ hobby }}">{{ hobby }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div style="position: relative;">
                    <select name="visibility" form="social-post-form" style="padding: 10px 12px; border-radius: 16px; border: 1px solid #e4e6eb; font-size: 13px; width: 100%; background: white;">
                        <option value="public">🌐 Public</option>
                        <option value="friends">👥 Amis</option>
                        <option value="private">🔒 Privé</option>
                    </select>
                </div>
            </div>
            
            <form method="post" action="{{ path('app_social_post') }}" enctype="multipart/form-data" style="display: contents;" id="social-post-form">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('social_post') }}">
                <textarea name="content" id="social-post-content" style="display: none;"></textarea>
                <input type="file" name="image_file" accept="image/jpeg,image/png,image/webp" style="display: none;" id="social-image-file">
                <input type="text" name="image_url" id="social-post-image-url" style="display: none;">
            </form>
        </div>
        
        <!-- Feed Posts -->
        {% for p in feed %}
        <div class="post-card">
            <!-- Post Header -->
            <div class="post-header">
                <div class="post-author-info">
                    <div class="post-avatar" style="{% if p.profile_picture %}background-image: url('{% if p.profile_picture starts with 'http' %}{{ p.profile_picture }}{% else %}{{ asset('images/profile_pictures/' ~ p.profile_picture) }}{% endif %}'); background-size: cover; background-position: center;{% else %}background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 20px;{% endif %}">
                        {% if not p.profile_picture %}{{ (p.full_name ?: p.username)[0:1] | upper }}{% endif %}
                    </div>
                    <div>
                        <div class="post-author-name">{{ p.full_name ?: p.username }}</div>
                        <div class="post-metadata">
                            @{{ p.username }} • {{ p.created_at }}
                            {% if p.updated_at %}• modifié{% endif %}
                        </div>
                        <div class="post-extra-meta" style="margin-top: 6px; font-size: 12px; color: #65676b; display: flex; flex-wrap: wrap; gap: 8px;">
                            {% if p.location %}<span>📍 {{ p.location }}</span>{% endif %}
                            {% if p.mood %}<span>✨ {{ p.mood }}</span>{% endif %}
                            {% if p.hobby_tag %}<span>🏷️ {{ p.hobby_tag }}</span>{% endif %}
                            {% if p.visibility %}<span>🔒 {{ p.visibility|capitalize }}</span>{% endif %}
                        </div>
                    </div>
                </div>
                {% if p.user_id == userId %}
                <div style="display: flex; align-items: center; gap: 10px;">
                    <button type="button" onclick="openEditPost('{{ p.post_id }}', '{{ p.content|escape('js') }}')" style="background: none; border: none; font-size: 18px; cursor: pointer; color: #4b5563;">✏️</button>
                    <form method="post" action="{{ path('app_social_post_delete') }}" onsubmit="return confirm('Supprimer ce post ?');" style="margin: 0;">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('social_post_delete') }}">
                        <input type="hidden" name="post_id" value="{{ p.post_id }}">
                        <button type="submit" style="background: none; border: none; font-size: 20px; cursor: pointer; color: #65676b;">✕</button>
                    </form>
                </div>
                {% endif %}
            </div>
            
            <!-- Post Content -->
            <div class="post-content">
                <div class="post-text">{{ p.content }}</div>
                {% if p.image_url %}
                    {% if p.image_url starts with 'http://' or p.image_url starts with 'https://' %}
                        <img src="{{ p.image_url }}" alt="Post image" class="post-image">
                    {% else %}
                        <img src="{{ asset('images/posts/' ~ p.image_url) }}" alt="Post image" class="post-image">
                    {% endif %}
                {% endif %}
            </div>
            
            <!-- Post Stats -->
            <div style="padding: 12px 16px; border-top: 1px solid #e4e6eb; border-bottom: 1px solid #e4e6eb; font-size: 13px; color: #65676b;">
                <span style="cursor: pointer;">👍 {{ p.likes_count }} J'aime</span>
                <span style="margin-left: 16px; cursor: pointer;">💬 {{ p.comments_count }} Commentaires</span>
            </div>
            
            <!-- Post Actions -->
            <div class="post-actions">
                <form method="post" action="{{ path('app_social_like') }}" style="flex: 1;">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('social_like') }}">
                    <input type="hidden" name="post_id" value="{{ p.post_id }}">
                    <button type="submit" class="action-item" style="width: 100%;">
                        {{ p.liked_by_me ? '❤️' : '👍' }} J'aime
                    </button>
                </form>
                <button class="action-item">
                    💬 Commenter
                </button>
                <button class="action-item" onclick="openShareDialog({post_id: {{ p.post_id }}, content: `{{ p.content | escape('js') }}`, image_url: `{{ p.image_url ?: '' | escape('js') }}`})">
                    📤 Partager
                </button>
            </div>
            
            <!-- Comments Section (Threaded) -->
            {% set comments = commentsByPost[p.post_id]|default([]) %}
            {% if comments|length > 0 %}
            <div class="comments-section">
                {# Render comment with its replies (threaded) #}
                {% macro render_comment(comment, userId, indent, postId) %}
                    <div class="comment" style="margin-left: {{ indent * 32 }}px; border-left: {% if indent > 0 %}2px solid #e4e6eb{% else %}none{% endif %}; padding-left: {% if indent > 0 %}12px{% else %}0{% endif %};">
                        <div class="comment-avatar"></div>
                        <div class="comment-content">
                            <div class="comment-header">
                                <span class="comment-author">{{ comment.full_name ?: comment.username }}</span>
                                {% if comment.reply_to_username %}
                                <span class="comment-reply-indicator" style="font-size: 12px; color: #8a8d91; margin-left: 8px;" title="Réponse à @{{ comment.reply_to_username }}">↳ @{{ comment.reply_to_username }}</span>
                                {% endif %}
                                <span class="comment-time">{{ comment.created_at }}</span>
                                {% if comment.updated_at %}<span class="comment-time" style="margin-left: 6px;">• modifié</span>{% endif %}
                                {% if comment.mood %}<span class="comment-time" style="margin-left: 6px;">• {{ comment.mood }}</span>{% endif %}
                            </div>
                            <div class="comment-text">
                                {{ comment.content }}
                            </div>
                            {% if comment.image_url %}
                            <div style="margin-top: 10px;">
                                {% if comment.image_url starts with 'http://' or comment.image_url starts with 'https://' %}
                                <img src="{{ comment.image_url }}" alt="Comment image" style="max-width: 260px; width: 100%; border-radius: 12px; border: 1px solid #e4e6eb; object-fit: cover;">
                                {% else %}
                                <img src="{{ asset('images/comments/' ~ comment.image_url) }}" alt="Comment image" style="max-width: 260px; width: 100%; border-radius: 12px; border: 1px solid #e4e6eb; object-fit: cover;">
                                {% endif %}
                            </div>
                            {% endif %}
                            <div class="comment-actions">
                                <button onclick="addMention('@{{ comment.username }}', {{ postId }})">↳ Répondre</button>
                                {% if comment.user_id == userId %}
                                <button type="button" onclick="openEditComment('{{ comment.comment_id }}', '{{ (comment.content ?? '')|escape('js') }}', '{{ (comment.mood ?? '')|escape('js') }}', '{{ (comment.image_url ?? '')|escape('js') }}')" style="background: none; border: none; color: #2563eb; cursor: pointer; padding: 0; font-weight: 600;">Modifier</button>
                                <form method="post" action="{{ path('app_social_comment_delete') }}" style="display: inline;">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('social_comment_delete') }}">
                                    <input type="hidden" name="comment_id" value="{{ comment.comment_id }}">
                                    <button type="submit" style="background: none; border: none; color: #e74c3c; cursor: pointer; padding: 0; font-weight: 600;">Supprimer</button>
                                </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {# Render replies recursively #}
                    {% if comment.replies|default([])|length > 0 %}
                        {% for reply in comment.replies %}
                            {{ _self.render_comment(reply, userId, indent + 1, postId) }}
                        {% endfor %}
                    {% endif %}
                {% endmacro %}
                
                {% for c in comments %}
                    {% if not c.is_reply %}
                        {{ _self.render_comment(c, userId, 0, p.post_id) }}
                    {% endif %}
                {% endfor %}
            </div>
            {% endif %}
            
            <!-- Add Comment Form -->
            <form method="post" action="{{ path('app_social_comment') }}" enctype="multipart/form-data" class="social-comment-form" style="padding: 12px 16px; border-top: 1px solid #e4e6eb; display: flex; flex-direction: column; gap: 8px;">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('social_comment') }}">
                <input type="hidden" name="post_id" value="{{ p.post_id }}">
                <div style="display: flex; gap: 8px; align-items: flex-start;">
                    <textarea name="content" rows="1" placeholder="Écrivez un commentaire..." style="flex: 1; padding: 8px 12px; background-color: #f0f2f5; border: 1px solid #e4e6eb; border-radius: 16px; resize: none; font-size: 13px; min-height: 32px; line-height: 18px; max-height: 100px; font-family: inherit;" class="comment-textarea"></textarea>
                    <button type="submit" class="btn btn-sm btn-primary" style="padding: 8px 14px; height: fit-content; align-self: flex-end;">Poster</button>
                </div>
                <div style="display: grid; grid-template-columns: minmax(0, 1fr) 180px; gap: 8px; align-items: center;">
                    <input type="file" name="image_file" accept="image/jpeg,image/png,image/webp" class="comment-image-input" style="padding: 8px 10px; background-color: #f8f9fa; border: 1px solid #e4e6eb; border-radius: 12px; font-size: 12px;">
                    <select name="mood" style="padding: 8px 10px; background-color: #f8f9fa; border: 1px solid #e4e6eb; border-radius: 12px; font-size: 12px;">
                        <option value="">😊 Humeur (optionnel)</option>
                        {% for mood in moodOptions %}
                        <option value="{{ mood }}">{{ mood }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; font-size: 11px;">
                    <span class="comment-status" style="color: #65676b;"></span>
                    <span class="comment-char-count" style="color: #65676b;">0 / 500</span>
                </div>
            </form>
        </div>
        {% else %}
        <div class="card" style="text-align: center; padding: 40px;">
            <div style="font-size: 40px; margin-bottom: 16px;">📭</div>
            <h3>Aucun post à afficher</h3>
            <p style="color: #65676b;">Soyez le premier à partager quelque chose !</p>
        </div>
        {% endfor %}
        
        <!-- Pagination -->
        {% if page > 1 or feed|length >= perPage %}
        <div style="display: flex; justify-content: center; gap: 12px; padding: 20px;">
            {% if page > 1 %}
            <a href="{{ path('app_social_index', { query: searchQuery, sort: sort, page: page - 1, perPage: perPage }) }}" class="btn btn-outline">← Précédent</a>
            {% endif %}
            <span style="padding: 10px 16px; text-align: center; color: #65676b;">Page {{ page }}</span>
            {% if feed|length >= perPage %}
            <a href="{{ path('app_social_index', { query: searchQuery, sort: sort, page: page + 1, perPage: perPage }) }}" class="btn btn-outline">Suivant →</a>
            {% endif %}
        </div>
        {% endif %}

        <form id="social-edit-post-form" method="post" action="{{ path('app_social_post_edit') }}" style="display: none;">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('social_post_edit') }}">
            <input type="hidden" name="post_id" id="social-edit-post-id">
            <textarea name="content" id="social-edit-post-content"></textarea>
        </form>

        <form id="social-edit-comment-form" method="post" action="{{ path('app_social_comment_edit') }}" enctype="multipart/form-data" style="display: none;">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('social_comment_edit') }}">
            <input type="hidden" name="comment_id" id="social-edit-comment-id">
        </form>
    </main>
    
    <!-- Right Sidebar -->
    <aside style="display: flex; flex-direction: column; gap: 16px;">
        
        <!-- Trending Hobbies -->
        <div class="card">
            <h4 style="margin-top: 0; display: flex; align-items: center; gap: 8px;">🔥 Tendances</h4>
            <div style="display: flex; flex-direction: column; gap: 10px;">
                <div style="padding: 10px; background: #f0f2f5; border-radius: 8px; cursor: pointer;">
                    <div style="font-weight: 600;">🎯 Hobbies Populaires</div>
                    <div style="font-size: 12px; color: #65676b; margin-top: 4px;">Explorez les tendances</div>
                </div>
            </div>
        </div>
        
        <!-- Friend Suggestions -->
        <div class="card">
            <h4 style="margin-top: 0; display: flex; align-items: center; gap: 8px;">✨ Suggestions</h4>
            <div style="display: flex; flex-direction: column; gap: 10px; font-size: 13px; color: #65676b;">
                Connectez-vous avec d'autres membres partageant vos passions
            </div>
        </div>
    </aside>
</div>

<style>
    @media (max-width: 1200px) {
        main > div {
            grid-template-columns: 1fr !important;
        }
    }
    
    @media (max-width: 768px) {
        main > div {
            grid-template-columns: 1fr !important;
            gap: 12px;
        }
        
        aside {
            display: none;
        }
    }
</style>


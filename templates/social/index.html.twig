                            {% endfor %}
                        </select>
                        <input type="file" name="image_file" form="social-edit-comment-form" accept="image/jpeg,image/png,image/webp" style="width: 100%; padding: 10px 12px; border: 1px solid #e4e6eb; border-radius: 8px; font-size: 12px; background: #f8f9fa; box-sizing: border-box;">
                        <label style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: #65676b;">
                            <input type="checkbox" name="remove_image" value="1" form="social-edit-comment-form">

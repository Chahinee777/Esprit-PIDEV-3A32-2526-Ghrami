                <div id="storyAvatarContainer" style="width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; overflow: hidden;"></div>
                <div>
                    <div id="storyAuthorName" style="font-weight: 600; color: #1c1e21; font-size: 14px;"></div>

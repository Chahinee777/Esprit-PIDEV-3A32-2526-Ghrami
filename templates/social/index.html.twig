                    <button type="button" onclick="closeEditCommentModal()" style="flex: 1; padding: 12px 24px; background: #f0f2f5; color: #1c1e21; border: none; border-radius: 8px; font-weight: 600; cursor: pointer;">Annuler</button>
                    <button type="submit" onclick="submitEditComment()" style="flex: 1; padding: 12px 24px; background: #667eea; color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='#5568d3'" onmouseout="this.style.background='#667eea'">Enregistrer</button>

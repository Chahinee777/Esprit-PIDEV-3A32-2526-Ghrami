<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
    <meta name="description" content="Ghrami - La plateforme tunisienne de développement personnel et d'apprentissage par les hobbies">
    <meta name="theme-color" content="#667eea">
    
    <title>{% block title %}Ghrami - Connectez. Partagez. Explorez.{% endblock %}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('css/ghrami-design-system.css') }}">
        <style>
            *, *::before, *::after { box-sizing: border-box; }
            html, body {
                margin: 0;
                padding: 0;
                min-height: 100vh;
            }
        </style>
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
    <main style="min-height: 100vh; margin: 0; padding: 0;">
        {% block auth_body %}{% endblock %}
    </main>

    <script>
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) target.scrollIntoView({ behavior: 'smooth' });
            });
        });
    </script>
</body>
</html>
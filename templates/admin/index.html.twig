{% extends 'admin_layout.html.twig' %}

{% block title %}Admin Dashboard | Ghrami{% endblock %}

{% block body %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --c-primary:   #5a3fb8;
    --c-primary-l: #7c5cff;
    --c-primary-bg:#ede9fb;
    --c-surface:   #ffffff;
    --c-bg:        #f4f5f9;
    --c-border:    #e8eaf0;
    --c-text:      #1a1d23;
    --c-muted:     #6b7280;
    --c-danger:    #e53935;
    --c-success:   #2e7d32;
    --c-warn:      #e65100;
    --sidebar-w:   240px;
    --header-h:    64px;
    --radius-lg:   16px;
    --radius-md:   10px;
    --shadow-sm:   0 1px 4px rgba(0,0,0,.07);
    --shadow-md:   0 4px 20px rgba(0,0,0,.09);
    --shadow-lg:   0 10px 40px rgba(0,0,0,.13);
  }

  /* ── Base ── */
  .ad-root {
    font-family: 'Sora', sans-serif;
    background: var(--c-bg);
    min-height: 100vh;
    display: flex;
    color: var(--c-text);
  }

  /* ════════════════════════════════════════
     SIDEBAR
  ════════════════════════════════════════ */
  .ad-sidebar {
    width: var(--sidebar-w);
    min-height: 100vh;
    background: var(--c-surface);
    border-right: 1px solid var(--c-border);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0; left: 0;
    z-index: 200;
    transition: transform .3s ease;
  }

  /* Logo */
  .ad-sidebar-logo {
    padding: 0 20px;
    height: var(--header-h);
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid var(--c-border);
    flex-shrink: 0;
  }
  .ad-logo-mark {
    width: 36px; height: 36px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--c-primary), var(--c-primary-l));
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .ad-logo-mark svg { width: 18px; height: 18px; stroke: #fff; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .ad-logo-text { line-height: 1; }
  .ad-logo-name { font-size: 15px; font-weight: 800; color: var(--c-primary); letter-spacing: -.3px; }
  .ad-logo-role { font-size: 10px; color: var(--c-muted); font-weight: 500; margin-top: 2px; text-transform: uppercase; letter-spacing: .5px; }

  /* Nav label */
  .ad-nav-section {
    padding: 20px 20px 6px;
    font-size: 10px; font-weight: 700;
    color: var(--c-muted);
    text-transform: uppercase;
    letter-spacing: .8px;
  }

  /* Nav items */
  .ad-nav {
    flex: 1;
    overflow-y: auto;
    padding: 8px 12px;
    scrollbar-width: none;
  }
  .ad-nav::-webkit-scrollbar { display: none; }

  .ad-nav-item {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 10px 12px;
    border-radius: var(--radius-md);
    cursor: pointer;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
    font-family: 'Sora', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--c-muted);
    transition: background .15s, color .15s;
    position: relative;
    margin-bottom: 2px;
    white-space: nowrap;
  }
  .ad-nav-item:hover {
    background: var(--c-bg);
    color: var(--c-text);
  }
  .ad-nav-item.active {
    background: var(--c-primary-bg);
    color: var(--c-primary);
    font-weight: 700;
  }
  .ad-nav-item.active::before {
    content: '';
    position: absolute;
    left: 0; top: 6px; bottom: 6px;
    width: 3px;
    border-radius: 0 3px 3px 0;
    background: var(--c-primary);
  }
  .ad-nav-icon {
    width: 20px; height: 20px;
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .ad-nav-icon svg {
    width: 17px; height: 17px;
    stroke: currentColor; fill: none;
    stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round;
  }

  /* Sidebar footer */
  .ad-sidebar-footer {
    padding: 16px 12px;
    border-top: 1px solid var(--c-border);
  }
  .ad-sidebar-user {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: var(--radius-md);
    background: var(--c-bg);
  }
  .ad-sidebar-avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: linear-gradient(135deg, var(--c-primary), var(--c-primary-l));
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 800; color: #fff;
    flex-shrink: 0;
  }
  .ad-sidebar-uname { font-size: 12px; font-weight: 700; color: var(--c-text); }
  .ad-sidebar-urole { font-size: 10px; color: var(--c-muted); margin-top: 1px; }
  .ad-sidebar-logout {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    margin-top: 8px;
    padding: 9px 12px;
    border-radius: var(--radius-md);
    border: 1px solid #fecdd3;
    background: #fff5f5;
    color: var(--c-danger);
    font-family: 'Sora', sans-serif;
    font-size: 12px; font-weight: 700;
    cursor: pointer;
    text-decoration: none;
    transition: background .15s;
  }
  .ad-sidebar-logout:hover { background: #fee2e2; }
  .ad-sidebar-logout svg { width: 15px; height: 15px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

  /* ════════════════════════════════════════
     WORKSPACE (right of sidebar)
  ════════════════════════════════════════ */
  .ad-workspace {
    margin-left: var(--sidebar-w);
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  /* ── Top Header ── */
  .ad-header {
    position: sticky; top: 0; z-index: 100;
    height: var(--header-h);
    background: var(--c-surface);
    border-bottom: 1px solid var(--c-border);
    padding: 0 32px;
    display: flex; align-items: center; gap: 16px;
    box-shadow: var(--shadow-sm);
  }
  .ad-header-title {
    font-size: 17px; font-weight: 800;
    color: var(--c-text); letter-spacing: -.3px;
    flex: 1;
  }
  .ad-header-sub {
    font-size: 12px; color: var(--c-muted);
    font-weight: 400; margin-top: 1px;
  }
  .ad-header-right { display: flex; align-items: center; gap: 12px; }

  /* ── Main ── */
  .ad-main { padding: 28px 32px 48px; flex: 1; }

  /* ── KPI Cards ── */
  .ad-kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 16px;
    margin-bottom: 28px;
  }
  .ad-kpi {
    background: var(--c-surface);
    border-radius: var(--radius-lg);
    padding: 20px 18px;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--c-border);
    display: flex; align-items: center; gap: 14px;
    transition: box-shadow .2s, transform .2s;
  }
  .ad-kpi:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .ad-kpi-icon {
    width: 46px; height: 46px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .ad-kpi-icon svg {
    width: 20px; height: 20px;
    stroke: #fff; fill: none;
    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
  }
  .ad-kpi-icon-1 { background: linear-gradient(135deg,#667eea,#764ba2); }
  .ad-kpi-icon-2 { background: linear-gradient(135deg,#f093fb,#f5576c); }
  .ad-kpi-icon-3 { background: linear-gradient(135deg,#ffa726,#fb8c00); }
  .ad-kpi-icon-4 { background: linear-gradient(135deg,#4CAF50,#2e7d32); }
  .ad-kpi-icon-5 { background: linear-gradient(135deg,#26c6da,#00838f); }
  .ad-kpi-icon-6 { background: linear-gradient(135deg,#ab47bc,#7b1fa2); }
  .ad-kpi-icon-7 { background: linear-gradient(135deg,#ef5350,#b71c1c); }
  .ad-kpi-icon-8 { background: linear-gradient(135deg,#42a5f5,#1565c0); }
  .ad-kpi-value { font-size: 28px; font-weight: 900; letter-spacing: -1px; line-height: 1; }
  .ad-kpi-value-1 { color: #667eea; }
  .ad-kpi-value-2 { color: #f5576c; }
  .ad-kpi-value-3 { color: #fb8c00; }
  .ad-kpi-value-4 { color: #4CAF50; }
  .ad-kpi-value-5 { color: #00838f; }
  .ad-kpi-value-6 { color: #7b1fa2; }
  .ad-kpi-value-7 { color: #b71c1c; }
  .ad-kpi-value-8 { color: #1565c0; }
  .ad-kpi-label { font-size: 11.5px; color: var(--c-muted); font-weight: 600; margin-top: 4px; }
  .ad-kpi-detail { font-size: 10.5px; color: #adb0bb; margin-top: 3px; }

  /* ── Tab Content ── */
  .ad-content-card {
    background: var(--c-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--c-border);
    overflow: hidden;
  }

  /* Keep the old tab system hidden — tabs are now driven by sidebar */
  .ad-tab-nav { display: none; }
  .ad-tab-pane { display: none; padding: 28px 24px; }
  .ad-tab-pane.active { display: block; }
  /* Wrap tabs-wrap styling */
  .ad-tabs-wrap {
    background: var(--c-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--c-border);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  /* ── Section header ── */
  .ad-section-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    margin-bottom: 20px; flex-wrap: wrap; gap: 14px;
  }
  .ad-section-title { font-size: 18px; font-weight: 800; color: var(--c-text); letter-spacing: -.3px; }
  .ad-section-sub { font-size: 12px; color: var(--c-muted); margin-top: 3px; }
  .ad-section-actions { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }

  /* ── Search ── */
  .ad-search {
    padding: 9px 16px;
    background: var(--c-bg);
    border: 1.5px solid var(--c-border);
    border-radius: 8px;
    font-size: 13px; font-family: 'Sora', sans-serif;
    color: var(--c-text); outline: none; min-width: 200px;
    transition: all .2s;
  }
  .ad-search::placeholder { color: #adb0bb; }
  .ad-search:focus { background: white; border-color: var(--c-primary); box-shadow: 0 0 0 3px rgba(90,63,184,.1); }

  /* ── Buttons ── */
  .ad-btn {
    padding: 9px 18px; border: none; border-radius: 8px;
    font-size: 12.5px; font-weight: 700; font-family: 'Sora', sans-serif;
    cursor: pointer; display: inline-flex; align-items: center; gap: 6px;
    transition: filter .15s, transform .15s, box-shadow .15s;
    white-space: nowrap;
  }
  .ad-btn:hover { filter: brightness(1.07); transform: translateY(-1px); }
  .ad-btn:active { transform: translateY(0); filter: brightness(.97); }
  .ad-btn svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

  .ad-btn-purple { background: var(--c-primary); color: white; box-shadow: 0 2px 8px rgba(90,63,184,.3); }
  .ad-btn-green  { background: #2e7d32; color: white; box-shadow: 0 2px 8px rgba(46,125,50,.3); }
  .ad-btn-blue   { background: #1565c0; color: white; box-shadow: 0 2px 8px rgba(21,101,192,.3); }
  .ad-btn-orange { background: #e65100; color: white; box-shadow: 0 2px 8px rgba(230,81,0,.3); }
  .ad-btn-red    { background: #c62828; color: white; box-shadow: 0 2px 8px rgba(198,40,40,.3); }
  .ad-btn-teal   { background: #00838f; color: white; box-shadow: 0 2px 8px rgba(0,131,143,.3); }
  .ad-btn-sm { padding: 6px 12px; font-size: 11.5px; }
  .ad-btn-icon { padding: 9px 11px; }

  /* ── Tooltip ── */
  [data-tip] { position: relative; }
  [data-tip]::after {
    content: attr(data-tip);
    position: absolute; bottom: calc(100% + 7px); left: 50%;
    transform: translateX(-50%) scale(0.85);
    background: #1c1e21; color: #fff;
    padding: 5px 10px; border-radius: 6px;
    font-size: 11px; font-weight: 600; white-space: nowrap;
    pointer-events: none; opacity: 0;
    transition: opacity .18s, transform .18s;
    z-index: 300;
  }
  [data-tip]::before {
    content: '';
    position: absolute; bottom: calc(100% + 3px); left: 50%;
    transform: translateX(-50%) scale(0.85);
    border: 5px solid transparent; border-top-color: #1c1e21;
    pointer-events: none; opacity: 0;
    transition: opacity .18s, transform .18s;
    z-index: 300;
  }
  [data-tip]:hover::after,
  [data-tip]:hover::before { opacity: 1; transform: translateX(-50%) scale(1); }

  /* ── Tables ── */
  .ad-table-wrap {
    background: var(--c-bg);
    border-radius: var(--radius-md);
    border: 1px solid var(--c-border);
    overflow: hidden;
    overflow-x: auto;
  }
  .ad-table { width: 100%; border-collapse: collapse; min-width: 700px; }
  .ad-table thead { background: var(--c-surface); }
  .ad-table th {
    padding: 13px 16px; font-size: 10.5px; font-weight: 700;
    color: var(--c-primary); text-align: left; text-transform: uppercase;
    letter-spacing: .7px; border-bottom: 1px solid var(--c-border);
    cursor: pointer; user-select: none; white-space: nowrap;
    transition: background .15s;
  }
  .ad-table th:hover { background: rgba(90,63,184,.04); }
  .ad-table th.sort-asc::after  { content: ' ▲'; font-size: 9px; opacity:.7; }
  .ad-table th.sort-desc::after { content: ' ▼'; font-size: 9px; opacity:.7; }
  .ad-table th.no-sort { cursor: default; }
  .ad-table th.no-sort:hover { background: none; }
  .ad-table td {
    padding: 11px 16px; font-size: 13px; color: #3d4049;
    border-bottom: 1px solid #eef0f6; vertical-align: middle;
  }
  .ad-table tbody tr { background: var(--c-surface); transition: background .15s; }
  .ad-table tbody tr:hover { background: #fafbff; }
  .ad-table tbody tr:last-child td { border-bottom: none; }
  .ad-avatar {
    width: 34px; height: 34px; border-radius: 50%;
    object-fit: cover; background: #e0e0e0;
    border: 2px solid var(--c-border);
  }

  /* ── Badges ── */
  .ad-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 3px 10px; border-radius: 6px;
    font-size: 11px; font-weight: 700;
  }
  .ad-badge-online    { background: #dcfce7; color: #166534; }
  .ad-badge-offline   { background: #f3f4f6; color: #6b7280; }
  .ad-badge-verified  { background: #dcfce7; color: #166534; }
  .ad-badge-unverified{ background: #fff7ed; color: #c2410c; }
  .ad-badge-google    { background: #eff6ff; color: #1d4ed8; }
  .ad-badge-local     { background: #ede9fb; color: var(--c-primary); }
  .ad-badge-accepted  { background: #dcfce7; color: #166534; }
  .ad-badge-pending   { background: #fefce8; color: #854d0e; }
  .ad-badge-rejected  { background: #fef2f2; color: #991b1b; }
  .ad-badge-banned    { background: #fef2f2; color: #991b1b; }

  .ad-action-group { display: flex; gap: 5px; flex-wrap: wrap; }

  /* ── Charts ── */
  .ad-charts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 18px; margin-top: 4px;
  }
  .ad-chart-card {
    background: var(--c-surface); border-radius: var(--radius-lg);
    padding: 20px; border: 1px solid var(--c-border);
    box-shadow: var(--shadow-sm);
  }
  .ad-chart-card h4 { font-size: 13px; font-weight: 700; color: var(--c-text); margin-bottom: 16px; }
  .ad-chart-wrap { position: relative; height: 260px; }
  .ad-chart-wide { grid-column: 1 / -1; }

  /* ── Analytics Detail Cards ── */
  .ad-detail-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }
  .ad-detail-card {
    background: var(--c-surface); border-radius: var(--radius-lg);
    border: 1px solid var(--c-border);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow .2s, transform .2s;
  }
  .ad-detail-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .ad-detail-card-head {
    padding: 14px 18px;
    font-size: 12.5px; font-weight: 800;
    display: flex; align-items: center; gap: 8px;
  }
  .ad-detail-card-body { padding: 6px 0 10px; }
  .ad-detail-stat-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 8px 18px;
    border-bottom: 1px solid #f5f6fa;
    font-size: 13px;
  }
  .ad-detail-stat-row:last-child { border-bottom: none; }
  .ad-detail-stat-label { color: var(--c-muted); font-weight: 500; }
  .ad-detail-stat-value { font-weight: 800; }

  .dcard-purple .ad-detail-card-head { background: #ede9fb22; color: var(--c-primary); border-bottom: 1px solid #e4ddfa; }
  .dcard-purple .ad-detail-stat-value { color: var(--c-primary); }
  .dcard-pink   .ad-detail-card-head { background: #fdf2f8; color: #be185d; border-bottom: 1px solid #fbdaef; }
  .dcard-pink   .ad-detail-stat-value { color: #be185d; }
  .dcard-orange .ad-detail-card-head { background: #fff7ed; color: #c2410c; border-bottom: 1px solid #fed7aa; }
  .dcard-orange .ad-detail-stat-value { color: #c2410c; }
  .dcard-green  .ad-detail-card-head { background: #f0fdf4; color: #166534; border-bottom: 1px solid #bbf7d0; }
  .dcard-green  .ad-detail-stat-value { color: #166534; }
  .dcard-teal   .ad-detail-card-head { background: #f0fdfa; color: #0f766e; border-bottom: 1px solid #99f6e4; }
  .dcard-teal   .ad-detail-stat-value { color: #0f766e; }
  .dcard-violet .ad-detail-card-head { background: #faf5ff; color: #7e22ce; border-bottom: 1px solid #e9d5ff; }
  .dcard-violet .ad-detail-stat-value { color: #7e22ce; }
  .dcard-red    .ad-detail-card-head { background: #fef2f2; color: #991b1b; border-bottom: 1px solid #fecaca; }
  .dcard-red    .ad-detail-stat-value { color: #991b1b; }

  /* ── Footer ── */
  .ad-footer {
    padding: 20px 32px;
    font-size: 12px; font-weight: 500; color: var(--c-muted);
    border-top: 1px solid var(--c-border);
    background: var(--c-surface);
  }

  /* ── Modals ── */
  .ad-modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(15,8,40,0.5); z-index: 500;
    align-items: center; justify-content: center;
    overflow-y: auto; padding: 20px 0; backdrop-filter: blur(3px);
  }
  .ad-modal-overlay.show { display: flex; }
  .ad-modal {
    background: white; border-radius: 18px;
    padding: 30px; width: 90%; max-width: 480px;
    box-shadow: 0 20px 60px rgba(0,0,0,.2);
    position: relative; margin: auto;
  }
  .ad-modal-lg { max-width: 580px; }
  .ad-modal-close {
    position: absolute; top: 16px; right: 18px;
    background: var(--c-bg); border: none; border-radius: 6px;
    font-size: 14px; width: 28px; height: 28px;
    cursor: pointer; color: var(--c-muted); transition: color .2s, background .2s;
    display: flex; align-items: center; justify-content: center;
  }
  .ad-modal-close:hover { color: var(--c-text); background: var(--c-border); }
  .ad-modal-title { font-size: 18px; font-weight: 800; color: var(--c-text); margin-bottom: 20px; }

  .ad-detail-row {
    display: flex; justify-content: space-between;
    padding: 9px 0; border-bottom: 1px solid #f0f2f5;
    font-size: 13px;
  }
  .ad-detail-row:last-child { border-bottom: none; }
  .ad-detail-label { font-weight: 700; color: var(--c-text); }
  .ad-detail-value { color: var(--c-muted); }

  .ad-form-group { margin-bottom: 16px; }
  .ad-form-group label {
    display: block; font-size: 11px; font-weight: 700;
    color: var(--c-primary); margin-bottom: 6px;
    text-transform: uppercase; letter-spacing: .5px;
  }
  .ad-form-input {
    width: 100%; padding: 10px 14px;
    background: var(--c-bg); border: 1.5px solid var(--c-border);
    border-radius: 8px; font-size: 13px; font-family: 'Sora', sans-serif;
    color: var(--c-text); outline: none; transition: border-color .2s, box-shadow .2s;
  }
  .ad-form-input:focus { border-color: var(--c-primary); box-shadow: 0 0 0 3px rgba(90,63,184,.1); background: white; }
  .ad-form-select {
    width: 100%; padding: 10px 14px;
    background: var(--c-bg); border: 1.5px solid var(--c-border);
    border-radius: 8px; font-size: 13px; font-family: 'Sora', sans-serif;
    color: var(--c-text); outline: none; cursor: pointer; appearance: none;
    transition: border-color .2s;
  }
  .ad-form-select:focus { border-color: var(--c-primary); }
  .ad-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .ad-form-actions { display: flex; gap: 10px; margin-top: 22px; justify-content: flex-end; }

  /* ── Mobile ── */
  .ad-sidebar-toggle {
    display: none;
    background: none; border: none; cursor: pointer;
    width: 36px; height: 36px; border-radius: 8px;
    align-items: center; justify-content: center;
    color: var(--c-text);
  }
  .ad-sidebar-toggle svg { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; }

  @media (max-width: 900px) {
    .ad-sidebar { transform: translateX(-100%); }
    .ad-sidebar.open { transform: translateX(0); box-shadow: var(--shadow-lg); }
    .ad-workspace { margin-left: 0; }
    .ad-sidebar-toggle { display: flex; }
    .ad-main { padding: 20px 16px 40px; }
    .ad-header { padding: 0 16px; }
    .ad-kpi-grid { grid-template-columns: repeat(2, 1fr); }
    .ad-charts-grid { grid-template-columns: 1fr; }
    .ad-form-row { grid-template-columns: 1fr; }
    .ad-detail-cards-grid { grid-template-columns: 1fr; }
    .ad-footer { padding: 16px; }
  }
</style>


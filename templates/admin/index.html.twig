                    <form method="post" action="{{ path('app_admin_meeting_delete') }}"
                          style="display:inline;"
                          onsubmit="return confirm('Delete meeting {{ m.meeting_id }}?');">
                      <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_meeting_delete') }}">
                      <input type="hidden" name="meeting_id" value="{{ m.meeting_id }}">

        <div class="ad-section-header">
          <div>
            <div class="ad-section-title">Badge Management</div>
            <div class="ad-section-sub">Create, edit and remove user badges</div>
          </div>
          <div class="ad-section-actions">
            <input class="ad-search" id="badgeSearch" type="text" placeholder="🔍 Search badges...">
            <button class="ad-btn ad-btn-purple" onclick="openAwardBadgeModal()" data-tip="Award a badge to a user">🏆 Award Badge</button>
          </div>
        </div>

        {# Badge distribution mini-chart #}
        <div style="background:#f8f9fe;border-radius:16px;border:1px solid #eaecf2;padding:22px;margin-bottom:24px;">
          <h4 style="font-size:14px;font-weight:700;color:#1c1e21;margin-bottom:16px;">📊 Badge Distribution</h4>
          <div style="position:relative;height:220px;"><canvas id="chartBadgeTab"></canvas></div>
        </div>

        {# Badge award statistics by name #}
        {% if badgeStats is defined and badgeStats is not empty %}
        <div style="background:#f8f9fe;border-radius:16px;border:1px solid #eaecf2;padding:22px;margin-bottom:28px;">
          <h4 style="font-size:14px;font-weight:700;color:#1c1e21;margin-bottom:16px;">🏅 Badge Catalog — Award Counts</h4>
          <div class="ad-table-wrap" style="box-shadow:none;border:none;">
            <table class="ad-table" id="badgeCatalogTable">
              <thead>
                <tr>
                  <th onclick="sortTable('badgeCatalogTable',0,this)">Badge Name</th>
                  <th onclick="sortTable('badgeCatalogTable',1,this)" style="text-align:center;">Times Awarded</th>
                  <th onclick="sortTable('badgeCatalogTable',2,this)">Last Awarded</th>
                  <th class="no-sort">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for bs in badgeStats %}
                  <tr>
                    <td><span class="ad-badge ad-badge-local">🏆 {{ bs.name }}</span></td>
                    <td style="text-align:center;font-weight:700;color:#5a3fb8;">{{ bs.total_awarded }}</td>
                    <td style="color:#65676b;font-size:12px;">{{ bs.last_awarded }}</td>
                    <td>
                      <form method="post" action="{{ path('app_admin_badge_revoke_by_name') }}" style="display:inline;"
                            onsubmit="return confirm('Revoke ALL «{{ bs.name }}» badges from every user? This cannot be undone.');">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_badge_revoke_name') }}">
                        <input type="hidden" name="badge_name" value="{{ bs.name }}">
                        <button type="submit" class="ad-btn ad-btn-red ad-btn-sm" data-tip="Remove this badge from all users">🗑️ Revoke All</button>
                      </form>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>

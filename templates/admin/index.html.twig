            <div class="ad-section-sub">Manage scheduled virtual and physical meetings</div>
          </div>
          <div class="ad-section-actions">
            <input class="ad-search" id="meetingSearch" type="text" placeholder="🔍 Search meetings...">
          </div>
        </div>

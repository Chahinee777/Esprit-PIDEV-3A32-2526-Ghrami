{% extends 'admin_layout.html.twig' %}

{% block title %}Admin Dashboard | Ghrami{% endblock %}

{% block body %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .ad-root {
    font-family: 'Sora', sans-serif;
    background: linear-gradient(135deg, #5a3fb8 0%, #6b4fd1 50%, #7c5cff 100%);
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  /* ── Orbs ── */
  .ad-orb {
    position: fixed; border-radius: 50%; pointer-events: none; z-index: 0;
    background: radial-gradient(circle, rgba(255,255,255,0.08), transparent 70%);
  }
  .ad-orb-1 { width: 900px; height: 900px; top: -300px; left: -350px; }
  .ad-orb-2 { width: 700px; height: 700px; bottom: -200px; right: -200px; }
  .ad-orb-3 { width: 500px; height: 500px; top: 40%; left: 30%; }

  /* ── Header ── */
  .ad-header {
    position: sticky; top: 0; z-index: 100;
    background: white;
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
    padding: 16px 36px;
    display: flex; align-items: center; gap: 24px;
  }
  .ad-header-brand { display: flex; align-items: center; gap: 16px; }
  .ad-crown {
    width: 56px; height: 56px; border-radius: 50%;
    background: linear-gradient(135deg, #667eea, #764ba2);
    display: flex; align-items: center; justify-content: center;
    font-size: 26px;
    box-shadow: 0 6px 20px rgba(102,126,234,0.45);
  }
  .ad-brand-title { font-size: 22px; font-weight: 800; color: #5a3fb8; letter-spacing: -.5px; }
  .ad-brand-sub { font-size: 12px; color: #7c5cff; font-weight: 600; margin-top: 1px; }
  .ad-header-spacer { flex: 1; }
  .ad-admin-info { text-align: right; }
  .ad-admin-name { font-size: 15px; font-weight: 700; color: #1c1e21; }
  .ad-admin-role { font-size: 11px; color: #65676b; font-weight: 500; margin-top: 1px; }
  .ad-logout-btn {
    padding: 11px 26px;
    background: linear-gradient(135deg, #ef5350, #e53935);
    color: white; border: none; border-radius: 50px;
    font-size: 13px; font-weight: 700; font-family: 'Sora', sans-serif;
    cursor: pointer; display: flex; align-items: center; gap: 6px;
    box-shadow: 0 4px 14px rgba(239,83,80,0.4);
    transition: transform .2s, box-shadow .2s;
  }
  .ad-logout-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(239,83,80,0.5); }

  /* ── Main ── */
  .ad-main { position: relative; z-index: 1; padding: 32px 36px 48px; }

  /* ── KPI Cards ── */
  .ad-kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 18px;
    margin-bottom: 32px;
  }
  .ad-kpi {
    background: rgba(255,255,255,0.97);
    border-radius: 20px;
    padding: 22px 18px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    display: flex; align-items: center; gap: 16px;
    transition: transform .25s, box-shadow .25s;
  }
  .ad-kpi:hover { transform: translateY(-5px); box-shadow: 0 16px 40px rgba(0,0,0,0.18); }
  .ad-kpi-icon {
    width: 54px; height: 54px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px; flex-shrink: 0;
  }
  .ad-kpi-icon-1 { background: linear-gradient(135deg,#667eea,#764ba2); }
  .ad-kpi-icon-2 { background: linear-gradient(135deg,#f093fb,#f5576c); }
  .ad-kpi-icon-3 { background: linear-gradient(135deg,#ffa726,#fb8c00); }
  .ad-kpi-icon-4 { background: linear-gradient(135deg,#4CAF50,#2e7d32); }
  .ad-kpi-icon-5 { background: linear-gradient(135deg,#26c6da,#00838f); }
  .ad-kpi-icon-6 { background: linear-gradient(135deg,#ab47bc,#7b1fa2); }
  .ad-kpi-icon-7 { background: linear-gradient(135deg,#ef5350,#b71c1c); }
  .ad-kpi-icon-8 { background: linear-gradient(135deg,#42a5f5,#1565c0); }
  .ad-kpi-value { font-size: 32px; font-weight: 900; letter-spacing: -1px; line-height: 1; }
  .ad-kpi-value-1 { color: #667eea; }
  .ad-kpi-value-2 { color: #f5576c; }
  .ad-kpi-value-3 { color: #fb8c00; }
  .ad-kpi-value-4 { color: #4CAF50; }
  .ad-kpi-value-5 { color: #00838f; }
  .ad-kpi-value-6 { color: #7b1fa2; }
  .ad-kpi-value-7 { color: #b71c1c; }
  .ad-kpi-value-8 { color: #1565c0; }
  .ad-kpi-label { font-size: 12px; color: #65676b; font-weight: 600; margin-top: 4px; }
  .ad-kpi-detail { font-size: 11px; color: #adb0bb; margin-top: 3px; }

  /* ── Tab System ── */
  .ad-tabs-wrap {
    background: rgba(255,255,255,0.97);
    border-radius: 24px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.14);
    overflow: hidden;
  }
  .ad-tab-nav {
    display: flex;
    background: #f8f9fe;
    border-bottom: 1px solid #eaecf2;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .ad-tab-nav::-webkit-scrollbar { display: none; }
  .ad-tab-btn {
    padding: 18px 24px;
    border: none; background: none;
    font-family: 'Sora', sans-serif;
    font-size: 13px; font-weight: 600; color: #9095a0;
    cursor: pointer; white-space: nowrap;
    display: flex; align-items: center; gap: 8px;
    border-bottom: 3px solid transparent;
    transition: all .2s;
    position: relative; bottom: -1px;
  }
  .ad-tab-btn:hover { color: #5a3fb8; background: rgba(102,126,234,.06); }
  .ad-tab-btn.active { color: #5a3fb8; border-bottom-color: #667eea; background: white; }
  .ad-tab-btn .tab-icon { font-size: 16px; }
  .ad-tab-pane { display: none; padding: 32px 28px; }
  .ad-tab-pane.active { display: block; }

  /* ── Section header ── */
  .ad-section-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    margin-bottom: 22px; flex-wrap: wrap; gap: 14px;
  }
  .ad-section-title { font-size: 20px; font-weight: 800; color: #1c1e21; letter-spacing: -.4px; }
  .ad-section-sub { font-size: 12px; color: #9095a0; margin-top: 3px; }
  .ad-section-actions { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }

  /* ── Search ── */
  .ad-search {
    padding: 11px 20px;
    background: #f0f2f8;
    border: 1.5px solid transparent;
    border-radius: 50px;
    font-size: 13px; font-family: 'Sora', sans-serif;
    color: #1c1e21; outline: none; min-width: 220px;
    transition: all .2s;
  }
  .ad-search::placeholder { color: #adb0bb; }
  .ad-search:focus { background: white; border-color: #667eea; box-shadow: 0 0 0 4px rgba(102,126,234,.1); }

  /* ── Buttons ── */
  .ad-btn {
    padding: 11px 22px; border: none; border-radius: 50px;
    font-size: 13px; font-weight: 700; font-family: 'Sora', sans-serif;
    cursor: pointer; display: inline-flex; align-items: center; gap: 6px;
    transition: transform .2s, box-shadow .2s, filter .2s;
    white-space: nowrap; position: relative;
  }
  .ad-btn:hover { transform: translateY(-2px); filter: brightness(1.05); }
  .ad-btn:active { transform: translateY(0); }
  .ad-btn-purple { background: linear-gradient(135deg,#667eea,#764ba2); color: white; box-shadow: 0 4px 14px rgba(102,126,234,.4); }
  .ad-btn-green  { background: linear-gradient(135deg,#4CAF50,#2e7d32); color: white; box-shadow: 0 4px 14px rgba(76,175,80,.4); }
  .ad-btn-blue   { background: linear-gradient(135deg,#2196F3,#1565c0); color: white; box-shadow: 0 4px 14px rgba(33,150,243,.4); }
  .ad-btn-orange { background: linear-gradient(135deg,#FF9800,#e65100); color: white; box-shadow: 0 4px 14px rgba(255,152,0,.4); }
  .ad-btn-red    { background: linear-gradient(135deg,#ef5350,#b71c1c); color: white; box-shadow: 0 4px 14px rgba(239,83,80,.4); }
  .ad-btn-teal   { background: linear-gradient(135deg,#00BCD4,#00838f); color: white; box-shadow: 0 4px 14px rgba(0,188,212,.4); }
  .ad-btn-sm { padding: 7px 14px; font-size: 11px; }
  .ad-btn-icon { padding: 11px 14px; }

  /* ── Tooltip ── */
  [data-tip] { position: relative; }
  [data-tip]::after {
    content: attr(data-tip);
    position: absolute; bottom: calc(100% + 7px); left: 50%;
    transform: translateX(-50%) scale(0.85);
    background: #1c1e21; color: #fff;
    padding: 5px 10px; border-radius: 8px;
    font-size: 11px; font-weight: 600; white-space: nowrap;
    pointer-events: none; opacity: 0;
    transition: opacity .18s, transform .18s;
    z-index: 300;
  }
  [data-tip]::before {
    content: '';
    position: absolute; bottom: calc(100% + 3px); left: 50%;
    transform: translateX(-50%) scale(0.85);
    border: 5px solid transparent; border-top-color: #1c1e21;
    pointer-events: none; opacity: 0;
    transition: opacity .18s, transform .18s;
    z-index: 300;
  }
  [data-tip]:hover::after,
  [data-tip]:hover::before { opacity: 1; transform: translateX(-50%) scale(1); }

  /* ── Tables ── */
  .ad-table-wrap {
    background: #f8f9fe;
    border-radius: 16px;
    border: 1px solid #eaecf2;
    overflow: hidden;
    overflow-x: auto;
  }
  .ad-table { width: 100%; border-collapse: collapse; min-width: 700px; }
  .ad-table thead { background: white; }
  .ad-table th {
    padding: 14px 16px; font-size: 11px; font-weight: 700;
    color: #5a3fb8; text-align: left; text-transform: uppercase;
    letter-spacing: .6px; border-bottom: 2px solid #eaecf2;
  }
  .ad-table td {
    padding: 12px 16px; font-size: 13px; color: #3d4049;
    border-bottom: 1px solid #eef0f6; vertical-align: middle;
  }
  .ad-table tbody tr { transition: background .15s; }
  .ad-table tbody tr:hover { background: rgba(102,126,234,.04); }
  .ad-table tbody tr:last-child td { border-bottom: none; }
  .ad-avatar {
    width: 36px; height: 36px; border-radius: 50%;
    object-fit: cover; background: #e0e0e0;
    border: 2px solid #eaecf2;
  }

  /* ── Badges ── */
  .ad-badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 12px; border-radius: 50px;
    font-size: 11px; font-weight: 700;
  }
  .ad-badge-online    { background: #e8f5e9; color: #1b5e20; }
  .ad-badge-offline   { background: #f3f4f6; color: #6b7280; }
  .ad-badge-verified  { background: #e8f5e9; color: #1b5e20; }
  .ad-badge-unverified{ background: #fff3e0; color: #e65100; }
  .ad-badge-google    { background: #e8f0fe; color: #1a56db; }
  .ad-badge-local     { background: #f0f1f8; color: #5a3fb8; }
  .ad-badge-accepted  { background: #e8f5e9; color: #1b5e20; }
  .ad-badge-pending   { background: #fff8e1; color: #f57f17; }
  .ad-badge-rejected  { background: #fce4ec; color: #880e4f; }
  .ad-badge-banned    { background: #fce4ec; color: #b71c1c; }

  .ad-action-group { display: flex; gap: 6px; flex-wrap: wrap; }

  /* ── Charts ── */
  .ad-charts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 20px; margin-top: 4px;
  }
  .ad-chart-card {
    background: white; border-radius: 16px;
    padding: 22px; border: 1px solid #eaecf2;
  }
  .ad-chart-card h4 { font-size: 14px; font-weight: 700; color: #1c1e21; margin-bottom: 18px; }
  .ad-chart-wrap { position: relative; height: 260px; }
  .ad-chart-wide { grid-column: 1 / -1; }

  /* ── Analytics Detail Cards ── */
  .ad-detail-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 18px;
    margin-bottom: 28px;
  }
  .ad-detail-card {
    background: white; border-radius: 18px;
    border: 1px solid #eaecf2;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    transition: transform .2s, box-shadow .2s;
  }
  .ad-detail-card:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0,0,0,0.12); }
  .ad-detail-card-head {
    padding: 14px 18px;
    font-size: 13px; font-weight: 800;
    display: flex; align-items: center; gap: 8px;
  }
  .ad-detail-card-body { padding: 6px 0 10px; }
  .ad-detail-stat-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 8px 18px;
    border-bottom: 1px solid #f5f6fa;
    font-size: 13px;
  }
  .ad-detail-stat-row:last-child { border-bottom: none; }
  .ad-detail-stat-label { color: #65676b; font-weight: 500; }
  .ad-detail-stat-value { font-weight: 800; }

  /* Card color variants */
  .dcard-purple .ad-detail-card-head { background: linear-gradient(135deg,#667eea22,#764ba222); color: #5a3fb8; }
  .dcard-purple .ad-detail-stat-value { color: #5a3fb8; }
  .dcard-pink   .ad-detail-card-head { background: linear-gradient(135deg,#f093fb22,#f5576c22); color: #c2185b; }
  .dcard-pink   .ad-detail-stat-value { color: #c2185b; }
  .dcard-orange .ad-detail-card-head { background: linear-gradient(135deg,#ffa72622,#fb8c0022); color: #e65100; }
  .dcard-orange .ad-detail-stat-value { color: #e65100; }
  .dcard-green  .ad-detail-card-head { background: linear-gradient(135deg,#4CAF5022,#2e7d3222); color: #2e7d32; }
  .dcard-green  .ad-detail-stat-value { color: #2e7d32; }
  .dcard-teal   .ad-detail-card-head { background: linear-gradient(135deg,#26c6da22,#00838f22); color: #00697a; }
  .dcard-teal   .ad-detail-stat-value { color: #00697a; }
  .dcard-violet .ad-detail-card-head { background: linear-gradient(135deg,#ab47bc22,#7b1fa222); color: #7b1fa2; }
  .dcard-violet .ad-detail-stat-value { color: #7b1fa2; }
  .dcard-red    .ad-detail-card-head { background: linear-gradient(135deg,#ef535022,#b71c1c22); color: #b71c1c; }
  .dcard-red    .ad-detail-stat-value { color: #b71c1c; }

  /* ── Footer ── */
  .ad-footer {
    margin-top: 28px;
    background: rgba(255,255,255,0.97);
    border-radius: 16px;
    padding: 16px 24px;
    text-align: center;
    font-size: 13px; font-weight: 600; color: #5a3fb8;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  /* ── Modals ── */
  .ad-modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(20,0,60,0.45); z-index: 500;
    align-items: center; justify-content: center;
    overflow-y: auto; padding: 20px 0;
  }
  .ad-modal-overlay.show { display: flex; }
  .ad-modal {
    background: white; border-radius: 20px;
    padding: 32px; width: 90%; max-width: 480px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    position: relative; margin: auto;
  }
  .ad-modal-lg { max-width: 600px; }
  .ad-modal-close {
    position: absolute; top: 18px; right: 20px;
    background: none; border: none; font-size: 22px;
    cursor: pointer; color: #9095a0; transition: color .2s;
  }
  .ad-modal-close:hover { color: #333; }
  .ad-modal-title { font-size: 20px; font-weight: 800; color: #1c1e21; margin-bottom: 22px; }

  /* View modal rows */
  .ad-detail-row {
    display: flex; justify-content: space-between;
    padding: 10px 0; border-bottom: 1px solid #f0f2f5;
    font-size: 13px;
  }
  .ad-detail-row:last-child { border-bottom: none; }
  .ad-detail-label { font-weight: 700; color: #1c1e21; }
  .ad-detail-value { color: #65676b; }

  /* Edit / Award form */
  .ad-form-group { margin-bottom: 18px; }
  .ad-form-group label {
    display: block; font-size: 12px; font-weight: 700;
    color: #5a3fb8; margin-bottom: 6px; text-transform: uppercase; letter-spacing: .5px;
  }
  .ad-form-input {
    width: 100%; padding: 12px 16px;
    background: #f8f9fe; border: 1.5px solid #eaecf2;
    border-radius: 12px; font-size: 13px; font-family: 'Sora', sans-serif;
    color: #1c1e21; outline: none; transition: border-color .2s, box-shadow .2s;
  }
  .ad-form-input:focus { border-color: #667eea; box-shadow: 0 0 0 4px rgba(102,126,234,.1); background: white; }
  .ad-form-select {
    width: 100%; padding: 12px 16px;
    background: #f8f9fe; border: 1.5px solid #eaecf2;
    border-radius: 12px; font-size: 13px; font-family: 'Sora', sans-serif;
    color: #1c1e21; outline: none; cursor: pointer;
    appearance: none;
    transition: border-color .2s;
  }
  .ad-form-select:focus { border-color: #667eea; }
  .ad-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .ad-form-actions { display: flex; gap: 10px; margin-top: 24px; justify-content: flex-end; }

  @media (max-width: 768px) {
    .ad-main { padding: 20px 16px 40px; }
    .ad-header { padding: 14px 20px; }
    .ad-kpi-grid { grid-template-columns: repeat(2, 1fr); }
    .ad-tab-btn { padding: 14px 16px; font-size: 12px; }
    .ad-tab-pane { padding: 20px 16px; }
    .ad-charts-grid { grid-template-columns: 1fr; }
    .ad-form-row { grid-template-columns: 1fr; }
    .ad-detail-cards-grid { grid-template-columns: 1fr; }
  }
</style>

<div class="ad-root">
  <div class="ad-orb ad-orb-1"></div>
  <div class="ad-orb ad-orb-2"></div>
  <div class="ad-orb ad-orb-3"></div>

  <!-- ════ Header ════ -->
  <header class="ad-header">
    <div class="ad-header-brand">
      <div class="ad-crown">👑</div>
      <div>
        <div class="ad-brand-title">Admin Control Center</div>
        <div class="ad-brand-sub">Ghrami Platform Management System</div>
      </div>
    </div>
    <div class="ad-header-spacer"></div>
    <div class="ad-admin-info">
      <div class="ad-admin-name">{{ app.user.username ?? 'Admin' }}</div>
      <div class="ad-admin-role">System Administrator</div>
    </div>
    <a href="{{ path('app_logout') }}" class="ad-logout-btn" data-tip="Sign out of admin panel">🚪 Logout</a>
  </header>

  <!-- ════ Main ════ -->
  <div class="ad-main">

    <!-- ── KPI Grid ── -->
    <div class="ad-kpi-grid">
      <div class="ad-kpi">
        <div class="ad-kpi-icon ad-kpi-icon-1">👥</div>
        <div>
          <div class="ad-kpi-value ad-kpi-value-1">{{ stats.users }}</div>
          <div class="ad-kpi-label">Total Users</div>
          <div class="ad-kpi-detail">Online: {{ stats.active_users }}</div>
        </div>
      </div>
      <div class="ad-kpi">
        <div class="ad-kpi-icon ad-kpi-icon-2">🤝</div>
        <div>
          <div class="ad-kpi-value ad-kpi-value-2">{{ stats.friendships ?? 0 }}</div>
          <div class="ad-kpi-label">Friendships</div>
          <div class="ad-kpi-detail">Active connections</div>
        </div>
      </div>
      <div class="ad-kpi">
        <div class="ad-kpi-icon ad-kpi-icon-3">🏆</div>
        <div>
          <div class="ad-kpi-value ad-kpi-value-3">{{ stats.badges ?? 13 }}</div>
          <div class="ad-kpi-label">Badges</div>
          <div class="ad-kpi-detail">Unique types</div>
        </div>
      </div>
      <div class="ad-kpi">
        <div class="ad-kpi-icon ad-kpi-icon-4">🎓</div>
        <div>
          <div class="ad-kpi-value ad-kpi-value-4">{{ stats.classes }}</div>
          <div class="ad-kpi-label">Classes</div>
          <div class="ad-kpi-detail">Bookings: {{ stats.bookings }}</div>
        </div>
      </div>
      <div class="ad-kpi">
        <div class="ad-kpi-icon ad-kpi-icon-5">🤝</div>
        <div>
          <div class="ad-kpi-value ad-kpi-value-5">{{ stats.meetings ?? 22 }}</div>
          <div class="ad-kpi-label">Meetings</div>
          <div class="ad-kpi-detail">Scheduled</div>
        </div>
      </div>
      <div class="ad-kpi">
        <div class="ad-kpi-icon ad-kpi-icon-6">🌱</div>
        <div>
          <div class="ad-kpi-value ad-kpi-value-6">{{ stats.hobbies ?? 18 }}</div>
          <div class="ad-kpi-label">Hobbies</div>
          <div class="ad-kpi-detail">Active tracked</div>
        </div>
      </div>
      <div class="ad-kpi">
        <div class="ad-kpi-icon ad-kpi-icon-7">💬</div>
        <div>
          <div class="ad-kpi-value ad-kpi-value-7">{{ stats.posts }}</div>
          <div class="ad-kpi-label">Posts</div>
          <div class="ad-kpi-detail">Comments: {{ stats.comments ?? 0 }}</div>
        </div>
      </div>
      <div class="ad-kpi">
        <div class="ad-kpi-icon ad-kpi-icon-8">🏢</div>
        <div>
          <div class="ad-kpi-value ad-kpi-value-8">{{ providers|length }}</div>
          <div class="ad-kpi-label">Instructors</div>
          <div class="ad-kpi-detail">Applications</div>
        </div>
      </div>
    </div>

    <!-- ── Tabs ── -->
    <div class="ad-tabs-wrap">
      <nav class="ad-tab-nav">
        <button class="ad-tab-btn active" onclick="switchTab('users', this)" data-tip="Manage platform users">
          <span class="tab-icon">👥</span> Users
        </button>
        <button class="ad-tab-btn" onclick="switchTab('providers', this)" data-tip="Review instructor applications">
          <span class="tab-icon">🏢</span> Instructors
        </button>
        <button class="ad-tab-btn" onclick="switchTab('classes', this)" data-tip="Manage all classes">
          <span class="tab-icon">🎓</span> Classes
        </button>
        <button class="ad-tab-btn" onclick="switchTab('friendships', this)" data-tip="View and manage friendships">
          <span class="tab-icon">🤝</span> Friendships
        </button>
        <button class="ad-tab-btn" onclick="switchTab('badges', this)" data-tip="Manage and award badges">
          <span class="tab-icon">🏆</span> Badges
        </button>
        <button class="ad-tab-btn" onclick="switchTab('analytics', this)" data-tip="Charts and analytics">
          <span class="tab-icon">📊</span> Analytics
        </button>
      </nav>

      {# ════════════════════════ USERS TAB ════════════════════════ #}
      <div id="tab-users" class="ad-tab-pane active">
        <div class="ad-section-header">
          <div>
            <div class="ad-section-title">All Users</div>
            <div class="ad-section-sub">Manage your platform users</div>
          </div>
          <div class="ad-section-actions">
            <input class="ad-search" id="userSearch" type="text" placeholder="🔍 Search users...">
            <button class="ad-btn ad-btn-purple" onclick="exportAnalyticsPDF()" data-tip="Download full analytics PDF">📄 Export PDF</button>
          </div>
        </div>
        <div class="ad-table-wrap">
          <table class="ad-table" id="usersTable">
            <thead>
              <tr>
                <th>ID</th>
                <th>Avatar</th>
                <th>Username</th>
                <th>Email</th>
                <th>Location</th>
                <th>Auth</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {% for u in users %}
                <tr class="user-row"
                    data-username="{{ u.username|lower }}"
                    data-email="{{ u.email|lower }}"
                    data-location="{{ u.location|default('')|lower }}">
                  <td style="color:#adb0bb;font-size:12px;">{{ u.user_id }}</td>
                  <td>
                    <img src="" class="ad-avatar" alt="avatar"
                         onerror="this.src='https://ui-avatars.com/api/?name={{ u.username|url_encode }}&background=667eea&color=fff&size=38'">
                  </td>
                  <td><strong>{{ u.username }}</strong></td>
                  <td style="color:#65676b;">{{ u.email }}</td>
                  <td style="color:#65676b;font-size:12px;">
                    {{ u.location|default('—') }}
                  </td>
                  <td>
                    <span class="ad-badge {% if u.auth_provider == 'google' %}ad-badge-google{% else %}ad-badge-local{% endif %}">
                      {{ u.auth_provider == 'google' ? '🔵 Google' : '🔐 Local' }}
                    </span>
                  </td>
                  <td>
                    {% if u.is_banned %}
                      <span class="ad-badge ad-badge-banned">🚫 Banned</span>
                    {% elseif u.is_online %}
                      <span class="ad-badge ad-badge-online">🟢 Online</span>
                    {% else %}
                      <span class="ad-badge ad-badge-offline">⚫ Offline</span>
                    {% endif %}
                  </td>
                  <td>
                    <div class="ad-action-group">
                      <button class="ad-btn ad-btn-blue ad-btn-sm"
                              data-tip="View user details"
                              onclick="viewUser({{ u.user_id }}, '{{ u.username }}', '{{ u.email }}', {{ u.is_banned ? 1 : 0 }}, '{{ u.location|default('') }}', '{{ u.auth_provider }}')">
                        👁️ View
                      </button>
                      <button class="ad-btn ad-btn-orange ad-btn-sm"
                              data-tip="Edit this user"
                              onclick="openEditUser({{ u.user_id }}, '{{ u.username }}', '{{ u.email }}', '{{ u.location|default('') }}')">
                        ✏️ Edit
                      </button>
                      <button class="ad-btn {% if u.is_banned %}ad-btn-green{% else %}ad-btn-purple{% endif %} ad-btn-sm"
                              data-tip="{{ u.is_banned ? 'Unban this user' : 'Ban this user' }}"
                              onclick="banUser({{ u.user_id }}, '{{ u.username }}')">
                        🚫 {{ u.is_banned ? 'Unban' : 'Ban' }}
                      </button>
                      <button class="ad-btn ad-btn-red ad-btn-sm"
                              data-tip="Permanently delete user"
                              onclick="deleteUser({{ u.user_id }}, '{{ u.username }}')">
                        🗑️ Delete
                      </button>
                    </div>
                  </td>
                </tr>
              {% else %}
                <tr><td colspan="8" style="text-align:center;padding:40px;color:#adb0bb;">No users found.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

      {# ════════════════════════ PROVIDERS TAB ════════════════════════ #}
      <div id="tab-providers" class="ad-tab-pane">
        <div class="ad-section-header">
          <div>
            <div class="ad-section-title">Instructor Applications</div>
            <div class="ad-section-sub">Review and verify instructor applications</div>
          </div>
          <div class="ad-section-actions">
            <input class="ad-search" id="providerSearch" type="text" placeholder="🔍 Search instructors...">
          </div>
        </div>
        <div class="ad-table-wrap">
          <table class="ad-table" id="providersTable">
            <thead>
              <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Email</th>
                <th>Company / Studio</th>
                <th>Expertise</th>
                <th>Rating</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {% for p in providers %}
                <tr class="provider-row"
                    data-username="{{ p.username|lower }}"
                    data-company="{{ p.company_name|default('')|lower }}"
                    data-expertise="{{ p.expertise|default('')|lower }}">
                  <td style="color:#adb0bb;font-size:12px;">{{ p.provider_id }}</td>
                  <td><strong>{{ p.username }}</strong></td>
                  <td style="color:#65676b;font-size:12px;">{{ p.email ?? '—' }}</td>
                  <td>{{ p.company_name ?? '—' }}</td>
                  <td>
                    {% if p.expertise %}
                      <span class="ad-badge ad-badge-local">{{ p.expertise }}</span>
                    {% else %}
                      <span style="color:#adb0bb;">—</span>
                    {% endif %}
                  </td>
                  <td>⭐ {{ p.rating ?? '0.0' }}</td>
                  <td>
                    <span class="ad-badge {% if p.is_verified %}ad-badge-verified{% else %}ad-badge-unverified{% endif %}">
                      {{ p.is_verified ? '✓ Verified' : '✗ Pending' }}
                    </span>
                  </td>
                  <td>
                    <div class="ad-action-group">
                      <form method="post" action="{{ path('app_admin_toggle_provider_verify') }}" style="display:inline;">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_provider_toggle') }}">
                        <input type="hidden" name="provider_id" value="{{ p.provider_id }}">
                        <button type="submit"
                                class="ad-btn {% if p.is_verified %}ad-btn-red{% else %}ad-btn-green{% endif %} ad-btn-sm"
                                data-tip="{{ p.is_verified ? 'Revoke verification' : 'Approve this instructor' }}">
                          {{ p.is_verified ? '🔒 Unverify' : '🔓 Verify' }}
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              {% else %}
                <tr><td colspan="8" style="text-align:center;padding:40px;color:#adb0bb;">No providers found.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

      {# ════════════════════════ CLASSES TAB ════════════════════════ #}
      <div id="tab-classes" class="ad-tab-pane">
        <div class="ad-section-header">
          <div>
            <div class="ad-section-title">Classes</div>
            <div class="ad-section-sub">Manage all platform classes</div>
          </div>
          <div class="ad-section-actions">
            <input class="ad-search" id="classSearch" type="text" placeholder="🔍 Search classes...">
          </div>
        </div>
        <div class="ad-table-wrap">
          <table class="ad-table" id="classesTable">
            <thead>
              <tr>
                <th>Title</th><th>Provider</th><th>Category</th>
                <th>Price</th><th>Bookings</th><th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {% for c in classes %}
                <tr class="class-row"
                    data-title="{{ c.title|lower }}"
                    data-provider="{{ c.provider_username|lower }}">
                  <td><strong>{{ c.title }}</strong></td>
                  <td>{{ c.provider_username }}</td>
                  <td><span class="ad-badge ad-badge-local">{{ c.category ?? 'General' }}</span></td>
                  <td><strong>{{ c.price }} TND</strong></td>
                  <td>{{ c.booking_count }}</td>
                  <td>
                    <form method="post" action="{{ path('app_admin_class_delete') }}"
                          style="display:inline;"
                          onsubmit="return confirm('Delete this class?');">
                      <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_class_delete') }}">
                      <input type="hidden" name="class_id" value="{{ c.class_id }}">
                      <button type="submit" class="ad-btn ad-btn-red ad-btn-sm" data-tip="Delete this class permanently">🗑️ Delete</button>
                    </form>
                  </td>
                </tr>
              {% else %}
                <tr><td colspan="6" style="text-align:center;padding:40px;color:#adb0bb;">No classes found.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

      {# ════════════════════════ FRIENDSHIPS TAB ════════════════════════ #}
      <div id="tab-friendships" class="ad-tab-pane">
        <div class="ad-section-header">
          <div>
            <div class="ad-section-title">Friendship Management</div>
            <div class="ad-section-sub">View, edit and remove user friendships</div>
          </div>
          <div class="ad-section-actions">
            <input class="ad-search" id="friendshipSearch" type="text" placeholder="🔍 Search friendships...">
            <select class="ad-form-select" id="friendshipFilter" onchange="filterFriendships()" style="min-width:140px;padding:11px 16px;border-radius:50px;">
              <option value="">All Statuses</option>
              <option value="accepted">✅ Accepted</option>
              <option value="pending">⏳ Pending</option>
              <option value="rejected">❌ Rejected</option>
            </select>
          </div>
        </div>
        <div class="ad-table-wrap">
          <table class="ad-table" id="friendshipsTable">
            <thead>
              <tr>
                <th>ID</th>
                <th>User 1</th>
                <th>User 2</th>
                <th>Status</th>
                <th>Created At</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {% for f in friendships %}
                <tr class="friendship-row"
                    data-user1="{{ f.user1_username|default(f.user1_id)|lower }}"
                    data-user2="{{ f.user2_username|default(f.user2_id)|lower }}"
                    data-status="{{ f.status|lower }}">
                  <td style="color:#adb0bb;font-size:12px;">{{ f.friendship_id }}</td>
                  <td><strong>{{ f.user1_username ?? f.user1_id }}</strong></td>
                  <td><strong>{{ f.user2_username ?? f.user2_id }}</strong></td>
                  <td>
                    {% set st = f.status|lower %}
                    <span class="ad-badge
                      {% if st == 'accepted' %}ad-badge-accepted
                      {% elseif st == 'pending' %}ad-badge-pending
                      {% else %}ad-badge-rejected{% endif %}">
                      {% if st == 'accepted' %}✅ Accepted
                      {% elseif st == 'pending' %}⏳ Pending
                      {% else %}❌ Rejected{% endif %}
                    </span>
                  </td>
                  <td style="color:#65676b;font-size:12px;">{{ f.created_at ?? '—' }}</td>
                  <td>
                    <div class="ad-action-group">
                      <button class="ad-btn ad-btn-orange ad-btn-sm"
                              data-tip="Edit friendship status"
                              onclick="openEditFriendship({{ f.friendship_id }}, '{{ f.user1_username ?? f.user1_id }}', '{{ f.user2_username ?? f.user2_id }}', '{{ f.status }}')">
                        ✏️ Edit
                      </button>
                      <form method="post" action="{{ path('app_admin_friendship_delete') }}"
                            style="display:inline;"
                            onsubmit="return confirm('Delete this friendship?');">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_friendship_delete') }}">
                        <input type="hidden" name="friendship_id" value="{{ f.friendship_id }}">
                        <button type="submit" class="ad-btn ad-btn-red ad-btn-sm" data-tip="Remove this friendship">🗑️ Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              {% else %}
                <tr><td colspan="6" style="text-align:center;padding:40px;color:#adb0bb;">No friendships found.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

      {# ════════════════════════ BADGES TAB ════════════════════════ #}
      <div id="tab-badges" class="ad-tab-pane">
        <div class="ad-section-header">
          <div>
            <div class="ad-section-title">Badge Management</div>
            <div class="ad-section-sub">View distribution and award badges to users</div>
          </div>
          <div class="ad-section-actions">
            <input class="ad-search" id="badgeSearch" type="text" placeholder="🔍 Search badges...">
            <button class="ad-btn ad-btn-purple" onclick="openAwardBadgeModal()" data-tip="Award a badge to a user">🏆 Award Badge</button>
          </div>
        </div>

        {# Badge distribution mini-chart #}
        <div style="background:#f8f9fe;border-radius:16px;border:1px solid #eaecf2;padding:22px;margin-bottom:24px;">
          <h4 style="font-size:14px;font-weight:700;color:#1c1e21;margin-bottom:16px;">📊 Badge Distribution</h4>
          <div style="position:relative;height:220px;"><canvas id="chartBadgeTab"></canvas></div>
        </div>

        <div class="ad-table-wrap">
          <table class="ad-table" id="badgesTable">
            <thead>
              <tr>
                <th>ID</th>
                <th>User</th>
                <th>Badge Name</th>
                <th>Description</th>
                <th>Awarded At</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {% for b in badges %}
                <tr class="badge-row"
                    data-name="{{ b.badge_name|lower }}"
                    data-user="{{ b.username|default('')|lower }}">
                  <td style="color:#adb0bb;font-size:12px;">{{ b.badge_id }}</td>
                  <td><strong>{{ b.username ?? b.user_id }}</strong></td>
                  <td>
                    <span class="ad-badge ad-badge-local">🏆 {{ b.badge_name }}</span>
                  </td>
                  <td style="color:#65676b;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                    {{ b.description ?? '—' }}
                  </td>
                  <td style="color:#65676b;font-size:12px;">{{ b.awarded_at ?? '—' }}</td>
                  <td>
                    <div class="ad-action-group">
                      <button class="ad-btn ad-btn-blue ad-btn-sm"
                              data-tip="View badge details"
                              onclick="viewBadge({{ b.badge_id }}, '{{ b.badge_name }}', '{{ b.description ?? '' }}', '{{ b.username ?? b.user_id }}')">
                        👁️ View
                      </button>
                      <form method="post" action="{{ path('app_admin_badge_delete') }}"
                            style="display:inline;"
                            onsubmit="return confirm('Remove this badge?');">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_badge_delete') }}">
                        <input type="hidden" name="badge_id" value="{{ b.badge_id }}">
                        <button type="submit" class="ad-btn ad-btn-red ad-btn-sm" data-tip="Remove badge from user">🗑️ Remove</button>
                      </form>
                    </div>
                  </td>
                </tr>
              {% else %}
                <tr><td colspan="6" style="text-align:center;padding:40px;color:#adb0bb;">No badges found.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

      {# ════════════════════════ ANALYTICS TAB ════════════════════════ #}
      <div id="tab-analytics" class="ad-tab-pane">
        <div class="ad-section-header">
          <div>
            <div class="ad-section-title">Platform Analytics</div>
            <div class="ad-section-sub">Charts, breakdowns and performance overview</div>
          </div>
          <div class="ad-section-actions">
            <button class="ad-btn ad-btn-purple" onclick="exportAnalyticsPDF()" data-tip="Download full analytics as PDF">📄 Export PDF</button>
          </div>
        </div>

        {# ── 7 Detail Cards ── #}
        <div class="ad-detail-cards-grid">

          {# 1 — Users #}
          <div class="ad-detail-card dcard-purple">
            <div class="ad-detail-card-head">👥 Users Analytics</div>
            <div class="ad-detail-card-body">
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Total Users</span><span class="ad-detail-stat-value">{{ stats.users }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Online Now</span><span class="ad-detail-stat-value">{{ stats.active_users }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Banned</span><span class="ad-detail-stat-value">{{ stats.banned_users ?? 0 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Google Sign-In</span><span class="ad-detail-stat-value">{{ stats.google_users ?? 0 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Local Accounts</span><span class="ad-detail-stat-value">{{ stats.local_users ?? 0 }}</span></div>
            </div>
          </div>

          {# 2 — Social #}
          <div class="ad-detail-card dcard-pink">
            <div class="ad-detail-card-head">💬 Social Stats</div>
            <div class="ad-detail-card-body">
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Total Posts</span><span class="ad-detail-stat-value">{{ stats.posts }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Comments</span><span class="ad-detail-stat-value">{{ stats.comments ?? 0 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Likes</span><span class="ad-detail-stat-value">{{ stats.likes ?? 0 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Stories</span><span class="ad-detail-stat-value">{{ stats.stories ?? 0 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Active Friendships</span><span class="ad-detail-stat-value">{{ stats.accepted_friendships ?? 0 }}</span></div>
            </div>
          </div>

          {# 3 — Classes / Revenue #}
          <div class="ad-detail-card dcard-orange">
            <div class="ad-detail-card-head">🎓 Classes &amp; Revenue</div>
            <div class="ad-detail-card-body">
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Total Classes</span><span class="ad-detail-stat-value">{{ stats.classes }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Total Bookings</span><span class="ad-detail-stat-value">{{ stats.bookings }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Completed</span><span class="ad-detail-stat-value">{{ stats.completed_bookings ?? 0 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Pending</span><span class="ad-detail-stat-value">{{ stats.pending_bookings ?? 0 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Total Revenue</span><span class="ad-detail-stat-value">{{ stats.total_revenue ?? '0.00' }} TND</span></div>
            </div>
          </div>

          {# 4 — Hobbies #}
          <div class="ad-detail-card dcard-green">
            <div class="ad-detail-card-head">🌱 Hobbies Details</div>
            <div class="ad-detail-card-body">
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Total Hobbies</span><span class="ad-detail-stat-value">{{ stats.hobbies ?? 18 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Total Hours</span><span class="ad-detail-stat-value">{{ stats.hobby_hours ?? '0.0' }} hrs</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Milestones</span><span class="ad-detail-stat-value">{{ stats.milestones ?? 0 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Achieved</span><span class="ad-detail-stat-value">{{ stats.achieved_milestones ?? 0 }}</span></div>
            </div>
          </div>

          {# 5 — Meetings #}
          <div class="ad-detail-card dcard-teal">
            <div class="ad-detail-card-head">🤝 Meetings Breakdown</div>
            <div class="ad-detail-card-body">
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Total Meetings</span><span class="ad-detail-stat-value">{{ stats.meetings ?? 22 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Scheduled</span><span class="ad-detail-stat-value">{{ stats.scheduled_meetings ?? 0 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Completed</span><span class="ad-detail-stat-value">{{ stats.completed_meetings ?? 0 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Cancelled</span><span class="ad-detail-stat-value">{{ stats.cancelled_meetings ?? 0 }}</span></div>
            </div>
          </div>

          {# 6 — Badges #}
          <div class="ad-detail-card dcard-violet">
            <div class="ad-detail-card-head">🏆 Badges Distribution</div>
            <div class="ad-detail-card-body">
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Total Badges</span><span class="ad-detail-stat-value">{{ stats.badges ?? 13 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Unique Types</span><span class="ad-detail-stat-value">{{ stats.unique_badge_types ?? 0 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Social Butterfly</span><span class="ad-detail-stat-value">{{ stats.badge_social ?? 45 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Class Hero</span><span class="ad-detail-stat-value">{{ stats.badge_class ?? 38 }}</span></div>
              <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Hobby Master</span><span class="ad-detail-stat-value">{{ stats.badge_hobby ?? 32 }}</span></div>
            </div>

                <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Online Now</span><span class="ad-detail-stat-value">{{ stats.active_users }}</span></div>
                <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Banned</span><span class="ad-detail-stat-value">{{ stats.banned_users ?? 0 }}</span></div>

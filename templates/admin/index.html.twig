<script>
/* ════════════════════════════════════════
   TAB SWITCHING
════════════════════════════════════════ */
function switchTab(name, btn) {
  document.querySelectorAll('.ad-tab-pane').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.ad-tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
  if (name === 'analytics') initCharts();
  if (name === 'badges')    initBadgeTabChart();
}

/* ════════════════════════════════════════
   SEARCH / FILTER
════════════════════════════════════════ */
function bindSearch(inputId, rowClass, dataAttrs) {
  const el = document.getElementById(inputId);
  if (!el) return;
  el.addEventListener('keyup', () => {
    const q = el.value.toLowerCase();
    document.querySelectorAll(rowClass).forEach(r => {
      const text = dataAttrs
        ? dataAttrs.map(a => (r.dataset[a] || '')).join(' ')
        : r.textContent.toLowerCase();
      r.style.display = text.includes(q) ? '' : 'none';
    });
  });
}

bindSearch('userSearch',       '.user-row',       ['username','email','location']);
bindSearch('providerSearch',   '.provider-row',   ['username','company','expertise']);
bindSearch('classSearch',      '.class-row',      ['title','provider']);
bindSearch('friendshipSearch', '.friendship-row', ['user1','user2','status']);
bindSearch('badgeSearch',      '.badge-row',      ['name','user']);

function filterFriendships() {
  const val = document.getElementById('friendshipFilter').value.toLowerCase();
  const q   = document.getElementById('friendshipSearch').value.toLowerCase();
  document.querySelectorAll('.friendship-row').forEach(r => {
    const matchFilter = !val || r.dataset.status === val;
    const matchSearch = !q || (r.dataset.user1 + r.dataset.user2 + r.dataset.status).includes(q);
    r.style.display = (matchFilter && matchSearch) ? '' : 'none';
  });
}

/* ════════════════════════════════════════
   MODALS
════════════════════════════════════════ */
function closeModal(id) { document.getElementById(id).classList.remove('show'); }
document.querySelectorAll('.ad-modal-overlay').forEach(o => {
  o.addEventListener('click', function(e) { if (e.target === this) closeModal(this.id); });
});

function viewUser(id, username, email, isBanned, location, auth) {
  document.getElementById('modalUserId').textContent   = id;
  document.getElementById('modalUsername').textContent = username;
  document.getElementById('modalEmail').textContent    = email;
  document.getElementById('modalLocation').textContent = location || '—';
  document.getElementById('modalAuth').textContent     = auth === 'google' ? '🔵 Google' : '🔐 Local';
  document.getElementById('modalStatus').textContent   = isBanned ? '🚫 Banned' : '✅ Active';
  document.getElementById('userModal').classList.add('show');
}

function openEditUser(id, username, email, location) {
  document.getElementById('editUserId').value       = id;
  document.getElementById('editUsername').value     = username;
  document.getElementById('editEmail').value        = email;
  document.getElementById('editLocation').value     = location;
  document.getElementById('editUserModal').classList.add('show');
}

function openEditFriendship(id, user1, user2, status) {
  document.getElementById('editFriendshipId').value     = id;
  document.getElementById('editFriendshipUser1').value  = user1;
  document.getElementById('editFriendshipUser2').value  = user2;
  const sel = document.getElementById('editFriendshipStatus');
  const up  = status.toUpperCase();
  for (let opt of sel.options) { if (opt.value === up) { opt.selected = true; break; } }
  document.getElementById('editFriendshipModal').classList.add('show');
}

function viewBadge(id, name, desc, user) {
  document.getElementById('modalBadgeId').textContent   = id;
  document.getElementById('modalBadgeName').textContent = name;
  document.getElementById('modalBadgeUser').textContent = user;
  document.getElementById('modalBadgeDesc').textContent = desc || '—';
  document.getElementById('badgeModal').classList.add('show');
}

function openAwardBadgeModal() {
  document.getElementById('awardBadgeModal').classList.add('show');
}

/* ════════════════════════════════════════
   BAN / DELETE USER
════════════════════════════════════════ */
function banUser(userId, username) {
  if (!confirm('Toggle ban for ' + username + '?')) return;
  const form = document.createElement('form');
  form.method  = 'POST';
  form.action  = '{{ path("app_admin_toggle_user_ban") }}';
  form.innerHTML = `<input type="hidden" name="user_id" value="${userId}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_user_toggle') }}">`;
  document.body.appendChild(form);
  form.submit();
}

function deleteUser(userId, username) {
  if (!confirm('Permanently delete user "' + username + '"? This cannot be undone.')) return;
  const form = document.createElement('form');
  form.method  = 'POST';
  form.action  = '{{ path("app_admin_user_delete") }}';
  form.innerHTML = `<input type="hidden" name="user_id" value="${userId}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_user_delete') }}">`;
  document.body.appendChild(form);
  form.submit();
}

/* ════════════════════════════════════════
   PDF EXPORT  (jsPDF + autoTable)
════════════════════════════════════════ */
function exportAnalyticsPDF() {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
  const now = new Date();
  const dateStr = now.toLocaleString('en-GB');
  const purple  = [90, 63, 184];
  const dark    = [28, 30, 33];
  const gray    = [100, 101, 107];

  // ── Title page header ──
  doc.setFillColor(...purple);
  doc.rect(0, 0, 210, 34, 'F');
  doc.setTextColor(255, 255, 255);
  doc.setFontSize(20); doc.setFont('helvetica', 'bold');
  doc.text('GHRAMI PLATFORM — ANALYTICS REPORT', 105, 16, { align: 'center' });
  doc.setFontSize(10); doc.setFont('helvetica', 'normal');
  doc.text('Generated: ' + dateStr, 105, 26, { align: 'center' });

  doc.setTextColor(...dark);
  let y = 46;

  function addSection(title, head, rows, color) {
    if (y > 250) { doc.addPage(); y = 20; }
    doc.setFontSize(13); doc.setFont('helvetica', 'bold');
    doc.setTextColor(...color);
    doc.text(title, 14, y); y += 8;
    doc.autoTable({
      startY: y,
      head: [head],
      body: rows,
      theme: 'striped',
      headStyles: { fillColor: color, textColor: [255,255,255], fontStyle: 'bold', fontSize: 10 },
      bodyStyles: { fontSize: 10, textColor: [50,50,50] },
      alternateRowStyles: { fillColor: [248,249,254] },
      margin: { left: 14, right: 14 },
    });
    y = doc.lastAutoTable.finalY + 12;
  }

  addSection('👥 Users', ['Metric', 'Value'], [
    ['Total Users',     '{{ stats.users }}'],
    ['Online Now',      '{{ stats.active_users }}'],
    ['Banned',          '{{ stats.banned_users ?? 0 }}'],
    ['Google Sign-In',  '{{ stats.google_users ?? 0 }}'],
    ['Local Accounts',  '{{ stats.local_users ?? 0 }}'],
  ], [90,63,184]);

  addSection('💬 Social Feed', ['Metric', 'Value'], [
    ['Total Posts',        '{{ stats.posts }}'],
    ['Comments',           '{{ stats.comments ?? 0 }}'],
    ['Likes',              '{{ stats.likes ?? 0 }}'],
    ['Stories',            '{{ stats.stories ?? 0 }}'],
    ['Active Friendships', '{{ stats.accepted_friendships ?? 0 }}'],
  ], [194,24,91]);

  addSection('🎓 Classes & Revenue', ['Metric', 'Value'], [
    ['Total Classes',  '{{ stats.classes }}'],
    ['Total Bookings', '{{ stats.bookings }}'],
    ['Completed',      '{{ stats.completed_bookings ?? 0 }}'],
    ['Pending',        '{{ stats.pending_bookings ?? 0 }}'],
    ['Cancelled',      '{{ stats.cancelled_bookings ?? 0 }}'],
    ['Total Revenue',  '{{ stats.total_revenue ?? "0.00" }} TND'],
  ], [230,101,0]);

  addSection('🌱 Hobbies', ['Metric', 'Value'], [
    ['Total Hobbies',    '{{ stats.hobbies ?? 18 }}'],
    ['Total Hours',      '{{ stats.hobby_hours ?? "0.0" }} hrs'],
    ['Milestones',       '{{ stats.milestones ?? 0 }}'],
    ['Achieved',         '{{ stats.achieved_milestones ?? 0 }}'],
  ], [46,125,50]);

  addSection('🤝 Meetings', ['Metric', 'Value'], [
    ['Total Meetings', '{{ stats.meetings ?? 22 }}'],
    ['Scheduled',      '{{ stats.scheduled_meetings ?? 0 }}'],
    ['Completed',      '{{ stats.completed_meetings ?? 0 }}'],
    ['Cancelled',      '{{ stats.cancelled_meetings ?? 0 }}'],
  ], [0,105,122]);

  addSection('🏆 Badges', ['Metric', 'Value'], [
    ['Total Badges',    '{{ stats.badges ?? 13 }}'],
    ['Unique Types',    '{{ stats.unique_badge_types ?? 0 }}'],
    ['Social Butterfly','{{ stats.badge_social ?? 45 }}'],
    ['Class Hero',      '{{ stats.badge_class ?? 38 }}'],
    ['Hobby Master',    '{{ stats.badge_hobby ?? 32 }}'],
  ], [123,31,162]);

  addSection('🤝 Friendships', ['Metric', 'Value'], [
    ['Total',    '{{ stats.friendships ?? 0 }}'],
    ['Accepted', '{{ stats.accepted_friendships ?? 0 }}'],
    ['Pending',  '{{ stats.pending_friendships ?? 0 }}'],
    ['Rejected', '{{ stats.rejected_friendships ?? 0 }}'],
  ], [183,28,28]);

  // Footer on last page
  const pCount = doc.internal.getNumberOfPages();
  for (let i = 1; i <= pCount; i++) {
    doc.setPage(i);
    doc.setFontSize(9); doc.setTextColor(...gray);
    doc.text('© 2026 Ghrami by OPGG  •  Page ' + i + ' of ' + pCount, 105, 290, { align: 'center' });
  }

  doc.save('Ghrami_Analytics_' + now.getFullYear()
    + String(now.getMonth()+1).padStart(2,'0')
    + String(now.getDate()).padStart(2,'0') + '.pdf');
}

/* ════════════════════════════════════════
   CHARTS
════════════════════════════════════════ */
let chartsInited = false;
let badgeTabInited = false;

function initCharts() {
  if (chartsInited) return;
  chartsInited = true;

  const palette = ['#667eea','#f5576c','#4CAF50','#FF9800','#00BCD4','#9C27B0','#ef5350','#42a5f5','#26c6da','#ffa726'];

  // ── 10-module horizontal bar ──
  new Chart(document.getElementById('chartPopulation').getContext('2d'), {
    type: 'bar',
    data: {
      labels: ['Users','Friendships','Badges','Classes','Bookings','Hobbies','Meetings','Posts','Comments','Stories'],
      datasets: [{
        label: 'Count',
        data: [
          {{ stats.users }},
          {{ stats.friendships ?? 0 }},
          {{ stats.badges ?? 13 }},
          {{ stats.classes }},
          {{ stats.bookings }},
          {{ stats.hobbies ?? 18 }},
          {{ stats.meetings ?? 22 }},
          {{ stats.posts }},
          {{ stats.comments ?? 0 }},
          {{ stats.stories ?? 0 }}
        ],
        backgroundColor: palette,
        borderRadius: 8,
        borderSkipped: false,
      }]
    },
    options: {
      indexAxis: 'y',
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false },
        tooltip: { callbacks: { label: ctx => '  ' + ctx.parsed.x.toLocaleString() } } },
      scales: {
        x: { beginAtZero: true, grid: { color: '#f0f2f5' },
             ticks: { font: { family: 'Sora', size: 11 } } },
        y: { grid: { display: false },
             ticks: { font: { family: 'Sora', size: 12, weight: '600' } } }
      }
    }
  });

  // ── Bookings doughnut ──
  new Chart(document.getElementById('chartBookings').getContext('2d'), {
    type: 'doughnut',
    data: { labels: ['Completed','Pending','Cancelled'],
      datasets: [{ data: [65,25,10], backgroundColor: ['#4CAF50','#2196F3','#f44336'],
        borderColor: '#fff', borderWidth: 3 }] },
    options: { responsive:true, maintainAspectRatio:false,
      plugins: { legend: { position:'bottom' } }, cutout: '65%' }
  });

  // ── Meetings doughnut ──
  new Chart(document.getElementById('chartMeetings').getContext('2d'), {
    type: 'doughnut',
    data: { labels: ['Completed','Scheduled','Cancelled'],
      datasets: [{ data: [45,35,20], backgroundColor: ['#4CAF50','#2196F3','#FF9800'],
        borderColor: '#fff', borderWidth: 3 }] },
    options: { responsive:true, maintainAspectRatio:false,
      plugins: { legend: { position:'bottom' } }, cutout: '65%' }
  });

  // ── Top Badges horizontal ──
  new Chart(document.getElementById('chartBadges').getContext('2d'), {
    type: 'bar',
    data: { labels: ['Social Butterfly','Class Hero','Hobby Master','Connector','Early Adopter'],
      datasets: [{ label: 'Count', data: [45,38,32,28,21],
        backgroundColor: ['#667eea','#f5576c','#4CAF50','#FF9800','#00BCD4'], borderRadius: 8 }] },
    options: { indexAxis: 'y', responsive:true, maintainAspectRatio:false,
      plugins: { legend: { display:false } },
      scales: { x: { beginAtZero:true, grid: { color:'#f0f2f5' } }, y: { grid: { display:false } } } }
  });

  // ── Friendships doughnut ──
  new Chart(document.getElementById('chartFriendships').getContext('2d'), {
    type: 'doughnut',
    data: { labels: ['Accepted','Pending','Rejected'],
      datasets: [{ data: [
          {{ stats.accepted_friendships ?? 0 }},
          {{ stats.pending_friendships ?? 0 }},
          {{ stats.rejected_friendships ?? 0 }}
        ],
        backgroundColor: ['#4CAF50','#FF9800','#f44336'],
        borderColor: '#fff', borderWidth: 3 }] },
    options: { responsive:true, maintainAspectRatio:false,
      plugins: { legend: { position:'bottom' } }, cutout: '65%' }
  });
}

function initBadgeTabChart() {
  if (badgeTabInited) return;
  badgeTabInited = true;
  new Chart(document.getElementById('chartBadgeTab').getContext('2d'), {
    type: 'bar',
    data: { labels: ['Social Butterfly','Class Hero','Hobby Master','Connector','Early Adopter','Top Rated','Community Leader'],
      datasets: [{ label: 'Count', data: [45,38,32,28,21,17,12],
        backgroundColor: ['#667eea','#f5576c','#4CAF50','#FF9800','#00BCD4','#9C27B0','#ef5350'],
        borderRadius: 8, borderSkipped: false }] },
    options: { indexAxis: 'y', responsive:true, maintainAspectRatio:false,
      plugins: { legend: { display:false } },
      scales: { x: { beginAtZero:true, grid: { color:'#f0f2f5' } }, y: { grid: { display:false } } } }
  });
}
</script>

          <table class="ad-table" id="meetingsTable">
            <thead>
              <tr>
                <th onclick="sortTable('meetingsTable',0,this)">ID</th>
                <th onclick="sortTable('meetingsTable',1,this)">Organizer</th>
                <th onclick="sortTable('meetingsTable',2,this)">Type</th>
                <th onclick="sortTable('meetingsTable',3,this)">Status</th>
                <th onclick="sortTable('meetingsTable',4,this)">Scheduled</th>
                <th onclick="sortTable('meetingsTable',5,this)">Participants</th>
                <th class="no-sort">Actions</th>
              </tr>
            </thead>

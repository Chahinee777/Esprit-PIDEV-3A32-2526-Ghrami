<script>
/* ════════════════════════════════════════
   TAB SWITCHING
════════════════════════════════════════ */
const tabMeta = {
  users:       { title: 'Users',               sub: 'Manage platform users' },
  providers:   { title: 'Instructors',          sub: 'Review instructor applications' },
  classes:     { title: 'Classes',              sub: 'Manage all platform classes' },
  hobbies:     { title: 'Hobbies',              sub: 'Manage user hobbies and logged hours' },
  meetings:    { title: 'Meetings',             sub: 'Manage scheduled meetings' },
  friendships: { title: 'Friendships',          sub: 'View and manage user friendships' },
  badges:      { title: 'Badges',               sub: 'Create, edit and remove user badges' },
  social:      { title: 'Social Media',         sub: 'Moderate posts and comments' },
  analytics:   { title: 'Analytics',            sub: 'Charts, breakdowns and performance overview' },
};

function switchTab(name, btn) {
  document.querySelectorAll('.ad-tab-pane').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.ad-tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.ad-nav-item').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  if (btn) btn.classList.add('active');
  // Sync header
  const meta = tabMeta[name];
  if (meta) {
    const t = document.getElementById('adPageTitle');
    const s = document.getElementById('adPageSub');
    if (t) t.textContent = meta.title;
    if (s) s.textContent = meta.sub;
  }
  if (name === 'analytics') initCharts();
  if (name === 'badges')    initBadgeTabChart();
  // Close mobile sidebar
  if (window.innerWidth <= 900) {
    document.getElementById('adSidebar').classList.remove('open');
  }
}

/* ════════════════════════════════════════
   SEARCH / FILTER
════════════════════════════════════════ */
function bindSearch(inputId, rowClass, dataAttrs) {
  const el = document.getElementById(inputId);
  if (!el) return;
  el.addEventListener('keyup', () => {
    const q = el.value.toLowerCase();
    document.querySelectorAll(rowClass).forEach(r => {
      const text = dataAttrs
        ? dataAttrs.map(a => (r.dataset[a] || '')).join(' ')
        : r.textContent.toLowerCase();
      r.style.display = text.includes(q) ? '' : 'none';
    });
  });
}

bindSearch('userSearch',       '.user-row',       ['username','email','location']);
bindSearch('providerSearch',   '.provider-row',   ['username','company','expertise']);
bindSearch('classSearch',      '.class-row',      ['title','provider']);
bindSearch('hobbySearch',      '.hobby-row',      ['user','name','category']);
bindSearch('meetingSearch',    '.meeting-row',    ['organizer','type','status','location']);
bindSearch('friendshipSearch', '.friendship-row', ['user1','user2','status']);
bindSearch('badgeSearch',      '.badge-row',      ['name','user']);
bindSearch('postSearch',       '.post-row',       ['content','author']);
// bindSearch('commentSearch',    '.comment-row',    ['content','author']); // Replaced with filterComments

function filterFriendships() {
  const val = document.getElementById('friendshipFilter').value.toLowerCase();
  const q   = document.getElementById('friendshipSearch').value.toLowerCase();
  document.querySelectorAll('.friendship-row').forEach(r => {
    const matchFilter = !val || r.dataset.status === val;
    const matchSearch = !q || (r.dataset.user1 + r.dataset.user2 + r.dataset.status).includes(q);
    r.style.display = (matchFilter && matchSearch) ? '' : 'none';
  });
}

function filterComments() {
  const year = document.getElementById('commentYearFilter').value;
  const month = document.getElementById('commentMonthFilter').value;
  const q = document.getElementById('commentSearch').value.toLowerCase();
  document.querySelectorAll('.comment-row').forEach(r => {
    const rowDate = r.dataset.date;
    const rowYear = rowDate ? new Date(rowDate).getFullYear().toString() : '';
    const rowMonth = rowDate ? (new Date(rowDate).getMonth() + 1).toString() : '';
    const matchYear = !year || rowYear === year;
    const matchMonth = !month || rowMonth === month;
    const matchSearch = !q || (r.dataset.content + ' ' + r.dataset.author).includes(q);
    r.style.display = (matchYear && matchMonth && matchSearch) ? '' : 'none';
  });
}

/* ════════════════════════════════════════
   MODALS
════════════════════════════════════════ */
function closeModal(id) { document.getElementById(id).classList.remove('show'); }
document.querySelectorAll('.ad-modal-overlay').forEach(o => {
  o.addEventListener('click', function(e) { if (e.target === this) closeModal(this.id); });
});

function viewUser(id, username, email, isBanned, location, auth) {
  document.getElementById('modalUserId').textContent   = id;
  document.getElementById('modalUsername').textContent = username;
  document.getElementById('modalEmail').textContent    = email;
  document.getElementById('modalLocation').textContent = location || '—';
  document.getElementById('modalAuth').textContent     = auth === 'google' ? '🔵 Google' : '🔐 Local';
  document.getElementById('modalStatus').textContent   = isBanned ? '🚫 Banned' : '✅ Active';
  document.getElementById('userModal').classList.add('show');
}

function openEditUser(id, username, email, location) {
  document.getElementById('editUserId').value       = id;
  document.getElementById('editUsername').value     = username;
  document.getElementById('editEmail').value        = email;
  document.getElementById('editLocation').value     = location;
  document.getElementById('editUserModal').classList.add('show');
}

function openEditFriendship(id, user1, user2, status) {
  document.getElementById('editFriendshipId').value     = id;
  document.getElementById('editFriendshipUser1').value  = user1;
  document.getElementById('editFriendshipUser2').value  = user2;
  const sel = document.getElementById('editFriendshipStatus');
  const up  = status.toUpperCase();
  for (let opt of sel.options) { if (opt.value === up) { opt.selected = true; break; } }
  document.getElementById('editFriendshipModal').classList.add('show');
}

function viewBadge(id, name, desc, user) {
  document.getElementById('modalBadgeId').textContent   = id;
  document.getElementById('modalBadgeName').textContent = name;
  document.getElementById('modalBadgeUser').textContent = user;
  document.getElementById('modalBadgeDesc').textContent = desc || '—';
  document.getElementById('badgeModal').classList.add('show');
}

function openAwardBadgeModal() {
  document.getElementById('awardBadgeModal').classList.add('show');
}

function openEditBadgeModal(id, name, desc) {
  document.getElementById('editBadgeId').value   = id;
  document.getElementById('editBadgeName').value = name;
  document.getElementById('editBadgeDesc').value = desc;
  document.getElementById('editBadgeModal').classList.add('show');
}

/* Award modal: sync custom text input when user picks "Custom..." */
function syncBadgeNameInput(sel) {
  const custom = document.getElementById('awardBadgeNameCustom');
  if (!custom) return;
  if (sel.value === '__custom__') {
    custom.style.display = 'block';
    custom.required = true;
    sel.name = '';
    custom.name = 'badge_name';
  } else {
    custom.style.display = 'none';
    custom.required = false;
    custom.name = '';
    sel.name = 'badge_name';
  }
}

function prepareAwardSubmit(form) {
  const sel = document.getElementById('awardBadgeNameSelect');
  if (sel && sel.value === '__custom__') {
    const txt = document.getElementById('awardBadgeNameCustom');
    if (!txt || !txt.value.trim()) { alert('Please enter a badge name.'); return false; }
  }
  return true;
}

/* ════════════════════════════════════════
   TABLE SORTING
════════════════════════════════════════ */
const _sortState = {};

function sortTable(tableId, colIdx, thEl) {
  const table  = document.getElementById(tableId);
  const tbody  = table.querySelector('tbody');
  const rows   = Array.from(tbody.querySelectorAll('tr'));
  const key    = tableId + ':' + colIdx;
  const asc    = _sortState[key] !== true;
  _sortState[key] = asc;

  // Update header indicators
  table.querySelectorAll('th').forEach(th => th.classList.remove('sort-asc','sort-desc'));
  thEl.classList.add(asc ? 'sort-asc' : 'sort-desc');

  rows.sort((a, b) => {
    const ca = a.cells[colIdx]?.textContent.trim() ?? '';
    const cb = b.cells[colIdx]?.textContent.trim() ?? '';
    // Numeric sort if both look like numbers
    const na = parseFloat(ca.replace(/[^0-9.\-]/g, ''));
    const nb = parseFloat(cb.replace(/[^0-9.\-]/g, ''));
    if (!isNaN(na) && !isNaN(nb)) return asc ? na - nb : nb - na;
    return asc ? ca.localeCompare(cb) : cb.localeCompare(ca);
  });

  rows.forEach(r => tbody.appendChild(r));
}

/* ════════════════════════════════════════
   BAN / DELETE USER
════════════════════════════════════════ */
function banUser(userId, username) {
  if (!confirm('Toggle ban for ' + username + '?')) return;
  const form = document.createElement('form');
  form.method  = 'POST';
  form.action  = '{{ path("app_admin_toggle_user_ban") }}';
  form.innerHTML = `<input type="hidden" name="user_id" value="${userId}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_user_toggle') }}">`;
  document.body.appendChild(form);
  form.submit();
}

function deleteUser(userId, username) {
  if (!confirm('Permanently delete user "' + username + '"? This cannot be undone.')) return;
  const form = document.createElement('form');
  form.method  = 'POST';
  form.action  = '{{ path("app_admin_user_delete") }}';
  form.innerHTML = `<input type="hidden" name="user_id" value="${userId}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_user_delete') }}">`;
  document.body.appendChild(form);
  form.submit();
}

/* ════════════════════════════════════════
   PDF EXPORT  (jsPDF + autoTable)
════════════════════════════════════════ */
function exportAnalyticsPDF() {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
  const now = new Date();
  const dateStr = now.toLocaleString('en-GB');

  // Brand colours (RGB)
  const purple  = [90, 63, 184];
  const purpleL = [116, 96, 194];
  const dark    = [28, 30, 33];
  const gray    = [100, 101, 107];
  const white   = [255, 255, 255];

  /* ── Cover strip ── */
  doc.setFillColor(...purple);
  doc.rect(0, 0, 210, 42, 'F');

  // Accent bar
  doc.setFillColor(...purpleL);
  doc.rect(0, 38, 210, 4, 'F');

  doc.setTextColor(...white);
  doc.setFontSize(18); doc.setFont('helvetica', 'bold');
  doc.text('GHRAMI PLATFORM', 105, 16, { align: 'center' });
  doc.setFontSize(11); doc.setFont('helvetica', 'normal');
  doc.text('Analytics Report', 105, 24, { align: 'center' });
  doc.setFontSize(9);
  doc.text('Generated: ' + dateStr, 105, 33, { align: 'center' });

  doc.setTextColor(...dark);
  let y = 54;

  /* ── Section helper ── */
  function addSection(title, head, rows, color) {
    // Page-break guard (leave 60 mm for a section minimum)
    if (y > 240) { doc.addPage(); y = 20; }

    // Section title pill
    doc.setFillColor(...color);
    doc.roundedRect(14, y - 5, 182, 9, 2, 2, 'F');
    doc.setTextColor(...white);
    doc.setFontSize(10); doc.setFont('helvetica', 'bold');
    doc.text(title, 18, y + 1.5);
    doc.setTextColor(...dark);
    y += 10;

    doc.autoTable({
      startY: y,
      head: [head],
      body: rows,
      theme: 'striped',
      headStyles: {
        fillColor: color,
        textColor: white,
        fontStyle: 'bold',
        fontSize: 9,
        cellPadding: { top: 4, bottom: 4, left: 5, right: 5 },
      },
      bodyStyles: {
        fontSize: 9,
        textColor: [50, 50, 50],
        cellPadding: { top: 3, bottom: 3, left: 5, right: 5 },
      },
      alternateRowStyles: { fillColor: [248, 249, 254] },
      columnStyles: {
        0: { fontStyle: 'bold', cellWidth: 90 },
        1: { cellWidth: 'auto' },
      },
      margin: { left: 14, right: 14 },
      tableLineColor: [234, 236, 242],
      tableLineWidth: 0.3,
    });
    y = doc.lastAutoTable.finalY + 10;
  }

  /* ── Sections — plain ASCII only (Helvetica has no emoji glyphs) ── */
  addSection('USERS', ['Metric', 'Value'], [
    ['Total Users',     '{{ stats.users }}'],
    ['Online Now',      '{{ stats.active_users }}'],
    ['Banned',          '{{ stats.banned_users ?? 0 }}'],
    ['Google Sign-In',  '{{ stats.google_users ?? 0 }}'],
    ['Local Accounts',  '{{ stats.local_users ?? 0 }}'],
  ], [90, 63, 184]);

  addSection('SOCIAL FEED', ['Metric', 'Value'], [
    ['Total Posts',        '{{ stats.posts }}'],
    ['Comments',           '{{ stats.comments ?? 0 }}'],
    ['Likes',              '{{ stats.likes ?? 0 }}'],
    ['Stories',            '{{ stats.stories ?? 0 }}'],
    ['Active Friendships', '{{ stats.accepted_friendships ?? 0 }}'],
  ], [194, 24, 91]);

  addSection('CLASSES & REVENUE', ['Metric', 'Value'], [
    ['Total Classes',  '{{ stats.classes }}'],
    ['Total Bookings', '{{ stats.bookings }}'],
    ['Completed',      '{{ stats.completed_bookings ?? 0 }}'],
    ['Pending',        '{{ stats.pending_bookings ?? 0 }}'],
    ['Cancelled',      '{{ stats.cancelled_bookings ?? 0 }}'],
    ['Total Revenue',  '{{ stats.total_revenue ?? "0.00" }} TND'],
  ], [230, 101, 0]);

  addSection('HOBBIES', ['Metric', 'Value'], [
    ['Total Hobbies',  '{{ stats.hobbies }}'],
    ['Total Hours',    '{{ stats.hobby_hours ?? "0.0" }} hrs'],
    ['Milestones',     '{{ stats.milestones ?? 0 }}'],
    ['Achieved',       '{{ stats.achieved_milestones ?? 0 }}'],
  ], [46, 125, 50]);

  addSection('MEETINGS', ['Metric', 'Value'], [
    ['Total Meetings', '{{ stats.meetings ?? 0 }}'],
    ['Scheduled',      '{{ stats.scheduled_meetings ?? 0 }}'],
    ['Completed',      '{{ stats.completed_meetings ?? 0 }}'],
    ['Cancelled',      '{{ stats.cancelled_meetings ?? 0 }}'],
  ], [0, 105, 122]);

  addSection('BADGES', ['Metric', 'Value'], [
    ['Total Badges',      '{{ stats.badges }}'],
    ['Unique Types',      '{{ stats.unique_badge_types ?? 0 }}'],
    ['Social Butterfly',  '{{ stats.badge_social ?? 0 }}'],
    ['Class Hero',        '{{ stats.badge_class ?? 0 }}'],
    ['Hobby Master',      '{{ stats.badge_hobby ?? 0 }}'],
  ], [123, 31, 162]);

  addSection('FRIENDSHIPS', ['Metric', 'Value'], [
    ['Total',    '{{ stats.friendships ?? 0 }}'],
    ['Accepted', '{{ stats.accepted_friendships ?? 0 }}'],
    ['Pending',  '{{ stats.pending_friendships ?? 0 }}'],
    ['Rejected', '{{ stats.rejected_friendships ?? 0 }}'],
  ], [183, 28, 28]);

  /* ── Footer on every page ── */
  const pCount = doc.internal.getNumberOfPages();
  for (let i = 1; i <= pCount; i++) {
    doc.setPage(i);
    // Bottom rule
    doc.setDrawColor(...purpleL);
    doc.setLineWidth(0.4);
    doc.line(14, 284, 196, 284);
    doc.setFontSize(8); doc.setTextColor(...gray);
    doc.text('(c) 2026 Ghrami by OPGG', 14, 289);
    doc.text('Page ' + i + ' / ' + pCount, 196, 289, { align: 'right' });
  }

  const stamp = now.getFullYear()
    + String(now.getMonth() + 1).padStart(2, '0')
    + String(now.getDate()).padStart(2, '0');
  doc.save('Ghrami_Analytics_' + stamp + '.pdf');
}


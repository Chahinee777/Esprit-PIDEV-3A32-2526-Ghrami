function viewPost(id, content, author, date, comments, likes, imageUrl) {
  document.getElementById('vPostId').textContent       = id;
  document.getElementById('vPostAuthor').textContent   = author;
  document.getElementById('vPostDate').textContent     = date;
  document.getElementById('vPostLikes').textContent    = likes;
  document.getElementById('vPostComments').textContent = comments;
  document.getElementById('vPostContent').textContent  = content;
  const imgRow  = document.getElementById('vPostImageRow');
  const imgLink = document.getElementById('vPostImageLink');
  if (imageUrl) {
    imgRow.style.display = '';
    imgLink.href = imageUrl;
  } else {
    imgRow.style.display = 'none';
  }
  document.getElementById('viewPostModal').classList.add('show');
}

function openEditPostModal(id, content) {
  document.getElementById('editPostId').value      = id;
  document.getElementById('editPostContent').value = content;
  document.getElementById('editPostModal').classList.add('show');
}

function openEditCommentModal(id, content) {
  document.getElementById('editCommentId').value      = id;
  document.getElementById('editCommentContent').value = content;
  document.getElementById('editCommentModal').classList.add('show');
}

                <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Local Accounts</span><span class="ad-detail-stat-value">{{ stats.local_users ?? 0 }}</span></div>
              </div>
            </div>
            <div class="ad-detail-card dcard-pink">
              <div class="ad-detail-card-head">Social Stats</div>
              <div class="ad-detail-card-body">
                <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Total Posts</span><span class="ad-detail-stat-value">{{ stats.posts }}</span></div>
                <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Comments</span><span class="ad-detail-stat-value">{{ stats.comments ?? 0 }}</span></div>
                <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Likes</span><span class="ad-detail-stat-value">{{ stats.likes ?? 0 }}</span></div>
                <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Stories</span><span class="ad-detail-stat-value">{{ stats.stories ?? 0 }}</span></div>
                <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Active Friendships</span><span class="ad-detail-stat-value">{{ stats.accepted_friendships ?? 0 }}</span></div>
              </div>
            </div>
            <div class="ad-detail-card dcard-orange">
              <div class="ad-detail-card-head">Classes &amp; Revenue</div>
              <div class="ad-detail-card-body">
                <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Total Classes</span><span class="ad-detail-stat-value">{{ stats.classes }}</span></div>
                <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Total Bookings</span><span class="ad-detail-stat-value">{{ stats.bookings }}</span></div>
                <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Completed</span><span class="ad-detail-stat-value">{{ stats.completed_bookings ?? 0 }}</span></div>
                <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Pending</span><span class="ad-detail-stat-value">{{ stats.pending_bookings ?? 0 }}</span></div>
                <div class="ad-detail-stat-row"><span class="ad-detail-stat-label">Total Revenue</span><span class="ad-detail-stat-value">{{ stats.total_revenue ?? '0.00' }} TND</span></div>
              </div>
            </div>
            <div class="ad-detail-card dcard-green">
              <div class="ad-detail-card-head">Hobbies Details</div>

        {# ════════════════════════ USERS TAB ════════════════════════ #}
        <div id="tab-users" class="ad-tab-pane active">
          <div class="ad-section-header">
            <div>
              <div class="ad-section-title">All Users</div>
              <div class="ad-section-sub">Manage your platform users</div>
            </div>
            <div class="ad-section-actions">
              <input class="ad-search" id="userSearch" type="text" placeholder="Search users...">
            </div>
          </div>
          <div class="ad-table-wrap">
            <table class="ad-table" id="usersTable">
              <thead>
                <tr>
                  <th onclick="sortTable('usersTable',0,this)">ID</th>
                  <th class="no-sort">Avatar</th>
                  <th onclick="sortTable('usersTable',2,this)">Username</th>
                  <th onclick="sortTable('usersTable',3,this)">Email</th>
                  <th onclick="sortTable('usersTable',4,this)">Location</th>
                  <th onclick="sortTable('usersTable',5,this)">Auth</th>
                  <th onclick="sortTable('usersTable',6,this)">Status</th>
                  <th class="no-sort">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for u in users %}
                  <tr class="user-row"
                      data-username="{{ u.username|lower }}"
                      data-email="{{ u.email|lower }}"
                      data-location="{{ u.location|default('')|lower }}">
                    <td style="color:#adb0bb;font-size:12px;">{{ u.user_id }}</td>
                    <td>
                      <img src="" class="ad-avatar" alt="avatar"
                           onerror="this.src='https://ui-avatars.com/api/?name={{ u.username|url_encode }}&background=667eea&color=fff&size=38'">
                    </td>
                    <td><strong>{{ u.username }}</strong></td>
                    <td style="color:#65676b;">{{ u.email }}</td>
                    <td style="color:#65676b;font-size:12px;">{{ u.location|default('—') }}</td>
                    <td>
                      <span class="ad-badge {% if u.auth_provider == 'google' %}ad-badge-google{% else %}ad-badge-local{% endif %}">
                        {{ u.auth_provider == 'google' ? 'Google' : 'Local' }}
                      </span>
                    </td>
                    <td>
                      {% if u.is_banned %}
                        <span class="ad-badge ad-badge-banned">Banned</span>
                      {% elseif u.is_online %}
                        <span class="ad-badge ad-badge-online">Online</span>
                      {% else %}
                        <span class="ad-badge ad-badge-offline">Offline</span>
                      {% endif %}
                    </td>
                    <td>
                      <div class="ad-action-group">
                        <button class="ad-btn ad-btn-blue ad-btn-sm" data-tip="View user details"
                                onclick="viewUser({{ u.user_id }}, '{{ u.username }}', '{{ u.email }}', {{ u.is_banned ? 1 : 0 }}, '{{ u.location|default('') }}', '{{ u.auth_provider }}')">
                          View
                        </button>
                        <button class="ad-btn ad-btn-orange ad-btn-sm" data-tip="Edit this user"
                                onclick="openEditUser({{ u.user_id }}, '{{ u.username }}', '{{ u.email }}', '{{ u.location|default('') }}')">
                          Edit
                        </button>
                        <button class="ad-btn {% if u.is_banned %}ad-btn-green{% else %}ad-btn-purple{% endif %} ad-btn-sm"
                                data-tip="{{ u.is_banned ? 'Unban this user' : 'Ban this user' }}"
                                onclick="banUser({{ u.user_id }}, '{{ u.username }}')">
                          {{ u.is_banned ? 'Unban' : 'Ban' }}
                        </button>
                        <button class="ad-btn ad-btn-red ad-btn-sm" data-tip="Permanently delete user"
                                onclick="deleteUser({{ u.user_id }}, '{{ u.username }}')">
                          Delete
                        </button>
                      </div>
                    </td>
                  </tr>
                {% else %}
                  <tr><td colspan="8" style="text-align:center;padding:40px;color:#adb0bb;">No users found.</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>

        {# ════════════════════════ PROVIDERS TAB ════════════════════════ #}
        <div id="tab-providers" class="ad-tab-pane">
          <div class="ad-section-header">
            <div>
              <div class="ad-section-title">Instructor Applications</div>
              <div class="ad-section-sub">Review and verify instructor applications</div>
            </div>
            <div class="ad-section-actions">
              <input class="ad-search" id="providerSearch" type="text" placeholder="Search instructors...">
            </div>
          </div>
          <div class="ad-table-wrap">
            <table class="ad-table" id="providersTable">
              <thead>
                <tr>
                  <th onclick="sortTable('providersTable',0,this)">ID</th>
                  <th onclick="sortTable('providersTable',1,this)">Username</th>
                  <th onclick="sortTable('providersTable',2,this)">Email</th>
                  <th onclick="sortTable('providersTable',3,this)">Company / Studio</th>
                  <th onclick="sortTable('providersTable',4,this)">Expertise</th>
                  <th onclick="sortTable('providersTable',5,this)">Rating</th>
                  <th onclick="sortTable('providersTable',6,this)">Status</th>
                  <th class="no-sort">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for p in providers %}
                  <tr class="provider-row"
                      data-username="{{ p.username|lower }}"
                      data-company="{{ p.company_name|default('')|lower }}"
                      data-expertise="{{ p.expertise|default('')|lower }}">
                    <td style="color:#adb0bb;font-size:12px;">{{ p.provider_id }}</td>
                    <td><strong>{{ p.username }}</strong></td>
                    <td style="color:#65676b;font-size:12px;">{{ p.email ?? '—' }}</td>
                    <td>{{ p.company_name ?? '—' }}</td>
                    <td>
                      {% if p.expertise %}
                        <span class="ad-badge ad-badge-local">{{ p.expertise }}</span>
                      {% else %}
                        <span style="color:#adb0bb;">—</span>
                      {% endif %}
                    </td>
                    <td>{{ p.rating ?? '0.0' }}</td>
                    <td>
                      <span class="ad-badge {% if p.is_verified %}ad-badge-verified{% else %}ad-badge-unverified{% endif %}">
                        {{ p.is_verified ? 'Verified' : 'Pending' }}
                      </span>
                    </td>
                    <td>
                      <div class="ad-action-group">
                        <form method="post" action="{{ path('app_admin_toggle_provider_verify') }}" style="display:inline;">
                          <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_provider_toggle') }}">
                          <input type="hidden" name="provider_id" value="{{ p.provider_id }}">
                          <button type="submit"
                                  class="ad-btn {% if p.is_verified %}ad-btn-red{% else %}ad-btn-green{% endif %} ad-btn-sm"
                                  data-tip="{{ p.is_verified ? 'Revoke verification' : 'Approve this instructor' }}">
                            {{ p.is_verified ? 'Unverify' : 'Verify' }}
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                {% else %}
                  <tr><td colspan="8" style="text-align:center;padding:40px;color:#adb0bb;">No providers found.</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>

        {# ════════════════════════ CLASSES TAB ════════════════════════ #}
        <div id="tab-classes" class="ad-tab-pane">
          <div class="ad-section-header">
            <div>
              <div class="ad-section-title">Classes</div>
              <div class="ad-section-sub">Manage all platform classes</div>
            </div>
            <div class="ad-section-actions">
              <input class="ad-search" id="classSearch" type="text" placeholder="Search classes...">
            </div>
          </div>
          <div class="ad-table-wrap">
            <table class="ad-table" id="classesTable">
              <thead>
                <tr>
                  <th onclick="sortTable('classesTable',0,this)">Title</th>
                  <th onclick="sortTable('classesTable',1,this)">Provider</th>
                  <th onclick="sortTable('classesTable',2,this)">Category</th>
                  <th onclick="sortTable('classesTable',3,this)">Price</th>
                  <th onclick="sortTable('classesTable',4,this)">Bookings</th>
                  <th class="no-sort">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for c in classes %}
                  <tr class="class-row"
                      data-title="{{ c.title|lower }}"
                      data-provider="{{ c.provider_username|lower }}">
                    <td><strong>{{ c.title }}</strong></td>
                    <td>{{ c.provider_username }}</td>
                    <td><span class="ad-badge ad-badge-local">{{ c.category ?? 'General' }}</span></td>
                    <td><strong>{{ c.price }} TND</strong></td>
                    <td>{{ c.booking_count }}</td>
                    <td>
                      <form method="post" action="{{ path('app_admin_class_delete') }}"
                            style="display:inline;"
                            onsubmit="return confirm('Delete this class?');">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_class_delete') }}">
                        <input type="hidden" name="class_id" value="{{ c.class_id }}">
                        <button type="submit" class="ad-btn ad-btn-red ad-btn-sm" data-tip="Delete this class permanently">Delete</button>
                      </form>
                    </td>
                  </tr>
                {% else %}
                  <tr><td colspan="6" style="text-align:center;padding:40px;color:#adb0bb;">No classes found.</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>

        {# ════════════════════════ HOBBIES TAB ════════════════════════ #}
        <div id="tab-hobbies" class="ad-tab-pane">
          <div class="ad-section-header">
            <div>
              <div class="ad-section-title">Hobbies</div>
              <div class="ad-section-sub">Manage user hobbies and logged hours</div>
            </div>
            <div class="ad-section-actions">
              <input class="ad-search" id="hobbySearch" type="text" placeholder="Search hobbies...">
            </div>
          </div>
          <div class="ad-table-wrap">
            <table class="ad-table" id="hobbiesTable">
              <thead>
                <tr>
                  <th onclick="sortTable('hobbiesTable',0,this)">ID</th>
                  <th onclick="sortTable('hobbiesTable',1,this)">User</th>
                  <th onclick="sortTable('hobbiesTable',2,this)">Hobby</th>
                  <th onclick="sortTable('hobbiesTable',3,this)">Category</th>
                  <th onclick="sortTable('hobbiesTable',4,this)">Hours</th>
                  <th class="no-sort">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for h in hobbies %}
                  <tr class="hobby-row"
                      data-user="{{ h.username|lower }}"
                      data-name="{{ h.name|lower }}"
                      data-category="{{ (h.category ?? '')|lower }}">
                    <td style="color:#adb0bb;font-size:12px;">{{ h.hobby_id }}</td>
                    <td><strong>{{ h.username }}</strong></td>
                    <td>{{ h.name }}</td>
                    <td><span class="ad-badge ad-badge-local">{{ h.category ?? 'Other' }}</span></td>
                    <td><strong>{{ h.total_hours|default(0)|round(1) }}h</strong></td>
                    <td>
                      <form method="post" action="{{ path('app_admin_hobby_delete') }}"
                            style="display:inline;"
                            onsubmit="return confirm('Delete hobby {{ h.name }} for {{ h.username }}?');">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_hobby_delete') }}">
                        <input type="hidden" name="hobby_id" value="{{ h.hobby_id }}">
                        <button type="submit" class="ad-btn ad-btn-red ad-btn-sm" data-tip="Delete this hobby permanently">Delete</button>
                      </form>
                    </td>
                  </tr>
                {% else %}
                  <tr><td colspan="6" style="text-align:center;padding:40px;color:#adb0bb;">No hobbies found.</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>

        {# ════════════════════════ MEETINGS TAB ════════════════════════ #}
        <div id="tab-meetings" class="ad-tab-pane">
          <div class="ad-section-header">
            <div>
              <div class="ad-section-title">Meetings</div>
              <div class="ad-section-sub">Manage scheduled virtual and physical meetings</div>
            </div>
            <div class="ad-section-actions">
              <input class="ad-search" id="meetingSearch" type="text" placeholder="Search meetings...">
            </div>
          </div>
          <div class="ad-table-wrap">
            <table class="ad-table" id="meetingsTable">
              <thead>
                <tr>
                  <th onclick="sortTable('meetingsTable',0,this)">ID</th>
                  <th onclick="sortTable('meetingsTable',1,this)">Organizer</th>
                  <th onclick="sortTable('meetingsTable',2,this)">Type</th>
                  <th onclick="sortTable('meetingsTable',3,this)">Status</th>
                  <th onclick="sortTable('meetingsTable',4,this)">Scheduled</th>
                  <th onclick="sortTable('meetingsTable',5,this)">Participants</th>
                  <th class="no-sort">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for m in meetings %}
                  <tr class="meeting-row"
                      data-organizer="{{ m.organizer_username|lower }}"
                      data-type="{{ m.meeting_type|lower }}"
                      data-status="{{ (m.status ?? 'scheduled')|lower }}"
                      data-location="{{ (m.location ?? '')|lower }}">
                    <td style="color:#adb0bb;font-size:12px;">{{ m.meeting_id }}</td>
                    <td><strong>{{ m.organizer_username }}</strong></td>
                    <td><span class="ad-badge ad-badge-local">{{ m.meeting_type|capitalize }}</span></td>
                    <td>
                      {% set ms = (m.status ?? 'scheduled')|lower %}
                      <span class="ad-badge {% if ms == 'completed' %}ad-badge-accepted{% elseif ms == 'cancelled' %}ad-badge-rejected{% else %}ad-badge-pending{% endif %}">
                        {{ ms|capitalize }}
                      </span>
                    </td>
                    <td style="color:#65676b;font-size:12px;">{{ m.scheduled_at ?? '—' }}</td>
                    <td>{{ m.participant_count|default(0) }}</td>
                    <td>
                      <form method="post" action="{{ path('app_admin_meeting_delete') }}"
                            style="display:inline;"
                            onsubmit="return confirm('Delete meeting {{ m.meeting_id }}?');">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_meeting_delete') }}">
                        <input type="hidden" name="meeting_id" value="{{ m.meeting_id }}">
                        <button type="submit" class="ad-btn ad-btn-red ad-btn-sm" data-tip="Delete this meeting permanently">Delete</button>
                      </form>
                    </td>
                  </tr>
                {% else %}
                  <tr><td colspan="7" style="text-align:center;padding:40px;color:#adb0bb;">No meetings found.</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>

        {# ════════════════════════ FRIENDSHIPS TAB ════════════════════════ #}
        <div id="tab-friendships" class="ad-tab-pane">
          <div class="ad-section-header">
            <div>
              <div class="ad-section-title">Friendship Management</div>
              <div class="ad-section-sub">View, edit and remove user friendships</div>
            </div>
            <div class="ad-section-actions">
              <input class="ad-search" id="friendshipSearch" type="text" placeholder="Search friendships...">
              <select class="ad-form-select" id="friendshipFilter" onchange="filterFriendships()" style="min-width:130px;padding:9px 14px;border-radius:8px;">
                <option value="">All Statuses</option>
                <option value="accepted">Accepted</option>
                <option value="pending">Pending</option>
                <option value="rejected">Rejected</option>
              </select>
            </div>
          </div>
          <div class="ad-table-wrap">
            <table class="ad-table" id="friendshipsTable">
              <thead>
                <tr>
                  <th onclick="sortTable('friendshipsTable',0,this)">ID</th>
                  <th onclick="sortTable('friendshipsTable',1,this)">User 1</th>
                  <th onclick="sortTable('friendshipsTable',2,this)">User 2</th>
                  <th onclick="sortTable('friendshipsTable',3,this)">Status</th>
                  <th onclick="sortTable('friendshipsTable',4,this)">Created At</th>
                  <th class="no-sort">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for f in friendships %}
                  <tr class="friendship-row"
                      data-user1="{{ f.user1_username|default(f.user1_id)|lower }}"
                      data-user2="{{ f.user2_username|default(f.user2_id)|lower }}"
                      data-status="{{ f.status|lower }}">
                    <td style="color:#adb0bb;font-size:12px;">{{ f.friendship_id }}</td>
                    <td><strong>{{ f.user1_username ?? f.user1_id }}</strong></td>
                    <td><strong>{{ f.user2_username ?? f.user2_id }}</strong></td>
                    <td>
                      {% set st = f.status|lower %}
                      <span class="ad-badge
                        {% if st == 'accepted' %}ad-badge-accepted
                        {% elseif st == 'pending' %}ad-badge-pending
                        {% else %}ad-badge-rejected{% endif %}">
                        {% if st == 'accepted' %}Accepted
                        {% elseif st == 'pending' %}Pending
                        {% else %}Rejected{% endif %}
                      </span>
                    </td>
                    <td style="color:#65676b;font-size:12px;">{{ f.created_at ?? '—' }}</td>
                    <td>
                      <div class="ad-action-group">
                        <button class="ad-btn ad-btn-orange ad-btn-sm" data-tip="Edit friendship status"
                                onclick="openEditFriendship({{ f.friendship_id }}, '{{ f.user1_username ?? f.user1_id }}', '{{ f.user2_username ?? f.user2_id }}', '{{ f.status }}')">
                          Edit
                        </button>
                        <form method="post" action="{{ path('app_admin_friendship_delete') }}"
                              style="display:inline;"
                              onsubmit="return confirm('Delete this friendship?');">
                          <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_friendship_delete') }}">
                          <input type="hidden" name="friendship_id" value="{{ f.friendship_id }}">
                          <button type="submit" class="ad-btn ad-btn-red ad-btn-sm" data-tip="Remove this friendship">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                {% else %}
                  <tr><td colspan="6" style="text-align:center;padding:40px;color:#adb0bb;">No friendships found.</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>

        {# ════════════════════════ BADGES TAB ════════════════════════ #}
        <div id="tab-badges" class="ad-tab-pane">
          <div class="ad-section-header">
            <div>
              <div class="ad-section-title">Badge Management</div>
              <div class="ad-section-sub">Create, edit and remove user badges</div>
            </div>
            <div class="ad-section-actions">
              <input class="ad-search" id="badgeSearch" type="text" placeholder="Search badges...">
              <button class="ad-btn ad-btn-purple" onclick="openAwardBadgeModal()" data-tip="Award a badge to a user">Award Badge</button>
            </div>
          </div>

          {# Badge distribution mini-chart #}
          <div style="background:var(--c-bg);border-radius:var(--radius-md);border:1px solid var(--c-border);padding:20px;margin-bottom:20px;">
            <h4 style="font-size:13px;font-weight:700;color:var(--c-text);margin-bottom:14px;">Badge Distribution</h4>
            <div style="position:relative;height:220px;"><canvas id="chartBadgeTab"></canvas></div>
          </div>

          {# Badge award statistics by name #}
          {% if badgeStats is defined and badgeStats is not empty %}
          <div style="background:var(--c-bg);border-radius:var(--radius-md);border:1px solid var(--c-border);padding:20px;margin-bottom:24px;">
            <h4 style="font-size:13px;font-weight:700;color:var(--c-text);margin-bottom:14px;">Badge Catalog — Award Counts</h4>
            <div class="ad-table-wrap" style="box-shadow:none;border:none;">
              <table class="ad-table" id="badgeCatalogTable">
                <thead>
                  <tr>
                    <th onclick="sortTable('badgeCatalogTable',0,this)">Badge Name</th>
                    <th onclick="sortTable('badgeCatalogTable',1,this)" style="text-align:center;">Times Awarded</th>
                    <th onclick="sortTable('badgeCatalogTable',2,this)">Last Awarded</th>
                    <th class="no-sort">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {% for bs in badgeStats %}
                    <tr>
                      <td><span class="ad-badge ad-badge-local">{{ bs.name }}</span></td>
                      <td style="text-align:center;font-weight:700;color:var(--c-primary);">{{ bs.total_awarded }}</td>
                      <td style="color:#65676b;font-size:12px;">{{ bs.last_awarded }}</td>
                      <td>
                        <form method="post" action="{{ path('app_admin_badge_revoke_by_name') }}" style="display:inline;"
                              onsubmit="return confirm('Revoke ALL «{{ bs.name }}» badges from every user? This cannot be undone.');">
                          <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_badge_revoke_name') }}">
                          <input type="hidden" name="badge_name" value="{{ bs.name }}">
                          <button type="submit" class="ad-btn ad-btn-red ad-btn-sm" data-tip="Remove this badge from all users">Revoke All</button>
                        </form>
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
          {% endif %}

          <div class="ad-table-wrap">
            <table class="ad-table" id="badgesTable">
              <thead>
                <tr>
                  <th onclick="sortTable('badgesTable',0,this)">ID</th>
                  <th onclick="sortTable('badgesTable',1,this)">User</th>
                  <th onclick="sortTable('badgesTable',2,this)">Badge Name</th>
                  <th onclick="sortTable('badgesTable',3,this)">Description</th>
                  <th onclick="sortTable('badgesTable',4,this)">Awarded At</th>
                  <th class="no-sort">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for b in badges %}
                  <tr class="badge-row"
                      data-name="{{ b.badge_name|lower }}"
                      data-user="{{ b.username|default('')|lower }}">
                    <td style="color:#adb0bb;font-size:12px;">{{ b.badge_id }}</td>
                    <td><strong>{{ b.username ?? b.user_id }}</strong></td>
                    <td><span class="ad-badge ad-badge-local">{{ b.badge_name }}</span></td>
                    <td style="color:#65676b;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                      {{ b.description ?? '—' }}
                    </td>
                    <td style="color:#65676b;font-size:12px;">{{ b.awarded_at ?? '—' }}</td>
                    <td>
                      <div class="ad-action-group">
                        <button class="ad-btn ad-btn-blue ad-btn-sm" data-tip="View badge details"
                                onclick="viewBadge({{ b.badge_id }}, '{{ b.badge_name }}', '{{ b.description ?? '' }}', '{{ b.username ?? b.user_id }}')">
                          View
                        </button>
                        <button class="ad-btn ad-btn-orange ad-btn-sm" data-tip="Edit this badge"
                                onclick="openEditBadgeModal({{ b.badge_id }}, '{{ b.badge_name|e('js') }}', '{{ (b.description ?? '')|e('js') }}')">
                          Edit
                        </button>
                        <form method="post" action="{{ path('app_admin_badge_delete') }}"
                              style="display:inline;"
                              onsubmit="return confirm('Remove this badge from {{ b.username ?? b.user_id }}?');">
                          <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_badge_delete') }}">
                          <input type="hidden" name="badge_id" value="{{ b.badge_id }}">
                          <button type="submit" class="ad-btn ad-btn-red ad-btn-sm" data-tip="Remove badge from user">Remove</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                {% else %}
                  <tr><td colspan="6" style="text-align:center;padding:40px;color:#adb0bb;">No badges found.</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>

        {# ════════════════════════ SOCIAL MEDIA TAB ════════════════════════ #}
        <div id="tab-social" class="ad-tab-pane">

          {# Posts sub-section #}
          <div class="ad-section-header">
            <div>
              <div class="ad-section-title">Posts Moderation</div>
              <div class="ad-section-sub">Review, edit and remove user posts</div>
            </div>
            <div class="ad-section-actions">
              <input class="ad-search" id="postSearch" type="text" placeholder="Search posts...">
              <a href="{{ path('app_admin_post_export') }}" class="ad-btn ad-btn-green" data-tip="Export all posts to CSV">Export CSV</a>
            </div>
          </div>

          <div class="ad-table-wrap" style="margin-bottom:36px;">
            <table class="ad-table" id="postsTable">
              <thead>
                <tr>
                  <th onclick="sortTable('postsTable',0,this)">ID</th>
                  <th onclick="sortTable('postsTable',1,this)">Author</th>
                  <th onclick="sortTable('postsTable',2,this)">Content</th>
                  <th onclick="sortTable('postsTable',3,this)">Comments</th>
                  <th onclick="sortTable('postsTable',4,this)">Likes</th>
                  <th onclick="sortTable('postsTable',5,this)">Created</th>
                  <th class="no-sort">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for p in posts %}
                  <tr class="post-row" data-content="{{ p.content|lower }}" data-author="{{ p.username|lower }}">
                    <td style="color:#adb0bb;font-size:12px;">{{ p.post_id }}</td>
                    <td><strong>{{ p.username }}</strong></td>
                    <td style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#444;">
                      {% if p.image_url %}<span title="Has image">[img] </span>{% endif %}
                      {{ p.content|slice(0,100) }}{% if p.content|length > 100 %}…{% endif %}
                    </td>
                    <td style="text-align:center;">
                      <span class="ad-badge ad-badge-local">{{ p.comment_count }}</span>
                    </td>
                    <td style="text-align:center;">
                      <span class="ad-badge ad-badge-accepted">{{ p.like_count }}</span>
                    </td>
                    <td style="color:#65676b;font-size:12px;">{{ p.created_at }}</td>
                    <td>
                      <div class="ad-action-group">
                        <button class="ad-btn ad-btn-blue ad-btn-sm" data-tip="View full post"
                                onclick="viewPost({{ p.post_id }}, {{ p.content|json_encode }}, '{{ p.username }}', '{{ p.created_at }}', {{ p.comment_count }}, {{ p.like_count }}, '{{ p.image_url ?? '' }}')">
                          View
                        </button>
                        <button class="ad-btn ad-btn-orange ad-btn-sm" data-tip="Edit post content"
                                onclick="openEditPostModal({{ p.post_id }}, {{ p.content|json_encode }})">
                          Edit
                        </button>
                        <form method="post" action="{{ path('app_admin_post_delete') }}" style="display:inline;"
                              onsubmit="return confirm('Delete this post by {{ p.username }}? This also removes its comments and likes.');">
                          <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_post_delete') }}">
                          <input type="hidden" name="post_id" value="{{ p.post_id }}">
                          <button type="submit" class="ad-btn ad-btn-red ad-btn-sm" data-tip="Delete post permanently">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                {% else %}
                  <tr><td colspan="7" style="text-align:center;padding:40px;color:#adb0bb;">No posts found.</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>

          {# Comments sub-section #}
          <div class="ad-section-header">
            <div>
              <div class="ad-section-title">Comments Moderation</div>
              <div class="ad-section-sub">Review, edit and remove user comments</div>
            </div>
            <div class="ad-section-actions">
              <select id="commentYearFilter" onchange="filterComments()" style="margin-right:8px;padding:9px 14px;border:1.5px solid var(--c-border);border-radius:8px;font-family:'Sora',sans-serif;font-size:12px;background:var(--c-bg);outline:none;">
                <option value="">All Years</option>
                {% set years = [] %}
                {% for c in comments %}
                  {% set year = c.created_at|date('Y') %}
                  {% if year not in years %}
                    {% set years = years|merge([year]) %}
                  {% endif %}
                {% endfor %}
                {% for year in years|sort|reverse %}
                  <option value="{{ year }}">{{ year }}</option>
                {% endfor %}
              </select>
              <select id="commentMonthFilter" onchange="filterComments()" style="margin-right:8px;padding:9px 14px;border:1.5px solid var(--c-border);border-radius:8px;font-family:'Sora',sans-serif;font-size:12px;background:var(--c-bg);outline:none;">
                <option value="">All Months</option>
                {% for month in 1..12 %}
                  <option value="{{ month }}">{{ month|date('M') }}</option>
                {% endfor %}
              </select>
              <input class="ad-search" id="commentSearch" type="text" placeholder="Search comments..." onkeyup="filterComments()">
            </div>
          </div>

          <div class="ad-table-wrap">
            <table class="ad-table" id="commentsTable">
              <thead>
                <tr>
                  <th onclick="sortTable('commentsTable',0,this)">ID</th>
                  <th onclick="sortTable('commentsTable',1,this)">Author</th>
                  <th onclick="sortTable('commentsTable',2,this)">Comment</th>
                  <th onclick="sortTable('commentsTable',3,this)">On Post by</th>
                  <th onclick="sortTable('commentsTable',4,this)">Created</th>
                  <th class="no-sort">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for c in comments %}
                  <tr class="comment-row" data-content="{{ c.content|lower }}" data-author="{{ c.username|lower }}" data-date="{{ c.created_at }}">
                    <td style="color:#adb0bb;font-size:12px;">{{ c.comment_id }}</td>
                    <td><strong>{{ c.username }}</strong></td>
                    <td style="max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#444;">
                      {{ c.content|slice(0,100) }}{% if c.content|length > 100 %}…{% endif %}
                    </td>
                    <td style="color:#65676b;font-size:12px;">
                      <span title="{{ c.post_excerpt }}">#{{ c.post_id }} — {{ c.post_author }}</span>
                    </td>
                    <td style="color:#65676b;font-size:12px;">{{ c.created_at }}</td>
                    <td>
                      <div class="ad-action-group">
                        <button class="ad-btn ad-btn-orange ad-btn-sm" data-tip="Edit comment"
                                onclick="openEditCommentModal({{ c.comment_id }}, {{ c.content|json_encode }})">
                          Edit
                        </button>
                        <form method="post" action="{{ path('app_admin_comment_delete') }}" style="display:inline;"
                              onsubmit="return confirm('Delete this comment by {{ c.username }}?');">
                          <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_comment_delete') }}">
                          <input type="hidden" name="comment_id" value="{{ c.comment_id }}">
                          <button type="submit" class="ad-btn ad-btn-red ad-btn-sm" data-tip="Delete comment">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                {% else %}
                  <tr><td colspan="6" style="text-align:center;padding:40px;color:#adb0bb;">No comments found.</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>

        {# ════════════════════════ ANALYTICS TAB ════════════════════════ #}
        <div id="tab-analytics" class="ad-tab-pane">
          <div class="ad-section-header">
            <div>
              <div class="ad-section-title">Platform Analytics</div>
              <div class="ad-section-sub">Charts, breakdowns and performance overview</div>
            </div>
            <div class="ad-section-actions">
              <button class="ad-btn ad-btn-purple" onclick="exportAnalyticsPDF()" data-tip="Download full analytics as PDF">Export PDF</button>
            </div>
          </div>

          {# 7 Detail Cards #}
          <div class="ad-detail-cards-grid">
            <div class="ad-detail-card dcard-purple">
              <div class="ad-detail-card-head">Users Analytics</div>
              <div class="ad-detail-card-body">

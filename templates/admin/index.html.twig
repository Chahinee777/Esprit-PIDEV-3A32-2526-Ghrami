    type: 'bar',
    data: {
      labels: ['Users','Friendships','Badges','Classes','Bookings','Hobbies','Meetings','Posts','Comments','Stories'],
      datasets: [{
        label: 'Count',
        data: [
          {{ stats.users }},
          {{ stats.friendships ?? 0 }},
          {{ stats.badges ?? 13 }},
          {{ stats.classes }},
          {{ stats.bookings }},
          {{ stats.hobbies ?? 18 }},
          {{ stats.meetings ?? 22 }},

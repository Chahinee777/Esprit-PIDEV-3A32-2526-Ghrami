/* Award modal: sync custom text input when user picks "Custom..." */
function syncBadgeNameInput(sel) {
  const custom = document.getElementById('awardBadgeNameCustom');
  if (!custom) return;
  if (sel.value === '__custom__') {
    custom.style.display = 'block';
    custom.required = true;
    sel.name = '';
    custom.name = 'badge_name';
  } else {
    custom.style.display = 'none';
    custom.required = false;
    custom.name = '';
    sel.name = 'badge_name';
  }
}

function prepareAwardSubmit(form) {
  const sel = document.getElementById('awardBadgeNameSelect');
  if (sel && sel.value === '__custom__') {
    const txt = document.getElementById('awardBadgeNameCustom');
    if (!txt || !txt.value.trim()) { alert('Please enter a badge name.'); return false; }
  }
  return true;
}

/* ════════════════════════════════════════
   TABLE SORTING
════════════════════════════════════════ */
const _sortState = {};

function sortTable(tableId, colIdx, thEl) {
  const table  = document.getElementById(tableId);
  const tbody  = table.querySelector('tbody');
  const rows   = Array.from(tbody.querySelectorAll('tr'));
  const key    = tableId + ':' + colIdx;
  const asc    = _sortState[key] !== true;
  _sortState[key] = asc;

  // Update header indicators
  table.querySelectorAll('th').forEach(th => th.classList.remove('sort-asc','sort-desc'));
  thEl.classList.add(asc ? 'sort-asc' : 'sort-desc');

  rows.sort((a, b) => {
    const ca = a.cells[colIdx]?.textContent.trim() ?? '';
    const cb = b.cells[colIdx]?.textContent.trim() ?? '';
    // Numeric sort if both look like numbers
    const na = parseFloat(ca.replace(/[^0-9.\-]/g, ''));
    const nb = parseFloat(cb.replace(/[^0-9.\-]/g, ''));
    if (!isNaN(na) && !isNaN(nb)) return asc ? na - nb : nb - na;
    return asc ? ca.localeCompare(cb) : cb.localeCompare(ca);
  });

  rows.forEach(r => tbody.appendChild(r));
}

/* ════════════════════════════════════════
   BAN / DELETE USER
════════════════════════════════════════ */
function banUser(userId, username) {
  if (!confirm('Toggle ban for ' + username + '?')) return;
  const form = document.createElement('form');
  form.method  = 'POST';
  form.action  = '{{ path("app_admin_toggle_user_ban") }}';
  form.innerHTML = `<input type="hidden" name="user_id" value="${userId}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_user_toggle') }}">`;
  document.body.appendChild(form);
  form.submit();
}

function deleteUser(userId, username) {
  if (!confirm('Permanently delete user "' + username + '"? This cannot be undone.')) return;
  const form = document.createElement('form');
  form.method  = 'POST';
  form.action  = '{{ path("app_admin_user_delete") }}';
  form.innerHTML = `<input type="hidden" name="user_id" value="${userId}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_user_delete') }}">`;
  document.body.appendChild(form);
  form.submit();
}

/* ════════════════════════════════════════
   PDF EXPORT  (jsPDF + autoTable)
════════════════════════════════════════ */
function exportAnalyticsPDF() {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
  const now = new Date();
  const dateStr = now.toLocaleString('en-GB');

  // Brand colours (RGB)
  const purple  = [90, 63, 184];
  const purpleL = [116, 96, 194];
  const dark    = [28, 30, 33];
  const gray    = [100, 101, 107];
  const white   = [255, 255, 255];

  /* ── Cover strip ── */
  doc.setFillColor(...purple);
  doc.rect(0, 0, 210, 42, 'F');

  // Accent bar
  doc.setFillColor(...purpleL);
  doc.rect(0, 38, 210, 4, 'F');

  doc.setTextColor(...white);
  doc.setFontSize(18); doc.setFont('helvetica', 'bold');
  doc.text('GHRAMI PLATFORM', 105, 16, { align: 'center' });
  doc.setFontSize(11); doc.setFont('helvetica', 'normal');
  doc.text('Analytics Report', 105, 24, { align: 'center' });
  doc.setFontSize(9);
  doc.text('Generated: ' + dateStr, 105, 33, { align: 'center' });

  doc.setTextColor(...dark);
  let y = 54;

  /* ── Section helper ── */
  function addSection(title, head, rows, color) {
    // Page-break guard (leave 60 mm for a section minimum)
    if (y > 240) { doc.addPage(); y = 20; }

    // Section title pill
    doc.setFillColor(...color);
    doc.roundedRect(14, y - 5, 182, 9, 2, 2, 'F');
    doc.setTextColor(...white);
    doc.setFontSize(10); doc.setFont('helvetica', 'bold');
    doc.text(title, 18, y + 1.5);
    doc.setTextColor(...dark);
    y += 10;

    doc.autoTable({
      startY: y,
      head: [head],
      body: rows,
      theme: 'striped',
      headStyles: {
        fillColor: color,
        textColor: white,
        fontStyle: 'bold',
        fontSize: 9,
        cellPadding: { top: 4, bottom: 4, left: 5, right: 5 },
      },
      bodyStyles: {
        fontSize: 9,
        textColor: [50, 50, 50],
        cellPadding: { top: 3, bottom: 3, left: 5, right: 5 },
      },
      alternateRowStyles: { fillColor: [248, 249, 254] },
      columnStyles: {
        0: { fontStyle: 'bold', cellWidth: 90 },
        1: { cellWidth: 'auto' },
      },
      margin: { left: 14, right: 14 },
      tableLineColor: [234, 236, 242],
      tableLineWidth: 0.3,
    });
    y = doc.lastAutoTable.finalY + 10;
  }

  /* ── Sections — plain ASCII only (Helvetica has no emoji glyphs) ── */
  addSection('USERS', ['Metric', 'Value'], [
    ['Total Users',     '{{ stats.users }}'],
    ['Online Now',      '{{ stats.active_users }}'],
    ['Banned',          '{{ stats.banned_users ?? 0 }}'],
    ['Google Sign-In',  '{{ stats.google_users ?? 0 }}'],
    ['Local Accounts',  '{{ stats.local_users ?? 0 }}'],
  ], [90, 63, 184]);

  addSection('SOCIAL FEED', ['Metric', 'Value'], [
    ['Total Posts',        '{{ stats.posts }}'],
    ['Comments',           '{{ stats.comments ?? 0 }}'],
    ['Likes',              '{{ stats.likes ?? 0 }}'],
    ['Stories',            '{{ stats.stories ?? 0 }}'],
    ['Active Friendships', '{{ stats.accepted_friendships ?? 0 }}'],
  ], [194, 24, 91]);

  addSection('CLASSES & REVENUE', ['Metric', 'Value'], [
    ['Total Classes',  '{{ stats.classes }}'],
    ['Total Bookings', '{{ stats.bookings }}'],
    ['Completed',      '{{ stats.completed_bookings ?? 0 }}'],
    ['Pending',        '{{ stats.pending_bookings ?? 0 }}'],
    ['Cancelled',      '{{ stats.cancelled_bookings ?? 0 }}'],
    ['Total Revenue',  '{{ stats.total_revenue ?? "0.00" }} TND'],
  ], [230, 101, 0]);

  addSection('HOBBIES', ['Metric', 'Value'], [
    ['Total Hobbies',  '{{ stats.hobbies }}'],
    ['Total Hours',    '{{ stats.hobby_hours ?? "0.0" }} hrs'],
    ['Milestones',     '{{ stats.milestones ?? 0 }}'],
    ['Achieved',       '{{ stats.achieved_milestones ?? 0 }}'],
  ], [46, 125, 50]);

  addSection('MEETINGS', ['Metric', 'Value'], [
    ['Total Meetings', '{{ stats.meetings ?? 0 }}'],
    ['Scheduled',      '{{ stats.scheduled_meetings ?? 0 }}'],
    ['Completed',      '{{ stats.completed_meetings ?? 0 }}'],
    ['Cancelled',      '{{ stats.cancelled_meetings ?? 0 }}'],
  ], [0, 105, 122]);

  addSection('BADGES', ['Metric', 'Value'], [
    ['Total Badges',      '{{ stats.badges }}'],
    ['Unique Types',      '{{ stats.unique_badge_types ?? 0 }}'],
    ['Social Butterfly',  '{{ stats.badge_social ?? 0 }}'],
    ['Class Hero',        '{{ stats.badge_class ?? 0 }}'],
    ['Hobby Master',      '{{ stats.badge_hobby ?? 0 }}'],
  ], [123, 31, 162]);

  addSection('FRIENDSHIPS', ['Metric', 'Value'], [
    ['Total',    '{{ stats.friendships ?? 0 }}'],
    ['Accepted', '{{ stats.accepted_friendships ?? 0 }}'],
    ['Pending',  '{{ stats.pending_friendships ?? 0 }}'],
    ['Rejected', '{{ stats.rejected_friendships ?? 0 }}'],
  ], [183, 28, 28]);

  /* ── Footer on every page ── */
  const pCount = doc.internal.getNumberOfPages();
  for (let i = 1; i <= pCount; i++) {
    doc.setPage(i);
    // Bottom rule
    doc.setDrawColor(...purpleL);
    doc.setLineWidth(0.4);
    doc.line(14, 284, 196, 284);
    doc.setFontSize(8); doc.setTextColor(...gray);
    doc.text('(c) 2026 Ghrami by OPGG', 14, 289);
    doc.text('Page ' + i + ' / ' + pCount, 196, 289, { align: 'right' });
  }

  const stamp = now.getFullYear()
    + String(now.getMonth() + 1).padStart(2, '0')
    + String(now.getDate()).padStart(2, '0');
  doc.save('Ghrami_Analytics_' + stamp + '.pdf');
}

/* ════════════════════════════════════════

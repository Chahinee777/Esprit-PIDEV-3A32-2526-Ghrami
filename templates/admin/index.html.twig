<script>
/* ════════════════════════════════════════
   TAB SWITCHING
════════════════════════════════════════ */
function switchTab(name, btn) {
  document.querySelectorAll('.ad-tab-pane').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.ad-tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
  if (name === 'analytics') initCharts();
  if (name === 'badges')    initBadgeTabChart();
}

/* ════════════════════════════════════════
   SEARCH / FILTER
════════════════════════════════════════ */
function bindSearch(inputId, rowClass, dataAttrs) {
  const el = document.getElementById(inputId);
  if (!el) return;
  el.addEventListener('keyup', () => {
    const q = el.value.toLowerCase();
    document.querySelectorAll(rowClass).forEach(r => {
      const text = dataAttrs
        ? dataAttrs.map(a => (r.dataset[a] || '')).join(' ')
        : r.textContent.toLowerCase();
      r.style.display = text.includes(q) ? '' : 'none';
    });
  });
}

bindSearch('userSearch',       '.user-row',       ['username','email','location']);
bindSearch('providerSearch',   '.provider-row',   ['username','company','expertise']);
bindSearch('classSearch',      '.class-row',      ['title','provider']);
bindSearch('hobbySearch',      '.hobby-row',      ['user','name','category']);
bindSearch('meetingSearch',    '.meeting-row',    ['organizer','type','status','location']);
bindSearch('friendshipSearch', '.friendship-row', ['user1','user2','status']);
bindSearch('badgeSearch',      '.badge-row',      ['name','user']);
bindSearch('postSearch',       '.post-row',       ['content','author']);
bindSearch('commentSearch',    '.comment-row',    ['content','author']);

function filterFriendships() {
  const val = document.getElementById('friendshipFilter').value.toLowerCase();
  const q   = document.getElementById('friendshipSearch').value.toLowerCase();
  document.querySelectorAll('.friendship-row').forEach(r => {
    const matchFilter = !val || r.dataset.status === val;
    const matchSearch = !q || (r.dataset.user1 + r.dataset.user2 + r.dataset.status).includes(q);
    r.style.display = (matchFilter && matchSearch) ? '' : 'none';
  });
}

/* ════════════════════════════════════════
   MODALS
════════════════════════════════════════ */
function closeModal(id) { document.getElementById(id).classList.remove('show'); }
document.querySelectorAll('.ad-modal-overlay').forEach(o => {

{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord - Ghrami{% endblock %}

{% block body %}
<div style="display: grid; grid-template-columns: 280px 1fr 280px; gap: 20px; margin-top: 20px;">
    
    <!-- Left Sidebar -->
    <aside style="display: flex; flex-direction: column; gap: 16px;">
        
        <!-- Profile Card -->
        <div class="card" style="text-align: center;">
            <div style="width: 100px; height: 100px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); margin: 0 auto 16px; border: 3px solid white;"></div>
            <h3 style="margin: 0 0 4px 0; font-size: 18px;">{{ app.user.fullName }}</h3>
            <p style="color: #65676b; margin: 4px 0 16px 0;">{{ app.user.email }}</p>
            <hr style="border: none; border-top: 1px solid #e4e6eb; margin: 16px 0;">
            
            <!-- Stats -->
            <div style="display: flex; justify-content: space-around; text-align: center;">
                <div>
                    <div style="font-size: 20px; font-weight: 700; color: #667eea;">{{ stats.posts }}</div>
                    <div style="font-size: 12px; color: #65676b;">Posts</div>
                </div>
                <div style="border-left: 1px solid #e4e6eb;"></div>
                <div>
                    <div style="font-size: 20px; font-weight: 700; color: #667eea;">{{ stats.bookings }}</div>
                    <div style="font-size: 12px; color: #65676b;">Réservations</div>
                </div>
                <div style="border-left: 1px solid #e4e6eb;"></div>
                <div>
                    <div style="font-size: 20px; font-weight: 700; color: #667eea;">{{ stats.hobbies }}</div>
                    <div style="font-size: 12px; color: #65676b;">Hobbies</div>
                </div>
            </div>
            
            <a href="{{ path('app_profile') }}" class="btn btn-primary" style="width: 100%; margin-top: 16px;">Voir mon profil</a>
        </div>
        
        <!-- Quick Actions -->
        <div class="card">
            <h4 style="margin-top: 0; display: flex; align-items: center; gap: 8px;">🚀 Actions Rapides</h4>
            <div style="display: flex; flex-direction: column; gap: 8px;">
                <a href="{{ path('app_social_index') }}" class="nav-link" style="justify-content: flex-start;">📰 Fil d'Actualité</a>
                <a href="{{ path('app_matching_index') }}" class="nav-link" style="justify-content: flex-start;">👥 Matching</a>
                <a href="{{ path('app_marketplace_index') }}" class="nav-link" style="justify-content: flex-start;">🏪 Marketplace</a>
                <a href="{{ path('app_meetings_index') }}" class="nav-link" style="justify-content: flex-start;">📅 Rencontres</a>
                <a href="{{ path('app_progress_index') }}" class="nav-link" style="justify-content: flex-start;">📈 Progression</a>
                <a href="{{ path('app_vr_rooms') }}" class="nav-link" style="justify-content: flex-start;">🥽 Salles VR</a>
            </div>
        </div>
        
        <!-- Trending Hobbies -->
        <div class="card">
            <h4 style="margin-top: 0; display: flex; align-items: center; gap: 8px;">🔥 Tendances</h4>
            <div style="display: flex; flex-direction: column; gap: 12px;">
                {% for hobby in trendingHobbies|slice(0, 3) %}
                <div style="padding: 8px; background: #f0f2f5; border-radius: 8px; cursor: pointer; transition: all 0.3s ease;" onmouseover="this.style.backgroundColor='#e4e6eb'" onmouseout="this.style.backgroundColor='#f0f2f5'">
                    <div style="font-weight: 600; color: #1c1e21; font-size: 14px;">{{ hobby.name }}</div>
                    <div style="font-size: 12px; color: #65676b;">{{ hobby.memberCount | default(0) }} membres</div>
                </div>
                {% endfor %}
            </div>
        </div>
    </aside>
    
    <!-- Center Feed -->
    <main style="display: flex; flex-direction: column; gap: 20px;">
        
        <!-- Welcome Card -->
        <div class="card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
            <div style="display: flex; align-items: center; gap: 20px;">
                <div style="font-size: 60px; min-width: 80px;">🚀</div>
                <div>
                    <h2 style="margin: 0 0 8px 0; color: white;">Connectez. Partagez. Explorez.</h2>
                    <p style="margin: 0; opacity: 0.9; font-size: 15px;">Bienvenue sur Ghrami - La plateforme tunisienne de développement personnel par les hobbies</p>
                </div>
            </div>
        </div>
        
        <!-- Statistics Cards -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 16px;">
            <div class="card" style="text-align: center; border-left: 4px solid #667eea;">
                <div style="font-size: 32px; font-weight: 700; color: #667eea;">{{ stats.users }}</div>
                <div style="color: #65676b; font-size: 14px;">Utilisateurs</div>
            </div>
            <div class="card" style="text-align: center; border-left: 4px solid #22c55e;">
                <div style="font-size: 32px; font-weight: 700; color: #22c55e;">{{ stats.posts }}</div>
                <div style="color: #65676b; font-size: 14px;">Publications</div>
            </div>
            <div class="card" style="text-align: center; border-left: 4px solid #ffc107;">
                <div style="font-size: 32px; font-weight: 700; color: #ffc107;">{{ stats.hobbies }}</div>
                <div style="color: #65676b; font-size: 14px;">Hobbies Actifs</div>
            </div>
            <div class="card" style="text-align: center; border-left: 4px solid #667eea;">
                <div style="font-size: 32px; font-weight: 700; color: #667eea;">{{ stats.meetings }}</div>
                <div style="color: #65676b; font-size: 14px;">Rencontres</div>
            </div>
            <div class="card" style="text-align: center; border-left: 4px solid #764ba2;">
                <div style="font-size: 32px; font-weight: 700; color: #764ba2;">{{ stats.classes }}</div>
                <div style="color: #65676b; font-size: 14px;">Cours</div>
            </div>
            <div class="card" style="text-align: center; border-left: 4px solid #e74c3c;">
                <div style="font-size: 32px; font-weight: 700; color: #e74c3c;">{{ stats.bookings }}</div>
                <div style="color: #65676b; font-size: 14px;">Réservations</div>
            </div>
        </div>
        
        <!-- Feature Overview -->
        <div class="card">
            <h3 style="margin-top: 0; display: flex; align-items: center; gap: 12px;">✨ Fonctionnalités Principales</h3>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
                
                <div style="padding: 16px; background: #f0f2f5; border-radius: 12px; border-left: 4px solid #667eea;">
                    <div style="font-size: 24px; margin-bottom: 8px;">👥</div>
                    <h4 style="margin: 0 0 4px 0;">Fil Social</h4>
                    <p style="margin: 0; font-size: 13px; color: #65676b;">Partagez vos passions et connectez-vous avec d'autres</p>
                </div>
                
                <div style="padding: 16px; background: #f0f2f5; border-radius: 12px; border-left: 4px solid #22c55e;">
                    <div style="font-size: 24px; margin-bottom: 8px;">🎯</div>
                    <h4 style="margin: 0 0 4px 0;">Matching Intelligent</h4>
                    <p style="margin: 0; font-size: 13px; color: #65676b;">Trouvez vos pairs basé sur les hobbies</p>
                </div>
                
                <div style="padding: 16px; background: #f0f2f5; border-radius: 12px; border-left: 4px solid #ffc107;">
                    <div style="font-size: 24px; margin-bottom: 8px;">🏪</div>
                    <h4 style="margin: 0 0 4px 0;">Marketplace</h4>
                    <p style="margin: 0; font-size: 13px; color: #65676b;">Acheter & enseigner des cours</p>
                </div>
                
                <div style="padding: 16px; background: #f0f2f5; border-radius: 12px; border-left: 4px solid #667eea;">
                    <div style="font-size: 24px; margin-bottom: 8px;">📅</div>
                    <h4 style="margin: 0 0 4px 0;">Rencontres</h4>
                    <p style="margin: 0; font-size: 13px; color: #65676b;">Organisez & participez à des meetups</p>
                </div>
                
                <div style="padding: 16px; background: #f0f2f5; border-radius: 12px; border-left: 4px solid #764ba2;">
                    <div style="font-size: 24px; margin-bottom: 8px;">📈</div>
                    <h4 style="margin: 0 0 4px 0;">Suivi Progression</h4>
                    <p style="margin: 0; font-size: 13px; color: #65676b;">Mesurez vos progrès & gagnez des badges</p>
                </div>
                
                <div style="padding: 16px; background: #f0f2f5; border-radius: 12px; border-left: 4px solid #e74c3c;">
                    <div style="font-size: 24px; margin-bottom: 8px;">🎮</div>
                    <h4 style="margin: 0 0 4px 0;">Salles VR</h4>
                    <p style="margin: 0; font-size: 13px; color: #65676b;">Explorez des mondes virtuels collectifs</p>
                </div>
            </div>
        </div>
        
        <!-- Platform Stats -->
        <div class="card">
            <h3 style="margin-top: 0;">📊 Statistiques Plateforme</h3>
            <p style="color: #65676b;">Cette version Symfony est entièrement mappée au schéma MySQL existant et expose les fonctionnalités du fil social, du matching intelligent, du marketplace de cours, et du suivi de progression.</p>
        </div>
    </main>
    
    <!-- Right Sidebar -->
    <aside style="display: flex; flex-direction: column; gap: 16px;">
        
        <!-- Recent Activities -->
        <div class="card">
            <h4 style="margin-top: 0; display: flex; align-items: center; gap: 8px;">⚡ Activités Récentes</h4>
            <div style="display: flex; flex-direction: column; gap: 12px;">
                {% for activity in recentActivities|slice(0, 5) %}
                <div style="padding: 8px; border-bottom: 1px solid #e4e6eb;">
                    <div style="font-weight: 600; font-size: 13px; color: #1c1e21;">{{ activity.type }}</div>
                    <div style="font-size: 12px; color: #65676b; margin-top: 4px;">{{ activity.description }}</div>
                </div>
                {% endfor %}
            </div>
        </div>
        
        <!-- Suggested Users -->
        <div class="card">
            <h4 style="margin-top: 0; display: flex; align-items: center; gap: 8px;">✨ Suggestions</h4>
            <div style="display: flex; flex-direction: column; gap: 12px;">
                {% for user in suggestedUsers|slice(0, 4) %}
                <div style="display: flex; align-items: center; gap: 10px; padding: 8px; background: #f0f2f5; border-radius: 8px;">
                    <div style="width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-width: 40px;"></div>
                    <div style="flex: 1; min-width: 0;">
                        <div style="font-weight: 600; font-size: 13px; color: #1c1e21;">{{ user.fullName }}</div>
                        <div style="font-size: 11px; color: #65676b;">{{ user.hobbies|length }} hobbies</div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        
        <!-- Upcoming Events -->
        <div class="card">
            <h4 style="margin-top: 0; display: flex; align-items: center; gap: 8px;">📅 À Venir</h4>
            <div style="display: flex; flex-direction: column; gap: 10px;">
                {% for meeting in upcomingMeetings|slice(0, 3) %}
                <div style="padding: 10px; background: #f0f2f5; border-radius: 8px; border-left: 3px solid #667eea;">
                    <div style="font-weight: 600; font-size: 13px; color: #1c1e21;">{{ meeting.title }}</div>
                    <div style="font-size: 11px; color: #65676b; margin-top: 4px;">{{ meeting.date|date('d M') }}</div>
                </div>
                {% endfor %}
            </div>
        </div>
    </aside>
</div>

<style>
    @media (max-width: 1200px) {
        main > div {
            grid-template-columns: 1fr !important;
        }
    }
    
    @media (max-width: 768px) {
        main > div {
            grid-template-columns: 1fr !important;
            gap: 12px;
        }
        
        aside {
            display: none;
        }
    }
</style>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}VR Room | Ghrami{% endblock %}

{% block body %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://aframe.io/releases/1.5.0/aframe.min.js"></script>

<style>
  /* ══════════════════════════════════════════════════════════════
     BASE & TOKENS
  ══════════════════════════════════════════════════════════════ */
  :root {
    --c-primary:   #667eea;
    --c-secondary: #764ba2;
    --c-grad:      linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    --c-green:     #22c55e;
    --c-green-bg:  #f0f7f0;
    --c-green-bdr: #c3e6cb;
    --c-green-txt: #2e7d32;
    --c-border:    #e5e7eb;
    --c-surface:   #ffffff;
    --c-muted:     #f9fafb;
    --c-text:      #1c1e21;
    --c-sub:       #9ca3af;
    --radius-lg:   16px;
    --radius-md:   12px;
    --radius-sm:   8px;
    --shadow-sm:   0 1px 4px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.04);
    --shadow-md:   0 4px 24px rgba(102,126,234,.12), 0 1px 4px rgba(0,0,0,.06);
    --sidebar-w:   260px;
    --transition:  .22s cubic-bezier(.4,0,.2,1);
    --font:        'Outfit', system-ui, sans-serif;
  }

  * { box-sizing: border-box; }

  /* ══════════════════════════════════════════════════════════════
     KEYFRAMES
  ══════════════════════════════════════════════════════════════ */
  @keyframes fadeUp   { from { opacity:0; transform:translateY(16px) } to { opacity:1; transform:none } }
  @keyframes fadeIn   { from { opacity:0 } to { opacity:1 } }
  @keyframes pulseDot { 0%,100% { box-shadow:0 0 0 0 rgba(34,197,94,.5) } 50% { box-shadow:0 0 0 6px rgba(34,197,94,0) } }
  @keyframes float    { 0%,100% { transform:translateY(0) } 50% { transform:translateY(-10px) } }
  @keyframes floatB   { 0%,100% { transform:translateY(0) rotate(0deg) } 50% { transform:translateY(-14px) rotate(8deg) } }
  @keyframes toastIn  { from { opacity:0; transform:translateY(20px) scale(.95) } to { opacity:1; transform:none } }
  @keyframes toastOut { to   { opacity:0; transform:translateY(20px) scale(.95) } }
  @keyframes countUp  { from { opacity:0; transform:scale(.7) } to { opacity:1; transform:scale(1) } }
  @keyframes ripple   { to { transform:scale(4); opacity:0 } }
  @keyframes pulse    { 0%,100%{opacity:.6} 50%{opacity:1} }

  /* ══════════════════════════════════════════════════════════════
     TOAST
  ══════════════════════════════════════════════════════════════ */
  #vr-toast-container {
    position: fixed;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
    pointer-events: none;
  }

  .vr-toast {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--c-text);
    color: #fff;
    font-family: var(--font);
    font-size: 13px;
    font-weight: 500;
    padding: 10px 18px;
    border-radius: 40px;
    box-shadow: 0 8px 32px rgba(0,0,0,.18);
    animation: toastIn .3s cubic-bezier(.34,1.56,.64,1) both;
    white-space: nowrap;
    pointer-events: auto;
  }

  .vr-toast.out { animation: toastOut .3s ease both; }
  .vr-toast-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }

  /* ══════════════════════════════════════════════════════════════
     PAGE SHELL
  ══════════════════════════════════════════════════════════════ */
  .vr-page {
    font-family: var(--font);
    display: flex;
    flex-direction: column;
    max-width: 1340px;
    margin: 0 auto;
    animation: fadeUp .4s ease both;
  }

  /* ── Page header ──────────────────────────────────────────── */
  .vr-page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 0 20px;
  }

  .vr-page-title {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .vr-page-title h2 {
    margin: 0;
    font-size: 22px;
    font-weight: 800;
    color: var(--c-text);
    letter-spacing: -.3px;
  }

  .vr-badge {
    background: var(--c-grad);
    color: white;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .06em;
    padding: 3px 9px;
    border-radius: 20px;
    text-transform: uppercase;
  }

  .vr-header-right {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .vr-live-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--c-green-bg);
    border: 1px solid var(--c-green-bdr);
    border-radius: 24px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 600;
    color: var(--c-green-txt);
    font-family: var(--font);
  }

  .vr-live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--c-green);
    animation: pulseDot 2s infinite;
  }

  /* Fullscreen button */
  .vr-toggle-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 13px;
    border: 1.5px solid var(--c-border);
    border-radius: 10px;
    background: var(--c-surface);
    font-family: var(--font);
    font-size: 12px;
    font-weight: 600;
    color: var(--c-sub);
    cursor: pointer;
    transition: all var(--transition);
    user-select: none;
    text-decoration: none;
  }

  .vr-toggle-btn:hover {
    border-color: var(--c-primary);
    color: var(--c-primary);
    background: rgba(102,126,234,.05);
  }

  /* ══════════════════════════════════════════════════════════════
     MAIN BODY GRID
  ══════════════════════════════════════════════════════════════ */
  .vr-body {
    display: grid;
    grid-template-columns: var(--sidebar-w) 1fr;
    gap: 16px;
    min-height: 680px;
  }

  /* ══════════════════════════════════════════════════════════════
     LEFT SIDEBAR
  ══════════════════════════════════════════════════════════════ */
  .vr-sidebar {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* Room info card */
  .vr-room-info {
    background: var(--c-surface);
    border: 1.5px solid var(--c-border);
    border-radius: var(--radius-lg);
    padding: 18px;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .vr-room-info-emoji {
    font-size: 44px;
    text-align: center;
    animation: floatB 3s ease-in-out infinite;
    filter: drop-shadow(0 4px 12px rgba(102,126,234,.2));
  }

  .vr-room-info-name {
    font-size: 16px;
    font-weight: 800;
    color: var(--c-text);
    text-align: center;
    letter-spacing: -.2px;
    font-family: var(--font);
  }

  .vr-room-info-desc {
    font-size: 12px;
    color: var(--c-sub);
    text-align: center;
    line-height: 1.5;
    font-family: var(--font);
  }

  .vr-room-info-online {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: var(--c-green-bg);
    border: 1px solid var(--c-green-bdr);
    border-radius: 20px;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 600;
    color: var(--c-green-txt);
    font-family: var(--font);
  }

  .vr-online-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--c-green);
    animation: pulseDot 2s infinite;
  }

  /* Controls card */
  .vr-controls {
    background: var(--c-surface);
    border: 1.5px solid var(--c-border);
    border-radius: var(--radius-lg);
    padding: 14px;
    box-shadow: var(--shadow-sm);
  }

  .vr-controls-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: var(--c-sub);
    margin-bottom: 12px;
    font-family: var(--font);
  }

  .vr-control-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .vr-btn {
    position: relative;
    overflow: hidden;
    padding: 9px 14px;
    border: none;
    background: var(--c-grad);
    color: white;
    border-radius: var(--radius-sm);
    font-size: 12px;
    font-weight: 600;
    font-family: var(--font);
    cursor: pointer;
    white-space: nowrap;
    transition: opacity var(--transition), transform var(--transition), box-shadow var(--transition);
    box-shadow: 0 2px 8px rgba(102,126,234,.3);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    text-decoration: none;
    width: 100%;
  }

  .vr-btn:hover {
    opacity: .92;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(102,126,234,.4);
  }

  .vr-btn-ghost {
    background: transparent;
    border: 1.5px solid var(--c-border);
    color: var(--c-sub);
    box-shadow: none;
  }

  .vr-btn-ghost:hover {
    border-color: var(--c-primary);
    color: var(--c-primary);
    background: rgba(102,126,234,.05);
    box-shadow: none;
    opacity: 1;
    transform: none;
  }

  /* Tips card */
  .vr-tips {
    background: linear-gradient(135deg, #f0f4ff 0%, #f7f5ff 100%);
    border: 1.5px solid #e0e7ff;
    border-radius: var(--radius-lg);
    padding: 14px;
    box-shadow: var(--shadow-sm);
  }

  .vr-tips-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: var(--c-primary);
    margin-bottom: 10px;
    font-family: var(--font);
  }

  .vr-tip {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 11px;
    color: #5a6478;
    font-family: var(--font);
    line-height: 1.5;
    margin-bottom: 6px;
  }

  .vr-tip:last-child { margin-bottom: 0; }
  .vr-tip-icon { flex-shrink: 0; font-size: 13px; margin-top: 1px; }

  /* Hobby doors legend */
  .vr-doors-legend {
    background: var(--c-surface);
    border: 1.5px solid var(--c-border);
    border-radius: var(--radius-lg);
    padding: 14px;
    box-shadow: var(--shadow-sm);
  }

  .vr-doors-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: var(--c-sub);
    margin-bottom: 10px;
    font-family: var(--font);
  }

  .vr-door-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: var(--c-text);
    font-family: var(--font);
    margin-bottom: 7px;
    font-weight: 500;
  }

  .vr-door-item:last-child { margin-bottom: 0; }

  .vr-door-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 6px currentColor;
  }

  /* ══════════════════════════════════════════════════════════════
     RIGHT PANEL
  ══════════════════════════════════════════════════════════════ */
  .vr-main {
    display: flex;
    flex-direction: column;
    border: 1.5px solid var(--c-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--c-surface);
    min-height: 680px;
    box-shadow: var(--shadow-md);
  }

  /* Room header bar */
  .vr-room-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px 18px;
    background: var(--c-surface);
    border-bottom: 1.5px solid #f3f4f6;
  }

  .vr-room-bar-emoji {
    font-size: 26px;
    line-height: 1;
    animation: float 3s ease-in-out infinite;
  }

  .vr-room-bar-info { flex: 1; min-width: 0; }

  .vr-room-bar-name {
    font-size: 15px;
    font-weight: 700;
    color: var(--c-text);
    font-family: var(--font);
    letter-spacing: -.2px;
  }

  .vr-room-bar-desc {
    font-size: 12px;
    color: var(--c-sub);
    margin-top: 1px;
    font-family: var(--font);
  }

  .vr-room-bar-right {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .vr-room-bar-online {
    display: flex;
    align-items: center;
    gap: 5px;
    background: var(--c-green-bg);
    border: 1px solid var(--c-green-bdr);
    border-radius: 20px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 600;
    color: var(--c-green-txt);
    font-family: var(--font);
  }

  .vr-room-bar-online-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--c-green);
    animation: pulseDot 2s infinite;
  }

  .vr-btn-outline {
    padding: 6px 13px;
    border: 1.5px solid var(--c-primary);
    background: transparent;
    color: var(--c-primary);
    border-radius: var(--radius-sm);
    font-size: 12px;
    font-weight: 600;
    font-family: var(--font);
    cursor: pointer;
    transition: background var(--transition), color var(--transition);
    display: flex;
    align-items: center;
    gap: 5px;
    text-decoration: none;
  }

  .vr-btn-outline:hover {
    background: var(--c-primary);
    color: white;
  }

  /* ── A-Frame scene wrap ───────────────────────────────────── */
  .vr-scene-wrap {
    flex: 1;
    position: relative;
    min-height: 580px;
    background: #060614;
  }

  .vr-scene-wrap a-scene {
    width: 100% !important;
    height: 100% !important;
    position: absolute !important;
    inset: 0;
  }

  /* Crosshair overlay */
  .vr-crosshair {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 2;
    opacity: .5;
  }

  .vr-crosshair::before,
  .vr-crosshair::after {
    content: '';
    position: absolute;
    background: rgba(255,255,255,.7);
    border-radius: 2px;
  }

  .vr-crosshair::before { width: 14px; height: 2px; top: -1px; left: -7px; }
  .vr-crosshair::after  { width: 2px; height: 14px; top: -7px; left: -1px; }

  /* Movement hint */
  .vr-hint {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,.55);
    backdrop-filter: blur(6px);
    color: rgba(255,255,255,.85);
    font-family: var(--font);
    font-size: 11px;
    font-weight: 500;
    padding: 5px 14px;
    border-radius: 20px;
    pointer-events: none;
    z-index: 3;
    white-space: nowrap;
    animation: fadeIn 1s ease 1.5s both;
  }

  /* ── Status bar ───────────────────────────────────────────── */
  .vr-status-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 18px;
    background: var(--c-muted);
    border-top: 1.5px solid #f3f4f6;
    font-size: 12px;
    color: var(--c-sub);
    font-family: var(--font);
  }

  .vr-status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--c-green);
    animation: pulseDot 2s infinite;
    flex-shrink: 0;
  }

  .vr-status-text { flex: 1; font-family: var(--font); }

  .vr-powered {
    display: flex;
    align-items: center;
    gap: 4px;
    color: #c4c9d4;
    font-size: 11px;
    font-family: var(--font);
  }

  .vr-powered a {
    color: var(--c-primary);
    text-decoration: none;
    font-weight: 600;
  }

  /* ══════════════════════════════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════════════════════════════ */
  @media (max-width: 900px) {
    .vr-body { grid-template-columns: 1fr; }
    .vr-main { min-height: 480px; }
    .vr-scene-wrap { min-height: 400px; }
  }
</style>

<!-- Toast container -->
<div id="vr-toast-container"></div>

{% set room = rooms|first %}

<div class="card vr-page">

  <!-- ── Page Header ───────────────────────────────────────── -->
  <div class="vr-page-header">
    <div class="vr-page-title">
      <h2>🎮 VR Room</h2>
      <span class="vr-badge">A-Frame</span>
    </div>
    <div class="vr-header-right">
      <div class="vr-live-pill">
        <div class="vr-live-dot"></div>
        {{ onlineCount }} en ligne
      </div>
    </div>
  </div>

  <!-- ── Main Grid ─────────────────────────────────────────── -->
  <div class="vr-body">

    <!-- ════════════ LEFT SIDEBAR ════════════ -->
    <div class="vr-sidebar">

      <!-- Room info -->
      <div class="vr-room-info">
        <div class="vr-room-info-emoji">{{ room.emoji ?? '🥽' }}</div>
        <div class="vr-room-info-name">{{ room.name ?? 'Salle VR' }}</div>
        <div class="vr-room-info-desc">{{ room.description ?? 'Espace virtuel immersif' }}</div>
        <div class="vr-room-info-online">
          <span class="vr-online-dot"></span>
          {{ room.online ?? onlineCount }} en ligne
        </div>
      </div>

      <!-- Controls -->
      <div class="vr-controls">
        <div class="vr-controls-title">🎮 Contrôles</div>
        <div class="vr-control-row">
          <button class="vr-btn" onclick="enterVR()">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/></svg>
            Mode VR / Plein écran
          </button>
          <button class="vr-btn vr-btn-ghost" onclick="resetCamera()">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/></svg>
            Réinitialiser la vue
          </button>
        </div>
      </div>

      <!-- Hobby Doors Legend -->
      <div class="vr-doors-legend">
        <div class="vr-doors-title">🚪 Portes des hobbies</div>
        <div class="vr-door-item">
          <div class="vr-door-dot" style="background:#22c55e;color:#22c55e"></div>
          <span>⚽ Football</span>
        </div>
        <div class="vr-door-item">
          <div class="vr-door-dot" style="background:#f59e0b;color:#f59e0b"></div>
          <span>🎬 Cinéma</span>
        </div>
        <div class="vr-door-item">
          <div class="vr-door-dot" style="background:#a855f7;color:#a855f7"></div>
          <span>🎵 Musique</span>
        </div>
        <div class="vr-door-item">
          <div class="vr-door-dot" style="background:#06b6d4;color:#06b6d4"></div>
          <span>🎮 Gaming</span>
        </div>
        <div class="vr-door-item">
          <div class="vr-door-dot" style="background:#f97316;color:#f97316"></div>
          <span>🎨 Art</span>
        </div>
        <div class="vr-door-item">
          <div class="vr-door-dot" style="background:#0ea5e9;color:#0ea5e9"></div>
          <span>✈️ Voyage</span>
        </div>
      </div>

      <!-- Tips -->
      <div class="vr-tips">
        <div class="vr-tips-title">💡 Navigation</div>
        <div class="vr-tip">
          <span class="vr-tip-icon">🖱️</span>
          <span>Cliquer + glisser pour regarder autour</span>
        </div>
        <div class="vr-tip">
          <span class="vr-tip-icon">⌨️</span>
          <span>W A S D ou flèches pour se déplacer</span>
        </div>
        <div class="vr-tip">
          <span class="vr-tip-icon">🥽</span>
          <span>Casque VR supporté via WebXR</span>
        </div>
        <div class="vr-tip">
          <span class="vr-tip-icon">📱</span>
          <span>Sur mobile : gyroscope activé</span>
        </div>
      </div>

    </div>
    <!-- ════════════ END SIDEBAR ════════════ -->

    <!-- ════════════ RIGHT PANEL ════════════ -->
    <div class="vr-main">

      <!-- Room header bar -->
      <div class="vr-room-bar">
        <div class="vr-room-bar-emoji">{{ room.emoji ?? '🥽' }}</div>
        <div class="vr-room-bar-info">
          <div class="vr-room-bar-name">{{ room.name ?? 'Salle VR Ghrami' }}</div>
          <div class="vr-room-bar-desc">{{ room.description ?? 'Espace virtuel immersif' }}</div>
        </div>
        <div class="vr-room-bar-right">
          <div class="vr-room-bar-online">
            <div class="vr-room-bar-online-dot"></div>
            {{ room.online ?? onlineCount }} en ligne
          </div>
          <button class="vr-btn-outline" onclick="enterVR()">
            <svg width="12" height="12" viewBox="0 0 20 20" fill="currentColor">

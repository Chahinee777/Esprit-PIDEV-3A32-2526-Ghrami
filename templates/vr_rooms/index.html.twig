<script>
  /* ══════════════════════════════════════
     TOAST
  ══════════════════════════════════════ */
  function toast(msg, color = '#667eea', duration = 3000) {
    const c  = document.getElementById('vr-toast-container');
    const el = document.createElement('div');
    el.className = 'vr-toast';
    el.innerHTML = `<span class="vr-toast-dot" style="background:${color}"></span>${msg}`;
    c.appendChild(el);
    setTimeout(() => {
      el.classList.add('out');
      el.addEventListener('animationend', () => el.remove());
    }, duration);
  }

  /* ══════════════════════════════════════
     VR / FULLSCREEN
  ══════════════════════════════════════ */
  function enterVR() {
    const scene = document.getElementById('vrScene');
    if (!scene) return;

    if (scene.is('vr-mode')) {
      scene.exitVR();
    } else if (navigator.xr) {
      scene.enterVR();
      toast('🥽 Mode VR activé !', '#667eea');
    } else {
      const wrap = document.getElementById('sceneWrap');
      if (document.fullscreenElement) {
        document.exitFullscreen();
      } else {
        wrap.requestFullscreen().then(() => {
          toast('🖥️ Plein écran activé', '#667eea');
        }).catch(() => {
          toast('⚠️ Plein écran non disponible', '#f59e0b');
        });
      }
    }
  }

  /* ══════════════════════════════════════
     RESET CAMERA
  ══════════════════════════════════════ */
  function resetCamera() {
    const rig = document.getElementById('rig');
    if (rig) {
      rig.setAttribute('position', '0 1.6 5');
      rig.setAttribute('rotation', '0 0 0');
      const cam = document.getElementById('mainCamera');
      if (cam) cam.setAttribute('rotation', '0 0 0');
      toast('🔄 Vue réinitialisée', '#22c55e');
    }
  }

  /* ══════════════════════════════════════
     WELCOME TOAST
  ══════════════════════════════════════ */
  window.addEventListener('load', () => {
    const scene = document.getElementById('vrScene');
    scene.addEventListener('loaded', () => {
      setTimeout(() => toast('🌌 VR Lounge prêt — 6 portes vous attendent !', '#9b72ff'), 900);
    });
  });
</script>

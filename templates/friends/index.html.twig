{% extends 'base.html.twig' %}

{% block title %}Amis - Ghrami{% endblock %}

{% block body %}
<div style="display: grid; grid-template-columns: 280px 1fr; gap: 20px; margin-top: 20px;">

    <!-- Left Sidebar -->
    <aside style="display: flex; flex-direction: column; gap: 16px;">
        
        <!-- Stats Card -->
        <div class="card">
            <div class="card-header">
                <h3 style="margin: 0;">👥 Amis</h3>
            </div>
            <div class="card-body" style="display: flex; flex-direction: column; gap: 12px;">
                <div>
                    <p style="margin: 0; font-size: var(--font-size-xs); color: var(--color-text-secondary);">Mes Amis</p>
                    <p style="margin: 4px 0 0; font-size: var(--font-size-2xl); font-weight: bold; color: #667eea;">{{ friendsCount }}</p>
                </div>
                <div>
                    <p style="margin: 0; font-size: var(--font-size-xs); color: var(--color-text-secondary);">Demandes en attente</p>
                    <p style="margin: 4px 0 0; font-size: var(--font-size-2xl); font-weight: bold; color: #f59e0b;">{{ pendingCount }}</p>
                </div>
                <div>
                    <p style="margin: 0; font-size: var(--font-size-xs); color: var(--color-text-secondary);">Utilisateurs</p>
                    <p style="margin: 4px 0 0; font-size: var(--font-size-2xl); font-weight: bold; color: #22c55e;">{{ totalUsersCount }}</p>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <div class="card">
            <div style="display: flex; flex-direction: column; gap: 8px;">
                <button class="tab-btn" data-tab="browse" onclick="switchTab('browse')" style="text-align: left; padding: 10px 16px; border: none; background: #f0f2f5; cursor: pointer; border-radius: 8px; font-weight: 600; color: #1c1e21;">
                    🔍 Explorer
                </button>
                <button class="tab-btn" data-tab="pending" onclick="switchTab('pending')" style="text-align: left; padding: 10px 16px; border: none; background: transparent; cursor: pointer; border-radius: 8px; color: #65676b;">
                    ⏳ Demandes ({{ pendingCount }})
                </button>
                <button class="tab-btn" data-tab="friends" onclick="switchTab('friends')" style="text-align: left; padding: 10px 16px; border: none; background: transparent; cursor: pointer; border-radius: 8px; color: #65676b;">
                    ✓ Amis ({{ friendsCount }})
                </button>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main style="display: flex; flex-direction: column; gap: 16px;">

        <!-- Browse Users Tab -->
        <div id="browse-tab" style="display: block;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                <h2 style="margin: 0; color: var(--color-text-primary);">Découvrez de nouvelles personnes</h2>
            </div>

            <input type="text" id="browseSearch" placeholder="🔍 Rechercher par nom ou @..." 
                   style="width: 100%; padding: var(--spacing-md) var(--spacing-lg); border: 1px solid var(--color-border); border-radius: 20px; font-size: var(--font-size-base); font-family: var(--font-family); margin-bottom: 16px;">

            <div id="browseUsersContainer" style="display: flex; flex-direction: column; gap: 12px;">
                {% if browseUsers is empty %}
                    <div class="card" style="text-align: center; padding: var(--spacing-xl);">
                        <p style="color: var(--color-text-secondary); font-size: var(--font-size-base);">Aucun utilisateur à explorer</p>
                    </div>
                {% else %}
                    {% for user in browseUsers %}
                        <div class="card" style="display: flex; align-items: center; gap: var(--spacing-lg); padding: var(--spacing-lg);">
                            <!-- Avatar -->
                            <div style="width: 50px; height: 50px; border-radius: 50%; background: var(--gradient-primary); flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                                {% if user.profile_picture %}
                                    <img src="{% if user.profile_picture starts with 'http' %}{{ user.profile_picture }}{% else %}{{ asset('images/profile_pictures/' ~ user.profile_picture) }}{% endif %}" 
                                         alt="{{ user.full_name }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                                {% else %}
                                    <span style="color: white; font-weight: bold; font-size: 20px;">{{ user.full_name[0:1] | upper }}</span>
                                {% endif %}
                            </div>

                            <!-- User Info -->
                            <div style="flex: 1;">
                                <div style="display: flex; align-items: center; gap: var(--spacing-md);">
                                    <h4 style="margin: 0; color: var(--color-text-primary); font-weight: 600;">{{ user.full_name }}</h4>
                                    <span style="font-size: 12px; padding: 2px 8px; border-radius: 12px; background: {% if user.is_online %}#d1fae5{% else %}#f3f4f6{% endif %}; color: {% if user.is_online %}#065f46{% else %}#374151{% endif %};">
                                        {% if user.is_online %}🟢 En ligne{% else %}⚫ Hors ligne{% endif %}
                                    </span>
                                </div>
                                <p style="margin: 4px 0 0; color: var(--color-text-secondary); font-size: var(--font-size-sm);">@{{ user.username }}</p>
                            </div>

                            <!-- Action Button -->
                            {% set status = userFriendshipStatus[user.user_id] ?? null %}
                            {% if status == 'ACCEPTED' %}
                                <button disabled style="padding: var(--spacing-md) var(--spacing-lg); background: #22c55e; color: white; border: none; border-radius: 20px; cursor: not-allowed; font-weight: 600; font-size: var(--font-size-sm); opacity: 0.7;">
                                    ✓ Ami
                                </button>
                            {% elseif status == 'PENDING_INCOMING' %}
                                <button disabled style="padding: var(--spacing-md) var(--spacing-lg); background: #f59e0b; color: white; border: none; border-radius: 20px; cursor: not-allowed; font-weight: 600; font-size: var(--font-size-sm); opacity: 0.7;">
                                    ⏳ Demande reçue
                                </button>
                            {% elseif status == 'PENDING_OUTGOING' %}
                                <button disabled style="padding: var(--spacing-md) var(--spacing-lg); background: #f59e0b; color: white; border: none; border-radius: 20px; cursor: not-allowed; font-weight: 600; font-size: var(--font-size-sm); opacity: 0.7;">
                                    ⏳ En attente
                                </button>
                            {% else %}
                                <button class="action-btn" data-user-id="{{ user.user_id }}" onclick="sendFriendRequest({{ user.user_id }}, this)" 
                                        style="padding: var(--spacing-md) var(--spacing-lg); background: var(--color-primary); color: white; border: none; border-radius: 20px; cursor: pointer; font-weight: 600; font-size: var(--font-size-sm); transition: var(--transition-fast);"
                                        onmouseover="this.style.background='var(--color-primary-dark)';"
                                        onmouseout="this.style.background='var(--color-primary)';">
                                    ➕ Ajouter
                                </button>
                            {% endif %}
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        <!-- Pending Requests Tab -->
        <div id="pending-tab" style="display: none;">
            <h2 style="margin-top: 0; color: var(--color-text-primary);">Demandes d'amitié en attente</h2>

            <div id="pendingRequestsContainer" style="display: flex; flex-direction: column; gap: 12px;">
                {% if pendingRequests is empty %}
                    <div class="card" style="text-align: center; padding: var(--spacing-xl);">
                        <p style="color: var(--color-text-secondary); font-size: var(--font-size-base);">😊 Aucune demande en attente</p>
                    </div>
                {% else %}
                    {% for req in pendingRequests %}
                        {% set sender = null %}
                        {% for s in pendingRequestSenders %}
                            {% if s.user_id == req.user1_id %}
                                {% set sender = s %}
                            {% endif %}
                        {% endfor %}
                        {% if sender %}
                        <div class="card" style="display: flex; align-items: center; gap: var(--spacing-lg); padding: var(--spacing-lg); border-left: 4px solid #f59e0b;">
                            <!-- Avatar -->
                            <div style="width: 50px; height: 50px; border-radius: 50%; background: var(--gradient-primary); flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                                {% if sender.profile_picture %}
                                    <img src="{% if sender.profile_picture starts with 'http' %}{{ sender.profile_picture }}{% else %}{{ asset('images/profile_pictures/' ~ sender.profile_picture) }}{% endif %}" 
                                         alt="{{ sender.full_name }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                                {% else %}
                                    <span style="color: white; font-weight: bold; font-size: 20px;">{{ sender.full_name[0:1] | upper }}</span>
                                {% endif %}
                            </div>

                            <!-- User Info -->
                            <div style="flex: 1;">
                                <h4 style="margin: 0; color: var(--color-text-primary); font-weight: 600;">{{ sender.full_name }}</h4>
                                <p style="margin: 4px 0 0; color: var(--color-text-secondary); font-size: var(--font-size-sm);">@{{ sender.username }} veut devenir votre ami</p>
                                <p style="margin: 4px 0 0; color: var(--color-text-secondary); font-size: var(--font-size-xs);">📅 {{ req.created_date | date('d M Y H:i') }}</p>
                            </div>

                            <!-- Action Buttons -->
                            <div style="display: flex; gap: var(--spacing-md);">
                                <button onclick="acceptFriendRequest({{ req.friendship_id }}, this)" 
                                        style="padding: var(--spacing-md) var(--spacing-lg); background: #22c55e; color: white; border: none; border-radius: 20px; cursor: pointer; font-weight: 600; font-size: var(--font-size-sm); transition: var(--transition-fast);"
                                        onmouseover="this.style.background='#16a34a';"
                                        onmouseout="this.style.background='#22c55e';">
                                    ✓ Accepter
                                </button>
                                <button onclick="rejectFriendRequest({{ req.friendship_id }}, this)" 
                                        style="padding: var(--spacing-md) var(--spacing-lg); background: #ef4444; color: white; border: none; border-radius: 20px; cursor: pointer; font-weight: 600; font-size: var(--font-size-sm); transition: var(--transition-fast);"
                                        onmouseover="this.style.background='#dc2626';"
                                        onmouseout="this.style.background='#ef4444';">
                                    ✗ Refuser
                                </button>
                            </div>
                        </div>
                        {% endif %}
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        <!-- My Friends Tab -->
        <div id="friends-tab" style="display: none;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                <h2 style="margin: 0; color: var(--color-text-primary);">Mes Amis ({{ friendsCount }})</h2>
            </div>

            <input type="text" id="friendsSearch" placeholder="🔍 Rechercher un ami..." 
                   style="width: 100%; padding: var(--spacing-md) var(--spacing-lg); border: 1px solid var(--color-border); border-radius: 20px; font-size: var(--font-size-base); font-family: var(--font-family); margin-bottom: 16px;">

            <div id="myFriendsContainer" style="display: flex; flex-direction: column; gap: 12px;">
                {% if acceptedFriends is empty %}
                    <div class="card" style="text-align: center; padding: var(--spacing-xl);">
                        <p style="color: var(--color-text-secondary); font-size: var(--font-size-base);">Vous n'avez pas encore d'amis. Commencez à explorer!</p>
                    </div>
                {% else %}
                    {% for friend in acceptedFriends %}
                        <div class="card" style="display: flex; align-items: center; gap: var(--spacing-lg); padding: var(--spacing-lg); border-left: 4px solid #22c55e;">
                            <!-- Avatar -->
                            <div style="width: 50px; height: 50px; border-radius: 50%; background: var(--gradient-primary); flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                                {% if friend.profile_picture %}
                                    <img src="{% if friend.profile_picture starts with 'http' %}{{ friend.profile_picture }}{% else %}{{ asset('images/profile_pictures/' ~ friend.profile_picture) }}{% endif %}" 
                                         alt="{{ friend.full_name }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                                {% else %}
                                    <span style="color: white; font-weight: bold; font-size: 20px;">{{ friend.full_name[0:1] | upper }}</span>
                                {% endif %}
                            </div>

                            <!-- User Info -->
                            <div style="flex: 1;">
                                <div style="display: flex; align-items: center; gap: var(--spacing-md);">
                                    <h4 style="margin: 0; color: var(--color-text-primary); font-weight: 600;">{{ friend.full_name }}</h4>
                                    <span style="font-size: 12px; padding: 2px 8px; border-radius: 12px; background: {% if friend.is_online %}#d1fae5{% else %}#f3f4f6{% endif %}; color: {% if friend.is_online %}#065f46{% else %}#374151{% endif %};">
                                        {% if friend.is_online %}🟢 En ligne{% else %}⚫ Hors ligne{% endif %}
                                    </span>
                                </div>
                                <p style="margin: 4px 0 0; color: var(--color-text-secondary); font-size: var(--font-size-sm);">@{{ friend.username }}</p>
                            </div>

                            <!-- Action Buttons -->
                            <div style="display: flex; gap: var(--spacing-md);">
                                <a href="{{ path('app_messages_index', {with: friend.user_id}) }}" 
                                   style="padding: var(--spacing-md) var(--spacing-lg); background: var(--color-primary); color: white; border: none; border-radius: 20px; cursor: pointer; font-weight: 600; font-size: var(--font-size-sm); text-decoration: none; display: inline-block; transition: var(--transition-fast);"
                                   onmouseover="this.style.background='var(--color-primary-dark)';"
                                   onmouseout="this.style.background='var(--color-primary)';">
                                    💬 Message
                                </a>
                                <button onclick="removeFriend({{ friend.friendship_id }}, this)" 
                                        style="width: 40px; height: 40px; background: #ef4444; color: white; border: none; border-radius: 50%; cursor: pointer; font-size: 16px; transition: var(--transition-fast);"
                                        title="Retirer l'ami"
                                        onmouseover="this.style.background='#dc2626';"
                                        onmouseout="this.style.background='#ef4444';">
                                    🗑️
                                </button>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

    </main>
</div>

<script>
    function switchTab(tabName) {
        // Hide all tabs
        document.getElementById('browse-tab').style.display = 'none';
        document.getElementById('pending-tab').style.display = 'none';
        document.getElementById('friends-tab').style.display = 'none';

        // Show selected tab
        document.getElementById(tabName + '-tab').style.display = 'block';

        // Update button styles
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.style.background = btn.getAttribute('data-tab') === tabName ? '#f0f2f5' : 'transparent';
            btn.style.color = btn.getAttribute('data-tab') === tabName ? '#1c1e21' : '#65676b';
            btn.style.fontWeight = btn.getAttribute('data-tab') === tabName ? '600' : 'normal';
        });
    }

    // Search functionality
    document.getElementById('browseSearch')?.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase();
        document.querySelectorAll('#browseUsersContainer .card').forEach(card => {
            const text = card.textContent.toLowerCase();
            card.style.display = text.includes(query) ? 'flex' : 'none';
        });
    });

    document.getElementById('friendsSearch')?.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase();
        document.querySelectorAll('#myFriendsContainer .card').forEach(card => {
            const text = card.textContent.toLowerCase();
            card.style.display = text.includes(query) ? 'flex' : 'none';
        });
    });

    // Friend actions
    async function sendFriendRequest(userId, btn) {
        try {
            const response = await fetch('{{ path("app_friends_send_request", {receiverId: 0}) }}'.replace('0', userId), {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            const data = await response.json();
            if (data.success) {
                btn.textContent = '⏳ En attente';
                btn.disabled = true;
                btn.style.background = '#f59e0b';
                btn.style.color = 'white';
                btn.style.cursor = 'not-allowed';
                btn.style.opacity = '0.7';
            } else if (data.error) {
                alert('Erreur: ' + data.error);
            }
        } catch (err) {
            console.error('Error:', err);
            alert('Erreur lors de l\'envoi de la demande');
        }
    }

    async function acceptFriendRequest(friendshipId, btn) {
        if (confirm('Accepter cette demande d\'amitié ?')) {
            try {
                const response = await fetch('{{ path("app_friends_accept", {friendshipId: 0}) }}'.replace('0', friendshipId), {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await response.json();
                if (data.success) {
                    btn.closest('.card').style.display = 'none';
                }
            } catch (err) {
                console.error('Error:', err);
                alert('Erreur lors de l\'acceptation');
            }
        }
    }

    async function rejectFriendRequest(friendshipId, btn) {
        if (confirm('Refuser cette demande d\'amitié ?')) {
            try {
                const response = await fetch('{{ path("app_friends_reject", {friendshipId: 0}) }}'.replace('0', friendshipId), {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await response.json();
                if (data.success) {
                    btn.closest('.card').style.display = 'none';
                }
            } catch (err) {
                console.error('Error:', err);
                alert('Erreur lors du refus');
            }
        }
    }

    async function removeFriend(friendshipId, btn) {
        if (confirm('Retirer cet ami ?')) {
            try {
                const response = await fetch('{{ path("app_friends_remove", {friendshipId: 0}) }}'.replace('0', friendshipId), {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await response.json();
                if (data.success) {
                    btn.closest('.card').style.display = 'none';
                }
            } catch (err) {
                console.error('Error:', err);
                alert('Erreur lors de la suppression');
            }
        }
    }
</script>

<style>
    .nav-link {
        transition: var(--transition-fast);
    }

    .nav-link:hover {
        transform: scale(1.1);
    }

    .card {
        background: white;
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: var(--spacing-lg);
        box-shadow: var(--shadow-sm);
    }

    .card-header h3 {
        margin: 0;
        color: var(--color-text-primary);
    }

    .card-body {
        margin-top: var(--spacing-md);
    }
</style>
{% endblock %}
